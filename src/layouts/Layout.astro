---
// Shared document shell. Replaces the per-page <head> boilerplate that was
// hand-copied across 38 files (charset, viewport, fonts, SEO/OG, theme-color).
// Page-specific CSS/JS still lives in the page (as <style is:global> /
// <script is:inline>) so the bespoke design ports over verbatim.
import Attribution from '../components/Attribution.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  description?: string;
  /** drives <meta theme-color>; default = homepage bg */
  themeColor?: string;
  /** inject the shared Attribution footer (pages with a bespoke footer pass false) */
  footer?: boolean;
  /** social preview image, site-relative (e.g. "/assets/trailer-4-4-0.jpg") */
  ogImage?: string;
  /** og:type — patch/topic pages pass "article" */
  ogType?: 'website' | 'article';
  /** keep crawlers off utility pages (404) */
  noindex?: boolean;
}

const {
  title,
  description = SITE.defaultDescription,
  themeColor = '#05070d',
  footer = false,
  ogImage,
  ogType = 'website',
  noindex = false,
} = Astro.props;

const base = SITE.url.replace(/\/$/, '');
const canonical = base + Astro.url.pathname;
const ogImageAbs = ogImage ? (ogImage.startsWith('http') ? ogImage : base + ogImage) : null;
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content={themeColor} />
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="de_DE" />
  {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
  <meta name="twitter:card" content="summary_large_image" />
  {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Rajdhani:wght@500;600;700&family=Barlow:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <style is:inline>
    /* Lesbarkeits-Grundlage: 18px-Wurzel statt Browser-Default 16px. Die
       gesamte Typo-Skala der Seite ist rem-basiert und wächst proportional —
       Fließtext 18px, Datentabellen ~17px, Micro-Caps-Labels ≥14px effektiv.
       Kleine Condensed-Caps rendern damit auch deutlich weicher (ClearType). */
    html { font-size: 112.5%; }
    /* Parallax-/Deko-Bleeds (data-par, Ken-Burns) dürfen das Dokument nie
       seitlich aufweiten — clip statt hidden: erzeugt keinen Scroll-Container. */
    html, body { overflow-x: clip; }
  </style>
  <slot name="head" />
</head>
<body>
  <slot />
  {footer && <Attribution />}
</body>
</html>
