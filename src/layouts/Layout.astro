---
// Shared document shell. Replaces the per-page <head> boilerplate that was
// hand-copied across 38 files (charset, viewport, fonts, SEO/OG, theme-color).
// Page-specific CSS/JS still lives in the page (as <style is:global> /
// <script is:inline>) so the bespoke design ports over verbatim.
import Attribution from '../components/Attribution.astro';
import { SITE } from '../consts';
import { localeFromPath, pathForLocale, HTML_LANG, OG_LOCALE } from '../i18n/ui';
import { LIGHT_RULES } from '../../scripts/lib/theme-color.mjs';

interface Props {
  title: string;
  description?: string;
  /** drives <meta theme-color>; default = homepage bg */
  themeColor?: string;
  /** inject the shared Attribution footer (pages with a bespoke footer pass false) */
  footer?: boolean;
  /** social preview image, site-relative (e.g. "/assets/trailer-4-4-0.jpg") */
  ogImage?: string;
  /** og:type — patch/topic pages pass "article" */
  ogType?: 'website' | 'article';
  /** keep crawlers off utility pages (404) */
  noindex?: boolean;
  /**
   * DE↔EN-Gegenstück existiert -> hreflang-Alternates ausgeben. Default false:
   * solange eine Seite noch KEIN Übersetzungspaar hat (Stufe 2/3), bewerben wir
   * keine 404-URL, und die DE-Ausgabe bleibt byte-gleich zu vorher.
   */
  translated?: boolean;
  /**
   * ItemPage-JSON-LD für Datenblätter (Schiffe/Missionen): sagt Suchmaschinen,
   * dass die Seite EIN Ding beschreibt, und trägt den Datenstand (dateModified
   * = Snapshot-/Extraktionsdatum). Redaktionelle Seiten nutzen stattdessen
   * PatchSeo/TopicSeo (Article, im Body gerendert).
   */
  itemPage?: {
    modified?: string;
    /** Name des beschriebenen Dings; ohne Angabe steht der volle <title> im LD. */
    name?: string;
  };
}

const {
  title,
  description: descriptionProp,
  themeColor = '#05070d',
  footer = false,
  ogImage,
  ogType = 'website',
  noindex = false,
  translated = false,
  itemPage,
} = Astro.props;

const base = SITE.url.replace(/\/$/, '');
const canonical = base + Astro.url.pathname;

// Locale aus dem Pfad (DE lebt unter /de/…). Steuert lang + og:locale und
// welche Fallback-Description greift (vorher: DE-Text auch auf EN-Seiten).
const lang = localeFromPath(Astro.url.pathname);
const description = descriptionProp ?? SITE.defaultDescription[lang];

// og:image mit Site-Fallback: twitter:card "summary_large_image" ohne Bild ist
// wirkungslos — Seiten ohne eigenes Motiv bekommen das VerseBase-Standardbild.
const ogImageEff = ogImage ?? SITE.ogDefault;
const ogImageAbs = ogImageEff.startsWith('http') ? ogImageEff : base + ogImageEff;
// hreflang-Ziele (nur wenn ein Übersetzungspaar existiert).
// '/' und '/index.html' sind dieselbe Seite; canonical nennt '/' (Astro liefert
// den Pfad so). hreflang MUSS dieselbe URL nennen — nennt es die andere Form,
// widersprechen sich canonical und hreflang und Google verwirft das
// Sprach-Cluster. Betrifft die Startseite, also die wichtigste URL der Seite.
const canon = (p: string) => (p === '/index.html' ? '/' : p);
const deHref = base + canon(pathForLocale(Astro.url.pathname, 'de'));
const enHref = base + canon(pathForLocale(Astro.url.pathname, 'en'));

// Die Browserleisten-Farbe (Android/Safari) muss im Hellmodus mitziehen —
// sonst rahmt eine schwarze Leiste eine weiße Seite. Der helle Wert wird
// beim Bauen aus dem dunklen abgeleitet (gleicher Farbton, Papier-
// Helligkeit), damit jede Seite ihre Tönung behält.
// Nur echte Hex-Werte gehen in das inline-Script (unten per set:html
// eingesetzt) — so kann eine Seite nicht versehentlich Code einschleusen.
const HEX = /^#[0-9a-f]{3,8}$/i;
const themeColorSafe = HEX.test(themeColor) ? themeColor : '#05070d';
const themeColorLight = LIGHT_RULES['--bg'](themeColorSafe);
---
<!doctype html>
<html lang={HTML_LANG[lang]}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {/* Beide Leistenfarben hängen am Meta-Tag selbst — so kommt der Umschalter
      in SiteNav an den zur Seite passenden Wert, ohne ihn kennen zu müssen. */}
  <meta name="theme-color" content={themeColor} data-dark={themeColorSafe} data-light={themeColorLight} />
  {/* Rolle (aus dem Session-Cache) UND Hell/Dunkel VOR dem ersten Paint
      festlegen — synchron und so früh wie möglich. Läuft das später, blitzt
      erst die dunkle und dann die helle Seite auf (bzw. der Umschalter für
      Nicht-Admins). Die Theme-Wahl ist ein Admin-Recht: nur Admins folgen
      ihrer gespeicherten Wahl bzw. dem Betriebssystem, alle anderen bekommen
      fest das dunkle Standard-Design. Der Rollen-Cache (vb_user_role) wird von
      account-lite.js gefüllt; steht er noch nicht (kalter Erstaufruf), gilt
      man als Nicht-Admin und account-lite gleicht das Theme nach dem Laden der
      echten Rolle an. Ohne gültigen localStorage-Wert bleibt data-theme-auto
      gesetzt — daran erkennt der Umschalter, dass er (für Admins) weiter dem
      System folgen darf. */}
  <script
    is:inline
    set:html={`(function(){var d=document.documentElement;
var p=location.pathname.toLowerCase();
if(p.indexOf('/archiv')!==-1||p.indexOf('/patches/')!==-1)d.classList.add('is-archive-guarded');
var admin=false;try{var raw=sessionStorage.getItem('vb_user_role');if(raw){var pr=JSON.parse(raw);if(pr&&pr.role==='admin')admin=true}}catch(e){}
if(admin)d.classList.add('is-admin');
var t=null;if(admin){try{t=localStorage.getItem('vb.theme')}catch(e){}}
var auto=admin&&(t!=='light'&&t!=='dark');
if(!admin){t='dark'}else if(auto){t=(window.matchMedia&&matchMedia('(prefers-color-scheme: light)').matches)?'light':'dark'}
d.setAttribute('data-theme',t==='light'?'light':'dark');if(auto)d.setAttribute('data-theme-auto','');
var m=document.querySelector('meta[name="theme-color"]');if(m)m.setAttribute('content',t==='light'?'${themeColorLight}':'${themeColorSafe}')})()`}
  />
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonical} />
  {translated && (
    <>
      <link rel="alternate" hreflang="de" href={deHref} />
      <link rel="alternate" hreflang="en" href={enHref} />
      <link rel="alternate" hreflang="x-default" href={enHref} />
    </>
  )}
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={OG_LOCALE[lang]} />
  {translated && <meta property="og:locale:alternate" content={OG_LOCALE[lang === 'de' ? 'en' : 'de']} />}
  <meta property="og:image" content={ogImageAbs} />
  <meta property="og:image:alt" content={title} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImageAbs} />
  {/* Strukturierte Daten (JSON-LD): sagt Suchmaschinen, dass alle Seiten zu
      EINEM Werk gehören (WebSite + Fan-Projekt als Herausgeber). Rein additiv —
      ändert nichts am sichtbaren HTML, hilft aber bei Sitelinks/Wissensgraph. */}
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: SITE.name,
      url: base + '/',
      inLanguage: HTML_LANG[lang],
      description: SITE.defaultDescription[lang],
      publisher: {
        '@type': 'Organization',
        name: SITE.name,
        url: base + '/',
        logo: { '@type': 'ImageObject', url: base + '/favicon.svg' },
      },
    })}
  />
  {itemPage && (
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'ItemPage',
        name: itemPage.name ?? title,
        description,
        image: ogImageAbs,
        url: canonical,
        inLanguage: HTML_LANG[lang],
        ...(itemPage.modified ? { dateModified: itemPage.modified } : {}),
        about: { '@type': 'VideoGame', name: 'Star Citizen' },
        isPartOf: { '@type': 'WebSite', name: SITE.name, url: base + '/' },
      })}
    />
  )}

  {/* Webfonts selbst gehostet (scripts/fetch-fonts.mjs) — kein Google-CDN,
      keine IP-Übertragung an Dritte beim Seitenaufruf (DSGVO). */}
  <link rel="preload" href="/assets/fonts/orbitron-700-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/assets/fonts/barlow-400-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link href="/assets/fonts.css" rel="stylesheet" />
  {/* Farbfundament für beide Modi. Muss VOR dem Seiten-CSS stehen: die
      hellen Paletten der Seiten liegen in deren inline-<style> und sollen
      diese Rückfallwerte über die Quellreihenfolge schlagen. */}
  <link href="/assets/theme.css" rel="stylesheet" />
  <style is:inline>
    /* Scrollbar überall komplett unsichtbar machen (Browser-Cache-sicher inline) */
    html, body, * {
      scrollbar-width: none !important;
      -ms-overflow-style: none !important;
    }
    html::-webkit-scrollbar,
    body::-webkit-scrollbar,
    *::-webkit-scrollbar {
      display: none !important;
      width: 0 !important;
      height: 0 !important;
      background: transparent !important;
    }
    /* Lesbarkeits-Grundlage: 18px-Wurzel statt Browser-Default 16px. Die
       gesamte Typo-Skala der Seite ist rem-basiert und wächst proportional —
       Fließtext 18px, Datentabellen ~17px, Micro-Caps-Labels ≥14px effektiv.
       Kleine Condensed-Caps rendern damit auch deutlich weicher (ClearType). */
    html { font-size: 112.5%; }
    /* Parallax-/Deko-Bleeds (data-par, Ken-Burns) dürfen das Dokument nie
       seitlich aufweiten — clip statt hidden: erzeugt keinen Scroll-Container. */
    html, body { overflow-x: clip; }
    /* i18n-Härtung: längere EN-Wörter (z. B. „PERSONAL HANGARS") sollen im
       Zweifel umbrechen statt vom Container abgeschnitten zu werden. :where()
       hat Spezifität 0 -> keine bestehende Regel wird überschrieben; da keine
       dieser Klassen overflow-wrap selbst setzt, greift der Fallback nur dort,
       wo bisher nichts stand. Kurze DE-Strings umbrechen nie -> DE unverändert. */
    :where(h1, h2, h3, h4, .big, .shot .big, .holo__title h1, .tile .lbl,
      .tile.word b, .tile.stat .num, .tile.stat .cap, .ship h3, .pcard .name,
      .pcard .ver, .ktcard b, .sd__sim .nm, .hubrows .ht, .kt b) {
      overflow-wrap: break-word;
    }
    /* Flex-Mono-Code-Zeilen (…//…): min-width:0 lässt die Ellipsis greifen,
       statt die Zeile (langer EN-System-Name) über den Rand zu drücken. */
    .tf__code, .qf__code, .do__code, .sd__code { min-width: 0; }
    /* Admin-only restricted content (Patch Archive, Account) */
    html:not(.is-admin) [data-restricted="patch-archive"],
    html:not(.is-admin) .js-restricted-archive {
      display: none !important;
    }
    /* Hell/Dunkel-Umschalter ist ein Admin-Recht — für alle anderen weg
       (Leiste + Menü). Das Verhalten ist zusätzlich in JS abgesichert. */
    html:not(.is-admin) .js-theme-toggle {
      display: none !important;
    }
    html.is-archive-guarded:not(.is-admin) body {
      display: none !important;
    }</style>
  <slot name="head" />
</head>
<body>
  <slot />
  {footer && <Attribution />}
  {/* Umschalt-Verhalten. Bewusst hier und nicht in ThemeToggle.astro: der
      Umschalter steht zweimal auf der Seite (Leiste + Menü), das Verhalten
      soll aber nur einmal existieren. Delegierter Klick -> beliebig viele
      Umschalter, auch nachträglich eingefügte. */}
  <script
    is:inline
    set:html={`(function(){var d=document.documentElement,meta=document.querySelector('meta[name="theme-color"]');
function isAdmin(){return d.classList.contains('is-admin');}
function paint(t){d.setAttribute('data-theme',t);
  if(meta&&meta.dataset.dark)meta.setAttribute('content',t==='light'?meta.dataset.light:meta.dataset.dark);
  var b=document.querySelectorAll('.js-theme-toggle');
  for(var i=0;i<b.length;i++)b[i].setAttribute('aria-pressed',t==='dark'?'true':'false');}
/* Theme-Wahl ist Admin-only: Nicht-Admins sind fest auf Dunkel. reconcile()
   gleicht das Theme an die aktuelle Rolle an und wird auch von account-lite.js
   aufgerufen, sobald die echte Rolle vom Server feststeht. */
function reconcile(){if(!isAdmin()){d.removeAttribute('data-theme-auto');paint('dark');return;}
  var t=null;try{t=localStorage.getItem('vb.theme')}catch(e){}
  if(t==='light'||t==='dark'){d.removeAttribute('data-theme-auto');paint(t);}
  else{d.setAttribute('data-theme-auto','');paint((window.matchMedia&&matchMedia('(prefers-color-scheme: light)').matches)?'light':'dark');}}
window.__vbReconcileTheme=reconcile;reconcile();
function choose(t){if(!isAdmin())return;try{localStorage.setItem('vb.theme',t)}catch(e){}
  d.removeAttribute('data-theme-auto');paint(t);}
document.addEventListener('click',function(e){
  var b=e.target&&e.target.closest&&e.target.closest('.js-theme-toggle');
  if(b)choose(d.getAttribute('data-theme')==='light'?'dark':'light');});
if(window.matchMedia){var mq=matchMedia('(prefers-color-scheme: light)');
  var os=function(){if(isAdmin()&&d.hasAttribute('data-theme-auto'))paint(mq.matches?'light':'dark')};
  mq.addEventListener?mq.addEventListener('change',os):mq.addListener(os);}
addEventListener('storage',function(e){if(e.key==='vb.theme'&&isAdmin()&&(e.newValue==='light'||e.newValue==='dark')){
  d.removeAttribute('data-theme-auto');paint(e.newValue);}});})()`}
  />
</body>
</html>
