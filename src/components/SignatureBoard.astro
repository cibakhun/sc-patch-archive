---
// SignatureBoard.astro — Scan-Signaturen als echte Rock-Kompositionen (4.8.x).
// Jede Signatur (z. B. 3170) gehört zu einem dominanten Mineral; die Karte zeigt
// die datamined Rock-Zusammensetzung (Mineral-Anteile in %-Ranges) plus die
// Rock-Physik (Resistance, Instabilität). Karten sind klickbar → Highlight an/aus
// (Merkliste, in localStorage), Detail aufklappbar. Daten: assets/mining-model.json.
import MODEL from '../../assets/mining-model.json';

interface Props { lang: 'de' | 'en'; }
const { lang } = Astro.props;

// Element-Lookup (Name → Physik).
const elemByName: Record<string, any> = {};
for (const e of MODEL.elements || []) elemByName[e.name] = e;

// Kompositionen mit dominantem Mineral + Physik anreichern.
const RARITY_ORDER = ['legendary', 'epic', 'rare', 'uncommon', 'common'];
const rows = (MODEL.compositions || []).map((c: any) => {
  const dom = elemByName[(c.parts?.[0]?.element) || c.name] || elemByName[c.name] || null;
  return {
    name: c.name,
    sig: dom?.scanSignature ?? null,
    rarity: dom?.rarity || 'common',
    resistance: dom?.resistance ?? null,
    instability: dom?.instability ?? null,
    parts: (c.parts || []).map((p: any) => ({
      name: p.element,
      min: p.minPercent,
      max: p.maxPercent,
      res: elemByName[p.element]?.resistance ?? null,
    })),
  };
}).filter((r) => r.sig != null)
  .sort((a, b) => (RARITY_ORDER.indexOf(a.rarity) - RARITY_ORDER.indexOf(b.rarity)) || (a.sig - b.sig));

// Nach Seltenheit gruppieren.
const groups = RARITY_ORDER.map((rar) => ({ rarity: rar, items: rows.filter((r) => r.rarity === rar) })).filter((g) => g.items.length);

const RARITY_LABEL: Record<string, { de: string; en: string }> = {
  legendary: { de: 'Legendär', en: 'Legendary' }, epic: { de: 'Episch', en: 'Epic' },
  rare: { de: 'Selten', en: 'Rare' }, uncommon: { de: 'Ungewöhnlich', en: 'Uncommon' }, common: { de: 'Häufig', en: 'Common' },
};

const S = {
  de: {
    intro: 'Seit Patch 4.7 verrät die Scan-Signatur das dominante Mineral eines Rocks. Jede Karte zeigt die datamined Rock-Zusammensetzung (Mineral-Anteile) und die Rock-Physik — Resistance & Instabilität, die im Fracturing-Rechner zählen. Karte anklicken → Highlight an/aus (Merkliste, bleibt gespeichert).',
    clear: 'Alle Markierungen aus', comp: 'Zusammensetzung', res: 'Resist', inst: 'Instab',
    src: 'Signaturen, Kompositionen und Physik-Werte aus datamined Spieldaten (Patch 4.8.3). Anteile sind Ranges — echte Rocks streuen darin.',
  },
  en: {
    intro: 'Since patch 4.7 the scan signature reveals a rock’s dominant mineral. Each card shows the datamined rock composition (mineral shares) and the rock physics — resistance & instability, which drive the fracturing calculator. Click a card to toggle its highlight (watchlist, saved).',
    clear: 'Clear all marks', comp: 'Composition', res: 'Resist', inst: 'Instab',
    src: 'Signatures, compositions and physics values from datamined game files (patch 4.8.3). Shares are ranges — real rocks vary within them.',
  },
}[lang];
---
<section class="sgb" id="sgb">
  <p class="sgb__intro">{S.intro}</p>
  <div class="sgb__groups">
    {groups.map((g) => (
      <div class="sgb__group" data-rarity={g.rarity}>
        <div class="sgb__gh">{RARITY_LABEL[g.rarity]?.[lang] ?? g.rarity}</div>
        <div class="sgb__cards">
          {g.items.map((r) => (
            <article class="sgb__card" data-sig={r.sig} aria-pressed="false">
              <button type="button" class="sgb__cardhd">
                <b class="sgb__sig">{r.sig}</b>
                <span class="sgb__name">{r.name}</span>
                <span class="sgb__phys">{r.resistance != null && (<em>{S.res} {r.resistance.toFixed(2)}</em>)}{r.instability != null && (<em>{S.inst} {r.instability}</em>)}</span>
              </button>
              <div class="sgb__comp">
                <div class="sgb__complabel">{S.comp}</div>
                <ul class="sgb__parts">
                  {r.parts.map((p) => (
                    <li><span class="pn">{p.name}</span><span class="pp">{Math.round(p.min)}–{Math.round(p.max)}%</span></li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
  <div class="sgb__foot">
    <button type="button" class="sgb__clear" id="sgb-clear">{S.clear}</button>
    <p class="sgb__src">{S.src}</p>
  </div>

  <script is:inline>
    (function () {
      var root = document.getElementById('sgb'); if (!root) return;
      var KEY = 'mine.sigs'; var marked = [];
      try { marked = JSON.parse(localStorage.getItem(KEY) || '[]'); } catch (e) {}
      if (!Array.isArray(marked)) marked = [];
      var cards = [].slice.call(root.querySelectorAll('.sgb__card'));
      function save(){ try { localStorage.setItem(KEY, JSON.stringify(marked)); } catch(e){} }
      function paint(){ cards.forEach(function(c){ var on=marked.indexOf(+c.getAttribute('data-sig'))>=0; c.classList.toggle('on',on); c.setAttribute('aria-pressed',String(on)); }); }
      cards.forEach(function(c){
        c.querySelector('.sgb__cardhd').addEventListener('click', function(){
          var sig=+c.getAttribute('data-sig'); var i=marked.indexOf(sig);
          if(i>=0) marked.splice(i,1); else marked.push(sig);
          save(); paint();
        });
      });
      var clearBtn=document.getElementById('sgb-clear');
      if(clearBtn) clearBtn.addEventListener('click', function(){ marked=[]; save(); paint(); });
      paint();
    })();
  </script>

  <style is:inline>
    .sgb{max-width:var(--maxw,1240px);margin:0 auto;padding:0 clamp(1rem,4vw,2rem)}
    .sgb__intro{font-size:.92rem;color:var(--muted,#8fa3a0);line-height:1.55;max-width:78ch;margin:0 0 1.1rem}
    .sgb__groups{display:flex;flex-direction:column;gap:1rem}
    .sgb__group{--rar:#8fa3a0}
    .sgb__group[data-rarity="legendary"]{--rar:#e0564b}
    .sgb__group[data-rarity="epic"]{--rar:#b06ae0}
    .sgb__group[data-rarity="rare"]{--rar:var(--accent-2,#E0A526)}
    .sgb__group[data-rarity="uncommon"]{--rar:var(--accent,#2FBFA4)}
    .sgb__group[data-rarity="common"]{--rar:#8fa3a0}
    .sgb__gh{font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.64rem;color:var(--rar);margin-bottom:.5rem;border-left:3px solid var(--rar);padding-left:.5rem}
    .sgb__cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:.6rem}
    .sgb__card{border:1px solid var(--line-soft,rgba(255,255,255,.1));border-top:2px solid var(--rar);background:var(--bg-2,#181d1f);border-radius:5px;overflow:hidden;transition:box-shadow .15s,border-color .15s}
    .sgb__card.on{box-shadow:0 0 16px color-mix(in srgb,var(--rar) 40%,transparent);border-color:var(--rar)}
    .sgb__cardhd{width:100%;display:grid;grid-template-columns:auto 1fr;grid-template-rows:auto auto;gap:.1rem .6rem;align-items:baseline;background:transparent;border:0;cursor:pointer;text-align:left;padding:.6rem .7rem;color:inherit;font:inherit}
    .sgb__sig{grid-row:1 / span 2;align-self:center;font-family:var(--font-display,inherit);font-weight:800;font-size:1.15rem;color:var(--rar);font-variant-numeric:tabular-nums}
    .sgb__name{font-family:var(--font-display,inherit);font-weight:700;color:#fff;font-size:.95rem}
    .sgb__phys{display:flex;gap:.5rem}
    .sgb__phys em{font-style:normal;font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:.56rem;color:var(--muted,#8fa3a0)}
    .sgb__comp{border-top:1px solid var(--line-soft,rgba(255,255,255,.07));padding:.5rem .7rem .6rem}
    .sgb__complabel{font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.54rem;color:var(--rar);margin-bottom:.35rem}
    .sgb__parts{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:.2rem}
    .sgb__parts li{display:flex;justify-content:space-between;gap:.6rem;font-size:.8rem}
    .sgb__parts .pn{color:var(--text,#eaf2f1)}
    .sgb__parts .pp{color:var(--muted,#8fa3a0);font-variant-numeric:tabular-nums;flex:none}
    .sgb__foot{display:flex;flex-wrap:wrap;align-items:center;gap:.6rem 1.2rem;margin-top:1rem}
    .sgb__clear{background:transparent;border:1px solid var(--line,rgba(47,191,164,.3));color:var(--muted,#8fa3a0);padding:.4rem .8rem;border-radius:6px;cursor:pointer;font-family:var(--font-ui,inherit);font-weight:700;font-size:.78rem}
    .sgb__clear:hover{border-color:var(--accent,#2FBFA4);color:var(--accent,#2FBFA4)}
    .sgb__src{font-size:.74rem;color:var(--muted,#8fa3a0);font-style:italic;margin:0}
  </style>
</section>
