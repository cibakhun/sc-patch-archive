---
// Ctrl+K search — an in-universe terminal prompt over the whole archive.
// Zero dependencies: lazy-fetches /search-index.json (built from the data
// layer) and scores with a tiny normalized matcher. Palette-aware, no motion
// beyond open/close. Rendered once per page via SiteNav.
---
<div class="scs" id="scs" hidden>
  <div class="scs__back" data-scs-close></div>
  <div class="scs__panel" role="dialog" aria-modal="true" aria-label="Archiv durchsuchen">
    <div class="scs__bar">
      <span class="scs__prompt" aria-hidden="true">›</span>
      <input
        id="scs-in"
        type="search"
        placeholder="Patches, Themen, Schiffe, Features…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Suchbegriff"
      />
      <span class="scs__sys" aria-hidden="true">Archiv&nbsp;//&nbsp;Suche</span>
      <button class="scs__x" data-scs-close aria-label="Suche schließen">Esc</button>
    </div>
    <ul class="scs__list" id="scs-list" role="listbox" aria-label="Suchergebnisse"></ul>
    <div class="scs__foot">
      <span><kbd>↑↓</kbd> wählen</span>
      <span><kbd>↵</kbd> öffnen</span>
      <span><kbd>Esc</kbd> schließen</span>
    </div>
  </div>
</div>

<style>
  .scs {
    position: fixed;
    inset: 0;
    z-index: 9600;
  }
  .scs__back {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(5px);
  }
  .scs__panel {
    position: relative;
    max-width: 660px;
    margin: 11vh auto 0;
    background: var(--bg-2, #0a0e18);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
    border-top: 2px solid var(--accent, #2dd4ff);
    clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
  }
  .scs__bar {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1.1rem;
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
  }
  .scs__prompt {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--accent, #2dd4ff);
  }
  .scs__sys {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
  }
  .scs__bar input {
    flex: 1;
    background: none;
    border: 0;
    outline: 0;
    color: var(--text, #e8eefc);
    caret-color: var(--accent, #2dd4ff);
    font-family: var(--font-ui, sans-serif);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }
  .scs__bar input::placeholder {
    color: var(--muted, #8a99b8);
    opacity: 0.7;
  }
  .scs__x {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    border-radius: 1px;
    color: var(--muted, #8a99b8);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.14rem 0.45rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .scs__x:hover {
    color: var(--accent, #2dd4ff);
    border-color: color-mix(in srgb, var(--accent, #2dd4ff) 55%, transparent);
  }
  @media (max-width: 480px) {
    .scs__sys {
      display: none;
    }
  }
  .scs__list {
    list-style: none;
    margin: 0;
    padding: 0.4rem;
    max-height: 52vh;
    overflow-y: auto;
  }
  .scs__list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.15rem 0.8rem;
    padding: 0.55rem 0.9rem;
    border-left: 3px solid transparent;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s;
  }
  .scs__list li.sel,
  .scs__list li:hover {
    background: color-mix(in srgb, var(--accent, #2dd4ff) 6%, transparent);
    border-left-color: var(--accent, #2dd4ff);
  }
  .scs__badge {
    grid-row: span 2;
    align-self: start;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    border: 1px solid color-mix(in srgb, var(--accent, #2dd4ff) 35%, transparent);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 8%, transparent);
    padding: 0.18rem 0.4rem;
    margin-top: 0.15rem;
    white-space: nowrap;
    min-width: 6.5rem;
    text-align: center;
  }
  .scs__t {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 1.02rem;
    color: var(--text, #e8eefc);
  }
  .scs__s {
    font-size: 0.85rem;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .scs__empty {
    padding: 1.2rem 1.4rem;
    color: var(--muted, #8a99b8);
    font-size: 0.95rem;
  }
  .scs__empty b {
    display: block;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text, #e8eefc);
    margin-bottom: 0.3rem;
  }
  .scs__empty b::before {
    content: '// ';
    color: color-mix(in srgb, var(--accent, #2dd4ff) 55%, transparent);
  }
  .scs__foot {
    display: flex;
    gap: 1.4rem;
    justify-content: flex-end;
    padding: 0.55rem 1.1rem;
    border-top: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    background: rgba(0, 0, 0, 0.25);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
  }
  .scs__foot kbd {
    font-family: inherit;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted, #8a99b8);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    background: rgba(0, 0, 0, 0.3);
    padding: 0.08rem 0.4rem;
    border-radius: 1px;
  }
  @media (max-width: 700px) {
    .scs__panel {
      margin: 6vh 4vw 0;
    }
    .scs__badge {
      min-width: 5rem;
    }
  }
</style>

<script is:inline>
  (function () {
    if (window.__scsInit) return;
    window.__scsInit = true;

    var root = document.getElementById('scs');
    var input = document.getElementById('scs-in');
    var list = document.getElementById('scs-list');
    if (!root || !input || !list) return;

    var index = null;
    var results = [];
    var sel = 0;
    var lastFocus = null;

    var norm = function (s) {
      return (s || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[̀-ͯ]/g, '');
    };

    function load() {
      if (index) return Promise.resolve(index);
      return fetch('/search-index.json')
        .then(function (r) { return r.json(); })
        .then(function (j) {
          index = j.map(function (e) {
            return Object.assign({}, e, { nt: norm(e.t), ns: norm(e.s), nx: norm(e.x) });
          });
          return index;
        });
    }

    function score(e, terms) {
      var total = 0;
      for (var i = 0; i < terms.length; i++) {
        var q = terms[i];
        var pts = 0;
        if (e.nt.indexOf(q) === 0) pts = 40;
        else if (e.nt.indexOf(q) >= 0) pts = 25;
        else if (e.nx.indexOf(q) >= 0) pts = 15;
        else if (e.ns.indexOf(q) >= 0) pts = 8;
        if (!pts) return 0; // AND semantics
        total += pts;
      }
      return total;
    }

    function render(q) {
      var terms = norm(q).split(/\s+/).filter(Boolean);
      list.innerHTML = '';
      sel = 0;
      if (!terms.length || !index) { results = []; return; }
      results = index
        .map(function (e) { return { e: e, sc: score(e, terms) }; })
        .filter(function (r) { return r.sc > 0; })
        .sort(function (a, b) { return b.sc - a.sc; })
        .slice(0, 20)
        .map(function (r) { return r.e; });
      if (!results.length) {
        var li = document.createElement('li');
        li.className = 'scs__empty';
        var h = document.createElement('b');
        h.textContent = 'Kein Eintrag im Register';
        var p = document.createElement('span');
        p.textContent = 'Anfrage »' + q + '« ergab keine Treffer — Version oder Codename versuchen.';
        li.appendChild(h);
        li.appendChild(p);
        list.appendChild(li);
        return;
      }
      results.forEach(function (e, i) {
        var li = document.createElement('li');
        li.setAttribute('role', 'option');
        if (i === 0) li.classList.add('sel');
        var badge = document.createElement('span');
        badge.className = 'scs__badge';
        badge.textContent = e.b + ' · ' + e.k;
        var t = document.createElement('div');
        t.className = 'scs__t';
        t.textContent = e.t;
        var s = document.createElement('div');
        s.className = 'scs__s';
        s.textContent = e.s;
        li.appendChild(badge);
        li.appendChild(t);
        li.appendChild(s);
        li.addEventListener('click', function () { go(i); });
        list.appendChild(li);
      });
    }

    function move(d) {
      if (!results.length) return;
      var items = list.querySelectorAll('li[role="option"]');
      items[sel] && items[sel].classList.remove('sel');
      sel = (sel + d + results.length) % results.length;
      items[sel].classList.add('sel');
      items[sel].scrollIntoView({ block: 'nearest' });
    }

    function go(i) {
      var e = results[i == null ? sel : i];
      if (e) location.href = e.u;
    }

    function open() {
      lastFocus = document.activeElement;
      root.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      load().then(function () { render(input.value); });
      requestAnimationFrame(function () { input.focus(); input.select(); });
    }

    function close() {
      root.hidden = true;
      document.documentElement.style.overflow = '';
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    window.__scsOpen = open;

    document.addEventListener('keydown', function (e) {
      if ((e.ctrlKey || e.metaKey) && (e.key === 'k' || e.key === 'K')) {
        e.preventDefault();
        root.hidden ? open() : close();
        return;
      }
      if (root.hidden) {
        if (e.key === '/' && !/^(input|textarea|select)$/i.test((e.target && e.target.tagName) || '')) {
          e.preventDefault();
          open();
        }
        return;
      }
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
      else if (e.key === 'Enter') { e.preventDefault(); go(); }
    });

    input.addEventListener('input', function () { render(input.value); });
    root.querySelectorAll('[data-scs-close]').forEach(function (el) {
      el.addEventListener('click', close);
    });
    document.querySelectorAll('[data-scs-open]').forEach(function (el) {
      el.addEventListener('click', open);
    });
  })();
</script>
