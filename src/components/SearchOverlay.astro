---
// Ctrl+K search — an in-universe terminal prompt over the whole archive.
// Zero dependencies: lazy-fetches /search-index.json (built from the data
// layer) and scores with a tiny normalized matcher. Palette-aware, no motion
// beyond open/close. Rendered once per page via SiteNav.
//
// i18n: Chrome kommt aus t(); die zwei JS-Strings (Leer-Zustand) reicht das
// Frontmatter via data-Attribute an das is:inline-Script durch.
import { useTranslations, type Locale, DEFAULT_LOCALE } from '../i18n/ui';
interface Props {
  lang?: Locale;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
---
<div
  class="scs"
  id="scs"
  hidden
  data-empty-title={t('search.empty.title')}
  data-empty-query={t('search.empty.query')}
  data-empty-hint={t('search.empty.hint')}
  data-k-schiff={t('search.kind.schiff')}
  data-k-patch={t('search.kind.patch')}
  data-k-thema={t('search.kind.thema')}
  data-k-feature={t('search.kind.feature')}
  data-k-event={t('search.kind.event')}
>
  <div class="scs__back" data-scs-close></div>
  <div class="scs__panel" role="dialog" aria-modal="true" aria-label={t('search.dialog')}>
    <div class="scs__bar">
      <span class="scs__prompt" aria-hidden="true">›</span>
      <input
        id="scs-in"
        type="search"
        placeholder={t('search.placeholder')}
        autocomplete="off"
        spellcheck="false"
        aria-label={t('search.term')}
      />
      <span class="scs__sys" aria-hidden="true" set:html={t('search.sys')}></span>
      <button class="scs__x" data-scs-close aria-label={t('search.close')}>Esc</button>
    </div>
    <ul class="scs__list" id="scs-list" role="listbox" aria-label={t('search.results')}></ul>
    <div class="scs__foot">
      <span><kbd>↑↓</kbd> {t('search.pick')}</span>
      <span><kbd>↵</kbd> {t('search.open')}</span>
      <span><kbd>Esc</kbd> {t('search.dismiss')}</span>
    </div>
  </div>
</div>

<!-- is:global — the result rows are built in the is:inline script below, so they
     never receive Astro's scope attribute; scoped selectors would silently miss
     them (that was the "unformatted text wall" bug). Every class is scs__-prefixed,
     so a global block is safe and applies to both template and injected nodes. -->
<style is:global>
  .scs {
    position: fixed;
    inset: 0;
    z-index: 9600;
  }
  .scs__back {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(5px);
  }
  .scs__panel {
    position: relative;
    max-width: 660px;
    margin: 11vh auto 0;
    background: var(--bg-2, #0a0e18);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
    border-top: 2px solid var(--accent, #2dd4ff);
    clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
  }
  .scs__bar {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1.1rem;
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
  }
  .scs__prompt {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--accent, #2dd4ff);
  }
  .scs__sys {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
  }
  .scs__bar input {
    flex: 1;
    background: none;
    border: 0;
    outline: 0;
    color: var(--text, #e8eefc);
    caret-color: var(--accent, #2dd4ff);
    font-family: var(--font-ui, sans-serif);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }
  .scs__bar input::placeholder {
    color: var(--muted, #8a99b8);
    opacity: 0.7;
  }
  .scs__x {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    border-radius: 1px;
    color: var(--muted, #8a99b8);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.14rem 0.45rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .scs__x:hover {
    color: var(--accent, #2dd4ff);
    border-color: color-mix(in srgb, var(--accent, #2dd4ff) 55%, transparent);
  }
  @media (max-width: 480px) {
    .scs__sys {
      display: none;
    }
  }
  .scs__list {
    list-style: none;
    margin: 0;
    padding: 0.5rem;
    max-height: 56vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, var(--accent, #2dd4ff) 45%, transparent) transparent;
  }
  /* one result = one clearly bounded card row (badge · body · arrow) */
  .scs__hit {
    --c: var(--accent, #2dd4ff);
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    grid-template-rows: auto auto;
    align-items: center;
    column-gap: 0.9rem;
    row-gap: 0.1rem;
    padding: 0.7rem 0.85rem 0.7rem 0.75rem;
    border: 1px solid var(--line, rgba(255, 255, 255, 0.12));
    border-left: 3px solid transparent;
    border-radius: 3px;
    background: color-mix(in srgb, var(--surface, #0f1524) 55%, transparent);
    cursor: pointer;
    scroll-margin: 0.5rem;
    transition: background-color 0.14s ease, border-color 0.14s ease, transform 0.14s ease;
  }
  /* hover AND keyboard selection share one unmistakable highlighted state —
     kept as two self-contained rules (not a shared selector list) so the
     keyboard `.sel` row always gets the full highlight, not just part of it */
  .scs__hit:hover {
    background: color-mix(in srgb, var(--c) 16%, var(--surface, #0f1524)) !important;
    border-color: color-mix(in srgb, var(--c) 45%, transparent) !important;
    border-left-color: var(--c) !important;
    transform: translateX(2px);
  }
  .scs__hit.sel {
    background: color-mix(in srgb, var(--c) 18%, var(--surface, #0f1524)) !important;
    border-color: color-mix(in srgb, var(--c) 45%, transparent) !important;
    border-left-color: var(--c) !important;
    transform: translateX(2px);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--c) 40%, transparent);
  }
  .scs__badge {
    grid-column: 1;
    grid-row: 1 / span 2;
    align-self: center;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c);
    border: 1px solid color-mix(in srgb, var(--c) 45%, transparent);
    background: color-mix(in srgb, var(--c) 12%, transparent);
    border-radius: 2px;
    padding: 0.2rem 0.45rem;
    white-space: nowrap;
    min-width: 4.6rem;
    text-align: center;
  }
  /* type colour-coding — instantly tells ships from patches from topics */
  .scs__hit--schiff { --c: var(--accent, #2dd4ff); }
  .scs__hit--patch { --c: var(--gold, #d4af37); }
  .scs__hit--thema { --c: var(--accent-2, #6ea8ff); }
  .scs__hit--feature { --c: #5ad19a; }
  .scs__hit--event { --c: #ff8a50; }
  .scs__t {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 1.02rem;
    line-height: 1.25;
    color: var(--text, #e8eefc);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .scs__s {
    grid-column: 2;
    grid-row: 2;
    font-size: 0.85rem;
    line-height: 1.35;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .scs__meta {
    grid-column: 3;
    grid-row: 1 / span 2;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
  }
  .scs__go {
    color: var(--c);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.14s ease, transform 0.14s ease;
  }
  .scs__hit:hover .scs__go {
    opacity: 1;
    transform: none;
  }
  .scs__hit.sel .scs__go {
    opacity: 1;
    transform: none;
  }
  .scs__hit:hover .scs__meta {
    color: var(--text, #e8eefc);
  }
  .scs__hit.sel .scs__meta {
    color: var(--text, #e8eefc);
  }
  .scs__empty {
    padding: 1.2rem 1.4rem;
    color: var(--muted, #8a99b8);
    font-size: 0.95rem;
  }
  .scs__empty b {
    display: block;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text, #e8eefc);
    margin-bottom: 0.3rem;
  }
  .scs__empty b::before {
    content: '// ';
    color: color-mix(in srgb, var(--accent, #2dd4ff) 55%, transparent);
  }
  .scs__foot {
    display: flex;
    gap: 1.4rem;
    justify-content: flex-end;
    padding: 0.55rem 1.1rem;
    border-top: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    background: rgba(0, 0, 0, 0.25);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
  }
  .scs__foot kbd {
    font-family: inherit;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted, #8a99b8);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    background: rgba(0, 0, 0, 0.3);
    padding: 0.08rem 0.4rem;
    border-radius: 1px;
  }
  @media (max-width: 700px) {
    .scs__panel {
      margin: 6vh 4vw 0;
    }
    .scs__badge {
      min-width: 3.9rem;
      font-size: 0.64rem;
      letter-spacing: 0.1em;
    }
    /* drop the right-hand version meta on narrow screens — the badge + title
       carry the identity, and the arrow alone signals the active row */
    .scs__meta-ver {
      display: none;
    }
    .scs__hit {
      column-gap: 0.7rem;
    }
  }
</style>

<script is:inline>
  (function () {
    if (window.__scsInit) return;
    window.__scsInit = true;

    var root = document.getElementById('scs');
    var input = document.getElementById('scs-in');
    var list = document.getElementById('scs-list');
    if (!root || !input || !list) return;

    var index = null;
    var results = [];
    var sel = 0;
    var lastFocus = null;

    var norm = function (s) {
      return (s || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[̀-ͯ]/g, '');
    };

    function load() {
      if (index) return Promise.resolve(index);
      return fetch('/search-index.json')
        .then(function (r) { return r.json(); })
        .then(function (j) {
          index = j.map(function (e) {
            return Object.assign({}, e, { nt: norm(e.t), ns: norm(e.s), nx: norm(e.x) });
          });
          return index;
        });
    }

    function score(e, terms) {
      var total = 0;
      for (var i = 0; i < terms.length; i++) {
        var q = terms[i];
        var pts = 0;
        if (e.nt.indexOf(q) === 0) pts = 40;
        else if (e.nt.indexOf(q) >= 0) pts = 25;
        else if (e.nx.indexOf(q) >= 0) pts = 15;
        else if (e.ns.indexOf(q) >= 0) pts = 8;
        if (!pts) return 0; // AND semantics
        total += pts;
      }
      return total;
    }

    function render(q) {
      var terms = norm(q).split(/\s+/).filter(Boolean);
      list.innerHTML = '';
      sel = 0;
      if (!terms.length || !index) { results = []; return; }
      results = index
        .map(function (e) { return { e: e, sc: score(e, terms) }; })
        .filter(function (r) { return r.sc > 0; })
        .sort(function (a, b) { return b.sc - a.sc; })
        .slice(0, 20)
        .map(function (r) { return r.e; });
      if (!results.length) {
        var li = document.createElement('li');
        li.className = 'scs__empty';
        var h = document.createElement('b');
        h.textContent = root.dataset.emptyTitle || 'Kein Eintrag im Register';
        var p = document.createElement('span');
        var qpre = (root.dataset.emptyQuery || 'Anfrage »%q%« ').replace('%q%', q);
        p.textContent = qpre + (root.dataset.emptyHint || 'ergab keine Treffer — Version oder Codename versuchen.');
        li.appendChild(h);
        li.appendChild(p);
        list.appendChild(li);
        return;
      }
      results.forEach(function (e, i) {
        var li = document.createElement('li');
        li.setAttribute('role', 'option');
        li.className = 'scs__hit scs__hit--' + e.k;
        li.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
        if (i === 0) li.classList.add('sel');

        var badge = document.createElement('span');
        badge.className = 'scs__badge';
        // localized type label (Schiff/Patch/Thema/…), falling back to the raw kind
        badge.textContent = root.dataset['k' + e.k.charAt(0).toUpperCase() + e.k.slice(1)] || e.k;

        var t = document.createElement('span');
        t.className = 'scs__t';
        t.textContent = e.t;

        var s = document.createElement('span');
        s.className = 'scs__s';
        s.textContent = e.s || '';

        var meta = document.createElement('span');
        meta.className = 'scs__meta';
        if (e.b) {
          var ver = document.createElement('span');
          ver.className = 'scs__meta-ver';
          ver.textContent = e.b;
          meta.appendChild(ver);
        }
        var go_ = document.createElement('span');
        go_.className = 'scs__go';
        go_.setAttribute('aria-hidden', 'true');
        go_.textContent = '→';
        meta.appendChild(go_);

        li.appendChild(badge);
        li.appendChild(t);
        li.appendChild(s);
        li.appendChild(meta);
        li.addEventListener('click', function () { go(i); });
        list.appendChild(li);
      });
    }

    function move(d) {
      if (!results.length) return;
      var items = list.querySelectorAll('li[role="option"]');
      if (items[sel]) { items[sel].classList.remove('sel'); items[sel].setAttribute('aria-selected', 'false'); }
      sel = (sel + d + results.length) % results.length;
      items[sel].classList.add('sel');
      items[sel].setAttribute('aria-selected', 'true');
      items[sel].scrollIntoView({ block: 'nearest' });
    }

    function go(i) {
      var e = results[i == null ? sel : i];
      if (e) location.href = e.u;
    }

    function open() {
      lastFocus = document.activeElement;
      root.hidden = false;
      document.documentElement.style.overflow = 'hidden';
      load().then(function () { render(input.value); });
      requestAnimationFrame(function () { input.focus(); input.select(); });
    }

    function close() {
      root.hidden = true;
      document.documentElement.style.overflow = '';
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    window.__scsOpen = open;

    document.addEventListener('keydown', function (e) {
      if ((e.ctrlKey || e.metaKey) && (e.key === 'k' || e.key === 'K')) {
        e.preventDefault();
        root.hidden ? open() : close();
        return;
      }
      if (root.hidden) {
        if (e.key === '/' && !/^(input|textarea|select)$/i.test((e.target && e.target.tagName) || '')) {
          e.preventDefault();
          open();
        }
        return;
      }
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
      else if (e.key === 'Enter') { e.preventDefault(); go(); }
    });

    input.addEventListener('input', function () { render(input.value); });
    root.querySelectorAll('[data-scs-close]').forEach(function (el) {
      el.addEventListener('click', close);
    });
    // Delegation statt Direktbindung: Trigger dürfen auch NACH diesem Script
    // im DOM stehen (z. B. das Hero-Suchfeld der Startseite unter der Nav).
    document.addEventListener('click', function (e) {
      if (e.target.closest && e.target.closest('[data-scs-open]')) open();
    });
  })();
</script>
