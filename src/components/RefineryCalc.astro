---
// RefineryCalc.astro — interaktiver Refinery-Rechner.
// Erz (raffinierbar, mit Preis) + Menge (SCU) + eine der 9 Methoden →
// Wartezeit, Kosten, Ertrag (refined SCU) und Verkaufswert; plus Methoden-
// Vergleich. Faktoren aus mining-db (UEX-Ratings, am Audit kalibriert) — Näherung.
import DB from '../../assets/mining-db.json';

interface Props { lang: 'de' | 'en'; }
const { lang } = Astro.props;

const methods = DB.methods || [];
// Raffinierbare Erze mit Verkaufspreis (refined SCU-Preis).
const ores = (DB.minerals || [])
  .filter((m) => m.needs_refine && m.sell && m.sell.best)
  .map((m) => ({ name: m.name, price: m.sell.best.price }))
  .sort((a, b) => a.name.localeCompare(b.name));

const S = {
  de: {
    ore: 'Erz', amount: 'Menge (SCU)', method: 'Methode',
    waitTime: 'Wartezeit', cost: 'Kosten', yieldOut: 'Ertrag (refined)', saleValue: 'Verkaufswert', net: 'Netto-Gewinn',
    compare: 'Methoden-Vergleich', best: 'bester Netto', fastest: 'schnellste', mostYield: 'meister Ertrag',
    colMethod: 'Methode', colYield: 'Ertrag', colTime: 'Zeit', colCost: 'Kosten', colNet: 'Netto',
    note: 'Näherung: Ertrag/Kosten/Zeit aus den UEX-Methoden-Ratings, kalibriert an spärlichen Audit-Daten (die exakte CIG-Formel ist nicht öffentlich, und Preise sind patch-volatil). Zum Methoden-Vergleich gedacht, nicht als exakte Prognose.',
  },
  en: {
    ore: 'Ore', amount: 'Amount (SCU)', method: 'Method',
    waitTime: 'Wait time', cost: 'Cost', yieldOut: 'Yield (refined)', saleValue: 'Sale value', net: 'Net profit',
    compare: 'Method comparison', best: 'best net', fastest: 'fastest', mostYield: 'most yield',
    colMethod: 'Method', colYield: 'Yield', colTime: 'Time', colCost: 'Cost', colNet: 'Net',
    note: 'Approximation: yield/cost/time from UEX method ratings, calibrated on sparse audit data (CIG’s exact formula isn’t public, and prices are patch-volatile). Meant for comparing methods, not an exact forecast.',
  },
}[lang];
---
<section class="rfc" id="rfc">
  <div class="rfc__grid">
    <div class="rfc__in">
      <div class="rfc__row">
        <label class="rfc__field"><span>{S.ore}</span>
          <select id="rfc-ore">
            {ores.map((o, i) => (<option value={i}>{o.name} · {o.price.toLocaleString('en-US')} aUEC/SCU</option>))}
          </select>
        </label>
        <label class="rfc__field rfc__field--sm"><span>{S.amount}</span>
          <input type="number" id="rfc-amt" min="1" step="1" value="32">
        </label>
        <label class="rfc__field"><span>{S.method}</span>
          <select id="rfc-meth">
            {methods.map((m, i) => (<option value={i}>{m.name}</option>))}
          </select>
        </label>
      </div>
      <div class="rfc__out">
        <div class="rfc__box"><span>{S.waitTime}</span><b id="rfc-time">—</b></div>
        <div class="rfc__box"><span>{S.yieldOut}</span><b id="rfc-yield">—</b></div>
        <div class="rfc__box"><span>{S.cost}</span><b id="rfc-cost">—</b></div>
        <div class="rfc__box"><span>{S.saleValue}</span><b id="rfc-sale">—</b></div>
        <div class="rfc__box rfc__box--net"><span>{S.net}</span><b id="rfc-net">—</b></div>
      </div>
    </div>

    <div class="rfc__cmp">
      <div class="rfc__cmphd">{S.compare}</div>
      <table class="rfc__tbl">
        <thead><tr><th>{S.colMethod}</th><th>{S.colYield}</th><th>{S.colTime}</th><th>{S.colCost}</th><th>{S.colNet}</th></tr></thead>
        <tbody id="rfc-tbody"></tbody>
      </table>
    </div>
  </div>
  <p class="rfc__note">{S.note}</p>

  <script type="application/json" id="rfc-data" set:html={JSON.stringify({ ores, methods, lang })}></script>
  <script is:inline>
    (function () {
      var el = document.getElementById('rfc-data');
      if (!el) return;
      var D = JSON.parse(el.textContent);
      var NF = new Intl.NumberFormat(D.lang === 'de' ? 'de-DE' : 'en-US');
      var $ = function (id) { return document.getElementById(id); };
      var oreSel = $('rfc-ore'), amtEl = $('rfc-amt'), methSel = $('rfc-meth');

      function fmtTime(sec) {
        sec = Math.round(sec);
        var h = Math.floor(sec / 3600), m = Math.floor((sec % 3600) / 60), s = sec % 60;
        if (h) return h + 'h ' + m + 'm';
        if (m) return m + 'm ' + (s ? s + 's' : '');
        return s + 's';
      }
      function compute(ore, meth, amt) {
        var yieldScu = amt * meth.yield_ratio;
        var sale = yieldScu * ore.price;
        var cost = amt * meth.cost_per_scu;
        var time = amt * meth.time_per_scu;
        return { yieldScu: yieldScu, sale: sale, cost: cost, time: time, net: sale - cost };
      }

      function render() {
        var ore = D.ores[+oreSel.value] || D.ores[0];
        var amt = Math.max(0, +amtEl.value || 0);
        var meth = D.methods[+methSel.value] || D.methods[0];
        var r = compute(ore, meth, amt);
        $('rfc-time').textContent = fmtTime(r.time);
        $('rfc-yield').textContent = (Math.round(r.yieldScu * 10) / 10) + ' SCU';
        $('rfc-cost').textContent = NF.format(Math.round(r.cost)) + ' aUEC';
        $('rfc-sale').textContent = NF.format(Math.round(r.sale)) + ' aUEC';
        $('rfc-net').textContent = NF.format(Math.round(r.net)) + ' aUEC';

        // Vergleichstabelle: alle Methoden für dieses Erz + Menge.
        var rows = D.methods.map(function (m) { return { m: m, r: compute(ore, m, amt) }; });
        var bestNet = Math.max.apply(null, rows.map(function (x) { return x.r.net; }));
        var fastest = Math.min.apply(null, rows.map(function (x) { return x.r.time; }));
        var mostYield = Math.max.apply(null, rows.map(function (x) { return x.r.yieldScu; }));
        rows.sort(function (a, b) { return b.r.net - a.r.net; });
        var tb = $('rfc-tbody');
        tb.innerHTML = rows.map(function (x) {
          var tags = '';
          if (x.r.net === bestNet) tags += '<i class="rfc-tag net">▲</i>';
          if (x.r.time === fastest) tags += '<i class="rfc-tag fast">⚡</i>';
          if (x.r.yieldScu === mostYield) tags += '<i class="rfc-tag yld">◆</i>';
          var sel = x.m.code === meth.code ? ' class="on"' : '';
          return '<tr' + sel + ' data-code="' + x.m.code + '"><td>' + x.m.name + ' ' + tags +
            '</td><td>' + (Math.round(x.r.yieldScu * 10) / 10) + '</td><td>' + fmtTime(x.r.time) +
            '</td><td>' + NF.format(Math.round(x.r.cost)) + '</td><td>' + NF.format(Math.round(x.r.net)) + '</td></tr>';
        }).join('');
        // Klick auf Tabellenzeile wählt die Methode.
        Array.prototype.forEach.call(tb.querySelectorAll('tr'), function (tr) {
          tr.addEventListener('click', function () {
            var idx = D.methods.findIndex(function (m) { return m.code === tr.getAttribute('data-code'); });
            if (idx >= 0) { methSel.value = idx; render(); }
          });
        });
      }

      oreSel.addEventListener('change', render);
      methSel.addEventListener('change', render);
      amtEl.addEventListener('input', render);
      render();
    })();
  </script>

  <style is:inline>
    .rfc{max-width:var(--maxw,1240px);margin:0 auto;padding:0 clamp(1rem,4vw,2rem)}
    .rfc *{box-sizing:border-box}
    .rfc__cmp{overflow-x:auto}
    .rfc__grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;align-items:start}
    .rfc__in,.rfc__cmp{border:1px solid var(--line,rgba(47,191,164,.22));background:var(--surface,#1e2427);border-radius:8px;padding:1rem 1.1rem}
    .rfc__in{border-top:2px solid var(--accent,#2FBFA4)}
    .rfc__row{display:flex;flex-wrap:wrap;gap:.7rem;margin-bottom:1rem}
    .rfc__field{display:flex;flex-direction:column;gap:.25rem;flex:1 1 150px;min-width:0}
    .rfc__field--sm{flex:0 1 110px}
    .rfc__field span{font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:.6rem;color:var(--muted,#8fa3a0)}
    .rfc__field select,.rfc__field input{background:var(--bg-2,#181d1f);border:1px solid var(--line,rgba(47,191,164,.3));color:var(--text,#eaf2f1);padding:.45rem .55rem;border-radius:5px;font-size:.9rem;font-family:var(--font-ui,inherit);max-width:100%}
    .rfc__out{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:.5rem}
    .rfc__box{background:var(--bg-2,#181d1f);border:1px solid var(--line-soft,rgba(255,255,255,.08));border-radius:5px;padding:.55rem .7rem}
    .rfc__box span{display:block;font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.06em;font-size:.56rem;color:var(--muted,#8fa3a0)}
    .rfc__box b{font-size:1.05rem;color:var(--text,#eaf2f1);font-variant-numeric:tabular-nums}
    .rfc__box--net{grid-column:1 / -1;border-color:color-mix(in srgb,var(--accent,#2FBFA4) 45%,transparent);border-left:3px solid var(--accent,#2FBFA4)}
    .rfc__box--net b{color:var(--accent,#2FBFA4);font-size:1.25rem}
    .rfc__cmphd{font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.66rem;color:var(--accent,#2FBFA4);margin-bottom:.6rem}
    .rfc__tbl{width:100%;border-collapse:collapse;font-size:.8rem}
    .rfc__tbl th{text-align:right;font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:.56rem;color:var(--muted,#8fa3a0);padding:.3rem .35rem;border-bottom:1px solid var(--line-soft,rgba(255,255,255,.1))}
    .rfc__tbl th:first-child{text-align:left}
    .rfc__tbl td{text-align:right;padding:.34rem .35rem;color:var(--text,#eaf2f1);border-bottom:1px solid var(--line-soft,rgba(255,255,255,.05));font-variant-numeric:tabular-nums;cursor:pointer}
    .rfc__tbl td:first-child{text-align:left;color:#fff}
    .rfc__tbl tr:hover td{background:rgba(47,191,164,.06)}
    .rfc__tbl tr.on td{background:color-mix(in srgb,var(--accent,#2FBFA4) 12%,transparent)}
    .rfc-tag{font-style:normal;margin-left:.15rem;font-size:.72rem}
    .rfc-tag.net{color:var(--accent,#2FBFA4)}
    .rfc-tag.fast{color:var(--accent-2,#E0A526)}
    .rfc-tag.yld{color:#8fa3a0}
    .rfc__note{max-width:var(--maxw,1240px);margin:.9rem auto 0;font-size:.78rem;color:var(--muted,#8fa3a0);line-height:1.5;font-style:italic}
    @media(max-width:760px){ .rfc__grid{grid-template-columns:1fr} }
  </style>
</section>
