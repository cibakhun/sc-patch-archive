---
// The full patch manifest — features & systems, ships, events, wipe/fixes.
// The uniform "Datenblatt" register: identical structure on every patch page,
// rendered entirely from the validated data layer. Plain and scannable by
// design; accent color only where it carries function (chips, links, header).
import type { CollectionEntry } from 'astro:content';

interface Props {
  patch: CollectionEntry<'patches'>['data'];
  num?: string;
}
const { patch, num } = Astro.props;
const hasUnverified =
  patch.features.some((f) => f.unverified || f.facts?.some((x) => x.unverified)) ||
  patch.ships.some((s) => s.unverified) ||
  patch.keyFacts.some((x) => x.unverified);
---
<section class="do" id="dossier" aria-label={`Dossier Alpha ${patch.version}`}>
  <div class="do__in">
    <header class="do__head">
      {num && <span class="do__num">{num}</span>}
      <h2>Dossier</h2>
      <span class="do__rule"></span>
      <span class="do__meta">Alpha {patch.version} · {patch.dateDisplay}</span>
    </header>

    <p class="do__summary">{patch.summary}</p>

    <h3 class="do__sub">Features &amp; Systeme</h3>
    <div class="do__features">
      {patch.features.map((f) => (
        <article class="do__feat">
          <div class="do__feat-head">
            <h4>{f.name}{f.unverified && <abbr class="do__unv" title="unbestätigt">*</abbr>}</h4>
            {f.system && <span class="do__chip">{f.system}</span>}
          </div>
          <p class="do__desc">{f.desc}</p>
          {(f.facts?.length ?? 0) > 0 && (
            <dl class="do__facts">
              {f.facts!.map((x) => (
                <div class="do__fact">
                  <dt>{x.label}</dt>
                  <dd>{x.value}{x.unverified && <abbr class="do__unv" title="unbestätigt">*</abbr>}</dd>
                </div>
              ))}
            </dl>
          )}
          {f.topicSlug && <a class="do__link" href={`/topics/${f.topicSlug}.html`}>Detailseite ansehen →</a>}
        </article>
      ))}
    </div>

    {patch.ships.length > 0 && (
      <>
        <h3 class="do__sub">Schiffe</h3>
        <table class="do__table">
          <thead>
            <tr><th>Schiff</th><th>Hersteller</th><th>Rolle</th><th>Status</th></tr>
          </thead>
          <tbody>
            {patch.ships.map((s) => (
              <tr>
                <td>{s.name}{s.unverified && <abbr class="do__unv" title="unbestätigt">*</abbr>}</td>
                <td>{s.manufacturer}</td>
                <td>{s.role}</td>
                <td>{s.status ?? '—'}{s.notes && <span class="do__shipnote"> · {s.notes}</span>}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {patch.events.length > 0 && (
      <>
        <h3 class="do__sub">Events</h3>
        <ul class="do__events">
          {patch.events.map((e) => (
            <li>
              <b>{e.name}</b>{e.period && <span class="do__period"> · {e.period}</span>} — {e.desc}
            </li>
          ))}
        </ul>
      </>
    )}

    {(patch.wipe || patch.fixesNote) && (
      <div class="do__foot">
        {patch.wipe && <span class="do__wipe">⚠ {patch.wipe}</span>}
        {patch.fixesNote && <span>{patch.fixesNote}</span>}
      </div>
    )}

    <p class="do__note">
      {hasUnverified && <span>* unbestätigt · </span>}Quellen: starcitizen.tools, RSI Comm-Links, Patch Notes
    </p>
  </div>
</section>

<style>
  .do {
    padding: clamp(3rem, 7vw, 6rem) clamp(1.25rem, 5vw, 4.5rem);
  }
  .do__in {
    max-width: var(--maxw, 1280px);
    margin: 0 auto;
  }
  .do__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }
  .do__num {
    font-family: var(--font-display, sans-serif);
    font-weight: 900;
    font-size: 0.95rem;
    color: var(--accent, #2dd4ff);
    opacity: 0.8;
  }
  .do__head h2 {
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: clamp(1.4rem, 3.5vw, 2.3rem);
    color: var(--text, #e8eefc);
  }
  .do__rule {
    flex: 1;
    height: 1px;
    background: var(--line, rgba(255, 255, 255, 0.14));
  }
  .do__meta {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
  }
  .do__summary {
    max-width: 72ch;
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--text, #e8eefc);
    opacity: 0.92;
    margin-bottom: 2.2rem;
  }
  .do__sub {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    margin: 2.2rem 0 1rem;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
  }
  .do__features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(430px, 100%), 1fr));
    gap: 1rem;
  }
  .do__feat {
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    background: var(--surface, #10151f);
    padding: 1.1rem 1.25rem 1.15rem;
  }
  .do__feat-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }
  .do__feat h4 {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 1.08rem;
    color: var(--text, #e8eefc);
  }
  .do__chip {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    padding: 0.14rem 0.5rem;
    white-space: nowrap;
  }
  .do__desc {
    font-size: 0.93rem;
    line-height: 1.6;
    color: var(--text, #e8eefc);
    opacity: 0.85;
  }
  .do__facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.55rem 1.2rem;
    margin: 0.85rem 0 0;
  }
  .do__fact {
    border-left: 2px solid var(--line, rgba(255, 255, 255, 0.14));
    padding-left: 0.65rem;
  }
  .do__fact dt {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.63rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
  }
  .do__fact dd {
    margin: 0.1rem 0 0;
    font-size: 0.9rem;
    color: var(--text, #e8eefc);
  }
  .do__link {
    display: inline-block;
    margin-top: 0.85rem;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
  }
  .do__link:hover {
    text-decoration: underline;
  }
  .do__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.93rem;
  }
  .do__table th {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    text-align: left;
    padding: 0.5rem 0.9rem 0.5rem 0;
    border-bottom: 1px solid var(--accent, #2dd4ff);
  }
  .do__table td {
    padding: 0.6rem 0.9rem 0.6rem 0;
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    color: var(--text, #e8eefc);
  }
  .do__table td:first-child {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
  }
  .do__shipnote {
    color: var(--muted, #8a99b8);
    font-size: 0.86rem;
  }
  .do__events {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }
  .do__events li {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text, #e8eefc);
    opacity: 0.9;
    border-left: 2px solid var(--line, rgba(255, 255, 255, 0.14));
    padding-left: 0.8rem;
  }
  .do__events b {
    font-family: var(--font-ui, sans-serif);
  }
  .do__period {
    color: var(--muted, #8a99b8);
  }
  .do__foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 2rem;
    margin-top: 2rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    background: var(--surface, #10151f);
    font-family: var(--font-ui, sans-serif);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text, #e8eefc);
  }
  .do__wipe {
    color: var(--accent, #2dd4ff);
  }
  .do__note {
    margin-top: 1.4rem;
    font-size: 0.72rem;
    color: var(--muted, #8a99b8);
    opacity: 0.8;
  }
  .do__unv {
    color: var(--accent, #2dd4ff);
    text-decoration: none;
    cursor: help;
    margin-left: 0.15rem;
  }
</style>
