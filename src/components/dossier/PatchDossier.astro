---
// The full patch manifest — REGISTRATUR design language.
// One big register panel (rail + notches) with a Kopfleiste + Aktencode.
// Feature cards run on Akzent-Dim (accent budget: rail, section labels,
// nothing else screams); tables use the readout style with tabular numerals.
// No motion beyond ≤150ms color/border hovers.
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import shipsSnapshot from '../../data/ships.json';
import { useTranslations, href, type Locale, DEFAULT_LOCALE } from '../../i18n/ui';

interface Props {
  patch: CollectionEntry<'patches'>['data'];
  num?: string;
  lang?: Locale;
}
const { patch, num, lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const L = (p: string) => href(p, lang);
const hasUnverified =
  patch.features.some((f) => f.unverified || f.facts?.some((x) => x.unverified)) ||
  patch.ships.some((s) => s.unverified) ||
  patch.keyFacts.some((x) => x.unverified);

// FleetYards specs (validated snapshot; join key = the patch-data ship name)
const fy = await getCollection('ships');
const specs = new Map(fy.map((s) => [s.data.matchedFrom.toLowerCase(), s.data]));
const spec = (name: string) => specs.get(name.toLowerCase().replace(/\s+/g, ' ').trim());
const crewFmt = (s?: (typeof fy)[number]['data']) =>
  s && (s.crewMin != null || s.crewMax != null)
    ? s.crewMin != null && s.crewMax != null && s.crewMax !== s.crewMin
      ? `${s.crewMin}–${s.crewMax}`
      : `${s.crewMin ?? s.crewMax}`
    : '—';
const scuFmt = (s?: (typeof fy)[number]['data']) =>
  s?.cargoSCU != null ? `${Number.isInteger(s.cargoSCU) ? s.cargoSCU : s.cargoSCU.toFixed(1)} SCU` : '—';
const priceFmt = (s?: (typeof fy)[number]['data']) =>
  s?.priceUSD != null ? `$${s.priceUSD}` : '—';
const anySpecs = patch.ships.some((s) => spec(s.name));
---
<section class="do" id="dossier" aria-label={t('do.aria').replace('%v%', patch.version)}>
  <div class="do__in">
    <header class="do__head">
      <span class="do__title">
        {num && <span class="do__num">{num}</span>}
        <h2>{t('do.title')}</h2>
      </span>
      <span class="do__code">{t('ship.code.dat')}&nbsp;//&nbsp;Alpha {patch.version} · {t('ship.asof')} {patch.dateDisplay}</span>
    </header>

    <p class="do__summary">{patch.summary}</p>

    <h3 class="do__sub">{t('do.featsystems')}</h3>
    <div class="do__features">
      {patch.features.map((f) => (
        <article class="do__feat">
          <div class="do__feat-head">
            <h4>{f.name}{f.unverified && <abbr class="do__unv" title={t('common.unverified')}>*</abbr>}</h4>
            {f.system && <span class="do__chip">{f.system}</span>}
          </div>
          <p class="do__desc">{f.desc}</p>
          {(f.facts?.length ?? 0) > 0 && (
            <dl class="do__facts">
              {f.facts!.map((x) => (
                <div class="do__fact">
                  <dt>{x.label}</dt>
                  <dd>{x.value}{x.unverified && <abbr class="do__unv" title={t('common.unverified')}>*</abbr>}</dd>
                </div>
              ))}
            </dl>
          )}
          {f.topicSlug && <a class="do__link" href={L(`/topics/${f.topicSlug}.html`)}>{t('do.deepdive')}</a>}
        </article>
      ))}
    </div>

    {patch.ships.length > 0 && (
      <>
        <h3 class="do__sub">{t('do.ships')}</h3>
        <div class="do__tablewrap">
          <table class="do__table">
            <thead>
              <tr><th>{t('do.th.ship')}</th><th>{t('do.th.role')}</th><th class="num">{t('do.th.crew')}</th><th class="num">{t('do.th.cargo')}</th><th class="num">{t('do.th.price')}</th><th>{t('do.th.status')}</th></tr>
            </thead>
            <tbody>
              {patch.ships.map((s) => {
                const f = spec(s.name);
                return (
                  <tr>
                    <td>
                      {f ? (
                        <a class="do__shiplink" href={f.fleetyardsUrl} target="_blank" rel="noopener">
                          {s.name}<span class="do__ext" aria-hidden="true"> ↗</span>
                        </a>
                      ) : (
                        s.name
                      )}
                      {s.unverified && <abbr class="do__unv" title="unbestätigt">*</abbr>}
                    </td>
                    <td>{s.role}</td>
                    <td class="num">{crewFmt(f)}</td>
                    <td class="num">{scuFmt(f)}</td>
                    <td class="num">{priceFmt(f)}</td>
                    <td>{s.status ?? '—'}{s.notes && <span class="do__shipnote"> · {s.notes}</span>}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        {anySpecs && (
          <p class="do__specsrc">
            {t('do.specs')}: <a href="https://fleetyards.net" target="_blank" rel="noopener">FleetYards.net</a> ({t('do.specsNote')}) · {t('ship.asof')} {shipsSnapshot.fetchedAt}
          </p>
        )}
      </>
    )}

    {patch.events.length > 0 && (
      <>
        <h3 class="do__sub">{t('do.events')}</h3>
        <ul class="do__events">
          {patch.events.map((e) => (
            <li>
              <b>{e.name}</b>{e.period && <span class="do__period"> · {e.period}</span>} — {e.desc}
            </li>
          ))}
        </ul>
      </>
    )}

    {(patch.wipe || patch.fixesNote) && (
      <div class="do__foot">
        {patch.wipe && <span class="do__wipe">⚠ {patch.wipe}</span>}
        {patch.fixesNote && <span>{patch.fixesNote}</span>}
      </div>
    )}

    <p class="do__note">
      {hasUnverified && <span>{t('do.unvNote')}</span>}{t('do.sources')}
    </p>
  </div>
</section>

<style>
  .do {
    padding: clamp(3rem, 7vw, 6rem) clamp(1.25rem, 5vw, 4.5rem);
  }
  .do__in {
    max-width: var(--maxw, 1280px);
    margin: 0 auto;
    background: var(--surface, #10151f);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    border-top: 2px solid var(--accent, #2dd4ff);
    padding: 1.25rem 1.5rem 1.4rem;
    clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
  }
  .do__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    padding-bottom: 0.55rem;
    margin-bottom: 1rem;
  }
  .do__title {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
  }
  .do__num {
    font-family: var(--font-display, sans-serif);
    font-weight: 900;
    font-size: 0.95rem;
    color: var(--accent, #2dd4ff);
    opacity: 0.8;
  }
  .do__head h2 {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
  }
  .do__code {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .do__summary {
    max-width: 78ch;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text, #e8eefc);
    opacity: 0.88;
    margin-bottom: 1.8rem;
  }
  .do__sub {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    margin: 2rem 0 0.85rem;
  }
  .do__features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  @media (max-width: 720px) {
    .do__features {
      grid-template-columns: 1fr;
    }
  }
  .do__feat {
    background: var(--bg-2, rgba(0, 0, 0, 0.2));
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    border-top: 2px solid color-mix(in srgb, var(--accent, #2dd4ff) 30%, transparent);
    padding: 0.9rem 1.1rem 0.85rem;
    transition: border-color 0.15s, background-color 0.15s;
  }
  .do__feat:hover {
    border-color: color-mix(in srgb, var(--accent, #2dd4ff) 55%, transparent);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 4%, var(--bg-2, rgba(0, 0, 0, 0.2)));
  }
  .do__feat-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }
  .do__feat h4 {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.05em;
    color: var(--text, #e8eefc);
  }
  .do__chip {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    border: 1px solid color-mix(in srgb, var(--accent, #2dd4ff) 35%, transparent);
    padding: 0.12rem 0.5rem;
    white-space: nowrap;
  }
  .do__desc {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--text, #e8eefc);
    opacity: 0.88;
  }
  .do__facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.55rem 1.2rem;
    margin: 0.8rem 0 0;
  }
  .do__fact {
    border-left: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    padding-left: 0.65rem;
  }
  .do__fact dt {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
  }
  .do__fact dd {
    margin: 0.1rem 0 0;
    font-family: var(--font-body, system-ui, sans-serif);
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.35;
    font-variant-numeric: tabular-nums;
    color: var(--text, #e8eefc);
  }
  .do__link {
    display: inline-block;
    margin-top: 0.8rem;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    transition: color 0.15s;
  }
  .do__link:hover {
    text-decoration: underline;
  }
  .do__tablewrap {
    overflow-x: auto;
  }
  .do__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1rem;
  }
  .do__table th.num,
  .do__table td.num {
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .do__shiplink:hover {
    color: var(--accent, #2dd4ff);
    text-decoration: underline;
  }
  .do__ext {
    color: var(--muted, #8a99b8);
    font-size: 0.85rem;
  }
  .do__specsrc {
    margin-top: 0.6rem;
    font-size: 0.85rem;
    color: var(--muted, #8a99b8);
  }
  .do__specsrc a {
    text-decoration: underline;
  }
  .do__specsrc a:hover {
    color: var(--accent, #2dd4ff);
  }
  .do__table th {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    text-align: left;
    padding: 0.5rem 0.75rem 0.5rem 0;
    border-bottom: 2px solid color-mix(in srgb, var(--accent, #2dd4ff) 30%, transparent);
  }
  .do__table td {
    padding: 0.45rem 0.75rem 0.45rem 0;
    border-bottom: 1px solid var(--line-soft, rgba(255, 255, 255, 0.08));
    color: var(--text, #e8eefc);
  }
  .do__table tbody tr {
    transition: background-color 0.15s;
  }
  .do__table tbody tr:hover {
    background: color-mix(in srgb, var(--accent, #2dd4ff) 5%, transparent);
  }
  .do__table td:first-child {
    font-family: var(--font-ui, sans-serif);
    font-weight: 600;
  }
  .do__shipnote {
    color: var(--muted, #8a99b8);
    font-size: 0.92rem;
  }
  .do__events {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }
  .do__events li {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--text, #e8eefc);
    opacity: 0.9;
    border-left: 2px solid var(--line, rgba(255, 255, 255, 0.14));
    padding-left: 0.8rem;
  }
  .do__events b {
    font-family: var(--font-ui, sans-serif);
    color: var(--text, #e8eefc);
  }
  .do__period {
    color: var(--muted, #8a99b8);
  }
  .do__foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 2rem;
    margin-top: 1.8rem;
    padding: 0.8rem 1rem;
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    background: var(--bg-2, rgba(0, 0, 0, 0.2));
    font-family: var(--font-ui, sans-serif);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text, #e8eefc);
  }
  .do__wipe {
    color: var(--accent, #2dd4ff);
  }
  .do__note {
    margin-top: 1.2rem;
    font-size: 0.8rem;
    color: var(--muted, #8a99b8);
    opacity: 0.8;
  }
  .do__unv {
    color: var(--accent, #2dd4ff);
    text-decoration: none;
    cursor: help;
    margin-left: 0.15rem;
    font-size: 1rem;
  }
  @media (max-width: 560px) {
    .do__head {
      flex-direction: column;
      gap: 0.2rem;
    }
  }
  /* Mobil: die dekorative Aktencode-Zeile (DAT // …) umbrechen statt am
     Viewport-Rand abzuschneiden — voller Text bleibt sichtbar, kein Clip. */
  @media (max-width: 640px) {
    .do__head {
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
    }
    .do__code {
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
      overflow-wrap: anywhere;
      min-width: 0;
    }
  }
</style>
