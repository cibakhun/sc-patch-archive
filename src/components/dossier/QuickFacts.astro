---
// "Auf einen Blick" — REGISTRATUR design language.
// Renders the page's single Registertrenner (cinema→data seam) followed by
// the facts panel: 2px accent top rail + 12px corner notches (the register's
// stamp), Kopfleiste with Aktencode, values-on-stage typography.
// Accent budget: rail, title, (values stay --text). No motion.
interface Fact {
  label: string;
  value: string;
  unverified?: boolean;
}
import { useTranslations, type Locale, DEFAULT_LOCALE } from '../../i18n/ui';
interface Props {
  facts: Fact[];
  /** Aktencode payload, e.g. "Alpha 4.0.0 · 19. Dez 2024" */
  stand?: string;
  title?: string;
  lang?: Locale;
}
const { facts, stand, title, lang = DEFAULT_LOCALE } = Astro.props;
const t = useTranslations(lang);
const heading = title ?? t('qf.title');
---
<div class="reg-divider">
  <div class="reg-divider__in">
    <span class="reg-divider__l">{t('qf.register')}</span>
    {stand && <span class="reg-divider__r">DAT&nbsp;//&nbsp;{stand}</span>}
  </div>
</div>
<section class="qf" aria-label={heading}>
  <div class="qf__in">
    <header class="qf__head">
      <h2>{heading}</h2>
      {stand && <span class="qf__code">DAT&nbsp;//&nbsp;{stand}</span>}
    </header>
    <dl class="qf__grid">
      {facts.map((f) => (
        <div class="qf__item">
          <dt>{f.label}</dt>
          <dd>{f.value}{f.unverified && <abbr class="qf__unv" title={t('common.unverified')}>*</abbr>}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  /* Registertrenner — the seam between film and file */
  .reg-divider {
    border-top: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    background: var(--bg-2, rgba(0, 0, 0, 0.25));
    padding: 0.45rem clamp(1.25rem, 5vw, 4.5rem);
  }
  .reg-divider__in {
    max-width: var(--maxw, 1280px);
    margin: 0 auto;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .reg-divider__l {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
  }
  .reg-divider__r {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Panel — Registerrahmen + Eckfase */
  .qf {
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 5vw, 4.5rem);
  }
  .qf__in {
    max-width: var(--maxw, 1280px);
    margin: 0 auto;
    background: var(--surface, #10151f);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    border-top: 2px solid var(--accent, #2dd4ff);
    padding: 1.25rem 1.5rem 1.4rem;
    clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
  }
  .qf__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    padding-bottom: 0.55rem;
    margin-bottom: 1rem;
  }
  .qf__head h2 {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
  }
  .qf__code {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
  }
  .qf__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.7rem 1.4rem;
    margin: 0;
  }
  .qf__item {
    border-left: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    padding-left: 0.8rem;
  }
  .qf__item dt {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
  }
  .qf__item dd {
    margin: 0.15rem 0 0;
    font-family: var(--font-body, system-ui, sans-serif);
    font-weight: 500;
    font-size: 1.15rem;
    line-height: 1.35;
    letter-spacing: 0.01em;
    font-variant-numeric: tabular-nums;
    color: var(--text, #e8eefc);
  }
  .qf__unv {
    color: var(--accent, #2dd4ff);
    text-decoration: none;
    cursor: help;
    margin-left: 0.15rem;
    font-size: 1rem;
  }
  @media (max-width: 560px) {
    .qf__head {
      flex-direction: column;
      gap: 0.2rem;
    }
    .reg-divider__r {
      display: none;
    }
  }
</style>
