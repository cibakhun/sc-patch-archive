---
// SignatureIdentifier.astro — Scan-Signatur-Identifier (wie scmdb) mit eigener Liste.
// Jedes Mineral hat eine n=1-Scan-Signatur; ein Cluster aus n Steinen zeigt
// n × Signatur. Max. Cluster-Größe hängt von der Seltenheit ab (legendär 2 …
// häufig 6). Du wählst gezielt Erze aus → nur diese erscheinen in der Tabelle
// (deine persönliche Signatur-Liste, in localStorage gespeichert). Ein Scan-Wert-
// Feld (exakt oder ~±10 %) identifiziert, welches Mineral in welcher Cluster-
// Größe du gescannt hast. Daten: mining-model.json.
import MODEL from '../../assets/mining-model.json';

interface Props { lang: 'de' | 'en'; }
const { lang } = Astro.props;

// Max. Cluster-Größe je Seltenheit (aus dem Referenz-Tool).
const MAXCLUSTER: Record<string, number> = { common: 6, uncommon: 5, rare: 4, epic: 3, legendary: 2 };
const RARITY_ORDER = ['legendary', 'epic', 'rare', 'uncommon', 'common'];

// Schiffs-Minerale mit Scan-Signatur.
const ship = (MODEL.elements || [])
  .filter((e: any) => e.scanSignature > 0)
  .map((e: any) => {
    const max = MAXCLUSTER[e.rarity] || 4;
    return {
      name: (e.material || e.name || '').replace(/ \((?:Ore|Raw|Pure)\)$/, ''),
      sig: e.scanSignature,
      rarity: e.rarity || 'common',
      max,
      multiples: Array.from({ length: max }, (_, i) => ({ n: i + 1, v: (i + 1) * e.scanSignature })),
      locations: (e.locations || []).slice(0, 5),
    };
  })
  .sort((a, b) => (RARITY_ORDER.indexOf(a.rarity) - RARITY_ORDER.indexOf(b.rarity)) || (a.sig - b.sig));

// Sonder-Kategorien (feste Signatur, Cluster bis floor(30000/sig)).
const SPECIAL = [
  { name: 'ROC / Bodenerz', sig: 4000, rarity: 'roc' },
  { name: 'FPS-Handerz', sig: 3000, rarity: 'fps' },
  { name: 'Salvage-Panel', sig: 2000, rarity: 'salvage' },
].map((s) => {
  const max = Math.floor(30000 / s.sig);
  return { ...s, max, multiples: Array.from({ length: max }, (_, i) => ({ n: i + 1, v: (i + 1) * s.sig })), locations: [] };
});

// Fundort-Typ → Label.
const TYPE_LABEL: Record<string, { de: string; en: string }> = {
  moon: { de: 'Mond', en: 'moon' }, planet: { de: 'Planet', en: 'planet' }, belt: { de: 'Gürtel', en: 'belt' },
  lagrange: { de: 'Lagrange', en: 'Lagrange' }, cluster: { de: 'Cluster', en: 'cluster' }, cave: { de: 'Höhle', en: 'cave' },
  station: { de: 'Station', en: 'station' }, event: { de: 'Event', en: 'event' }, special: { de: 'Spezial', en: 'special' },
};

const entries = [...ship, ...SPECIAL];

// Für die Auswahl-Chips nach Seltenheit/Kategorie gruppieren.
const GROUP_ORDER = [...RARITY_ORDER, 'roc', 'fps', 'salvage'];
const groups = GROUP_ORDER.map((r) => ({ rarity: r, items: entries.filter((e) => e.rarity === r) })).filter((g) => g.items.length);

const RARITY_LABEL: Record<string, { de: string; en: string }> = {
  legendary: { de: 'Legendär', en: 'Legendary' }, epic: { de: 'Episch', en: 'Epic' },
  rare: { de: 'Selten', en: 'Rare' }, uncommon: { de: 'Ungewöhnlich', en: 'Uncommon' }, common: { de: 'Häufig', en: 'Common' },
  roc: { de: 'ROC / Boden', en: 'ROC / ground' }, fps: { de: 'FPS-Hand', en: 'FPS hand' }, salvage: { de: 'Salvage', en: 'Salvage' },
};

const S = {
  de: {
    intro: 'Ein Cluster aus n Steinen zeigt n × die Basis-Signatur; die maximale Cluster-Größe hängt von der Seltenheit ab. Wähle deine Erze aus — nur die stehen dann in der Tabelle (deine persönliche Liste, bleibt gespeichert). Gib einen gescannten Wert ein, um Mineral + Cluster-Größe zu identifizieren.',
    scanLabel: 'Scan-Wert identifizieren', scanPh: 'z.B. 6340 oder ~6340 (±10%)',
    pick: 'Erze für deine Liste', all: 'Alle', none: 'Keine',
    selectedNone: 'Keine Erze ausgewählt — es werden alle gezeigt. Tippe oben auf Erze für deine eigene Liste.',
    matches: 'Treffer', noMatch: 'Kein Mineral passt zu diesem Wert.',
    base: 'Basis (1 Stein)', bestSpot: 'Bester Fundort', top5: 'Top-5 Fundorte', noLoc: 'keine Fundort-Daten',
    src: 'Signaturen aus datamined 4.8.3-Spieldaten. Cluster = n × Basis-Signatur; echte In-Game-Werte streuen mit der Rock-Masse leicht (Scan als Näherung nutzen).',
  },
  en: {
    intro: 'A cluster of n rocks shows n × the base signature; the max cluster size depends on rarity. Pick your ores — only those appear in the table (your personal list, saved). Enter a scanned value to identify mineral + cluster size.',
    scanLabel: 'Identify scanned value', scanPh: 'e.g. 6340 or ~6340 (±10%)',
    pick: 'Ores for your list', all: 'All', none: 'None',
    selectedNone: 'No ores selected — showing all. Tap ores above to build your own list.',
    matches: 'Matches', noMatch: 'No mineral matches this value.',
    base: 'base (1 rock)', bestSpot: 'Best spot', top5: 'Top 5 locations', noLoc: 'no location data',
    src: 'Signatures from datamined 4.8.3 game files. Cluster = n × base signature; real in-game values vary slightly with rock mass (use scan as a guide).',
  },
}[lang];
---
<section class="sid" id="sid" data-loc5="false">
  <p class="sid__intro">{S.intro}</p>

  <div class="sid__pick">
    <div class="sid__pickhd">
      <span class="sid__picklabel">{S.pick}</span>
      <span class="sid__count" id="sid-count"></span>
      <span class="sid__pickbtns">
        <button type="button" class="sid__mini" id="sid-all">{S.all}</button>
        <button type="button" class="sid__mini" id="sid-none">{S.none}</button>
      </span>
    </div>
    <div class="sid__groups">
      {groups.map((g) => (
        <div class="sid__group" data-rar={g.rarity}>
          <span class="sid__glabel">{RARITY_LABEL[g.rarity]?.[lang] ?? g.rarity}</span>
          {g.items.map((e) => (
            <button type="button" class="sid__chip" data-name={e.name} aria-pressed="false">{e.name}</button>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div class="sid__controls">
    <label class="sid__scan">
      <span>{S.scanLabel}</span>
      <input type="text" id="sid-scan" inputmode="numeric" placeholder={S.scanPh} autocomplete="off" />
    </label>
    <button type="button" class="sid__loc5" id="sid-top5" aria-pressed="false">◎ {S.top5}</button>
  </div>

  <div class="sid__matchbox" id="sid-matchbox" hidden>
    <span class="sid__mlabel">{S.matches}</span>
    <div class="sid__matches" id="sid-matches"></div>
  </div>

  <p class="sid__hint" id="sid-hint">{S.selectedNone}</p>

  <div class="sid__list" id="sid-list">
    {entries.map((e) => (
      <article class="sid__row" data-rar={e.rarity} data-name={e.name}>
        <div class="sid__rowhd">
          <span class="sid__rname">{e.name}</span>
          <span class="sid__rtag">{RARITY_LABEL[e.rarity]?.[lang] ?? e.rarity}</span>
          <span class="sid__rbase">{e.sig.toLocaleString('en-US')} · {S.base}</span>
          <button type="button" class="sid__rx" data-name={e.name} title="✕" aria-label="✕">✕</button>
        </div>
        <div class="sid__mults">
          {e.multiples.map((m) => (
            <span class="sid__mult" data-v={m.v}><b>{m.n}×</b>{m.v.toLocaleString('en-US')}</span>
          ))}
        </div>
        {e.locations.length > 0 && (
          <div class="sid__locs">
            <span class="sid__loclabel">{S.bestSpot}</span>
            {e.locations.map((l, i) => (
              <span class="sid__loc" data-rank={i}>
                <b>{l.location}</b><em>{l.system} · {TYPE_LABEL[l.type]?.[lang] ?? l.type}</em><span class="sid__locab">{l.abundance}%</span>
              </span>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>
  <p class="sid__empty" id="sid-empty" hidden>{S.noMatch}</p>
  <p class="sid__src">{S.src}</p>

  <script is:inline>
    (function () {
      var KEY = 'mine.sigList';
      var scan = document.getElementById('sid-scan');
      var rows = [].slice.call(document.querySelectorAll('#sid-list .sid__row'));
      var chips = [].slice.call(document.querySelectorAll('.sid__chip'));
      var matchbox = document.getElementById('sid-matchbox'), matchesEl = document.getElementById('sid-matches');
      var emptyEl = document.getElementById('sid-empty'), hintEl = document.getElementById('sid-hint');
      var countEl = document.getElementById('sid-count');

      var sel = new Set();
      try { var saved = JSON.parse(localStorage.getItem(KEY) || '[]'); if (Array.isArray(saved)) saved.forEach(function (n) { sel.add(n); }); } catch (e) {}
      function save() { try { var arr = []; sel.forEach(function (n) { arr.push(n); }); localStorage.setItem(KEY, JSON.stringify(arr)); } catch (e) {} }

      function parseScan(s) {
        s = (s || '').trim();
        if (!s) return null;
        var tol = s.charAt(0) === '~' || s.charAt(0) === '≈';
        var n = parseInt(s.replace(/[~≈\s,\.]/g, ''), 10);
        if (!n || n <= 0) return null;
        if (tol) return { lo: Math.round(n * 0.9), hi: Math.round(n * 1.1), v: n };
        return { lo: n, hi: n, v: n };
      }

      function render() {
        var showAll = sel.size === 0;
        // chips reflect selection
        chips.forEach(function (c) {
          var on = sel.has(c.getAttribute('data-name'));
          c.setAttribute('aria-pressed', String(on));
        });
        // rows: show selected (or all if none)
        rows.forEach(function (r) {
          r.hidden = !(showAll || sel.has(r.getAttribute('data-name')));
        });
        hintEl.hidden = !showAll;
        countEl.textContent = sel.size ? (sel.size + '') : '';

        // scan matching over visible rows
        var q = parseScan(scan.value);
        var found = [];
        rows.forEach(function (r) {
          var rname = r.querySelector('.sid__rname').textContent;
          [].forEach.call(r.querySelectorAll('.sid__mult'), function (m) {
            var v = +m.getAttribute('data-v');
            var hit = q && !r.hidden && v >= q.lo && v <= q.hi;
            m.classList.toggle('hit', !!hit);
            if (hit) found.push({ name: rname, n: m.querySelector('b').textContent, v: v });
          });
        });
        if (q) {
          matchbox.hidden = false;
          if (found.length) {
            found.sort(function (a, b) { return Math.abs(a.v - q.v) - Math.abs(b.v - q.v); });
            matchesEl.innerHTML = found.map(function (f) {
              return '<span class="sid__match"><b>' + f.name + '</b> ' + f.n + ' <em>' + f.v.toLocaleString('en-US') + '</em></span>';
            }).join('');
            emptyEl.hidden = true;
          } else { matchesEl.innerHTML = ''; emptyEl.hidden = false; }
        } else { matchbox.hidden = true; emptyEl.hidden = true; }
      }

      // Top-5-Fundorte-Umschalter (Default aus, gemerkt).
      var root = document.getElementById('sid'), top5btn = document.getElementById('sid-top5');
      var loc5 = false; try { loc5 = localStorage.getItem('mine.sigLoc5') === '1'; } catch (e) {}
      function setLoc5(v) { loc5 = v; root.setAttribute('data-loc5', v ? 'true' : 'false'); top5btn.setAttribute('aria-pressed', String(v)); try { localStorage.setItem('mine.sigLoc5', v ? '1' : '0'); } catch (e) {} }
      top5btn.addEventListener('click', function () { setLoc5(!loc5); });
      setLoc5(loc5);

      function toggle(name) { if (sel.has(name)) sel.delete(name); else sel.add(name); save(); render(); }
      chips.forEach(function (c) { c.addEventListener('click', function () { toggle(c.getAttribute('data-name')); }); });
      [].forEach.call(document.querySelectorAll('.sid__rx'), function (b) {
        b.addEventListener('click', function () { sel.delete(b.getAttribute('data-name')); save(); render(); });
      });
      document.getElementById('sid-all').addEventListener('click', function () { chips.forEach(function (c) { sel.add(c.getAttribute('data-name')); }); save(); render(); });
      document.getElementById('sid-none').addEventListener('click', function () { sel.clear(); save(); render(); });
      scan.addEventListener('input', render);
      render();
    })();
  </script>

  <style is:inline>
    .sid{max-width:var(--maxw,1240px);margin:0 auto;padding:0 clamp(1rem,4vw,2rem)}
    .sid__intro{font-size:.92rem;color:var(--muted,#8fa3a0);line-height:1.55;max-width:80ch;margin:0 0 1.1rem}
    /* Auswahl-Panel */
    .sid__pick{border:1px solid var(--line,rgba(47,191,164,.22));background:var(--surface,#1e2427);border-radius:8px;padding:.8rem .9rem;margin-bottom:1rem}
    .sid__pickhd{display:flex;align-items:center;gap:.6rem;margin-bottom:.7rem}
    .sid__picklabel{font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.1em;font-size:.62rem;color:var(--accent,#2FBFA4)}
    .sid__count{font-family:var(--font-ui,inherit);font-weight:800;font-size:.72rem;color:var(--ink,#0e1214);background:var(--accent,#2FBFA4);border-radius:50px;min-width:1.3rem;text-align:center;padding:.05rem .4rem}
    .sid__count:empty{display:none}
    .sid__pickbtns{margin-left:auto;display:flex;gap:.35rem}
    .sid__mini{background:var(--bg-2,#181d1f);border:1px solid var(--line,rgba(47,191,164,.3));color:var(--muted,#8fa3a0);padding:.28rem .6rem;border-radius:50px;cursor:pointer;font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:.58rem}
    .sid__mini:hover{border-color:var(--accent,#2FBFA4);color:var(--accent,#2FBFA4)}
    .sid__groups{display:flex;flex-direction:column;gap:.5rem}
    .sid__group{--rar:#8fa3a0;display:flex;flex-wrap:wrap;align-items:center;gap:.3rem}
    .sid__group[data-rar="legendary"]{--rar:#e0564b}.sid__group[data-rar="epic"]{--rar:#b06ae0}
    .sid__group[data-rar="rare"]{--rar:var(--accent-2,#E0A526)}.sid__group[data-rar="uncommon"]{--rar:var(--accent,#2FBFA4)}
    .sid__group[data-rar="common"]{--rar:#8fa3a0}.sid__group[data-rar="roc"]{--rar:#66ddaa}.sid__group[data-rar="fps"]{--rar:#77bbdd}.sid__group[data-rar="salvage"]{--rar:#aa9977}
    .sid__glabel{font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.06em;font-size:.54rem;color:var(--rar);flex:0 0 6.5rem;min-width:6.5rem}
    .sid__chip{background:var(--bg-2,#181d1f);border:1px solid var(--line-soft,rgba(255,255,255,.12));color:var(--text,#eaf2f1);padding:.26rem .55rem;border-radius:50px;cursor:pointer;font-family:var(--font-ui,inherit);font-weight:600;font-size:.76rem;transition:background-color .12s,border-color .12s,color .12s}
    .sid__chip:hover{border-color:var(--rar)}
    .sid__chip[aria-pressed="true"]{background:var(--rar);border-color:var(--rar);color:#0e1214;font-weight:800}
    /* Scan-Feld + Fundort-Toggle */
    .sid__controls{display:flex;flex-wrap:wrap;align-items:flex-end;gap:.8rem 1rem;margin-bottom:1rem}
    .sid__scan{display:flex;flex-direction:column;gap:.3rem;max-width:360px;flex:1 1 260px}
    .sid__scan span{font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:.6rem;color:var(--accent,#2FBFA4)}
    .sid__scan input{background:var(--bg-2,#181d1f);border:1px solid var(--line,rgba(47,191,164,.35));color:var(--text,#eaf2f1);padding:.6rem .8rem;border-radius:6px;font-size:1.05rem;font-family:var(--font-ui,inherit);font-variant-numeric:tabular-nums;letter-spacing:.03em}
    .sid__scan input:focus{outline:2px solid var(--accent,#2FBFA4);outline-offset:1px}
    .sid__loc5{background:var(--bg-2,#181d1f);border:1px solid var(--line,rgba(47,191,164,.3));color:var(--muted,#8fa3a0);padding:.5rem .8rem;border-radius:6px;cursor:pointer;font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.05em;font-size:.62rem;white-space:nowrap}
    .sid__loc5:hover{border-color:var(--accent,#2FBFA4);color:var(--accent,#2FBFA4)}
    .sid__loc5[aria-pressed="true"]{background:var(--accent,#2FBFA4);border-color:var(--accent,#2FBFA4);color:var(--ink,#0e1214)}
    .sid__matchbox{display:flex;flex-wrap:wrap;align-items:center;gap:.5rem .8rem;background:color-mix(in srgb,var(--accent,#2FBFA4) 10%,transparent);border:1px solid color-mix(in srgb,var(--accent,#2FBFA4) 40%,transparent);border-radius:6px;padding:.6rem .8rem;margin-bottom:1rem}
    .sid__mlabel{font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.1em;font-size:.6rem;color:var(--accent,#2FBFA4)}
    .sid__matches{display:flex;flex-wrap:wrap;gap:.4rem}
    .sid__match{font-size:.85rem;color:var(--text,#eaf2f1);background:var(--bg-2,#181d1f);border:1px solid var(--line-soft,rgba(255,255,255,.1));border-radius:4px;padding:.2rem .5rem}
    .sid__match b{color:#fff}.sid__match em{color:var(--accent,#2FBFA4);font-style:normal;font-variant-numeric:tabular-nums;font-weight:700}
    .sid__hint{font-size:.82rem;color:var(--muted,#8fa3a0);font-style:italic;margin:0 0 .8rem}
    .sid__hint[hidden]{display:none}
    .sid__list{display:flex;flex-direction:column;gap:.4rem}
    .sid__row{--rar:#8fa3a0;border:1px solid var(--line-soft,rgba(255,255,255,.1));border-left:3px solid var(--rar);background:var(--bg-2,#181d1f);border-radius:5px;padding:.6rem .8rem}
    .sid__row[hidden]{display:none}
    .sid__row[data-rar="legendary"]{--rar:#e0564b}.sid__row[data-rar="epic"]{--rar:#b06ae0}
    .sid__row[data-rar="rare"]{--rar:var(--accent-2,#E0A526)}.sid__row[data-rar="uncommon"]{--rar:var(--accent,#2FBFA4)}
    .sid__row[data-rar="common"]{--rar:#8fa3a0}.sid__row[data-rar="roc"]{--rar:#66ddaa}.sid__row[data-rar="fps"]{--rar:#77bbdd}.sid__row[data-rar="salvage"]{--rar:#aa9977}
    .sid__rowhd{display:flex;flex-wrap:wrap;align-items:baseline;gap:.5rem .8rem;margin-bottom:.45rem}
    .sid__rname{font-family:var(--font-display,inherit);font-weight:800;color:#fff;font-size:1rem}
    .sid__rtag{font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:.56rem;color:var(--rar)}
    .sid__rbase{margin-left:auto;font-size:.72rem;color:var(--muted,#8fa3a0);font-variant-numeric:tabular-nums}
    .sid__rx{background:transparent;border:0;color:var(--muted,#8fa3a0);cursor:pointer;font-size:.8rem;padding:0 .2rem;line-height:1;opacity:.6}
    .sid__rx:hover{color:#e0564b;opacity:1}
    .sid__mults{display:flex;flex-wrap:wrap;gap:.3rem}
    .sid__mult{display:inline-flex;align-items:baseline;gap:.3rem;font-size:.82rem;color:var(--text,#eaf2f1);background:var(--surface,#1e2427);border:1px solid var(--line-soft,rgba(255,255,255,.08));border-radius:4px;padding:.18rem .5rem;font-variant-numeric:tabular-nums;transition:background-color .12s,border-color .12s}
    .sid__mult b{color:var(--rar);font-family:var(--font-ui,inherit);font-weight:800;font-size:.72rem}
    .sid__mult.hit{background:color-mix(in srgb,var(--accent,#2FBFA4) 22%,var(--surface,#1e2427));border-color:var(--accent,#2FBFA4);color:#fff;box-shadow:0 0 10px color-mix(in srgb,var(--accent,#2FBFA4) 35%,transparent)}
    .sid__mult.hit b{color:#fff}
    /* Fundorte */
    .sid__locs{display:flex;flex-wrap:wrap;align-items:center;gap:.3rem .5rem;margin-top:.5rem;padding-top:.5rem;border-top:1px solid var(--line-soft,rgba(255,255,255,.06))}
    .sid__loclabel{font-family:var(--font-ui,inherit);font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:.54rem;color:var(--rar);flex:none}
    .sid[data-loc5="true"] .sid__loclabel::after{content:" · Top 5";color:var(--muted,#8fa3a0)}
    .sid__loc{display:inline-flex;align-items:baseline;gap:.3rem;font-size:.78rem;color:var(--text,#eaf2f1);background:var(--surface,#1e2427);border:1px solid var(--line-soft,rgba(255,255,255,.08));border-radius:4px;padding:.16rem .45rem}
    .sid__loc b{color:#fff;font-weight:600}
    .sid__loc em{font-style:normal;color:var(--muted,#8fa3a0);font-size:.72rem}
    .sid__locab{color:var(--rar);font-weight:700;font-variant-numeric:tabular-nums;font-size:.72rem}
    .sid[data-loc5="false"] .sid__loc[data-rank]:not([data-rank="0"]){display:none}
    .sid__empty{color:var(--muted,#8fa3a0);font-size:.9rem;padding:.5rem 0}
    .sid__src{font-size:.74rem;color:var(--muted,#8fa3a0);font-style:italic;margin:1rem 0 0;line-height:1.5}
    @media(max-width:560px){.sid__glabel{flex-basis:100%;min-width:0}}
  </style>
</section>
