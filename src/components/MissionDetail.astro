---
// MISSION — Detailseite (geteilt DE/EN, Prop `lang`), /missionen/<slug>.html
// Zeigt alles, was zu einer Mission in den Spieldateien steht: Belohnung,
// Reputationshuerden, Auftraggeber, Orte, Regeln, Ablauf — und die Varianten-
// tabelle, wenn die Familie mehrere Angebote buendelt.
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Attribution from '../components/Attribution.astro';
import { db, uec, dur, mins, cmpSign, repSummary, missions, bpCount, seoTitle, seoText, clip } from '../lib/missions';
import type { Mission } from '../lib/missions';
import { ICON_BLUEPRINT } from '../lib/icons';
import { blueprintPath, blueprintsByMission } from '../lib/crafting';
import { href, useTranslations } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props { m: Mission; lang: Locale }
const { m, lang } = Astro.props;
const L = (p: string) => href(p, lang);
const nf = lang === 'de' ? 'de-DE' : 'en-US';

const S = {
  de: {
    // titleKind nur im <title> (Suchanfrage ist „star citizen <mission>");
    // kind bleibt der sichtbare Eyebrow-Text auf der Seite.
    back: 'Alle Missionen', kind: 'Mission', titleKind: 'Star-Citizen-Mission',
    internal: 'Interner Name', internalT: 'Diese Mission trägt keinen festen Titel. Angezeigt wird ihr interner Name — im Spiel heißt sie anders.',
    mgHead: 'Auftragstext', mgCode: 'mobiGlas // Übertragung',
    mgEnd: 'Ende der Übertragung', mgAria: 'Auftragstext, wie ihn das mobiGlas anzeigt',
    dynamic: 'Titel wird zur Laufzeit gefüllt',
    dynamicT: 'Die markierten Stellen sind Platzhalter. Das Spiel setzt dort Werte wie den Reputationsrang oder den Namen des Ziels ein.',
    appears: 'Erscheint im Spiel als',
    appearsP: 'Je nach Auftraggeber setzt das Spiel einen anderen Titel ein:',
    facts: 'Eckdaten',
    reward: 'Belohnung', rewardR: 'Belohnungsspanne', buyIn: 'Einsatz', type: 'Typ', giver: 'Auftraggeber',
    region: 'Region', places: 'Orte', legal: 'Rechtslage', lawful: 'Legal', unlawful: 'Illegal', mixed: 'Gemischt',
    players: 'Spieler je Instanz', shareable: 'Teilbar', yes: 'Ja', no: 'Nein',
    deadline: 'Zeitlimit', lifetime: 'Angebot verfällt nach', cooldown: 'Abklingzeit', wanted: 'Max. Fahndungsstufe',
    offers: 'Angebote', offersP: 'Dieselbe Mission wird %n% mal angeboten — mit unterschiedlichem Auftraggeber, Ort, Rang oder Lohn.',
    single: 'Dieses Angebot gibt es genau einmal.',
    rep: 'Reputation', repP: 'Diese Bedingungen müssen erfüllt sein, damit die Mission überhaupt erscheint.',
    repNone: 'Keine Reputationsbedingung im Spiel.',
    faction: 'Fraktion', standing: 'Rang', scope: 'Bereich', threshold: 'Schwelle', perk: 'Vorteil',
    flow: 'Ablauf', flowNote: 'Achtung: Das ist nicht der Zieltext aus dem mobiGlas.',
    flowP: 'Der Spielertext der Missionsziele ist nicht verfügbar — die Missionslogik läuft serverseitig. Was hier steht, sind die Schritte und Ablaufregeln, wie die Entwickler sie benannt haben.',
    steps: 'Schritte', rules: 'Ablaufregeln', flowNone: 'Kein Ablauf im Spiel hinterlegt.',
    tblKey: 'Eintrag', tblGiver: 'Auftraggeber', tblLoc: 'Region', tblReward: 'Belohnung', tblRep: 'Reputation', tblPlaces: 'Orte',
    module: 'Missionsmodul', tags: 'Tags', none: '—', noReward: 'keine',
    guild: 'Gilde', rank: 'Karrierestufe', src: 'Quelle', calcReward: 'wird zur Laufzeit berechnet',
    bpH: 'Blueprints', bpChance: 'Chance',
    bpCraft: 'Rezepte mit dieser Mission als Quelle',
    bpP: 'Diese Mission kann Blueprints abwerfen. Ein Pool ist eine gewichtete Liste — welcher Blueprint fällt, entscheidet der Zufall, du bekommst nicht die ganze Liste.',
    bpPool: 'Pool', bpWeight: 'Gewicht',
    srcBroker: 'Missionsbrett', srcContract: 'Contract-Manager',
    srcNote: 'Es gibt zwei Missionssysteme: das ältere Missionsbrett und den Contract-Manager, in den CIG gerade migriert. Blueprints und Gilden gibt es nur im zweiten.',
    src: 'Quelle', srcP: 'Spielgenau zur aktuellen Live-Version (Patch 4.9). Missionstexte gibt es nur auf Englisch.',
    rec: 'Datensatz',
  },
  en: {
    back: 'All missions', kind: 'Mission', titleKind: 'Star Citizen Mission',
    internal: 'Internal name', internalT: 'This mission has no fixed title. Shown is its internal name — in game it is called something else.',
    mgHead: 'Contract briefing', mgCode: 'mobiGlas // transmission',
    mgEnd: 'End of transmission', mgAria: 'Contract briefing as the mobiGlas shows it',
    dynamic: 'Title is filled in at runtime',
    dynamicT: 'The marked spots are placeholders. The game substitutes values like the reputation rank or the target name.',
    appears: 'Appears in game as',
    appearsP: 'Depending on the contractor, the game uses a different title:',
    facts: 'Key facts',
    reward: 'Reward', rewardR: 'Reward range', buyIn: 'Buy-in', type: 'Type', giver: 'Contractor',
    region: 'Region', places: 'Locations', legal: 'Legality', lawful: 'Lawful', unlawful: 'Unlawful', mixed: 'Mixed',
    players: 'Players per instance', shareable: 'Shareable', yes: 'Yes', no: 'No',
    deadline: 'Time limit', lifetime: 'Offer expires after', cooldown: 'Cooldown', wanted: 'Max. wanted level',
    offers: 'Offers', offersP: 'The same mission is offered %n% times — with a different contractor, location, rank or payout.',
    single: 'This offer exists exactly once.',
    rep: 'Reputation', repP: 'These conditions must be met for the mission to show up at all.',
    repNone: 'No reputation requirement in the game.',
    faction: 'Faction', standing: 'Standing', scope: 'Scope', threshold: 'Threshold', perk: 'Perk',
    flow: 'Flow', flowNote: 'Note: this is not the objective text from your mobiGlas.',
    flowP: 'The player-facing objective text is not available — mission logic runs server-side. What follows are the steps and flow rules as the developers named them.',
    steps: 'Steps', rules: 'Flow rules', flowNone: 'No flow recorded in the game.',
    tblKey: 'Entry', tblGiver: 'Contractor', tblLoc: 'Region', tblReward: 'Reward', tblRep: 'Reputation', tblPlaces: 'Locations',
    module: 'Mission module', tags: 'Tags', none: '—', noReward: 'none',
    guild: 'Guild', rank: 'Career rank', src: 'Source', calcReward: 'calculated at runtime',
    bpH: 'Blueprints', bpChance: 'Chance',
    bpCraft: 'Recipes that name this mission as a source',
    bpP: 'This mission can drop blueprints. A pool is a weighted list — which blueprint drops is chance-based, you do not get the whole list.',
    bpPool: 'Pool', bpWeight: 'Weight',
    srcBroker: 'Mission board', srcContract: 'Contract Manager',
    srcNote: 'There are two mission systems: the older mission board and the Contract Manager that CIG is migrating to. Blueprints and guilds exist only in the latter.',
    src: 'Source', srcP: 'Game-accurate to the current live build (patch 4.9). Mission text exists in English only.',
    rec: 'Record',
  },
}[lang];

// Regex mit geschweiften Klammern gehoert ins Frontmatter: im Template zaehlt
// der Astro-Compiler die Klammern des Literals mit und bricht ab.
const parts = (s: string) => String(s).split(/(\{[^}]*\})/).filter(Boolean)
  .map((x) => (x.startsWith('{') ? { t: x.slice(1, -1), ph: true } : { t: x, ph: false }));
const titleParts = parts(m.title);
const descParts = m.desc ? parts(m.desc) : null;
const reps = repSummary(m);
const bpTotal = bpCount(m);
// Rezepte, die DIESE Mission als Quelle nennen (Join nur in dieser Richtung
// moeglich — die Pools oben tragen interne Kennungen, keine Anzeigenamen).
const craftedHere = blueprintsByMission.get(m.slug) ?? [];
const srcLabel = m.sources.map((s) => (s === 'broker' ? S.srcBroker : S.srcContract)).join(' + ');
const legal = m.lawful && m.unlawful ? S.mixed : m.lawful ? S.lawful : S.unlawful;
const v0 = m.variants[0];
const rewardTxt = !m.rewardMax && m.calcReward ? S.calcReward : m.rewardMax
  ? (m.rewardMin === m.rewardMax ? `${uec(m.rewardMax, lang)} aUEC` : `${uec(m.rewardMin, lang)} – ${uec(m.rewardMax, lang)} aUEC`)
  : S.noReward;
// Spalten der Variantentabelle nur zeigen, wenn sie irgendwo etwas enthalten —
// bei 470 Hauling-Angeboten waeren 4 leere Spalten reines Rauschen.
const colGiver = m.variants.some((v) => v.giver);
const colLoc = m.variants.some((v) => v.locality);
const colPlaces = m.variants.some((v) => v.places.length);
const colRep = m.variants.some((v) => v.rep.length);
const related = missions
  .filter((o) => o.slug !== m.slug && o.types.some((t) => m.types.includes(t)))
  .sort((a, b) => b.count - a.count).slice(0, 6);
// SEO-Meta: seoName statt plain — plain laesst {TargetName} & Co. als rohes
// CamelCase stehen; im h1 bleiben die Marker sichtbar (titleParts), aber in
// <title>/description sollen lesbare Woerter stehen. clip() kuerzt an der
// Wortgrenze auf SERP-Laenge (~160), statt hart bei 180 abzuschneiden.
const seoName = seoTitle(m.title);
// Platzhalter-Descs aus dem DataCore („Mission description (WIP)“) fallen
// unter die 50-Zeichen-SEO-Schwelle — dann trägt das generische Template mehr.
const descFallback = lang === 'de'
  ? `${seoName}: Belohnung, Reputation, Auftraggeber und Orte für Star Citizen.`
  : `${seoName}: reward, reputation, contractors and locations for Star Citizen.`;
const descFromData = m.desc ? `${seoName} — ${seoText(m.desc)}` : '';
const desc = clip(descFromData.length >= 50 ? descFromData : descFallback);
const t = useTranslations(lang);
---
<Layout
  title={`${seoName} — ${S.titleKind} | VerseBase`}
  description={desc}
  themeColor="#0b0906"
  footer={false}
  ogType="article"
  translated={true}
  itemPage={{ modified: db.meta.generated }}
>
  <link slot="head" rel="stylesheet" href="/assets/detail.css" />
  <style is:inline>
    :root {
      --bg: #0b0906; --bg-2: #110d08; --surface: #191309; --surface-2: #221a0e;
      --accent: #f5a524; --accent-2: #ffd79a; --hot: #ff7a45;
      --text: #f3ece1; --muted: #a1927c; --line: rgba(245, 165, 36, .22); --line-soft: rgba(243, 236, 225, .10);
      --glow: 0 0 44px rgba(245, 165, 36, .26); --ink: #0b0906; --maxw: 1180px;
    }
    /* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
    :root[data-theme="light"]{--bg:#faf7f1;--bg-2:#f3ede5;--surface:#fffdfa;--surface-2:#f8f1e8;--text:#231e16;--muted:#635642;--accent:#7d5001;--accent-2:#714d02;--hot:#8c3001;--ink:#ffffff;--accent-media:#f5a524;--accent-2-media:#ffd79a;--line:rgba(149,103,37,.3);--line-soft:rgba(50,45,37,.12);--glow:0 6px 22px rgba(149,103,37,.18)}

    /* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */</style>

  <a class="skip" href="#main">{lang === 'de' ? 'Zum Inhalt' : 'Skip to content'}</a>
  <div class="cursorglow" aria-hidden="true"></div>
  {/* crumbs -> BreadcrumbList-JSON-LD (wie Schiffe/Topics); hasEn, damit der
      Sprachumschalter zur Mission wechselt statt zur EN-Startseite. */}
  <SiteNav
    crumbs={[
      { label: t('crumbs.archive'), href: L('/index.html') },
      { label: t('crumbs.missions'), href: L('/missionen.html') },
      { label: seoName },
    ]}
    hasEn={true}
  />

  <main id="main" class="md">
    <div class="md__wrap">
      <a class="md__back" href={L('/missionen.html')}>← {S.back}</a>

      <header class="md__head">
        <p class="md__eyebrow">{m.typeNames.join(' · ') || S.kind}</p>
        <h1 class="md__h1">
          {titleParts.map((p) => (p.ph ? <i class="md__ph">{p.t}</i> : <span>{p.t}</span>))}
        </h1>
        {/* Original-Auftragstext aus den Spieldateien — inszeniert als
            mobiGlas-Uebertragung (Holo-Panel mit Brackets + Scanlines). */}
        {descParts && (
          <figure class="md__mg" role="group" aria-label={S.mgAria}>
            <figcaption class="md__mgHead">
              <span class="md__mgDot" aria-hidden="true"></span>
              <span>{S.mgHead}</span>
              <span class="md__mgCode">{S.mgCode}</span>
            </figcaption>
            <p class="md__desc">
              {descParts.map((p) => (p.ph ? <i class="md__ph md__ph--sm">{p.t}</i> : <span>{p.t}</span>))}
            </p>
            <p class="md__mgEnd" aria-hidden="true">{S.mgEnd}</p>
          </figure>
        )}

        {m.noTitle && (
          <p class="md__warn" role="note">
            <b>{S.internal}.</b> {S.internalT}
          </p>
        )}
        {m.titleDynamic && !m.noTitle && (
          <p class="md__warn" role="note">
            <b>{S.dynamic}.</b> {S.dynamicT}
          </p>
        )}
      </header>

      {/* Konkrete Titel je Auftraggeber */}
      {m.titleVariants.length > 0 && (
        <section class="md__sec">
          <h2 class="md__h2">{S.appears}</h2>
          <p class="md__p">{S.appearsP}</p>
          <ul class="md__appear">
            {m.titleVariants.map((v) => (
              <li><span class="md__org">{v.org}</span><span class="md__at">{v.text}</span></li>
            ))}
          </ul>
        </section>
      )}

      {/* Eckdaten */}
      <section class="md__sec">
        <h2 class="md__h2">{S.facts}</h2>
        <dl class="md__facts">
          <div><dt>{m.rewardMin === m.rewardMax ? S.reward : S.rewardR}</dt><dd class="md__uec">{rewardTxt}</dd></div>
          <div><dt>{S.type}</dt><dd>{m.typeNames.join(', ') || S.none}</dd></div>
          <div><dt>{S.giver}</dt><dd>{m.giverNames.length ? m.giverNames.join(', ') : S.none}</dd></div>
          <div><dt>{S.region}</dt><dd>{m.localityNames.length ? m.localityNames.join(', ') : S.none}</dd></div>
          {m.guilds.length > 0 && <div><dt>{S.guild}</dt><dd>{m.guilds.join(', ')}{m.orgs.length > 0 && <span class="md__dim"> · {m.orgs.join(', ')}</span>}</dd></div>}
          {m.ranks.length > 0 && <div><dt>{S.rank}</dt><dd>{m.ranks.join(' – ')}</dd></div>}
          <div><dt>{S.legal}</dt><dd>{legal}</dd></div>
          <div><dt>{S.offers}</dt><dd>{m.count}</dd></div>
          <div><dt>{S.src}</dt><dd>{srcLabel}</dd></div>
          <div><dt>{S.players}</dt><dd>{m.maxPlayers || S.none}</dd></div>
          <div><dt>{S.shareable}</dt><dd>{m.shareable ? S.yes : S.no}</dd></div>
          {v0.buyIn > 0 && <div><dt>{S.buyIn}</dt><dd>{uec(v0.buyIn, lang)} aUEC</dd></div>}
          {dur(v0.deadlineSec, lang) && <div><dt>{S.deadline}</dt><dd>{dur(v0.deadlineSec, lang)}</dd></div>}
          {mins(v0.lifetimeMin, lang) && <div><dt>{S.lifetime}</dt><dd>{mins(v0.lifetimeMin, lang)}</dd></div>}
          {mins(v0.cooldownMin, lang) && <div><dt>{S.cooldown}</dt><dd>{mins(v0.cooldownMin, lang)}</dd></div>}
          {v0.wantedMax != null && <div><dt>{S.wanted}</dt><dd>{v0.wantedMax}</dd></div>}
          {m.module && <div><dt>{S.module}</dt><dd><code class="md__code">{m.module}</code></dd></div>}
        </dl>
        {m.places.length > 0 && (
          <>
            <h3 class="md__h3">{S.places}</h3>
            <ul class="md__tags">{m.places.map((p) => <li class="md__tag">{p}</li>)}</ul>
          </>
        )}
      </section>

      {/* Blueprints — die Antwort auf "wirft die was ab?" */}
      {(m.blueprints.length > 0 || craftedHere.length > 0) && (
        <section class="md__sec">
          <h2 class="md__h2">
            <Fragment set:html={ICON_BLUEPRINT} /> {S.bpH} <span class="md__n">{bpTotal || craftedHere.length}</span>
            {m.bpChance != null && <span class="md__badge md__badge--bp">{S.bpChance} {Math.round(m.bpChance * 100)}%</span>}
          </h2>
          {m.blueprints.length > 0 && <p class="md__p">{S.bpP}</p>}
          {m.blueprints.map((p) => (
            <>
              <h3 class="md__h3">{S.bpPool}: <code class="md__code">{p.poolKey}</code>{p.chance != null && ` · ${S.bpChance} ${Math.round(p.chance * 100)}%`}</h3>
              <ul class="md__tags">
                {p.blueprints.map((b) => (
                  <li class="md__tag md__tag--bp">{b.name}{b.weight !== 1 && <span class="md__dim"> ×{b.weight}</span>}</li>
                ))}
              </ul>
            </>
          ))}
          {/* Die Pools oben führen interne Kennungen. Die Crafting-Datenbank
              nennt umgekehrt pro Rezept seine Missionen — daraus entsteht die
              lesbare, verlinkte Liste. */}
          {craftedHere.length > 0 && (
            <>
              <h3 class="md__h3">{S.bpCraft}</h3>
              <ul class="md__tags">
                {craftedHere.map((b) => (
                  <li class="md__tag md__tag--bp"><a href={L(blueprintPath(b))}>{b.name}</a></li>
                ))}
              </ul>
            </>
          )}
        </section>
      )}

      {/* Reputation */}
      <section class="md__sec">
        <h2 class="md__h2">{S.rep}</h2>
        {reps.length ? (
          <>
            <p class="md__p">{S.repP}</p>
            <div class="md__tblWrap">
              <table class="md__tbl">
                <thead><tr>
                  <th>{S.faction}</th><th>{S.scope}</th><th>{S.standing}</th><th>{S.threshold}</th><th>{S.perk}</th>
                </tr></thead>
                <tbody>
                  {reps.map((r) => (
                    <tr>
                      <td>{r.factionName ?? S.none}</td>
                      <td class="md__dim">{r.scope ?? S.none}</td>
                      <td><span class="md__cmp">{cmpSign(r.comparison)}</span> {r.standing ?? S.none}</td>
                      <td class="md__num">{r.standingMin != null ? uec(r.standingMin, lang) : S.none}</td>
                      <td class="md__dim">{r.perk ?? S.none}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        ) : <p class="md__p md__dim">{S.repNone}</p>}
      </section>

      {/* Ablauf — bewusst NICHT "Ziele" */}
      <section class="md__sec">
        <h2 class="md__h2">{S.flow}</h2>
        <p class="md__note"><b>{S.flowNote}</b> {S.flowP}</p>
        {(m.flow.steps.length || m.flow.rules.length) ? (
          <>
            {m.flow.steps.length > 0 && (
              <>
                <h3 class="md__h3">{S.steps}</h3>
                <ol class="md__steps">
                  {m.flow.steps.map((s) => (
                    <li><code class="md__code">{s.name}</code>{s.startsActive && <span class="md__badge">start</span>}</li>
                  ))}
                </ol>
              </>
            )}
            {m.flow.rules.length > 0 && (
              <>
                <h3 class="md__h3">{S.rules}</h3>
                <ul class="md__rules">{m.flow.rules.map((r) => <li>{r}</li>)}</ul>
              </>
            )}
          </>
        ) : <p class="md__p md__dim">{S.flowNone}</p>}
      </section>

      {/* Varianten */}
      <section class="md__sec">
        <h2 class="md__h2">{S.offers} <span class="md__n">{m.count}</span></h2>
        {m.count > 1 ? (
          <p class="md__p" set:html={S.offersP.replace('%n%', String(m.count))} />
        ) : <p class="md__p md__dim">{S.single}</p>}
        <div class="md__tblWrap">
          <table class="md__tbl md__tbl--var">
            <thead><tr>
              <th>{S.tblKey}</th>
              {colGiver && <th>{S.tblGiver}</th>}
              {colLoc && <th>{S.tblLoc}</th>}
              {colPlaces && <th>{S.tblPlaces}</th>}
              <th>{S.tblReward}</th>
              {colRep && <th>{S.tblRep}</th>}
            </tr></thead>
            <tbody>
              {m.variants.map((v) => (
                <tr>
                  <td><code class="md__code">{v.key}</code>{!v.lawful && <span class="md__badge md__badge--il">{S.unlawful}</span>}</td>
                  {colGiver && <td>{v.giver ?? S.none}</td>}
                  {colLoc && <td>{v.locality ?? S.none}</td>}
                  {colPlaces && <td class="md__dim md__places">{v.places.length ? v.places.join(', ') : S.none}</td>}
                  <td class="md__num md__uec">{v.reward ? uec(v.reward, lang) : S.none}</td>
                  {colRep && <td class="md__dim">{v.rep.length
                    ? v.rep.map((r) => `${r.factionName} ${cmpSign(r.comparison)} ${r.standing}`).join(' · ')
                    : S.none}</td>}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      {/* Verwandte */}
      {related.length > 0 && (
        <section class="md__sec">
          <h2 class="md__h2">{lang === 'de' ? 'Ähnliche Missionen' : 'Related missions'}</h2>
          <ul class="md__rel">
            {related.map((r) => (
              <li>
                <a href={L(`/missionen/${r.slug}.html`)}>
                  <b>{seoTitle(r.title)}</b>
                  <span>{r.typeNames[0] ?? ''}{r.rewardMax ? ` · ${uec(r.rewardMax, lang)} aUEC` : ''}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

    </div>
  </main>

  <Attribution />
  <script is:inline src="/assets/detail.js"></script>
</Layout>

{/* KEIN is:inline: gebuendelt in den <head> statt hinter den Inhalt (FOUC).
    Die :root-Palette oben bleibt inline — die muss detail.css ueberschreiben. */}
<style>
  .md { padding: 5.5rem 0 4rem; }
  .md__wrap { width: min(var(--maxw), 100%); margin: 0 auto; padding: 0 clamp(1rem, 4vw, 3rem); }
  .md__back {
    display: inline-block; font-family: var(--font-ui); text-transform: uppercase; letter-spacing: .12em;
    font-size: .7rem; color: var(--muted); margin-bottom: 1.4rem;
  }
  .md__back:hover { color: var(--accent); }

  .md__head { padding-bottom: 1.6rem; border-bottom: 1px solid var(--line); margin-bottom: 2rem; }
  .md__eyebrow {
    font-family: var(--font-ui); text-transform: uppercase; letter-spacing: .28em; font-size: .68rem;
    color: var(--accent); margin-bottom: .6rem;
  }
  .md__h1 {
    font-family: var(--font-display); font-size: clamp(1.9rem, 5vw, 3.4rem); line-height: 1.04; font-weight: 900;
    letter-spacing: -.01em; margin-bottom: .7rem; color: var(--text);
  }
  .md__ph {
