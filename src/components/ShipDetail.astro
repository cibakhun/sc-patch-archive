---
// Schiff-Datenblatt — geteilte, locale-bewusste Ansicht (DE + EN).
// Aus src/pages/schiffe/[slug].astro extrahiert, damit DE und EN dieselbe
// Vorlage teilen (alle 226 Seiten pro Sprache).
//
// i18n-Stand (Stufe 2, vollständig): Template-Chrome + alle Daten-Row-Labels
// (src/lib via t()), Freitext (Beschreibung/Foci/Typ/Größe/Status via
// vehicleText) und Zahlenformat (loc = de-DE / en-US) sind lokalisiert.
import { readFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import Layout from '../layouts/Layout.astro';
import SiteNav from './SiteNav.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import vehiclesSnapshot from '../data/vehicles.json';
import { buildFacts, buildArmament, buildArmStats, crewFmt } from '../lib/shipFacts';
import { buildVisuals } from '../lib/shipVisuals';
import type { Visuals } from '../lib/shipVisuals';
import { pickHero } from '../lib/shipRenders';
import {
  priceInfo, aUEC, pricesFetchedAt,
  extrasInfo, extrasFetchedAt,
  shipVideo, shipGallery,
} from '../lib/shipExtras';
import type { SimilarShip, ShipExtras, ProfileBar } from '../lib/shipExtras';
import { useTranslations, href, type Locale, DEFAULT_LOCALE } from '../i18n/ui';
import { vRole, vSize, vStatus, vDesc } from '../i18n/vehicleText';
import holoMarkersSnapshot from '../data/holo-markers.json';
import holoMeshesSnapshot from '../data/holo-meshes.json';
import shipHardpointsSnapshot from '../data/ship-hardpoints.json';
// Hersteller-Logos (game-sourced aus Data.p4k, self-hosted unter /assets/manufacturers/).
// Manifest: exakter Herstellername -> { file, w, h }. Kein Treffer -> Text-Fallback.
import manufacturerLogos from '../data/manufacturer-logos.json';
import { itemInfo } from '../lib/holoItems';
import { HOLO_GRP_ICON, HOLO_ICON } from '../lib/holoIcons';

interface Props {
  d: CollectionEntry<'vehicles'>['data'];
  id: string;
  similar: SimilarShip[];
  profile: ProfileBar[];
  viz: Visuals;
  lang?: Locale;
  /** DE↔EN-Gegenstück existiert -> hreflang ausgeben */
  hasEn?: boolean;
}
const { d, id, similar, profile, viz, lang = DEFAULT_LOCALE, hasEn = false } = Astro.props;

const t = useTranslations(lang);
const L = (p: string) => href(p, lang);
const loc = lang === 'en' ? 'en-US' : 'de-DE';

const hero = pickHero(d);
// Echtes Marken-Logo, wenn der Hersteller im Manifest steht; sonst Text-Eyebrow.
const makerLogo =
  (d.manufacturer && (manufacturerLogos as Record<string, { file: string; w: number; h: number; full?: boolean }>)[d.manufacturer]) ||
  null;
// Kopf-Medien: kuratiertes Commercial (YouTube) + Bild-Galerie (Hero + Paints)
const videoId = shipVideo(id);
const gallery = shipGallery(id, d);
// Cache-Busting: /assets/holo-viewer.js hat eine feste URL und wird vom CDN
// (Cloudflare, 4h) gecached -> nach einem Deploy sonst die ALTE Datei. Ein
// Content-Hash im Query erzwingt bei Änderung eine neue URL (Cache-Miss).
let holoViewerVer = 'x';
try { holoViewerVer = createHash('sha1').update(readFileSync('assets/holo-viewer.js')).digest('hex').slice(0, 8); } catch { /* dev-Fallback */ }
const holoViewerSrc = `/assets/holo-viewer.js?v=${holoViewerVer}`;
const prices = priceInfo(id);
const buyMin = prices?.buy[0] ?? null;
const rentMin = prices?.rent[0] ?? null;
const MAX_ROWS = 6;

const extras: ShipExtras = extrasInfo(id);
const holoUrl = extras?.holo ?? null;
const paints = extras?.paints ?? [];
const variants = (extras?.variants ?? []).filter((v) => v.id !== id);
const loaners = (extras?.loaners ?? []).filter((v) => v.id !== id);

// patch-spine: version -> codename/page
const patches = await getCollection('patches');
const spine = d.patches
  .map((v) => patches.find((p) => p.data.version === v))
  .filter(Boolean);

// cargo/ore/dims werden anderswo (Maße & Fracht) gezeigt -> hier per stabilem
// key ausfiltern (sprachunabhängig, da Labels jetzt lokalisiert sind).
const facts = buildFacts(d, lang).filter((f) => !['cargo', 'ore', 'dims'].includes(f.key ?? ''));
const armament = buildArmament(d, lang);
const armStats = buildArmStats(d, lang);
const desc = vDesc(d, lang);
// FleetYards liefert vereinzelt "<= PLACEHOLDER =>" als Komponentennamen
// (z. B. Javelin, ROC-DS) — solche Einträge tragen keine Information und
// werden ausgefiltert statt gerendert.
const realName = (it: { name: string }) => !/placeholder|<=|=>|\bTBD\b/i.test(it.name ?? '');
const slots: [string, { name: string; size: number | null; count: number }[]][] = (
  [
    [t('ship.slot.generators'), (d.components?.powerPlants ?? []).filter(realName)],
    [t('ship.slot.shields'), (d.components?.shields ?? []).filter(realName)],
    [t('ship.slot.coolers'), (d.components?.coolers ?? []).filter(realName)],
    [t('ship.slot.quantum'), (d.components?.quantumDrives ?? []).filter(realName)],
    [t('ship.slot.radar'), (d.components?.radars ?? []).filter(realName)],
  ] as [string, { name: string; size: number | null; count: number }[]][]
).filter(([, a]) => a.length > 0);

const dims = [d.lengthM, d.widthM, d.heightM].every((x) => x != null)
  ? `${t('ship.abbr.l')} ${d.lengthM} m · ${t('ship.abbr.w')} ${d.widthM} m · ${t('ship.abbr.h')} ${d.heightM} m`
  : null;
const stageStats: { label: string; value: string }[] = [
  { label: t('ship.stage.length'), value: d.lengthM != null ? `${d.lengthM.toLocaleString(loc)} m` : '—' },
  { label: t('ship.stage.crew'), value: crewFmt(d) },
  { label: t('ship.stage.cargo'), value: d.cargoSCU != null ? `${d.cargoSCU.toLocaleString(loc)} SCU` : '—' },
  { label: t('ship.stage.scm'), value: d.scmSpeed != null ? `${d.scmSpeed} m/s` : '—' },
  {
    label: buyMin ? t('ship.stage.priceIngame') : t('ship.stage.pledge'),
    value: buyMin ? aUEC(buyMin.price, lang) : d.msrpUSD != null ? `$${d.msrpUSD.toLocaleString('en-US')}` : '—',
  },
];

// ---------- Interaktives Komponenten-Hologramm ----------
// Zwei Positionsquellen, in Reihenfolge der Genauigkeit:
//  1. Echtes Spielmesh (src/data/holo-meshes.json): das gerenderte Mesh und
//     die Hardpoints (ship-hardpoints.json, COMPILED_BONES) teilen denselben
//     Raum -> Marker EXAKT, nur feste Achsvertauschung cry->glTF (x, z, -y).
//  2. FleetYards-Holo (holo-markers.json): auf ein fremdes Kunst-Mesh
//     kalibriert -> nur ungefähr, Marker tragen "geschätzt".
// Angezeigt werden bewusst NUR Komponenten (core) + Bewaffnung (arms) —
// Triebwerke sind ausgeblendet (zu viele, kein Mehrwert).
type HoloPort = {
  k: string; g: string; p: number[];
  label: string | null; size: number | null;
  /** lab: dauerhaft sichtbare Beschriftung (nur Kern-Komponenten) */
  lab?: string;
  /** Item-Finder-Anreicherung (Kategorie / günstigster Preis / Kauforte / Item-ID) */
  cat?: string; price?: number; shops?: number; iid?: string;
  /** np: nicht physicalisiert · est: Position geschätzt · dim: gedämpfter Marker-Stil */
  np?: boolean; est?: boolean; dim?: boolean;
  /** badge: Vorbehalt, den der Callout selbst trägt (np/est) — ohne Klick lesbar */
  badge?: string;
};
// Alle Hardpoint-Ebenen sind verfügbar; standardmäßig sichtbar sind nur
// Komponenten + Bewaffnung, den Rest (Antrieb, Sonstiges) schaltet der Nutzer
// per Filter selbst zu — nichts wird künstlich entfernt.
const HOLO_GRP: Record<string, string> = {
  power: 'core', shield: 'core', cooler: 'core', quantum: 'core', radar: 'core',
  turret: 'arms', missile: 'arms', weapon: 'arms',
  thruster_main: 'prop', thruster_retro: 'prop', thruster_vtol: 'prop', thruster_mav: 'prop',
  fuel: 'other', countermeasure: 'other',
};
const HOLO_GRP_ORDER = ['core', 'arms', 'prop', 'other'] as const;
const HOLO_DEFAULT_ON = ['core', 'arms'];
const holoShip = (holoMarkersSnapshot as any).ships?.[id] ?? null;
const gameMesh = (holoMeshesSnapshot as any).meshes?.[id] ?? null;
const gameHp = gameMesh ? ((shipHardpointsSnapshot as any).ships?.[id] ?? null) : null;
const hasHolo = !!((gameMesh && gameHp) || (holoUrl && holoShip));

let holoData: {
  url: string | null; mesh: { c: number[]; s: number[] } | null; ax: number[] | null;
  ports: HoloPort[]; groups: readonly string[]; defaultOn: string[]; kinds: Record<string, string>;
  grpLabels: Record<string, string>; icons: Record<string, string>; loc: string; finder: string;
} | null = null;

if (hasHolo) {
  // Loadout-Pools (Name/Größe je Kategorie), von beiden Quellen geteilt
  const expand = (list: { name: string; size: number | null; count: number }[]) =>
    list.filter(realName).flatMap((it) => Array.from({ length: it.count }, () => it));
  const pools: Record<string, { name: string; size: number | null }[]> = {
    power: expand(d.components?.powerPlants ?? []),
    shield: expand(d.components?.shields ?? []),
    cooler: expand(d.components?.coolers ?? []),
    quantum: expand(d.components?.quantumDrives ?? []),
    radar: expand(d.components?.radars ?? []),
    missile: expand(d.missileRacks ?? []),
    turret: (d.turrets ?? []).flatMap((tu) => {
      const guns = tu.weapons.filter(realName);
      return Array.from({ length: tu.stations }, () => ({
        name: guns.length ? guns.map((w) => `${w.count}× ${w.name}`).join(', ') : tu.label,
        size: tu.sizes[0]?.size ?? null,
      }));
    }),
    weapon: (d.fixedWeapons ?? []).filter(realName).flatMap((w) =>
      Array.from({ length: w.count }, () => ({ name: w.name, size: null }))
    ),
  };
  // Gemischte Loadouts (mehrere VERSCHIEDENE Komponenten derselben Art):
  // Bone- und API-Reihenfolge sind unabhängig -> keine geratene 1:1-Zuordnung,
  // stattdessen ehrlich alle Namen am Marker zeigen.
  const mixedLabel: Record<string, string | null> = {};
  for (const [k, pool] of Object.entries(pools)) {
    const names = [...new Set(pool.map((it) => it.name))];
    mixedLabel[k] = names.length > 1 ? names.join(' / ') : null;
  }

  // Positionsquelle wählen
  let meshUrl: string | null = null;
  let meshBox: { c: number[]; s: number[] } | null = null;
  let axis: number[] | null = null;
  let est = false;
  let srcPorts: { k: string; p: number[] }[] = [];
  if (gameMesh && gameHp) {
    // ?v=<Content-Hash> aus dem Manifest: nginx cached /holo/ 1 Jahr — der
    // Buster laesst Patch-Re-Exporte sofort durchschlagen (vgl. holoViewerSrc)
    meshUrl = gameMesh.v ? `${gameMesh.url}?v=${gameMesh.v}` : gameMesh.url;
    const hull = gameHp.hull ?? gameHp.bbox; // cry-AABB
    // cry -> glTF: (x, z, -y) — feste Achsvertauschung, keine Kalibrierung
    meshBox = {
      c: [(hull[0][0] + hull[1][0]) / 2, (hull[0][2] + hull[1][2]) / 2, -((hull[0][1] + hull[1][1]) / 2)],
      s: [Math.abs(hull[1][0] - hull[0][0]), Math.abs(hull[1][2] - hull[0][2]), Math.abs(hull[1][1] - hull[0][1])],
    };
    srcPorts = (gameHp.hp as { k: string; p: number[] }[])
      .filter((h) => HOLO_GRP[h.k])
      .map((h) => ({ k: h.k, p: [h.p[0], h.p[2], -h.p[1]] }));
  } else if (holoUrl && holoShip) {
    meshUrl = holoUrl;
    meshBox = holoShip.mesh;
    axis = holoShip.ax ?? null;
    est = holoShip.mode === 'mapped' && holoShip.conf !== 'high';
    // conf 'low': Ausrichtung nicht belastbar -> keine kalibrierten Marker
    if (holoShip.conf !== 'low') {
      srcPorts = (holoShip.ports as { k: string; p: number[] }[]).filter((h) => HOLO_GRP[h.k]);
    }
  }

  // Item-Finder-Anreicherung: Kategorie/Preis/Kauforte für einen Item-Namen
  const enrich = (name: string | null | undefined) => {
    const info = itemInfo(name);
    if (!info) return {};
    return { cat: info.cat, shops: info.shops, iid: info.id, ...(info.price != null ? { price: info.price } : {}) };
  };
  // Marker -> Loadout joinen
  const holoPorts: HoloPort[] = [];
  const taken: Record<string, number> = {};
  for (const hp of srcPorts) {
    const g = HOLO_GRP[hp.k];
    const pool = pools[hp.k];
    const item = pool ? pool[(taken[hp.k] = (taken[hp.k] ?? 0) + 1) - 1] : undefined;
    const mixed = mixedLabel[hp.k];
    holoPorts.push({
      k: hp.k, g, p: hp.p,
      label: mixed ?? item?.name ?? null,
      size: mixed ? null : item?.size ?? null,
      ...(!mixed ? enrich(item?.name) : {}),
      ...(g === 'core' ? { lab: t(`holo.kind.${hp.k}` as any) } : {}),
      // Kein Badge für est: 83 Schiffe sind komplett "mapped/mid", ein Badge an
      // JEDEM Chip würde das Gold abstumpfen, das "Ohne Einbauort" (np) tragen
      // muss. est ist die schwächere Aussage (echte Daten, ungefähr platziert)
      // und bleibt bei gestrichelt + Vorbehalt in Kopfzeile/Detailkarte.
      ...(est ? { est: true, dim: true } : {}),
    });
  }
  // Kern-Komponente ganz ohne physisches Hardpoint -> schematisch mittig + Vermerk
  if (meshBox) {
    const mc = meshBox.c, ms = meshBox.s;
    let stackI = 0;
    for (const k of Object.keys(HOLO_GRP).filter((x) => HOLO_GRP[x] === 'core')) {
      const pool = pools[k] ?? [];
      if (!pool.length || (taken[k] ?? 0) > 0) continue;
      const off = (stackI++ - 1) * 0.08;
      holoPorts.push({
        k, g: 'core',
        p: [mc[0] + off * ms[0] * 0.3, mc[1], mc[2] + off * ms[2] * 0.3].map((x) => Math.round(x * 100) / 100),
        label: mixedLabel[k] ?? pool[0].name, size: mixedLabel[k] ? null : pool[0].size,
        ...(!mixedLabel[k] ? enrich(pool[0].name) : {}),
        lab: t(`holo.kind.${k}` as any),
        np: true, dim: true, badge: t('holo.badge.np' as any),
      });
    }
  }

  if (holoPorts.length) {
    const present = new Set(holoPorts.map((p2) => p2.g));
    holoData = {
      url: meshUrl,
      mesh: meshBox,
      ax: axis,
      ports: holoPorts,
      groups: HOLO_GRP_ORDER.filter((gr) => present.has(gr)),
      defaultOn: HOLO_DEFAULT_ON.filter((gr) => present.has(gr)),
      kinds: Object.fromEntries([...new Set(holoPorts.map((p2) => p2.k))].map((k) => [k, t(`holo.kind.${k}` as any)])),
      grpLabels: Object.fromEntries(HOLO_GRP_ORDER.map((g) => [g, t(`holo.grp.${g}` as any)])),
      icons: Object.fromEntries([...new Set(holoPorts.map((p2) => p2.k))].filter((k) => HOLO_ICON[k]).map((k) => [k, HOLO_ICON[k]])),
      loc,
      finder: L('/item-finder.html'),
    };
  }
}

// Belastbarkeit der gezeigten Positionen — steuert die Herkunfts-Zeile unter dem
// Titel. Wenn KEIN Marker verortet ist (Schiffe ohne Hardpoints im Mesh bzw.
// conf:low), darf dort nicht "Positionen aus den Spieldateien" stehen.
const holoNp = holoData?.ports.filter((p) => p.np).length ?? 0;
const holoEst = holoData?.ports.some((p) => p.est) ?? false;
const holoAllNp = !!holoData && holoData.ports.length > 0 && holoNp === holoData.ports.length;

const shipCode = d.manufacturer ?? d.makerCode ?? t('ship.code.ship');
// Kopf-Modi (Umschalter): Video (kuratiertes Commercial) · Bilder (Slideshow) · Holo (3D)
// holoAvail deckt sich mit der Bedingung, unter der das Holodata-Script unten ausgegeben wird.
const holoAvail = !!(holoData || holoUrl);
const hasGallery = gallery.length > 0;
const stageModeCount = (videoId ? 1 : 0) + (hasGallery ? 1 : 0) + (holoAvail ? 1 : 0);
const defaultMode: 'video' | 'img' | 'holo' = videoId ? 'video' : hasGallery ? 'img' : 'holo';
const metaDesc = t('ship.meta.desc')
  .replace('%name%', d.name)
  .replace('%maker%', d.manufacturer ?? t('ship.maker.unknown'));
// Alt-Texte: jede Galerie-Kachel benennt, WAS sie zeigt (A11y + Bilder-SEO) —
// Lacke mit Namen, Hero/Store-Bild generisch. Astro würde alt={''} als nacktes
// `alt` ohne Wert rendern, deshalb nie leer lassen.
const altView = t('ship.img.view').replace('%name%', d.name);
const altPaint = (paint: string) => t('ship.img.paint').replace('%name%', d.name).replace('%paint%', paint);

// Icon-Pfade (24×24, stroke)
const IC: Record<string, string> = {
  handel: 'M12 4a8 8 0 100 16 8 8 0 000-16z M14.8 9.2c-.9-.9-4.2-1.1-4.6.8-.4 2 4.9 1 4.5 3.1-.4 1.8-3.8 1.7-4.8.7 M12 6.6v1.6 M12 15.8v1.6',
  datenblatt: 'M7 3h7l4 4v14H7z M14 3v4h4 M10 12h6 M10 16h6',
  bewaffnung: 'M12 5a7 7 0 100 14 7 7 0 000-14z M12 3v4 M12 17v4 M3 12h4 M17 12h4',
  verteidigung: 'M12 3l7 3v6c0 4.4-2.9 7.6-7 9-4.1-1.4-7-4.6-7-9V6z',
  flug: 'M5 17a8 8 0 0114 0 M12 16l4.2-5.6 M12 16a1.4 1.4 0 100 .01',
  quantum: 'M12 9.4a2.6 2.6 0 100 5.2 2.6 2.6 0 000-5.2z M3.5 15.5C6 18 18 12 20.5 8.5 M3.5 8.5C6 6 18 12 20.5 15.5',
  kern: 'M8 8h8v8H8z M10 3v3 M14 3v3 M10 18v3 M14 18v3 M3 10h3 M3 14h3 M18 10h3 M18 14h3',
  versicherung: 'M12 3l7 3v6c0 4.4-2.9 7.6-7 9-4.1-1.4-7-4.6-7-9V6z M9 11.6l2.2 2.2 4-4.2',
  profil: 'M5 20v-8 M10 20V5 M15 20v-6 M20 20V9',
  paints: 'M12 3.5s5.6 6.8 5.6 10.4a5.6 5.6 0 11-11.2 0C6.4 10.3 12 3.5 12 3.5z',
  varianten: 'M6 6a2 2 0 100-.01 M6 18a2 2 0 100-.01 M18 8a2 2 0 100-.01 M6 8v8 M6 12c7 0 5-3.4 10-3.9',
  aehnlich: 'M4 4h7v7H4z M13 4h7v7h-7z M4 13h7v7H4z M13 13h7v7h-7z',
  masse: 'M3 9h18v6H3z M7 9v3 M11 9v4 M15 9v3',
};
---
<Layout
  title={`${d.name} — ${t('ship.title.suffix')} | VerseBase`}
  description={metaDesc}
  themeColor="#05070d"
  footer={true}
  translated={hasEn}
  ogImage={hero?.src}
  itemPage={{ modified: vehiclesSnapshot.fetchedAt }}
>
<style is:inline>
:root{
  --bg:#05070d;--bg-2:#0a0e18;--surface:#0f1524;--surface-2:#141c30;
  --accent:#2dd4ff;--accent-2:#6ea8ff;--gold:#d4af37;
  --text:#e8eefc;--muted:#8a99b8;--line:rgba(110,168,255,.16);
  --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;
  --maxw:1100px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
::selection{background:var(--accent);color:#05070d}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
.ic{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round;vertical-align:-3px;margin-right:.5rem;flex:none}

/* ============ HANGAR-BÜHNE ============ */
/* Layout: Info links, interaktive Holo-Bühne rechts (Grid). Das Hologramm
   ist eingebettet (kein Popup-Toggle mehr) und lädt lazy beim Scrollen. */
.holo{position:relative;height:clamp(540px,74vh,760px);margin-top:56px;overflow:hidden;
  background:radial-gradient(120% 90% at 50% 8%,#0c1424 0%,var(--bg) 62%),var(--bg);
  border-bottom:1px solid var(--line)}
.holo__grid{position:absolute;left:-24%;right:-24%;bottom:-4%;height:56%;pointer-events:none;
  transform:perspective(760px) rotateX(63deg);transform-origin:50% 100%;
  background:
    repeating-linear-gradient(90deg,rgba(45,212,255,.13) 0 1px,transparent 1px 44px),
    repeating-linear-gradient(0deg,rgba(45,212,255,.13) 0 1px,transparent 1px 44px);
  -webkit-mask-image:linear-gradient(0deg,rgba(0,0,0,.85),transparent 82%);
  mask-image:linear-gradient(0deg,rgba(0,0,0,.85),transparent 82%)}
.holo__pad{position:absolute;bottom:7%;left:62%;transform:translateX(-50%);width:min(42%,520px);height:5%;pointer-events:none;
  border-radius:50%;background:radial-gradient(50% 50% at 50% 50%,rgba(45,212,255,.4),rgba(45,212,255,.1) 55%,transparent 72%);
  filter:blur(5px);transition:opacity .5s}
.is-3d-active .holo__pad{background:radial-gradient(50% 50% at 50% 50%,rgba(45,212,255,.55),rgba(45,212,255,.16) 55%,transparent 72%)}
/* Vollbreite: Bühne randlos über die ganze Hero-Breite -> Modell mittig,
   groß, und bis zum Bildschirmrand verschiebbar. Titel liegt als Overlay auf. */
.holo__wrap{position:relative;z-index:2;height:100%;width:100%}
.holo__stage{position:absolute;inset:0;min-height:360px}
/* Bilder fuellen die Buehne randlos wie das Video (cover statt contain) —
   User-Feedback "Bild nicht ueber die ganze Breite". Volle Ansichten ohne
   Beschnitt liefert weiterhin die Galerie-Sektion darunter. */
.holo__ship{position:absolute;inset:0;display:grid;grid-template:100%/100%;place-items:center;min-height:0}
.holo__ship img{width:100%;height:100%;object-fit:cover;transition:opacity .6s}
.holo__3d{position:absolute;inset:0;opacity:0;pointer-events:none;cursor:grab;transition:opacity .6s}
.holo__3d:active{cursor:grabbing}
.holo__stage.is-3d .holo__ship img{opacity:0}
.holo__stage.is-3d .holo__3d{opacity:1;pointer-events:auto}
.holo__status{position:absolute;left:50%;bottom:12%;transform:translateX(-50%);z-index:5;white-space:nowrap;
  font-family:var(--font-ui);font-weight:700;font-size:.9rem;letter-spacing:.16em;text-transform:uppercase;color:var(--accent)}
/* Status (Lade-%/Fehler) nur zeigen, solange geladen wird oder 3D aktiv ist —
   ein stiller Auto-Start-Fehlschlag darf das Foto nicht dauerhaft überlagern */
.holo__stage:not(.is-3d):not(.is-loading) .holo__status{display:none}
.holo__activate{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);z-index:6;cursor:pointer;
  appearance:none;border:1px solid color-mix(in srgb,var(--accent) 55%,transparent);background:rgba(5,7,13,.7);color:var(--accent);
  font-family:var(--font-ui);font-weight:700;font-size:.85rem;letter-spacing:.18em;text-transform:uppercase;padding:.7rem 1.2rem;
  backdrop-filter:blur(4px)}
.holo__activate:hover{background:color-mix(in srgb,var(--accent) 16%,rgba(5,7,13,.7))}
.holo__hintline{position:absolute;left:50%;bottom:2%;transform:translateX(-50%);z-index:4;pointer-events:none;white-space:nowrap;
  font-family:var(--font-ui);font-weight:600;font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);opacity:0;transition:opacity .6s}
.holo__stage.is-3d .holo__hintline{opacity:.75}
/* ===== Bilder-Slideshow: alle Slides liegen im selben Grid-Feld, langsames Crossfade ===== */
.holo__ship img{opacity:0;transition:opacity 1.2s ease}
.holo__ship img.is-active{opacity:1}
.holo__stage.is-video .holo__ship img,
.holo__stage.is-3d .holo__ship img{opacity:0}
/* dezente Slide-Zähler-Punkte unten */
.holo__dots{position:absolute;left:50%;bottom:2.4%;transform:translateX(-50%);z-index:5;display:flex;gap:.4rem;pointer-events:none;opacity:0;transition:opacity .4s}
.holo__stage:not(.is-video):not(.is-3d) .holo__dots{opacity:.9}
.holo__dots i{width:6px;height:6px;border-radius:50%;background:var(--muted);opacity:.4;transition:opacity .3s,background .3s}
.holo__dots i.on{background:var(--accent);opacity:1}
/* ===== Video-Layer (Commercial): Facade -> YouTube-Embed on demand ===== */
/* Video randlos bis zum Bildschirmrand (Hero ist full-bleed) */
.holo__video{position:absolute;inset:0;z-index:5;opacity:0;pointer-events:none;transition:opacity .5s;background:#000;overflow:hidden}
.holo__stage.is-video .holo__video{opacity:1;pointer-events:auto}
/* Poster deckt den Player anfangs voll ab (Schiffsbild) und blendet erst kurz
   NACH Abspielstart aus -> YouTubes kurzes Pause/Play-Symbol beim Start bleibt
   darunter verborgen. z-index über iframe UND Schutzschicht. */
.holo__videoposter{position:absolute;inset:0;z-index:6;background:#05070d center/cover no-repeat;opacity:1;transition:opacity .9s ease}
.holo__videoposter::after{content:"";position:absolute;inset:0;background:radial-gradient(65% 65% at 50% 42%,transparent,rgba(5,7,13,.55))}
.holo__playertarget{position:absolute;inset:0;width:100%;height:100%;z-index:2}
/* Videobild FÜLLT den Hero (cover, keine schwarzen Balken): 16:9-iframe so
   groß, dass es Breite UND Höhe deckt, zentriert, Überstand wird geclippt */
.holo__video iframe{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  --hh:clamp(540px,74vh,760px);
  width:max(100vw,calc(var(--hh) * 16 / 9));
  height:max(calc(100vw * 9 / 16),var(--hh));
  border:0;background:#000}
/* Schutzschicht: fängt Hover/Klick ab -> keine YouTube-Leiste/-Chrome sichtbar,
   wirkt wie ein natives Hintergrund-Video (bei reduce-motion per JS deaktiviert) */
.holo__videoshield{position:absolute;inset:0;z-index:4;cursor:default}
@media(prefers-reduced-motion:reduce){.holo__ship img{transition:none}}
/* ===== Ebenen-Panel (oben links) — Sci-Fi-MFD ===== */
.holo__layers{position:absolute;left:clamp(14px,3vw,30px);top:52px;z-index:6;width:min(184px,44vw);
  display:flex;flex-direction:column;padding:.2rem .2rem .25rem;
  background:linear-gradient(180deg,rgba(9,14,24,.9),rgba(6,10,18,.8));border:1px solid var(--line);
  backdrop-filter:blur(7px);box-shadow:0 10px 30px rgba(0,0,0,.4);
  clip-path:polygon(0 0,100% 0,100% calc(100% - 10px),calc(100% - 10px) 100%,0 100%)}
/* Ebenen-Panel NUR in der Holo-Ansicht: display:none schlägt das base
   display:flex (das sonst das [hidden]-Attribut aushebelt) */
.holo__stage:not(.is-3d) .holo__layers{display:none}
.holo__layers-h{display:flex;align-items:center;justify-content:space-between;gap:.5rem;width:100%;
  appearance:none;background:transparent;border:0;border-bottom:1px solid rgba(255,255,255,.07);cursor:default;text-align:left;
  font:700 .62rem/1 var(--font-ui);letter-spacing:.24em;text-transform:uppercase;color:var(--muted);
  padding:.5rem .55rem .5rem;margin-bottom:.15rem}
.holo__layers-chev{width:13px;height:13px;flex:none;color:var(--muted);display:none;transition:transform .2s}
.holo__layer{--gc:var(--accent);display:flex;align-items:center;gap:.55rem;width:100%;cursor:pointer;appearance:none;border:0;
  background:transparent;padding:.44rem .55rem;border-radius:3px;
  font:700 .74rem/1 var(--font-ui);letter-spacing:.05em;text-transform:uppercase;color:var(--muted);
  transition:color .13s,background .13s,opacity .13s}
.holo__layer[data-g="arms"]{--gc:var(--gold)}
.holo__layer[data-g="prop"]{--gc:var(--accent-2)}
.holo__layer[data-g="other"]{--gc:#a78bfa}
.holo__layer:hover{background:rgba(255,255,255,.05);color:var(--text)}
.holo__layer-ic{width:17px;height:17px;flex:none;stroke:var(--gc);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;
  transition:filter .13s}
.holo__layer-lb{flex:1;text-align:left;white-space:nowrap}
.holo__layer-ct{flex:none;font-size:.68rem;font-variant-numeric:tabular-nums;color:color-mix(in srgb,var(--gc) 80%,#fff);
  background:color-mix(in srgb,var(--gc) 16%,transparent);
  clip-path:polygon(3px 0,100% 0,100% calc(100% - 3px),calc(100% - 3px) 100%,0 100%,0 3px);padding:.08rem .4rem;min-width:1.5rem;text-align:center}
.holo__layer[aria-pressed="true"]{color:#fff}
.holo__layer[aria-pressed="true"] .holo__layer-ic{filter:drop-shadow(0 0 5px color-mix(in srgb,var(--gc) 70%,transparent))}
.holo__layer[aria-pressed="false"]{opacity:.5}
.holo__layer[aria-pressed="false"] .holo__layer-ct{background:transparent;color:var(--muted)}
.holo__layer--lab{margin-top:.15rem;padding-top:.5rem;border-top:1px solid rgba(255,255,255,.07)}
.holo__layer-eye{width:15px;height:15px;flex:none;stroke:var(--accent);fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
.holo__layer--lab[aria-pressed="false"] .holo__layer-eye{stroke:var(--muted)}

/* Dauerhafte Komponenten-Beschriftungen: entzerrte HUD-Callouts. Gestapelt als
   Leader-Linien (unten) · Text-Chips (Mitte) · Positions-Knoten (oben) — so
   verdeckt kein Chip je den Punkt, der das Bauteil markiert. */
.holo-lbllayer{position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:4}
.holo-leaders,.holo-nodes{position:absolute;inset:0;width:100%;height:100%;overflow:visible}
/* Leader müssen auf dem HELLEN Hologramm UND im dunklen Raum lesbar sein ->
   heller Strich mit dunklem Halo (Kontrast überall) + Cyan-Glow. */
.holo-leaders line{stroke:var(--accent);stroke-width:1.5;
  filter:drop-shadow(0 0 1.5px rgba(2,10,18,.95)) drop-shadow(0 0 4px color-mix(in srgb,var(--accent) 60%,transparent));
  transition:stroke .16s,stroke-width .16s}
.holo-leaders line.is-active{stroke:#fff;stroke-width:2.2}
/* Knoten = exakter Bauteil-Punkt. Muss auf dem hellen, leuchtenden Hologramm
   ablesbar bleiben -> weißer Kern + kräftiger dunkler Ring (Kontrast) + WEISSER
   Glow (Cyan-Glow ginge im Cyan-Holo unter) + harte Dunkelkante. Liegt über den
   Chips -> immer sichtbar. */
.holo-nodes circle{fill:#fff;stroke:#02141f;stroke-width:2.2;paint-order:stroke;
  filter:drop-shadow(0 0 1.5px rgba(0,0,0,.9)) drop-shadow(0 0 5px rgba(216,246,255,.95));transition:r .16s}
.holo-nodes circle.is-active{stroke:var(--accent);
  filter:drop-shadow(0 0 2px #000) drop-shadow(0 0 8px #fff)}
.holo-lbl{position:absolute;transform:translate(-50%,-50%);white-space:nowrap;
  font-family:var(--font-ui);font-weight:700;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:#eafaff;
  padding:.22rem .5rem .22rem .62rem;
  background:linear-gradient(180deg,rgba(11,20,33,.92),rgba(6,11,19,.84));
  border:1px solid color-mix(in srgb,var(--accent) 34%,transparent);border-left:2px solid var(--accent);
  box-shadow:0 4px 16px rgba(0,0,0,.5),inset 0 0 14px color-mix(in srgb,var(--accent) 9%,transparent);
  backdrop-filter:blur(4px);text-shadow:0 1px 4px #000;
  clip-path:polygon(0 0,100% 0,100% calc(100% - 5px),calc(100% - 5px) 100%,0 100%);
  transition:border-color .16s,box-shadow .16s,color .16s;will-change:left,top}
.holo-lbl.is-active{border-color:var(--accent);color:#fff;
  box-shadow:0 4px 18px rgba(0,0,0,.55),0 0 16px color-mix(in srgb,var(--accent) 42%,transparent),inset 0 0 14px color-mix(in srgb,var(--accent) 14%,transparent)}

/* --- Vorbehalt am Callout selbst ---------------------------------------------
   Ein normaler Chip behauptet "Bauteil sitzt HIER". Zwei Abstufungen, bewusst
   NICHT gleich laut — sonst stumpft die laute ab:

   is-np  (Bauteil hat gar keinen Einbauort im Mesh, Marker frei erfunden):
     Gold + gestrichelt + ausgeschriebenes Badge. Selten (24 Schiffe) und die
     einzige Stelle, an der Gold "diese Position ist keine Messung" bedeutet.
   is-est (echter Hardpoint, nur ungefähr auf ein Fremdmesh gemappt):
     bleibt Cyan (es sind echte Daten), nur gestrichelt + hohler Knoten. Betrifft
     83 Schiffe komplett — ein Badge an jedem Chip wäre Lärm, kein Signal. */
.holo-lbl.is-np{border-style:dashed;
  border-color:color-mix(in srgb,var(--gold) 46%,transparent);
  border-left:2px dashed var(--gold);color:#f6e7c4;
  box-shadow:0 4px 16px rgba(0,0,0,.5),inset 0 0 14px color-mix(in srgb,var(--gold) 8%,transparent)}
.holo-lbl.is-np.is-active{border-color:var(--gold);color:#fff8e6;
  box-shadow:0 4px 18px rgba(0,0,0,.55),0 0 16px color-mix(in srgb,var(--gold) 40%,transparent),inset 0 0 14px color-mix(in srgb,var(--gold) 13%,transparent)}
.holo-lbl.is-est{border-style:dashed;border-left:2px dashed color-mix(in srgb,var(--accent) 75%,transparent)}
.holo-lbl__b{display:inline-block;margin-left:.2rem;padding:0 .3rem;font-style:normal;font-size:.86em;
  font-weight:800;letter-spacing:.06em;color:#0b1421;background:var(--gold);border-radius:2px;vertical-align:baseline}
/* Leader/Knoten tragen denselben Vorbehalt: gestrichelte Linie (keine feste
   Zuordnung) und ein HOHLER Knoten — der gefüllte Punkt bleibt der exakten
   Position vorbehalten. */
.holo-leaders line.is-np{stroke:var(--gold);stroke-dasharray:5 5;stroke-width:1.4;
  filter:drop-shadow(0 0 1.5px rgba(2,10,18,.95)) drop-shadow(0 0 4px color-mix(in srgb,var(--gold) 55%,transparent))}
.holo-leaders line.is-np.is-active{stroke:#ffe9a8;stroke-width:2}
.holo-leaders line.is-est{stroke-dasharray:5 5}
.holo-nodes circle.is-np{fill:none;stroke:var(--gold);stroke-width:2.4;
  filter:drop-shadow(0 0 1.5px rgba(0,0,0,.95)) drop-shadow(0 0 5px color-mix(in srgb,var(--gold) 75%,transparent))}
.holo-nodes circle.is-np.is-active{stroke:#ffe9a8;
  filter:drop-shadow(0 0 2px #000) drop-shadow(0 0 8px var(--gold))}
.holo-nodes circle.is-est{fill:none;stroke:#dff6ff;stroke-width:2.2}

/* ===== Komponenten-Detail-Karte (Bord-MFD, gruppenfarbig) ===== */
.holo__panel{--gc:var(--accent);position:absolute;right:clamp(14px,2vw,24px);top:52px;z-index:7;width:min(272px,86vw);
  background:linear-gradient(180deg,rgba(10,16,27,.94),rgba(6,10,18,.9));backdrop-filter:blur(8px);
  border:1px solid color-mix(in srgb,var(--gc) 42%,transparent);
  box-shadow:0 14px 44px rgba(0,0,0,.55),0 0 26px color-mix(in srgb,var(--gc) 14%,transparent);
  clip-path:polygon(0 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%)}
.holo__panel[data-g="arms"]{--gc:var(--gold)}
.holo__panel[data-g="prop"]{--gc:var(--accent-2)}
.holo__panel[data-g="other"]{--gc:#a78bfa}
.holo__panel .hp__head{position:relative;padding:.62rem .8rem .6rem;border-top:2px solid var(--gc);
  background:linear-gradient(180deg,color-mix(in srgb,var(--gc) 16%,transparent),transparent)}
.holo__panel .hp__eyebrow{font:700 .6rem/1 var(--font-ui);letter-spacing:.2em;text-transform:uppercase;
  color:color-mix(in srgb,var(--gc) 78%,var(--muted))}
.holo__panel .hp__eyebrow:empty{display:none}
.holo__panel .hp__x{position:absolute;top:.4rem;right:.45rem;appearance:none;border:0;background:transparent;
  color:color-mix(in srgb,var(--gc) 75%,#fff);cursor:pointer;font-size:1.2rem;line-height:1;padding:0 .2rem}
.holo__panel .hp__x:hover{color:#fff}
.holo__panel .hp__title{display:flex;align-items:center;gap:.55rem;margin:.2rem 1.2rem .05rem 0}
.holo__panel .hp__icon{width:27px;height:27px;flex:none;stroke:var(--gc);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;
  filter:drop-shadow(0 0 7px color-mix(in srgb,var(--gc) 45%,transparent))}
.holo__panel .hp__kind{font:800 1.15rem/1.1 var(--font-ui);letter-spacing:.03em;text-transform:uppercase;color:#fff;
  text-shadow:0 0 18px color-mix(in srgb,var(--gc) 40%,transparent)}
.holo__panel .hp__name{font:600 .9rem/1.25 var(--font-body);color:color-mix(in srgb,var(--gc) 82%,#fff)}
.holo__panel .hp__name:empty{display:none}
.holo__panel dl{margin:0;padding:.15rem .8rem .1rem;display:flex;flex-direction:column}
.holo__panel dl>div{display:flex;align-items:center;justify-content:space-between;gap:1rem;
  padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.06)}
.holo__panel dl>div:last-child{border-bottom:0}
.holo__panel dt{font:600 .72rem/1 var(--font-ui);letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.holo__panel dd{margin:0;font:700 .9rem/1 var(--font-ui);color:var(--text);font-variant-numeric:tabular-nums;text-align:right}
.holo__panel .hp__price{color:var(--gold)}
.holo__panel .hp__link{display:flex;align-items:center;gap:.4rem;margin:.55rem .8rem .7rem;padding:.5rem .65rem;
  font:700 .72rem/1 var(--font-ui);letter-spacing:.1em;text-transform:uppercase;color:var(--gc);
  border:1px solid color-mix(in srgb,var(--gc) 40%,transparent);background:color-mix(in srgb,var(--gc) 9%,transparent);
  transition:background .13s,color .13s}
.holo__panel .hp__link:hover{background:color-mix(in srgb,var(--gc) 20%,transparent);color:#fff}
/* Vorbehalt in der Detailkarte: getönter Block statt Fußnote — er schränkt die
   Kernaussage der Karte ein ("Bauteil sitzt hier") und darf nicht überlesen
   werden. Gold + gestrichelt = dieselbe Sprache wie Marker und Callout. */
.holo__panel .hp__note{margin:0;padding:.5rem .8rem .6rem 2rem;font-size:.76rem;line-height:1.45;color:#f6e7c4;
  background:color-mix(in srgb,var(--gold) 12%,transparent);
  border-top:1px dashed color-mix(in srgb,var(--gold) 45%,transparent);text-transform:none;letter-spacing:0}
.holo__panel .hp__note::before{content:"!";position:absolute;margin-left:-1.35rem;margin-top:.02rem;
  width:.95rem;height:.95rem;line-height:.95rem;text-align:center;font-weight:900;font-size:.7rem;
  color:#0b1421;background:var(--gold);border-radius:50%}
/* Diegetische HUD-Details: Eck-Klammer + MFD-Scanlines */
.holo__layers::before,.holo__panel::before{content:"";position:absolute;top:5px;left:5px;width:12px;height:12px;
  border-top:2px solid var(--accent);border-left:2px solid var(--accent);pointer-events:none}
.holo__panel::before{border-color:var(--gc)}
.holo__panel::after{content:"";position:absolute;inset:0;pointer-events:none;
  background:repeating-linear-gradient(0deg,transparent 0 3px,color-mix(in srgb,var(--gc) 7%,transparent) 3px 4px)}
.holo__frame{position:absolute;inset:14px;pointer-events:none;
  background:
    linear-gradient(90deg,var(--accent) 0 22px,transparent 22px) top left/44px 2px no-repeat,
    linear-gradient(180deg,var(--accent) 0 22px,transparent 22px) top left/2px 44px no-repeat,
    linear-gradient(270deg,var(--accent) 0 22px,transparent 22px) bottom right/44px 2px no-repeat,
    linear-gradient(0deg,var(--accent) 0 22px,transparent 22px) bottom right/2px 44px no-repeat;
  opacity:.6}
.holo__hud{position:absolute;top:26px;left:30px;font-family:var(--font-ui);font-weight:700;font-size:.78rem;
  letter-spacing:.22em;text-transform:uppercase;color:var(--muted)}
.holo__hud b{color:var(--accent);font-weight:700}
.holo__dims{position:absolute;top:26px;right:30px;font-family:var(--font-ui);font-weight:700;font-size:.78rem;
  letter-spacing:.14em;text-transform:uppercase;color:var(--muted);text-align:right}
.holo__toggle{position:absolute;right:26px;bottom:24px;z-index:6;display:flex;border:1px solid var(--line);background:rgba(5,7,13,.65);backdrop-filter:blur(4px)}
.holo__toggle button{appearance:none;border:0;background:transparent;color:var(--muted);cursor:pointer;
  font-family:var(--font-ui);font-weight:700;font-size:.8rem;letter-spacing:.16em;text-transform:uppercase;padding:.5rem .95rem}
.holo__toggle button[aria-pressed="true"]{background:color-mix(in srgb,var(--accent) 16%,transparent);color:var(--accent)}
.holo__title{position:absolute;left:clamp(18px,3.5vw,46px);bottom:clamp(18px,4vh,40px);z-index:4;
  max-width:min(56%,600px);pointer-events:none;display:flex;flex-direction:column}
.holo__title .sd__maker{margin-bottom:.15rem}
.holo__title h1{font-family:var(--font-display);font-weight:900;font-size:clamp(2rem,4.5vw,3.2rem);line-height:1.02;color:#fff;
  text-shadow:0 2px 26px rgba(0,0,0,.85),0 0 44px rgba(45,212,255,.22)}
.holo__chips{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:.7rem}
.holo__chips span{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;
  color:var(--accent);border:1px solid color-mix(in srgb,var(--accent) 40%,transparent);
  background:rgba(5,7,13,.55);padding:.28rem .6rem}
.holo__src{margin-top:.7rem;display:flex;flex-direction:column;gap:.28rem;
  font-family:var(--font-ui);font-weight:600;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);opacity:.8}
/* Vorbehalt zur Herkunft: gold wie die betroffenen Marker/Chips, damit die Zeile
   und die Callouts im Modell als dieselbe Aussage lesbar sind. */
.holo__caveat{color:var(--gold);opacity:.95;letter-spacing:.08em;text-transform:none;font-size:.74rem;
  padding-left:.5rem;border-left:2px dashed color-mix(in srgb,var(--gold) 55%,transparent)}
.holo__none{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);opacity:.6}
/* Hinweis nur auf der leeren Bilder-Bühne — nie über Video oder 3D-Holo */
.holo__stage.is-video .holo__none,.holo__stage.is-3d .holo__none{display:none}
@media(max-width:900px){
  .holo__panel{top:auto;bottom:52px;right:clamp(10px,3vw,20px);left:auto;width:min(280px,92%)}
  .holo__title{max-width:74%}
}
/* Tablet-Portrait: Hero nicht ganz so wuchtig (steht VOR der 760er-Query,
   damit Handys unten die noch flachere Variante behalten) */
@media(max-width:900px){.holo{height:clamp(430px,62vh,620px)}}
@media(max-width:760px){
  /* Hero auf kleinen Geräten flacher, damit der Inhalt darunter früher sichtbar ist */
  .holo{height:clamp(400px,58vh,560px)}
  /* Holo: 3D-Modell bekommt die obere Zone (Canvas unten einkürzen), damit es
     nicht hinter dem Titel klumpt. Viewer skaliert per ResizeObserver mit. */
  .holo__3d{bottom:44%}
  /* Toggle volle Breite unten (größere Tap-Ziele) */
  .holo__toggle{left:14px;right:14px;bottom:14px}
  .holo__toggle button{flex:1}
  /* Titel kompakt in die freie untere Zone (über dem Toggle); Hersteller weg
     (steht bereits im HUD oben) */
  .holo__title{left:14px;right:14px;max-width:none;bottom:64px}
  .holo__title .sd__maker,.holo__title .sd__makerlogo{display:none}
  .holo__title h1{font-size:1.7rem}
  .holo__chips{gap:.35rem;margin-top:.4rem}
  .holo__chips span{font-size:.66rem;padding:.2rem .48rem}
  .holo__hud{left:16px;top:18px}.holo__dims{display:none}
  /* Ebenen-Panel kompakter + einklappbar (Klasse hieß fälschlich .holo__filters) */
  .holo__layers{top:44px;left:12px;width:min(148px,42vw)}
  .holo__layers-h{font-size:.56rem;padding:.42rem .5rem .42rem;cursor:pointer}
  .holo__layers-chev{display:block}
  .holo__layer{padding:.34rem .5rem;font:700 .66rem/1 var(--font-ui);gap:.4rem}
  .holo__layer-ic{width:15px;height:15px}
  /* zugeklappt: nur der Kopf bleibt sichtbar, gibt das Modell frei */
  .holo__layers.is-collapsed .holo__layer{display:none}
  .holo__layers.is-collapsed .holo__layers-h{border-bottom:0;margin-bottom:0}
  .holo__layers.is-collapsed .holo__layers-chev{transform:rotate(-90deg)}
  .holo__ship{inset:0}
}

/* Kennwerte-Leiste */
.holo__bar{border-bottom:1px solid var(--line);background:var(--bg-2)}
.holo__bar dl{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:0;padding:0 clamp(1rem,3vw,2.5rem)}
.holo__bar .kv{padding:.85rem 1rem .9rem;border-left:1px solid var(--line)}
.holo__bar .kv:first-child{border-left:0}
.holo__bar dt{font-family:var(--font-ui);font-weight:700;font-size:.74rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}
.holo__bar dd{margin:.1rem 0 0;font-family:var(--font-ui);font-weight:700;font-size:1.18rem;font-variant-numeric:tabular-nums;color:var(--text)}
.holo__bar .kv--price dd{color:var(--gold)}
@media(max-width:760px){.holo__bar dl{grid-template-columns:repeat(2,1fr)}.holo__bar .kv{border-left:0;border-top:1px solid var(--line)}}
/* sehr schmal: kompaktere Kennwerte, damit lange aUEC-Werte einzeilig passen */
@media(max-width:560px){.holo__bar .kv{padding:.6rem .7rem .65rem}.holo__bar dd{font-size:1rem}.holo__bar dt{font-size:.68rem;letter-spacing:.12em}}

.sd{max-width:var(--maxw);margin:0 auto;padding:1.8rem clamp(1rem,3vw,2.5rem) 4rem}
.sd__maker{font-family:var(--font-ui);font-weight:700;font-size:.85rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent)}
/* Echtes Hersteller-Logo (game-sourced, weiß-auf-transparent -> sichtbar auf
   dunklem Grund). Höhe fix, Breite proportional; leichter Glow für Trennung. */
/* Höhe treibt die Größe (einheitliche Zeile), Breite proportional; max-width
   nur als Sicherheitsnetz (kein Logo wird bei dieser Höhe so breit). */
.sd__makerlogo{display:block;align-self:flex-start;height:clamp(28px,3.4vw,44px);width:auto;max-width:min(240px,56vw);margin-bottom:.5rem;object-fit:contain;filter:drop-shadow(0 1px 3px rgba(0,0,0,.5))}
/* Volle Marken-Logos (Emblem + Wortmarke) höher, damit der Schriftzug lesbar bleibt */
.sd__makerlogo--full{height:clamp(46px,6vw,72px);max-width:min(340px,70vw)}
.sd__panel{position:relative;background:var(--surface);border:1px solid var(--line);border-top:2px solid var(--accent);
  padding:1.25rem 1.5rem 1.4rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px);
  margin-bottom:1.6rem}
.sd__phead{display:flex;align-items:baseline;justify-content:space-between;gap:1rem;border-bottom:1px solid var(--line);padding-bottom:.55rem;margin-bottom:1rem}
.sd__phead h2{display:flex;align-items:center;font-family:var(--font-ui);font-weight:700;font-size:.95rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent)}
.sd__code{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
/* Mobil: Aktencode-Zeile (…//…) umbrechen statt clippen — voller Text sichtbar */
@media(max-width:640px){.sd__phead{flex-direction:column;align-items:stretch;gap:.35rem}.sd__code{white-space:normal;overflow:visible;text-overflow:clip;overflow-wrap:anywhere;min-width:0}}

/* Handel */
.sd__pricehero{display:flex;flex-wrap:wrap;align-items:baseline;gap:.6rem 1rem;margin-bottom:1rem}
.sd__pricehero .val{font-family:var(--font-ui);font-weight:700;font-size:clamp(1.7rem,4vw,2.4rem);color:var(--gold);font-variant-numeric:tabular-nums}
.sd__pricehero .at{font-size:1rem;color:var(--muted)}
.sd__shoprows{display:flex;flex-direction:column}
.sd__shoprow{display:grid;grid-template-columns:minmax(0,1.3fr) minmax(0,1fr) auto;gap:.3rem 1.2rem;align-items:baseline;
  padding:.5rem 0;border-bottom:1px solid rgba(255,255,255,.06)}
.sd__shoprow:last-child{border-bottom:0}
.sd__shopname{font-family:var(--font-ui);font-weight:700;font-size:.95rem;letter-spacing:.06em;color:var(--text)}
.sd__shopwhere{color:var(--muted);font-size:.95rem}
.sd__shopprice{font-family:var(--font-ui);font-weight:700;font-size:1.05rem;font-variant-numeric:tabular-nums;white-space:nowrap;color:var(--text)}
.sd__more{margin-top:.6rem}
.sd__more summary{cursor:pointer;font-family:var(--font-ui);font-weight:700;font-size:.82rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent)}
.sd__nobuy{color:var(--muted);font-size:1.02rem;margin-bottom:.6rem}
.sd__pledgerow{margin-top:.9rem;padding-top:.8rem;border-top:1px solid var(--line);display:flex;flex-wrap:wrap;gap:.5rem 1.2rem;align-items:baseline}
.sd__pledgerow .p{font-family:var(--font-ui);font-weight:700;font-size:1.05rem;color:var(--text)}
.sd__pledgerow a{color:var(--accent);text-decoration:underline}
.sd__pledgerow a:hover{color:#fff}
.sd__hint{margin-top:.9rem;font-size:.85rem;color:var(--muted)}
@media(max-width:640px){.sd__shoprow{grid-template-columns:1fr auto}.sd__shopwhere{grid-column:1 / -1;margin-top:-.2rem}}

/* Leistungsprofil */
.sd__prof{display:flex;flex-direction:column;gap:.65rem}
.sd__profrow{display:grid;grid-template-columns:150px minmax(0,1fr) auto;gap:.9rem;align-items:center}
.sd__proflabel{font-family:var(--font-ui);font-weight:700;font-size:.82rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.sd__proftrack{position:relative;height:10px;background:rgba(255,255,255,.06);border:1px solid var(--line);overflow:hidden}
.sd__proftrack::after{content:"";position:absolute;left:50%;top:0;bottom:0;width:1px;background:rgba(255,255,255,.14)}
.sd__proffill{height:100%;background:linear-gradient(90deg,color-mix(in srgb,var(--accent) 45%,transparent),var(--accent))}
.sd__profval{font-family:var(--font-ui);font-weight:700;font-size:.98rem;font-variant-numeric:tabular-nums;color:var(--text);white-space:nowrap}
.sd__profval i{font-style:normal;color:var(--muted);font-size:.8rem;margin-left:.45rem}
/* Mobil: Label + Wert in eine Zeile (Label links, Wert rechts), der Balken
   darunter über die volle Breite — so überlappt der Text NIE den Balken und
   längere EN-Labels haben Platz (keine feste, auf DE getunte Label-Spalte). */
@media(max-width:640px){
  .sd__profrow{grid-template-columns:1fr auto;column-gap:.8rem;row-gap:.3rem;align-items:baseline}
  .sd__proflabel{grid-column:1;grid-row:1}
  .sd__profval{grid-column:2;grid-row:1;justify-self:end;margin-top:0}
  .sd__proftrack{grid-column:1 / -1;grid-row:2;margin-top:.15rem}
}

/* Lackierungen */
.sd__paints{display:grid;grid-auto-flow:column;grid-auto-columns:172px;gap:.7rem;overflow-x:auto;padding-bottom:.5rem;
  scrollbar-width:thin;scrollbar-color:var(--accent) transparent}
.sd__paint{border:1px solid var(--line);background:var(--bg-2)}
.sd__paint .im{aspect-ratio:16/10;overflow:hidden;background:#080c16}
.sd__paint img{width:100%;height:100%;object-fit:cover}
.sd__paint .nm{padding:.45rem .6rem;font-family:var(--font-ui);font-weight:700;font-size:.85rem;color:var(--text);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* Varianten & Loaner */
.sd__reflist{display:flex;flex-wrap:wrap;gap:.55rem}
.sd__ref{display:inline-flex;align-items:center;gap:.4rem;border:1px solid var(--line);background:var(--bg-2);
  padding:.42rem .75rem;font-family:var(--font-ui);font-weight:700;font-size:.9rem}
a.sd__ref{transition:border-color .15s,color .15s}
a.sd__ref:hover{border-color:var(--accent);color:var(--accent)}
a.sd__ref::after{content:"→";color:var(--muted)}
a.sd__ref:hover::after{color:var(--accent)}
span.sd__ref{color:var(--muted)}

.sd__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:.7rem 1.4rem;margin:0}
.sd__item{border-left:1px solid var(--line);padding-left:.8rem}
.sd__item dt{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
.sd__item dd{margin:.15rem 0 0;font-weight:500;font-size:1.15rem;line-height:1.35;font-variant-numeric:tabular-nums;color:var(--text)}
.sd__sub{display:flex;align-items:center;font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);
  margin:1.6rem 0 .8rem;padding-bottom:.4rem;border-bottom:1px solid var(--line)}
/* ---------------- Bewaffnung: Hardpoint-Ledger ----------------
   Eine Zeile je Waffenart statt einer Reihe nackter Zahlen. Jede Zeile ist
   für sich lesbar: Stückzahl · Größenklasse (mit maßstäblichem Balken) ·
   Name · Schadensart · Hardpoint-Reserve. Die Größen-Chips bilden eine
   linksbündige Spalte -> das Kaliberprofil ist senkrecht abscanbar. */
.arm__sum{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1px;
  background:var(--line);border:1px solid var(--line);margin-bottom:1.2rem}
.arm__scell{background:var(--bg-2);padding:.6rem .8rem;display:flex;flex-wrap:wrap;align-items:baseline;gap:.05rem .45rem}
.arm__scell b{font-family:var(--font-ui);font-weight:700;font-size:1.5rem;line-height:1.1;color:var(--accent);
  font-variant-numeric:tabular-nums}
.arm__scell span{font-family:var(--font-ui);font-weight:700;font-size:.72rem;letter-spacing:.12em;
  text-transform:uppercase;color:var(--muted)}
.arm__scell i{flex-basis:100%;font-style:normal;font-family:var(--font-ui);font-weight:700;font-size:.76rem;
  letter-spacing:.06em;color:var(--text);opacity:.75;font-variant-numeric:tabular-nums}
.arm__scell--g b{color:var(--gold)}

.arm__list{display:flex;flex-direction:column;gap:1.1rem}
.arm__grp{border-left:2px solid color-mix(in srgb,var(--accent) 55%,transparent);padding-left:.9rem}
.arm__grp--g{border-left-color:color-mix(in srgb,var(--gold) 60%,transparent)}
.arm__ghead{display:flex;flex-wrap:wrap;align-items:baseline;gap:.3rem .7rem;
  padding-bottom:.45rem;border-bottom:1px solid rgba(255,255,255,.07);margin-bottom:.5rem}
.arm__glabel{font-family:var(--font-ui);font-weight:700;font-size:.84rem;letter-spacing:.14em;
  text-transform:uppercase;color:var(--text)}
.arm__gmeta{font-family:var(--font-ui);font-weight:600;font-size:.76rem;letter-spacing:.06em;color:var(--muted)}
.arm__gval{margin-left:auto;font-family:var(--font-ui);font-weight:700;font-size:1rem;color:var(--text);
  font-variant-numeric:tabular-nums;white-space:nowrap}
.arm__grp--g .arm__gval{color:var(--gold)}

.arm__lines{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:.3rem}
.arm__line{display:grid;grid-template-columns:2.6rem 54px minmax(0,1fr) auto;align-items:center;gap:.7rem}
.arm__n{font-family:var(--font-ui);font-weight:700;font-size:1rem;color:var(--text);
  font-variant-numeric:tabular-nums;text-align:right;white-space:nowrap}
.arm__n i{font-style:normal;font-size:.78rem;color:var(--muted);margin-left:.06rem}
/* Größen-Chip: fixe Breite (Spalte bleibt bündig), Füllbalken = Klasse
   maßstäblich (S1 fast leer … S10+ voll) — dieselbe Sprache wie die Gauges */
.arm__size{position:relative;display:grid;place-items:center;height:26px;overflow:hidden;
  border:1px solid color-mix(in srgb,var(--accent) 45%,transparent);background:rgba(255,255,255,.03)}
.arm__size::before{content:"";position:absolute;left:0;top:0;bottom:0;width:calc(100% * min(var(--s,1) / 10, 1));
  background:linear-gradient(90deg,color-mix(in srgb,var(--accent) 22%,transparent),color-mix(in srgb,var(--accent) 48%,transparent))}
.arm__size em{position:relative;font-style:normal;font-family:var(--font-ui);font-weight:700;font-size:.84rem;
  line-height:1;color:var(--accent);font-variant-numeric:tabular-nums}
.arm__size--n{border-style:dashed;border-color:var(--line)}
.arm__size--n em{color:var(--muted)}
.arm__grp--g .arm__size{border-color:color-mix(in srgb,var(--gold) 50%,transparent)}
.arm__grp--g .arm__size::before{background:linear-gradient(90deg,color-mix(in srgb,var(--gold) 20%,transparent),color-mix(in srgb,var(--gold) 45%,transparent))}
.arm__grp--g .arm__size em{color:var(--gold)}
.arm__name{min-width:0;font-size:1rem;color:var(--text)}
.arm__anon{color:var(--muted)}
.arm__bdg{font-family:var(--font-ui);font-weight:700;font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;
  color:var(--muted);white-space:nowrap}
.arm__bdg--up{color:var(--accent);border:1px solid color-mix(in srgb,var(--accent) 40%,transparent);
  background:color-mix(in srgb,var(--accent) 8%,transparent);padding:.14rem .4rem}
.arm__note{margin:.5rem 0 0;font-size:.9rem;color:var(--muted);line-height:1.5}
.arm__note span{font-family:var(--font-ui);font-weight:700;font-size:.68rem;letter-spacing:.1em;
  text-transform:uppercase;margin-right:.4rem}
@media(max-width:640px){
  .arm__line{grid-template-columns:2.2rem 48px minmax(0,1fr);row-gap:.15rem}
  .arm__bdg{grid-column:3;justify-self:start}
  .arm__gval{margin-left:0;flex-basis:100%}
}

.sd__desc{max-width:78ch;margin:0 0 1.6rem;font-size:1.05rem;line-height:1.65;color:var(--text);opacity:.92}
.sd__spine{margin-bottom:1.6rem;border:1px solid var(--line);border-left:3px solid var(--gold);background:var(--bg-2);padding:1rem 1.2rem}
.sd__spine h2{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.5rem}
.sd__spine a{display:block;padding:.3rem 0;font-family:var(--font-ui);font-weight:700;font-size:1rem}
.sd__spine a:hover{color:var(--gold);text-decoration:underline}
.sd__spine span{color:var(--muted);font-weight:600}

.sd__simgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.8rem}
.sd__sim{border:1px solid var(--line);background:var(--surface);transition:border-color .15s,background .15s;display:flex;flex-direction:column}
.sd__sim:hover{border-color:color-mix(in srgb,var(--accent) 55%,transparent);background:var(--surface-2)}
.sd__sim .im{aspect-ratio:16/9;background:#080c16;display:grid;place-items:center;overflow:hidden}
.sd__sim .im img{width:100%;height:100%;object-fit:cover}
.sd__sim .im span{font-family:var(--font-ui);font-weight:700;letter-spacing:.2em;color:var(--muted);font-size:.72rem}
.sd__sim .tx{padding:.6rem .8rem .7rem}
.sd__sim .nm{font-family:var(--font-ui);font-weight:700;font-size:1rem;color:var(--text)}
.sd__sim .mt{font-size:.85rem;color:var(--muted)}

.sd__links{display:flex;flex-wrap:wrap;gap:.7rem;margin-top:1.6rem}
.sd__links a{font-family:var(--font-ui);font-weight:700;font-size:.85rem;letter-spacing:.1em;text-transform:uppercase;
  border:1px solid var(--line);padding:.45rem .9rem;transition:border-color .15s,color .15s}
.sd__links a:hover{border-color:var(--accent);color:var(--accent)}
.sd__src{margin-top:1.4rem;font-size:.85rem;color:var(--muted)}
.sd__src a{text-decoration:underline}
.sd__src a:hover{color:var(--accent)}

/* Gauges (generisch, katalog-relativ) */
.sd__g{display:flex;flex-direction:column;gap:.55rem}
.sd__grow{display:grid;grid-template-columns:150px minmax(0,1fr) auto;gap:.9rem;align-items:center}
.sd__glabel{font-family:var(--font-ui);font-weight:700;font-size:.8rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.sd__gtrack{position:relative;height:9px;background:rgba(255,255,255,.06);border:1px solid var(--line);overflow:hidden}
.sd__gtrack::after{content:"";position:absolute;left:50%;top:0;bottom:0;width:1px;background:rgba(255,255,255,.14)}
.sd__gfill{height:100%;background:linear-gradient(90deg,color-mix(in srgb,var(--accent) 45%,transparent),var(--accent))}
.sd__gval{font-family:var(--font-ui);font-weight:700;font-size:.95rem;font-variant-numeric:tabular-nums;color:var(--text);white-space:nowrap}
@media(max-width:640px){
  .sd__grow{grid-template-columns:1fr auto;column-gap:.8rem;row-gap:.3rem;align-items:baseline}
  .sd__glabel{grid-column:1;grid-row:1}
  .sd__gval{grid-column:2;grid-row:1;justify-self:end;margin-top:0}
  .sd__gtrack{grid-column:1 / -1;grid-row:2;margin-top:.15rem}
}

/* Maße & Fracht */
.sd__dims{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(0,1fr);gap:1.6rem}
@media(max-width:760px){.sd__dims{grid-template-columns:1fr}}
.sd__footbox{border:1px dashed color-mix(in srgb,var(--accent) 55%,transparent);background:color-mix(in srgb,var(--accent) 6%,transparent);
  min-width:56px;max-width:100%;margin:.5rem 0 .45rem;position:relative}
.sd__footbox::after{content:"";position:absolute;left:12%;right:12%;top:50%;height:1px;background:color-mix(in srgb,var(--accent) 35%,transparent)}
.sd__footcap{font-size:.85rem;color:var(--muted)}
.sd__cargonum{font-family:var(--font-ui);font-weight:700;font-size:1.7rem;color:var(--gold);font-variant-numeric:tabular-nums}
.sd__cubes{display:flex;flex-wrap:wrap;gap:4px;margin:.55rem 0 .35rem}
.sd__cube{width:15px;height:15px;background:color-mix(in srgb,var(--gold) 30%,transparent);border:1px solid color-mix(in srgb,var(--gold) 75%,transparent)}

/* Hardpoint-Slots (Komponenten-Abschnitt) */
.sd__hp{display:inline-grid;place-items:center;height:24px;min-width:calc(15px + var(--hs,1)*4px);padding:0 .3rem;
  border:1px solid var(--accent);background:color-mix(in srgb,var(--accent) 10%,transparent);color:var(--accent);
  font-family:var(--font-ui);font-weight:700;font-size:.78rem;line-height:1}
.sd__hpmore{font-family:var(--font-ui);font-weight:700;font-size:.8rem;color:var(--muted);align-self:center}
.sd__hprow{display:flex;flex-wrap:wrap;gap:6px;align-items:center}

/* Komponenten-Slots */
.sd__slots{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.7rem}
.sd__slot{border:1px solid var(--line);background:var(--bg-2);padding:.6rem .8rem}
.sd__slot .t{font-family:var(--font-ui);font-weight:700;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
.sd__slot .n{font-family:var(--font-ui);font-weight:700;font-size:1.02rem;color:var(--text);margin:.15rem 0 .3rem}

/* Quantum-Chips */
.sd__qgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.7rem 1.4rem}

/* Versicherung */
.sd__inscards{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.7rem}
.sd__ins{border:1px solid var(--line);background:var(--bg-2);padding:.7rem .9rem}
.sd__ins .t{font-family:var(--font-ui);font-weight:700;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
.sd__ins .v{font-family:var(--font-ui);font-weight:700;font-size:1.35rem;font-variant-numeric:tabular-nums;color:var(--text);margin-top:.15rem}
.sd__ins--gold .v{color:var(--gold)}

/* System-Chips (Kauforte) */
.sd__sys{display:inline-block;font-family:var(--font-ui);font-weight:700;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;
  border:1px solid rgba(110,168,255,.4);color:var(--accent-2);padding:.1rem .4rem;margin-left:.5rem;vertical-align:1px}
.sd__sys.sys-pyro{border-color:rgba(255,138,80,.45);color:#ff8a50}
.sd__sys.sys-nyx{border-color:rgba(192,154,255,.45);color:#c09aff}

/* Favoriten-Stern (Konto-Feature; /assets/account-lite.js toggelt .is-fav) */
.holo__fav{margin-top:.7rem}
.favbtn{display:inline-flex;align-items:center;gap:.45rem;background:rgba(0,0,0,.35);border:1px solid var(--line);color:var(--muted);
  font-family:var(--font-ui);font-weight:700;font-size:.76rem;letter-spacing:.1em;text-transform:uppercase;padding:.42rem .85rem;cursor:pointer;
  transition:color .15s,border-color .15s,background-color .15s}
.favbtn:hover{color:var(--accent);border-color:var(--accent);background:color-mix(in srgb,var(--accent) 7%,transparent)}
.favbtn.is-fav{color:var(--accent-2);border-color:color-mix(in srgb,var(--accent-2) 60%,transparent);background:color-mix(in srgb,var(--accent-2) 10%,transparent)}
.favbtn.is-fav .favbtn__star path{fill:currentColor}
</style>

<SiteNav
  crumbs={[
    { label: t('crumbs.archive'), href: L('/index.html') },
    { label: t('crumbs.ships'), href: L('/schiffe.html') },
    { label: d.name },
  ]}
  hasEn={hasEn}
/>

<main>
  <!-- HANGAR-BÜHNE: Info links, interaktives Komponenten-Hologramm rechts -->
  <section class="holo" id="holo" aria-label={`${d.name} — Visual`}>
    <div class="holo__grid" aria-hidden="true"></div>
    <div class="holo__pad" aria-hidden="true"></div>
    <div class="holo__frame" aria-hidden="true"></div>
    <div class="holo__hud">{t('ship.code.hangar')}&nbsp;//&nbsp;<b>{d.manufacturer ?? d.makerCode ?? t('ship.code.ship')}</b></div>
    {dims && <div class="holo__dims">{dims}</div>}
    <div class="holo__wrap">
      <header class="holo__title">
        {makerLogo ? (
          <img
            class:list={['sd__makerlogo', makerLogo.full && 'sd__makerlogo--full']}
            src={`/assets/manufacturers/${makerLogo.file}`}
            alt={d.manufacturer}
            width={makerLogo.w}
            height={makerLogo.h}
            loading="eager"
            decoding="async"
          />
        ) : (
          d.manufacturer && <div class="sd__maker">{d.manufacturer}</div>
        )}
        <h1>{d.name}</h1>
        <div class="holo__chips">
          {vRole(d, lang) && <span>{vRole(d, lang)}</span>}
          {vSize(d, lang) && <span>{vSize(d, lang)}</span>}
          {vStatus(d, lang) && <span>{vStatus(d, lang)}</span>}
        </div>
        <div class="holo__fav">
          <button
            type="button"
            class="favbtn"
            data-fav
            data-fav-kind="ship"
            data-fav-slug={id}
            data-fav-label={d.name}
            data-fav-on={t('fav.saved')}
            data-fav-off={t('fav.save')}
            aria-pressed="false"
            aria-label={t('fav.aria')}
            title={t('fav.aria')}
          >
            <svg class="favbtn__star" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path d="M12 2.5l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6L12 18.6 6.1 21.3l1.2-6.6L2.5 9.5l6.6-.9z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
            <span class="js-fav-txt">{t('fav.save')}</span>
          </button>
        </div>
        {holoData && holoData.ports.length > 0 && (
          <div class="holo__src">
            <span class={holoAllNp ? 'holo__caveat' : undefined}>{holoAllNp ? t('holo.src.none' as any) : t('holo.src')}</span>
            {holoNp > 0 && !holoAllNp && <span class="holo__caveat">{t('holo.legend.np' as any)}</span>}
            {holoEst && <span class="holo__caveat">{t('holo.legend.est' as any)}</span>}
          </div>
        )}
      </header>
      <div
        class={`holo__stage${defaultMode === 'video' ? ' is-video' : ''}`}
        id="holostage"
        data-default={defaultMode}
        data-holo-src={holoViewerSrc}
        data-loading={t('ship.holo.loading')}
        data-error={t('ship.holo.error')}
        data-novisual={t('ship.novisual')}
      >
        <figure class="holo__ship" id="shipfig">
          {hasGallery ? (
            gallery.map((g, i) => (
              <img
                src={i === 0 ? g.src : undefined}
                data-src={i === 0 ? undefined : g.src}
                data-fb={g.fb}
                class={i === 0 ? 'is-active' : undefined}
                alt={g.paint ? altPaint(g.paint) : altView}
                referrerpolicy="no-referrer"
                onerror="if(this.dataset.fb){this.src=this.dataset.fb;this.removeAttribute('data-fb')}else{this.dataset.bad='1';this.style.display='none'}"
              />
            ))
          ) : (
            <span class="holo__none">{t('ship.novisual')}</span>
          )}
        </figure>
        {videoId && (
          <div class="holo__video" id="holovideo" data-vid={videoId}>
            {/* Schneller Videostart: Verbindungen zu den YouTube-Hosts schon
                beim Parsen aufbauen und die IFrame-API parallel zum Seiten-
                aufbau laden — loadYT() findet das Script per id und wartet
                nur noch auf ready, statt die Ladekette seriell zu starten */}
            <link rel="preconnect" href="https://www.youtube.com" />
            <link rel="preconnect" href="https://www.youtube-nocookie.com" />
            <link rel="preconnect" href="https://i.ytimg.com" />
            <script is:inline id="yt-iframe-api" src="https://www.youtube.com/iframe_api" async></script>
            {/* Poster IMMER rendern (ohne Galerie-Bild dunkel) — es verdeckt
                YouTubes Start-Chrome; fehlte es (Schiffe ohne Bilder, z. B.
                Basher), blitzte die Player-UI beim Start nackt durch */}
            <span class="holo__videoposter" style={gallery[0] ? `background-image:url('${gallery[0].src}')` : undefined} aria-hidden="true"></span>
            <div class="holo__playertarget" id="holoplayer"></div>
            <span class="holo__videoshield" id="holovideoshield" aria-hidden="true"></span>
          </div>
        )}
        {gallery.length > 1 && (
          <div class="holo__dots" id="holodots" aria-hidden="true">
            {gallery.map((_, i) => <i class={i === 0 ? 'on' : undefined}></i>)}
          </div>
        )}
        <div class="holo__3d" id="holo3d" aria-label={t('ship.holo.drag')}></div>
        <div class="holo__status" id="holostatus" role="status"></div>
        {(holoData || holoUrl) && <button type="button" class="holo__activate" id="holoact" hidden>{t('holo.activate')}</button>}
        <div class="holo__hintline" aria-hidden="true">{t('holo.hint')}</div>
        {holoData && (holoData.groups.length > 1 || holoData.ports.some((p) => p.lab)) && (
          <div class="holo__layers" id="holofilters" role="group" aria-label={t('holo.filter.aria')} hidden>
            <button type="button" class="holo__layers-h" id="holo-layers-toggle" aria-expanded="true">
              <span>{t('holo.layers.title')}</span>
              <svg class="holo__layers-chev" viewBox="0 0 24 24" aria-hidden="true"><polyline points="6 9 12 15 18 9" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            {holoData.groups.length > 1 && holoData.groups.map((gr) => (
              <button type="button" class="holo__layer" data-g={gr} aria-pressed={String(holoData!.defaultOn.includes(gr))}>
                <svg class="holo__layer-ic" viewBox="0 0 24 24" aria-hidden="true"><path d={HOLO_GRP_ICON[gr]} /></svg>
                <span class="holo__layer-lb">{t(`holo.grp.${gr}` as any)}</span>
                <span class="holo__layer-ct">{holoData!.ports.filter((p) => p.g === gr).length}</span>
              </button>
            ))}
            {holoData.ports.some((p) => p.lab) && (
              <button type="button" class="holo__layer holo__layer--lab" id="holoblabels" aria-pressed="true" title={t('holo.labels.toggle')}>
                <svg class="holo__layer-eye" viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.6-7 10-7 10 7 10 7-3.6 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
                <span class="holo__layer-lb">{t('holo.labels.short')}</span>
              </button>
            )}
          </div>
        )}
        <aside class="holo__panel" id="holopanel" hidden data-np={t('holo.panel.notPhys')} data-est={t('holo.panel.estimated')} data-auec={t('holo.panel.auec')}>
          <div class="hp__head">
            <span class="hp__eyebrow" id="hpgrp"></span>
            <button type="button" class="hp__x" id="holopclose" aria-label={t('holo.panel.close')}>×</button>
            <div class="hp__title">
              <svg class="hp__icon" id="hpicon" viewBox="0 0 24 24" aria-hidden="true"><path /></svg>
              <div class="hp__kind" id="hpkind"></div>
            </div>
            <div class="hp__name" id="hpname"></div>
          </div>
          <dl>
            <div><dt>{t('holo.panel.size')}</dt><dd id="hpsize"></dd></div>
            <div class="hp__row" id="hpcatrow" hidden><dt>{t('holo.panel.cat')}</dt><dd id="hpcat"></dd></div>
            <div class="hp__row" id="hppricerow" hidden><dt>{t('holo.panel.price')}</dt><dd class="hp__price" id="hpprice"></dd></div>
            <div class="hp__row" id="hpshopsrow" hidden><dt>{t('holo.panel.shops')}</dt><dd id="hpshops"></dd></div>
          </dl>
          <a class="hp__link" id="hplink" hidden><span>{t('holo.panel.finder')}</span></a>
          <p class="hp__note" id="hpnote" hidden></p>
        </aside>
      </div>
    </div>
    {stageModeCount > 1 && (
      <div class="holo__toggle" role="group" aria-label={t('ship.view.switch')}>
        {videoId && <button type="button" id="btnvid" aria-pressed={String(defaultMode === 'video')}>{t('ship.view.video')}</button>}
        {hasGallery && <button type="button" id="btnimg" aria-pressed={String(defaultMode === 'img')}>{t('ship.view.img')}</button>}
        {holoAvail && <button type="button" id="btn3d" aria-pressed={String(defaultMode === 'holo')}>{t('ship.view.3d')}</button>}
      </div>
    )}
  </section>
  {(holoData || holoUrl) && (
    <script
      type="application/json"
      id="holodata"
      is:inline
      set:html={JSON.stringify(
        holoData ?? { url: holoUrl, mesh: null, ax: null, ports: [], groups: [], defaultOn: [], kinds: {}, grpLabels: {}, icons: {}, loc, finder: L('/item-finder.html') }
      ).replace(/</g, '\\u003c')}
    />
  )}

  <!-- Kennwerte -->
  <div class="holo__bar">
    <dl>
      {stageStats.map((s, i) => (
        <div class={`kv${i === stageStats.length - 1 ? ' kv--price' : ''}`}>
          <dt>{s.label}</dt>
          <dd>{s.value}</dd>
        </div>
      ))}
    </dl>
  </div>

  <div class="sd">
    <!-- KAUFEN IM VERSE -->
    <section class="sd__panel" aria-label={t('ship.buy.title')}>
      <header class="sd__phead">
        <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.handel} /></svg>{t('ship.buy.title')}</h2>
        <span class="sd__code">{t('ship.code.trade')}&nbsp;//&nbsp;UEX · {t('ship.asof')} {pricesFetchedAt}</span>
      </header>
      {buyMin ? (
        <>
          <div class="sd__pricehero">
            <span class="val">{aUEC(buyMin.price)}</span>
            <span class="at">{t('ship.buy.cheapest')} {buyMin.shop}, {buyMin.where}{buyMin.system && ` · ${buyMin.system}`}</span>
          </div>
          <div class="sd__shoprows">
            {prices!.buy.slice(0, MAX_ROWS).map((b) => (
              <div class="sd__shoprow">
                <span class="sd__shopname">{b.shop}</span>
                <span class="sd__shopwhere">{b.where}{b.system && <span class={`sd__sys sys-${b.system.toLowerCase()}`}>{b.system}</span>}</span>
                <span class="sd__shopprice">{aUEC(b.price)}</span>
              </div>
            ))}
          </div>
          {prices!.buy.length > MAX_ROWS && (
            <details class="sd__more">
              <summary>+{prices!.buy.length - MAX_ROWS} {t('ship.buy.more')}</summary>
              <div class="sd__shoprows">
                {prices!.buy.slice(MAX_ROWS).map((b) => (
                  <div class="sd__shoprow">
                    <span class="sd__shopname">{b.shop}</span>
                    <span class="sd__shopwhere">{b.where}{b.system && <span class={`sd__sys sys-${b.system.toLowerCase()}`}>{b.system}</span>}</span>
                    <span class="sd__shopprice">{aUEC(b.price)}</span>
                  </div>
                ))}
              </div>
            </details>
          )}
        </>
      ) : (
        <p class="sd__nobuy">{t('ship.buy.none')}</p>
      )}
      {rentMin && (
        <>
          <h3 class="sd__sub">{t('ship.rent.title')}</h3>
          <div class="sd__shoprows">
            {prices!.rent.slice(0, 4).map((r) => (
              <div class="sd__shoprow">
                <span class="sd__shopname">{r.shop}</span>
                <span class="sd__shopwhere">{r.where}{r.system && <span class={`sd__sys sys-${r.system.toLowerCase()}`}>{r.system}</span>}</span>
                <span class="sd__shopprice">{aUEC(r.price)} {t('ship.rent.perDay')}</span>
              </div>
            ))}
          </div>
        </>
      )}
      {d.msrpUSD != null && (
        <div class="sd__pledgerow">
          <span class="p">{t('ship.pledge')} ${d.msrpUSD.toLocaleString('en-US')}</span>
          {d.pledgeUrl && <a href={d.pledgeUrl} target="_blank" rel="noopener">{t('ship.pledge.store')}</a>}
        </div>
      )}
      <p class="sd__hint">{t('ship.buy.hint')}</p>
    </section>

    <!-- LEISTUNGSPROFIL -->
    {profile.length > 0 && (
      <section class="sd__panel" aria-label={t('ship.profile.title')}>
        <header class="sd__phead">
          <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.profil} /></svg>{t('ship.profile.title')}</h2>
          <span class="sd__code">{t('ship.code.rank')}&nbsp;//&nbsp;{t('ship.profile.rank')} ({vehiclesSnapshot.count} {t('ship.unit.ships')})</span>
        </header>
        <div class="sd__prof">
          {profile.map((p) => (
            <div class="sd__profrow">
              <span class="sd__proflabel">{p.label}</span>
              <div class="sd__proftrack" role="img" aria-label={`${p.label}: ${p.value}, ${t('ship.profile.percentile')} ${p.pct}`}>
                <div class="sd__proffill" style={`width:${p.pct}%`}></div>
              </div>
              <span class="sd__profval">{p.value}<i>P{p.pct}</i></span>
            </div>
          ))}
        </div>
        <p class="sd__hint">{t('ship.profile.hint')}</p>
      </section>
    )}

    {desc && <p class="sd__desc">{desc}</p>}

    <!-- DATENBLATT -->
    <section class="sd__panel" aria-label={t('ship.sheet.title')}>
      <header class="sd__phead">
        <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.datenblatt} /></svg>{t('ship.sheet.title')}</h2>
        <span class="sd__code">{t('ship.code.dat')}&nbsp;//&nbsp;{shipCode} · {t('ship.asof')} {vehiclesSnapshot.fetchedAt}</span>
      </header>
      <dl class="sd__grid">
        {facts.map((f) => (
          <div class="sd__item">
            <dt>{f.label}</dt>
            <dd>{f.value}</dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- MASSE & FRACHT -->
    {(viz.dims || viz.cargo || viz.fuel.length > 0) && (
      <section class="sd__panel" aria-label={t('ship.dims.title')}>
        <header class="sd__phead">
          <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.masse} /></svg>{t('ship.dims.title')}</h2>
          <span class="sd__code">{t('ship.code.space')}&nbsp;//&nbsp;{shipCode}</span>
        </header>
        <div class="sd__dims">
          <div>
            {viz.dims && (
              <>
                <div class="sd__glabel">{t('ship.dims.top')}</div>
                <div class="sd__footbox" style={`width:${viz.dims.footWidthPct}%;aspect-ratio:${viz.dims.footAspect}`} role="img"
                  aria-label={t('ship.dims.aria').replace('%l%', String(viz.dims.l)).replace('%w%', String(viz.dims.w))}></div>
                <div class="sd__footcap">{t('ship.abbr.l')} {viz.dims.l.toLocaleString(loc)} m · {t('ship.abbr.w')} {viz.dims.w.toLocaleString(loc)} m · {t('ship.abbr.h')} {viz.dims.h.toLocaleString(loc)} m</div>
                <div class="sd__g" style="margin-top:.9rem">
                  {viz.dims.bars.map((b) => (
                    <div class="sd__grow">
                      <span class="sd__glabel">{b.label}</span>
                      <div class="sd__gtrack"><div class="sd__gfill" style={`width:${b.pct}%`}></div></div>
                      <span class="sd__gval">{b.value}</span>
                    </div>
                  ))}
                </div>
              </>
            )}
          </div>
          <div>
            {viz.cargo && (
              <>
                <div class="sd__glabel">{t('ship.dims.cargo')}</div>
                <div class="sd__cargonum">{viz.cargo.scu.toLocaleString(loc)} SCU</div>
                <div class="sd__cubes">
                  {Array.from({ length: viz.cargo.cubes }).map(() => <span class="sd__cube"></span>)}
                </div>
                <div class="sd__footcap">■ = {viz.cargo.cubeVal} SCU{viz.cargo.ore && ` · ${t('ship.dims.oreExtra')}: ${viz.cargo.ore.toLocaleString(loc)} SCU`}</div>
              </>
            )}
            {viz.fuel.length > 0 && (
              <div class="sd__g" style={viz.cargo ? 'margin-top:1.2rem' : ''}>
                {viz.fuel.map((b) => (
                  <div class="sd__grow">
                    <span class="sd__glabel">{b.label}</span>
                    <div class="sd__gtrack"><div class="sd__gfill" style={`width:${b.pct}%`}></div></div>
                    <span class="sd__gval">{b.value}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- BEWAFFNUNG -->
    {(armament.length > 0 || viz.firepower.length > 0) && (
      <section class="sd__panel" aria-label={t('ship.arms.title')}>
        <header class="sd__phead">
          <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.bewaffnung} /></svg>{t('ship.arms.title')}</h2>
          <span class="sd__code">{t('ship.code.arsenal')}&nbsp;//&nbsp;{shipCode}</span>
        </header>
        {viz.firepower.length > 0 && (
          <div class="sd__g" style="margin-bottom:1.1rem">
            {viz.firepower.map((b) => (
              <div class="sd__grow">
                <span class="sd__glabel">{b.label}</span>
                <div class="sd__gtrack"><div class="sd__gfill" style={`width:${b.pct}%`}></div></div>
                <span class="sd__gval">{b.value}</span>
              </div>
            ))}
          </div>
        )}
        {armStats.length > 0 && (
          <div class="arm__sum">
            {armStats.map((s) => (
              <div class={`arm__scell${s.gold ? ' arm__scell--g' : ''}`}>
                <b>{s.n}</b>
                <span>{s.label}</span>
                {s.range && <i>{s.range}</i>}
              </div>
            ))}
          </div>
        )}
        <div class="arm__list">
          {armament.map((r) => (
            <div class={`arm__grp${r.gold ? ' arm__grp--g' : ''}`}>
              <div class="arm__ghead">
                <span class="arm__glabel">{r.label}</span>
                {r.meta && <span class="arm__gmeta">{r.meta}</span>}
                {r.value && <span class="arm__gval">{r.value}</span>}
              </div>
              {r.lines.length > 0 && (
                <ul class="arm__lines">
                  {r.lines.map((l) => (
                    <li class="arm__line">
                      <span class="arm__n">{l.count}<i>×</i></span>
                      {l.size != null ? (
                        <span class="arm__size" style={`--s:${l.size}`}
                              title={`${t('arm.sizeTip')} ${l.size}`}>
                          <em>S{l.size}</em>
                        </span>
                      ) : (
                        <span class="arm__size arm__size--n"><em>?</em></span>
                      )}
                      <span class="arm__name">
                        {l.name ?? <span class="arm__anon">{t('arm.weapon')}</span>}
                      </span>
                      {l.mount != null && l.size != null && (
                        l.mount > l.size ? (
                          <span class="arm__bdg arm__bdg--up"
                                title={`${t('arm.mountTip')} S${l.mount} · ${t('arm.fittedTip')} S${l.size}`}>
                            {t('arm.upgrade')} S{l.mount}
                          </span>
                        ) : (
                          <span class="arm__bdg" title={`${t('arm.mountTip')} S${l.mount} · ${t('arm.fittedTip')} S${l.size}`}>
                            {t('arm.maxed')}
                          </span>
                        )
                      )}
                    </li>
                  ))}
                </ul>
              )}
              {r.note && (
                <p class="arm__note"><span>{t('arm.loadout')}</span>{r.note}</p>
              )}
            </div>
          ))}
        </div>
        <p class="sd__hint">{t('ship.arms.hint')}</p>
      </section>
    )}

    <!-- FLUGLEISTUNG & QUANTUM -->
    {(viz.speeds.length > 0 || viz.agility.length > 0 || viz.quantum.length > 0) && (
      <section class="sd__panel" aria-label={t('ship.flight.title')}>
        <header class="sd__phead">
          <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.flug} /></svg>{t('ship.flight.title')}</h2>
          <span class="sd__code">{t('ship.code.drive')}&nbsp;//&nbsp;{shipCode}</span>
        </header>
        {viz.speeds.length > 0 && (
          <div class="sd__g">
            {viz.speeds.map((b) => (
              <div class="sd__grow">
                <span class="sd__glabel">{b.label}</span>
                <div class="sd__gtrack"><div class="sd__gfill" style={`width:${b.pct}%`}></div></div>
                <span class="sd__gval">{b.value}</span>
              </div>
            ))}
          </div>
        )}
        {viz.agility.length > 0 && (
          <>
            <h3 class="sd__sub">{t('ship.flight.agility')}</h3>
            <div class="sd__g">
              {viz.agility.map((b) => (
                <div class="sd__grow">
                  <span class="sd__glabel">{b.label}</span>
                  <div class="sd__gtrack"><div class="sd__gfill" style={`width:${b.pct}%`}></div></div>
                  <span class="sd__gval">{b.value}</span>
                </div>
              ))}
            </div>
          </>
        )}
        {viz.quantum.length > 0 && (
          <>
            <h3 class="sd__sub"><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.quantum} /></svg>{t('ship.flight.quantum')}</h3>
            <dl class="sd__qgrid">
              {viz.quantum.map((q) => (
                <div class="sd__item">
                  <dt>{q.label}</dt>
                  <dd>{q.value}</dd>
                </div>
              ))}
            </dl>
          </>
        )}
      </section>
    )}

    <!-- KOMPONENTEN & VERTEIDIGUNG -->
    {(viz.defense.length > 0 || slots.length > 0) && (
      <section class="sd__panel" aria-label={t('ship.comp.title')}>
        <header class="sd__phead">
          <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.kern} /></svg>{t('ship.comp.title')}</h2>
          <span class="sd__code">{t('ship.code.works')}&nbsp;//&nbsp;{shipCode}</span>
        </header>
        {viz.defense.length > 0 && (
          <div class="sd__g" style={slots.length > 0 ? 'margin-bottom:1.1rem' : ''}>
            {viz.defense.map((b) => (
              <div class="sd__grow">
                <span class="sd__glabel">{b.label}</span>
                <div class="sd__gtrack"><div class="sd__gfill" style={`width:${b.pct}%`}></div></div>
                <span class="sd__gval">{b.value}</span>
              </div>
            ))}
          </div>
        )}
        {slots.length > 0 && (
          <div class="sd__slots">
            {slots.map(([label, items]) =>
              items.map((it) => (
                <div class="sd__slot">
                  <div class="t">{label}</div>
                  <div class="n">{it.name}</div>
                  <span class="sd__hprow">
                    {it.size != null && <i class="sd__hp" style={`--hs:${it.size}`}>{it.size}</i>}
                    {it.count > 1 && <span class="sd__hpmore">×{it.count}</span>}
                  </span>
                </div>
              ))
            )}
          </div>
        )}
      </section>
    )}

    <!-- VERSICHERUNG -->
    {viz.insurance.length > 0 && (
      <section class="sd__panel" aria-label={t('ship.ins.title')}>
        <header class="sd__phead">
          <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.versicherung} /></svg>{t('ship.ins.title')}</h2>
          <span class="sd__code">{t('ship.code.protect')}&nbsp;//&nbsp;{t('ship.code.uee')}</span>
        </header>
        <div class="sd__inscards">
          {viz.insurance.map((i) => (
            <div class={`sd__ins${i.gold ? ' sd__ins--gold' : ''}`}>
              <div class="t">{i.label}</div>
              <div class="v">{i.value}</div>
            </div>
          ))}
        </div>
        <p class="sd__hint">{t('ship.ins.hint')}</p>
      </section>
    )}

    <!-- LACKIERUNGEN -->
    {paints.length > 0 && (
      <section class="sd__panel" aria-label={t('ship.paints.title')}>
        <header class="sd__phead">
          <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.paints} /></svg>{t('ship.paints.title')}</h2>
          <span class="sd__code">{t('ship.code.skins')}&nbsp;//&nbsp;{paints.length} · FleetYards · {t('ship.asof')} {extrasFetchedAt}</span>
        </header>
        <div class="sd__paints">
          {paints.map((p) => (
            <figure class="sd__paint">
              <div class="im">
                <img src={p.image} alt={altPaint(p.name)} loading="lazy" referrerpolicy="no-referrer"
                  onerror="this.closest('figure').style.display='none'" />
              </div>
              <figcaption class="nm">{p.name}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    <!-- VARIANTEN & LOANER -->
    {(variants.length > 0 || loaners.length > 0) && (
      <section class="sd__panel" aria-label={t('ship.series.title')}>
        <header class="sd__phead">
          <h2><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.varianten} /></svg>{t('ship.series.title')}</h2>
          <span class="sd__code">{t('ship.code.series')}&nbsp;//&nbsp;FleetYards · {t('ship.asof')} {extrasFetchedAt}</span>
        </header>
        {variants.length > 0 && (
          <>
            <h3 class="sd__sub">{t('ship.series.variants')}</h3>
            <div class="sd__reflist">
              {variants.map((v) =>
                v.id ? <a class="sd__ref" href={L(`/schiffe/${v.id}.html`)}>{v.name}</a> : <span class="sd__ref">{v.name}</span>
              )}
            </div>
          </>
        )}
        {loaners.length > 0 && (
          <>
            <h3 class="sd__sub">{t('ship.series.loaners')}</h3>
            <div class="sd__reflist">
              {loaners.map((v) =>
                v.id ? <a class="sd__ref" href={L(`/schiffe/${v.id}.html`)}>{v.name}</a> : <span class="sd__ref">{v.name}</span>
              )}
            </div>
          </>
        )}
      </section>
    )}

    {spine.length > 0 && (
      <section class="sd__spine" aria-label={t('ship.spine.title')}>
        <h2>{t('ship.spine.title')}</h2>
        {spine.map((p) => (
          <a href={L(`/patches/sc-${p!.id}.html`)}>
            Alpha {p!.data.version} — {p!.data.codename} <span>· {p!.data.dateDisplay} →</span>
          </a>
        ))}
      </section>
    )}

    {similar.length > 0 && (
      <section aria-label={t('ship.similar.title')}>
        <h3 class="sd__sub"><svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d={IC.aehnlich} /></svg>{t('ship.similar.title')}</h3>
        <div class="sd__simgrid">
          {similar.map((s) => (
            <a class="sd__sim" href={L(`/schiffe/${s.id}.html`)}>
              <div class="im">
                {s.thumb ? <img src={s.thumb} alt={s.name} loading="lazy" referrerpolicy="no-referrer" /> : <span>{t('ship.similar.noimg')}</span>}
              </div>
              <div class="tx">
                <div class="nm">{s.name}</div>
                <div class="mt">{s.meta}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="sd__links">
      <a href={L('/schiffe.html')}>{t('ship.links.all')}</a>
      {d.pledgeUrl && <a href={d.pledgeUrl} target="_blank" rel="noopener">{t('ship.pledge.store')}</a>}
      {extras?.fySlug && <a href={`https://www.fleetyards.net/ships/${extras.fySlug}`} target="_blank" rel="noopener">FleetYards ↗</a>}
    </div>

    <p class="sd__src">
      {t('ship.source')} <a href="https://api.star-citizen.wiki" target="_blank" rel="noopener">Star Citizen Wiki API</a>
      ({t('ship.source.wikiNote')}) · {t('ship.asof')} {vehiclesSnapshot.fetchedAt}
      {d.gameVersion && ` · ${t('ship.source.gameData')} ${d.gameVersion.split('-')[0]}`}
      {hero?.api && ` · ${t('ship.source.image')}: ${d.image?.source ?? 'starcitizen.tools'}`}
      {' '}· {t('ship.source.ingame')}: <a href="https://uexcorp.space" target="_blank" rel="noopener">UEX Corp</a> · {t('ship.asof')} {pricesFetchedAt}
      {extras && ` · ${t('ship.source.extras')}: `}{extras && <a href="https://fleetyards.net" target="_blank" rel="noopener">FleetYards.net</a>}
    </p>
  </div>
</main>

<script type="importmap" is:inline>
{"imports":{"three":"/vendor/three/three.module.min.js","three/addons/":"/vendor/three/addons/"}}
</script>
<script is:inline>
// Kopf-Bühne mit drei Modi: Video (kuratiertes Commercial, YouTube on demand),
// Bilder (langsame Crossfade-Slideshow aus Hero + Paints) und Holo (3D-
// Komponenten-Hologramm, lazy). Der Umschalter unten rechts wählt den Modus;
// das Holo lädt erst bei Klick auf "3D-Holo" (bzw. wenn es der einzige Modus ist).
(function () {
  var stage = document.getElementById('holostage');
  if (!stage) return;
  var holoSec = document.getElementById('holo');
  var fig = document.getElementById('shipfig');
  var btnVid = document.getElementById('btnvid');
  var btnImg = document.getElementById('btnimg');
  var btn3d = document.getElementById('btn3d');
  var videoBox = document.getElementById('holovideo');
  var videoPoster = videoBox ? videoBox.querySelector('.holo__videoposter') : null;
  var dots = document.getElementById('holodots');
  var status = document.getElementById('holostatus');
  var slides = fig ? [].slice.call(fig.querySelectorAll('img')) : [];
  var defaultMode = stage.getAttribute('data-default') || 'img';
  var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  var mode = defaultMode;
  var viewer = null, loading = false;
  var showPanel = null; // vom Holo-Block gesetzt, sonst null

  // ---------- Modus-Umschaltung ----------
  function setPressed() {
    if (btnVid) btnVid.setAttribute('aria-pressed', String(mode === 'video'));
    if (btnImg) btnImg.setAttribute('aria-pressed', String(mode === 'img'));
    if (btn3d) btn3d.setAttribute('aria-pressed', String(mode === 'holo'));
  }
  function applyMode() {
    stage.classList.toggle('is-video', mode === 'video');
    stage.classList.toggle('is-3d', mode === 'holo');
    if (holoSec) holoSec.classList.toggle('is-3d-active', mode === 'holo');
    // Ebenen-Panel nur in der Holo-Ansicht (und erst wenn der Viewer geladen ist)
    var f = document.getElementById('holofilters');
    if (f) f.hidden = !(mode === 'holo' && viewer);
    if (mode === 'img') startSlideshow();
    if (mode === 'video') initVideo(); else pauseVideo();
    setPressed();
  }
  function showVideo() { mode = 'video'; applyMode(); }
  function showImg() {
    mode = 'img'; applyMode();
    if (!loading) { stage.classList.remove('is-loading'); if (status) status.textContent = ''; }
    if (showPanel) showPanel(null);
    // Bühne darf nach dem Umschalten nicht dunkel sein: aktives Bild tot
    // (z. B. im Video-Modus gestorben) oder gar keins intakt -> auf das erste
    // fertige Bild wechseln bzw. weiter eskalieren (Holo/Hinweis)
    if (slides.length && (!goodSlides().length || slides[slideIdx].dataset.bad)) showFirstReady();
  }
  function showHolo() { mode = 'holo'; applyMode(); }
  if (btnVid) btnVid.addEventListener('click', showVideo);
  if (btnImg) btnImg.addEventListener('click', showImg);

  // ---------- Bilder-Slideshow (langsames Crossfade) ----------
  var slideTimer = null, slideIdx = 0;
  // Bilder erst bei Bedarf laden (data-src -> src), sonst feuern alle 11 gleich-
  // zeitig gegen FleetYards und haengen. Aktives + naechstes Bild vorladen.
  function ensureLoaded(i) {
    var im = slides[i];
    if (im && !im.getAttribute('src') && im.dataset.src) im.src = im.dataset.src;
  }
  function paint(i) {
    slides.forEach(function (im, k) { im.classList.toggle('is-active', k === i); });
    if (dots) [].forEach.call(dots.children, function (dd, k) { dd.classList.toggle('on', k === i); });
    ensureLoaded(i); ensureLoaded((i + 1) % slides.length);
  }
  function startSlideshow() {
    ensureLoaded(slideIdx); ensureLoaded((slideIdx + 1) % slides.length);
    if (slideTimer || reduce || slides.length < 2) return;
    slideTimer = setInterval(function () {
      if (mode !== 'img' || document.hidden) return;
      var r = stage.getBoundingClientRect();
      if (r.bottom < 0 || r.top > innerHeight) return; // offscreen -> pausieren
      var next = slideIdx;
      for (var n = 0; n < slides.length; n++) {
        next = (next + 1) % slides.length;
        if (!slides[next].dataset.bad) break; // kaputte Bilder überspringen
      }
      // Nie auf ein noch ladendes Bild blenden (grosse FleetYards-Dateien
      // brauchen laenger als der 6-s-Vorlauf -> schwarze Buehne): Laden
      // anstossen, Tick aussetzen, der naechste versucht es erneut.
      var im = slides[next];
      ensureLoaded(next);
      if (next !== slideIdx && !(im.complete && im.naturalWidth > 0)) return;
      slideIdx = next; paint(slideIdx);
    }, 6000);
  }

  // ---------- Kaputte Bilder: Kette Ersatz-Thumb -> nächstes Bild -> Holo -> Hinweis ----------
  // Externe Bild-URLs (Wiki/FleetYards) können jederzeit sterben. Der inline-
  // onerror am <img> probiert erst data-fb (kleineres Wiki-Thumb) und markiert
  // das Bild sonst als bad+unsichtbar. Hier die Stufen danach — eine dauerhaft
  // schwarze Bühne darf es nicht geben.
  var autoHolo = null; // wird im Holo-Block auf start() gesetzt, wenn 3D verfügbar
  var holoTried = false; // Schleifen-Schutz: Holo-Fehlschlag -> showImg -> nicht erneut Holo
  function goodSlides() {
    return slides.filter(function (im) { return !im.dataset.bad; });
  }
  function escalateNoImages() {
    if (viewer) { showHolo(); return; }
    if (autoHolo && !holoTried) { holoTried = true; autoHolo(false); return; }
    if (fig && !fig.querySelector('.holo__none')) {
      var sp = document.createElement('span');
      sp.className = 'holo__none';
      sp.textContent = stage.getAttribute('data-novisual') || '';
      fig.appendChild(sp);
    }
  }
  // Erstes Bild, das intakt UND fertig geladen ist — nur auf solche wird
  // gewechselt. is-active auf einem noch leeren lazy-Bild = schwarze Bühne
  // (FleetYards-Blobs können zudem lange hängen), genau das darf nie passieren.
  function readyIdx() {
    for (var i = 0; i < slides.length; i++) {
      var im = slides[i];
      if (!im.dataset.bad && im.getAttribute('src') && im.complete && im.naturalWidth > 0) return i;
    }
    return -1;
  }
  var waitTimer = null;
  function showFirstReady() {
    if (mode !== 'img') return;
    var good = goodSlides();
    if (!good.length) { escalateNoImages(); return; }
    var r = readyIdx();
    if (r >= 0) { slideIdx = r; paint(r); return; }
    // Nichts fertig: Laden der intakten anstoßen und kurz nachhalten; kommt
    // binnen 8 s keins an (tote/hängende Quellen), weiter zu Holo/Hinweis.
    good.slice(0, 2).forEach(function (im) { ensureLoaded(slides.indexOf(im)); });
    if (waitTimer) return;
    var t0 = Date.now();
    waitTimer = setInterval(function () {
      if (mode !== 'img') { clearInterval(waitTimer); waitTimer = null; return; }
      var i = readyIdx();
      if (i >= 0) { clearInterval(waitTimer); waitTimer = null; slideIdx = i; paint(i); return; }
      if (!goodSlides().length || Date.now() - t0 > 8000) {
        clearInterval(waitTimer); waitTimer = null; escalateNoImages();
      }
    }, 400);
  }
  function slideFailed(im) {
    if (mode !== 'img') return; // Video/Holo laufen sichtbar weiter; showImg() heilt beim Umschalten
    // Totes Hintergrund-Bild stört nicht, solange das aktive intakt ist
    if (!im.classList.contains('is-active') && goodSlides().length) return;
    showFirstReady();
  }
  slides.forEach(function (im) {
    im.addEventListener('error', function () {
      // Der inline-Handler lief zuerst: entweder hat er den Ersatz-Thumb
      // eingesetzt (kein bad -> neuer Ladeversuch läuft) oder bad gesetzt.
      if (im.dataset.bad) slideFailed(im);
    });
  });

  // ---------- Video: YouTube-IFrame-API -> stummes Autoplay im Video-Modus ----------
  // Der rohe iframe-Embed scheiterte auf localhost mit "Fehler 153"
  // (fehlender origin). Die offizielle IFrame-API konfiguriert den Player
  // korrekt, erlaubt browser-konformes Muted-Autoplay und meldet Fehler sauber.
  var ytPlayer = null, ytLoading = false, ytReady = false, playStarted = false;
  function fadePoster() {
    if (videoPoster) { videoPoster.style.opacity = '0'; videoPoster.style.pointerEvents = 'none'; }
  }
  function loadYT() {
    return new Promise(function (res) {
      if (window.YT && window.YT.Player) return res();
      var prev = window.onYouTubeIframeAPIReady;
      window.onYouTubeIframeAPIReady = function () { if (prev) { try { prev(); } catch (e) {} } res(); };
      if (!document.getElementById('yt-iframe-api')) {
        var s = document.createElement('script');
        s.id = 'yt-iframe-api';
        s.src = 'https://www.youtube.com/iframe_api';
        document.head.appendChild(s);
      }
    });
  }
  function initVideo() {
    if (!videoBox) return;
    if (ytPlayer) { if (ytReady) { try { ytPlayer.mute(); ytPlayer.playVideo(); } catch (e) {} } return; }
    if (ytLoading) return;
    var vid = videoBox.getAttribute('data-vid');
    if (!vid) return;
    var shield = document.getElementById('holovideoshield');
    ytLoading = true;
    loadYT().then(function () {
      ytPlayer = new YT.Player('holoplayer', {
        videoId: vid,
        host: 'https://www.youtube-nocookie.com',
        playerVars: {
          // Ambient-Video: IMMER stummes Autoplay ohne jede Player-UI — auch
          // bei prefers-reduced-motion (frueher gab es dort einen Player MIT
          // Controls; genau diese Icons sollen nie zu sehen sein — der Modus
          // bleibt ueber die Umschalter abwaehlbar). KEIN programmatisches
          // playVideo() -> YouTube zeigt keinen bleibenden Play/Pause-Button;
          // das kurze Start-Symbol liegt unter dem Poster.
          autoplay: 1, mute: 1, playsinline: 1,
          controls: 0, disablekb: 1, fs: 0, iv_load_policy: 3,
          rel: 0, modestbranding: 1, start: 4, origin: location.origin,
        },
        events: {
          onReady: function (e) {
            ytReady = true;
            // Nur Stummschaltung sicherstellen; Start/Position macht das native
            // Autoplay + start-Param. Kein playVideo()/seekTo() -> kein Button.
            try { e.target.mute(); } catch (er) {}
            // Nahtlos-Loop: kurz VOR dem Ende zurueckspringen, damit YouTubes
            // Endscreen (Vorschlags-Kacheln) nie aufblitzt. Der ENDED-Zweig in
            // onStateChange bleibt als Fallback, falls ein Tick das Fenster
            // verpasst (Tab gedrosselt o. ae.).
            setInterval(function () {
              try {
                if (!ytPlayer || ytPlayer.getPlayerState() !== 1) return;
                var d = ytPlayer.getDuration();
                if (d > 0 && ytPlayer.getCurrentTime() > d - 0.9) ytPlayer.seekTo(3.8, true);
              } catch (er) {}
            }, 500);
          },
          onStateChange: function (e) {
            // erst kurz NACH echtem Abspielstart das Poster wegblenden -> das
            // YouTube-Start-Chrome (Titel-Einblendung oben, ~3 s) liegt darunter
            // unsichtbar. 3000 ms + 0,9 s Fade decken das ab; die frueheren
            // 4500 ms waren unnoetig traege (User-Feedback "startet nicht direkt").
            // Inline-Style (kein Klassen-Toggle): umgeht ein Astro-Scoping-Problem,
            // bei dem die opacity-Klassenregel nicht zuverlässig greift.
            if (e.data === 1) { playStarted = true; setTimeout(fadePoster, 3000); }
            // Endlosschleife OHNE playlist-Param (der sonst Zurück/Weiter-Buttons zeigt):
            // am Ende (0) einfach zurück an 3,8 s und weiterspielen
            else if (e.data === 0) { try { e.target.seekTo(3.8, true); e.target.playVideo(); } catch (er) {} }
          },
          onError: function (e) {
            // Video nicht abspielbar (Region/Embed/Netz) -> auf Bilder ausweichen,
            // damit kein YouTube-Fehlerbildschirm stehen bleibt
            console.warn('YT player error', e && e.data);
            if (slides.length) { fadePoster(); showImg(); if (btnVid) btnVid.style.display = 'none'; }
          },
        },
      });
      // Fallback: bleibt Autoplay wider Erwarten blockiert, NICHT den Player
      // samt YouTube-UI freischalten (es soll nie Player-Chrome zu sehen sein),
      // sondern auf die Bilder-Galerie ausweichen. Nur ohne Galerie als letzter
      // Ausweg die Schutzschicht loesen, damit kein totes schwarzes Feld bleibt.
      setTimeout(function () {
        if (playStarted) return;
        if (slides.length) { fadePoster(); showImg(); }
        else { fadePoster(); if (shield) shield.style.pointerEvents = 'none'; }
      }, 7000);
    });
  }
  function pauseVideo() {
    if (ytPlayer && ytReady) { try { ytPlayer.pauseVideo(); } catch (e) {} }
  }
  // Tab-Rueckkehr: YouTube pausiert Videos in Hintergrund-Tabs — beim
  // Sichtbarwerden laeuft das Ambient-Video im Video-Modus sonst nicht wieder
  // an und es bliebe ein Standbild stehen (API-play zeigt kein Overlay-Icon,
  // anders als ein Klick auf den Player).
  document.addEventListener('visibilitychange', function () {
    if (!document.hidden && mode === 'video' && ytPlayer && ytReady) {
      try { ytPlayer.mute(); ytPlayer.playVideo(); } catch (e) {}
    }
  });

  // ---------- Holo (nur wenn Holodaten vorhanden) ----------
  var dataEl = document.getElementById('holodata');
  if (dataEl) {
    var cfg = JSON.parse(dataEl.textContent);
    var wrap = document.getElementById('holo3d');
    var filters = document.getElementById('holofilters');
    var panel = document.getElementById('holopanel');
    var pclose = document.getElementById('holopclose');
    var loadingTpl = stage.getAttribute('data-loading') || '3D-Modell lädt … %p% %';
    var errorTxt = stage.getAttribute('data-error') || '3D-Modell konnte nicht geladen werden.';
    var debug = /[?&]holodebug/.test(location.search);

    var row = function (id, val) {
      var r = document.getElementById(id + 'row'), d = document.getElementById(id);
      if (!r || !d) return;
      if (val == null || val === '') { r.hidden = true; }
      else { d.textContent = val; r.hidden = false; }
    };
    showPanel = function (i) {
      if (i == null || !cfg.ports[i]) {
        panel.hidden = true;
        if (viewer) viewer.select(null);
        return;
      }
      var p = cfg.ports[i];
      var kind = cfg.kinds[p.k] || p.k;
      panel.setAttribute('data-g', p.g);
      var grpEl = document.getElementById('hpgrp');
      if (grpEl) grpEl.textContent = (cfg.grpLabels && cfg.grpLabels[p.g]) || '';
      var iconPath = document.querySelector('#hpicon path');
      if (iconPath) iconPath.setAttribute('d', (cfg.icons && cfg.icons[p.k]) || '');
      document.getElementById('hpkind').textContent = kind;
      var nameEl = document.getElementById('hpname');
      nameEl.textContent = (p.label && p.label !== kind) ? p.label : '';
      nameEl.hidden = !nameEl.textContent;
      document.getElementById('hpsize').textContent = p.size != null ? 'S' + p.size : '—';
      row('hpcat', p.cat || null);
      row('hpprice', p.price != null ? p.price.toLocaleString(cfg.loc) + ' ' + (panel.getAttribute('data-auec') || 'aUEC') : null);
      row('hpshops', p.shops ? String(p.shops) : null);
      var link = document.getElementById('hplink');
      if (p.iid && cfg.finder) {
        link.href = cfg.finder + '?item=' + encodeURIComponent(p.iid);
        link.hidden = false;
      } else link.hidden = true;
      var note = document.getElementById('hpnote');
      var noteTxt = p.np ? panel.getAttribute('data-np') : (p.est ? panel.getAttribute('data-est') : '');
      note.textContent = noteTxt;
      note.hidden = !noteTxt;
      panel.hidden = false;
      if (viewer) viewer.select(i);
    };

    var start = function (explicit) {
      if (viewer || loading) return;
      loading = true;
      stage.classList.add('is-loading');
      status.textContent = loadingTpl.replace('%p%', '0');
      import(stage.getAttribute('data-holo-src') || '/assets/holo-viewer.js')
        .then(function (m) {
          return m.initHolo(wrap, {
            url: cfg.url, ports: cfg.ports, mesh: cfg.mesh, ax: cfg.ax,
            defaultOn: cfg.defaultOn, debug: debug,
            onProgress: function (p) { status.textContent = loadingTpl.replace('%p%', p); },
            onSelect: showPanel,
          });
        })
        .then(function (v) {
          viewer = v; loading = false;
          status.textContent = '';
          stage.classList.remove('is-loading');
          showHolo(); // blendet via applyMode das Ebenen-Panel ein
          // Mobil: dauerhafte Bauteil-Labels standardmäßig AUS — auf dem kleinen
          // Modell überlappen sie sich sonst und mit dem Ebenen-Panel. Antippen
          // eines Markers zeigt weiterhin die Detailkarte; "Labels" schaltet an.
          if (matchMedia('(max-width: 760px)').matches) {
            try { v.setLabels(false); } catch (er) {}
            var lblBtn = document.getElementById('holoblabels');
            if (lblBtn) lblBtn.setAttribute('aria-pressed', 'false');
            // Panel standardmäßig zugeklappt -> gibt das kleine Modell frei
            if (filters) filters.classList.add('is-collapsed');
            var lt0 = document.getElementById('holo-layers-toggle');
            if (lt0) lt0.setAttribute('aria-expanded', 'false');
          }
        })
        .catch(function (e) {
          console.error(e);
          loading = false;
          showImg();
          if (explicit) { stage.classList.add('is-loading'); status.textContent = errorTxt; }
        });
    };

    autoHolo = start; // Eskalationsziel, wenn alle Galerie-Bilder tot sind
    if (btn3d) btn3d.addEventListener('click', function () { viewer ? showHolo() : start(true); });
    if (pclose) pclose.addEventListener('click', function () { showPanel(null); });
    var layersToggle = document.getElementById('holo-layers-toggle');
    if (layersToggle) layersToggle.addEventListener('click', function () {
      var collapsed = filters.classList.toggle('is-collapsed');
      layersToggle.setAttribute('aria-expanded', String(!collapsed));
    });
    if (filters) filters.addEventListener('click', function (ev) {
      var b = ev.target.closest('button');
      if (!b || !viewer) return;
      var pr = b.getAttribute('aria-pressed') !== 'true';
      b.setAttribute('aria-pressed', String(pr));
      if (b.id === 'holoblabels') { viewer.setLabels(pr); return; }
      if (!b.hasAttribute('data-g')) return;
      var groups = [];
      filters.querySelectorAll('button[data-g][aria-pressed="true"]').forEach(function (x) { groups.push(x.getAttribute('data-g')); });
      viewer.setFilter(groups);
    });

    // Holo ist der einzige Modus (kein Video, keine Bilder) -> direkt laden
    if (defaultMode === 'holo') start(false);
  }

  // Bilder, die schon VOR diesem Script gescheitert sind (nur der inline-
  // onerror lief), jetzt nachziehen — autoHolo ist ab hier gesetzt.
  slides.forEach(function (im) { if (im.dataset.bad) slideFailed(im); });
  applyMode();
})();
</script>
</Layout>
