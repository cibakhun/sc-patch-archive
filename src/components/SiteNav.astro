  /* Cluster ist nur ein DOM-Anker (Tag + seine Items in Lese-Reihenfolge,
     wichtig für die mobile Listenansicht weiter unten) — in der Desktop-
     Ringansicht positionieren sich alle Kinder unabhängig via --angle,
     der Wrapper selbst braucht kein eigenes Layout. */
  .snav-orbit__cluster {
    display: contents;
  }
  /* Vier Ebenen für "gehört zusammen", nicht nur Farbe: Linienstil (solid/
     dashed/dotted/dicker) je Spoke, Form je Dot (--shape), ein Text-Tag am
     Sektor, und erst dann --gc als vierte, verstärkende Farbebene. */
  .snav-orbit__spoke {
