<script is:inline>
  (function () {
    if (window.__snavInit) return;
    window.__snavInit = true;
    var nav = document.getElementById('topbar');
    if (!nav) return;
    addEventListener('scroll', function () {
      var scrolled = scrollY > 40;
      nav.classList.toggle('scrolled', scrolled);
      var prog = nav.querySelector('.snav__progress-fill');
      if (prog) {
        var h = document.documentElement.scrollHeight - innerHeight;
        var pct = h > 0 ? Math.min(100, Math.max(0, (scrollY / h) * 100)) : 0;
        prog.style.width = pct + '%';
      }
    }, { passive: true });

    // ---- Menü-Overlay: Öffnen/Schließen, Fokus-Falle, Pfeiltasten-Navigation
    // (gleiches Grundmuster wie SearchOverlay: lastFocus merken/wiederher-
    // stellen, Body-Scroll sperren) --------------------------------------
    var btn = document.getElementById('snavMenuBtn');
    var deck = document.getElementById('snavDeck');
    if (!btn || !deck) return;
    var lastFocus = null;

    function focusable() {
      return [].slice.call(deck.querySelectorAll('a[href], button')).filter(function (el) {
        return el.offsetParent !== null;
      });
    }

    /** Zeilen spaltenweise (ein Array je Gruppen-Block) — Basis der 2D-Navigation */
    function columns() {
      return [].slice.call(deck.querySelectorAll('.snav-deck__group')).map(function (grp) {
        return [].slice.call(grp.querySelectorAll('[data-deck-row]'));
      }).filter(function (col) { return col.length; });
    }

    // ---- Bühne: spiegelt die gerade anvisierte Zeile groß ------------------
    var stage = deck.querySelector('.snav-deck__stage');
    var stageGrp = document.getElementById('deckStageGrp');
    var stageTitle = document.getElementById('deckStageTitle');
    var stageSub = document.getElementById('deckStageSub');
    var stageGlyph = document.getElementById('deckGlyph');
    var allRows = [].slice.call(deck.querySelectorAll('[data-deck-row]'));
    var activeRow = null;
    var swapTimer = null;

    var shots = [].slice.call(deck.querySelectorAll('.snav-deck__shot'));

    /** Motive beim ersten Öffnen laden — danach liegen sie im Cache und der
     *  Wechsel zwischen zwei Einträgen ist ein reiner Opacity-Übergang.
     *  Unter 900px ist die Bühne ausgeblendet: dort werden die ~94 KB gar
     *  nicht geladen. shotsPrimed bleibt dann bewusst false, damit ein
     *  späteres Öffnen im breiteren Layout nachlädt. */
    var shotsPrimed = false;
    function primeShots() {
      if (shotsPrimed) return;
      if (window.matchMedia('(max-width: 900px)').matches) return;
      shotsPrimed = true;
      shots.forEach(function (img) {
        var src = img.getAttribute('data-src');
        if (src && !img.getAttribute('src')) img.setAttribute('src', src);
      });
    }

    function paintStage(row, instant) {
      if (!row || !stage || row === activeRow) return;
      activeRow = row;
      allRows.forEach(function (r) { r.classList.toggle('is-active', r === row); });

      // Bild kreuzt SOFORT (eigene, längere Transition) — nur der Text wartet
      // kurz, sonst laufen zwei Bewegungen gegeneinander
      var media = row.getAttribute('data-media');
      shots.forEach(function (img) {
        img.classList.toggle('is-shown', !!media && img.getAttribute('data-shot') === media);
      });
      // ohne kuratiertes Motiv trägt das Glyph die Bühne
      stage.classList.toggle('is-glyph', !media);

      var apply = function () {
        stageGrp.textContent = row.getAttribute('data-group') || '';
        stageTitle.textContent = row.querySelector('.snav-deck__label').textContent;
        stageSub.textContent = row.querySelector('.snav-deck__sub').textContent;
        stageGlyph.textContent = '';
        var svg = row.querySelector('.snav-deck__icon svg');
        // Klon statt innerHTML: kein String-Parsing, Markup bleibt identisch
        if (svg) stageGlyph.appendChild(svg.cloneNode(true));
        stage.classList.remove('is-swapping');
      };
      clearTimeout(swapTimer);
      if (instant) { apply(); return; }
      stage.classList.add('is-swapping');
      swapTimer = setTimeout(apply, 130);
    }

    // Hover UND Fokus füttern dieselbe Bühne -> Maus und Tastatur fühlen sich
    // identisch an; Delegation, damit nur zwei Listener nötig sind
    deck.addEventListener('mouseover', function (e) {
      var row = e.target.closest && e.target.closest('[data-deck-row]');
      if (row) paintStage(row);
    });
    deck.addEventListener('focusin', function (e) {
      var row = e.target.closest && e.target.closest('[data-deck-row]');
      if (row) paintStage(row);
    });

    /** Fokus setzen UND Bühne nachziehen. focusin allein reicht nicht: hat das
     *  Fenster keinen Fokus, verschiebt .focus() zwar activeElement, feuert
     *  aber kein focusin — die Bühne bliebe stehen. Doppelaufruf ist billig,
     *  paintStage steigt bei unveränderter Zeile sofort aus. */
    function focusRow(row) {
      if (!row) return;
      row.focus();
      paintStage(row);
    }

    function openDeck() {
      lastFocus = document.activeElement;
      deck.hidden = false;
      primeShots();
      // Bühne auf die aktuelle Seite setzen (sonst erste Zeile) — ohne
      // Übergang, das Menü soll bereits gefüllt aufblenden
      activeRow = null;
      var start = deck.querySelector('[data-deck-row][aria-current]') || allRows[0];
      paintStage(start, true);
      // erzwungener Reflow statt requestAnimationFrame: garantiert, dass der
      // Browser den hidden->visible-Wechsel VOR dem Klassenwechsel committet,
      // sonst startet die Opacity-Transition in manchen Rendering-Kontexten
      // nie (rAF kann in gedrosselten/eingebetteten Views ausbleiben).
      void deck.offsetHeight;
      deck.classList.add('is-open');
      document.documentElement.classList.add('is-deck-open');
      btn.setAttribute('aria-expanded', 'true');
    }

    function closeDeck() {
      deck.classList.remove('is-open');
      document.documentElement.classList.remove('is-deck-open');
      btn.setAttribute('aria-expanded', 'false');
      setTimeout(function () { deck.hidden = true; }, 380);
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    btn.addEventListener('click', function () {
      deck.hidden ? openDeck() : closeDeck();
    });
    deck.querySelectorAll('[data-deck-close]').forEach(function (el) {
      el.addEventListener('click', closeDeck);
    });

    var ARROWS = { ArrowUp: 1, ArrowDown: 1, ArrowLeft: 1, ArrowRight: 1 };

    addEventListener('keydown', function (e) {
      if (deck.hidden) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        closeDeck();
        return;
      }
      if (ARROWS[e.key]) {
        var cols = columns();
        if (!cols.length) return;
        e.preventDefault();
        var active = document.activeElement;
        var c = -1;
        var r = -1;
        for (var i = 0; i < cols.length; i++) {
          var idx = cols[i].indexOf(active);
          if (idx > -1) { c = i; r = idx; break; }
        }
        // noch keine Zeile fokussiert -> erste Zeile übernehmen
        if (c === -1) { focusRow(cols[0][0]); return; }
        if (e.key === 'ArrowDown') r = (r + 1) % cols[c].length;
        else if (e.key === 'ArrowUp') r = (r - 1 + cols[c].length) % cols[c].length;
        else {
          c = e.key === 'ArrowRight' ? (c + 1) % cols.length : (c - 1 + cols.length) % cols.length;
          // Spalten sind unterschiedlich lang: Zeilenindex klemmen statt springen
          r = Math.min(r, cols[c].length - 1);
        }
        focusRow(cols[c][r]);
        return;
      }
      if (e.key !== 'Tab') return;
      // Fokus-Falle: Tab kreist innerhalb des Overlays statt in die Seite zu entkommen
      var items = focusable();
      if (!items.length) return;
      var first = items[0];
      var last = items[items.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  })();
</script>
