---
// Global sticky navigation: brand monogram + breadcrumbs (left),
// Suche + Sprachumschalter + Menü-Dropdown (right) — eine Leiste für alle
// Breiten, das Menü trägt Bereiche + Patch-Liste. Keeps id="topbar" so
// existing per-page scroll JS keeps working.
// Plumbing, not a reskin: themes itself via the page's palette variables,
// no motion beyond the existing scrolled-state.
import { getCollection } from 'astro:content';
import SearchOverlay from './SearchOverlay.astro';
import LangSwitcher from './LangSwitcher.astro';
import { SITE } from '../consts';
import { localeFromPath, useTranslations, href } from '../i18n/ui';
import { eraLabel } from '../i18n/patchText';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs?: Crumb[];
  pill?: string;
  /** hat DIESE Seite ein EN-Gegenstück? -> steuert den Umschalter (kein 404) */
  hasEn?: boolean;
}
const { crumbs = [], pill, hasEn = false } = Astro.props;

// Locale aus dem Pfad; t() + L() halten Chrome/Links in der aktiven Sprache.
// Für DE liefern beide exakt die bisherigen Werte -> DE-Ausgabe unverändert.
const lang = localeFromPath(Astro.url.pathname);
const t = useTranslations(lang);
const L = (p: string) => href(p, lang);

// BreadcrumbList JSON-LD — the nav already knows the trail (last item = page)
const siteBase = SITE.url.replace(/\/$/, '');
const crumbLd =
  crumbs.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.label,
          item: siteBase + (c.href ?? Astro.url.pathname),
        })),
      }
    : null;

const patches = (await getCollection('patches')).sort((a, b) =>
  a.data.date.localeCompare(b.data.date)
);
// eras in chronological order of first appearance
const eras: string[] = [];
for (const p of patches) if (!eras.includes(p.data.era)) eras.push(p.data.era);
const topicCount = patches.reduce((n, p) => n + p.data.topics.length, 0);
const current = Astro.url.pathname;
---
<nav class="snav" id="topbar" aria-label={t('nav.main')}>
  <div class="snav__left">
    <a class="snav__brand" href={L('/index.html')} aria-label={t('nav.home.aria')}>
      <svg viewBox="0 0 64 64" width="24" height="24" aria-hidden="true"><path d="M32 8 52 20v24L32 56 12 44V20z" fill="none" stroke="currentColor" stroke-width="5" stroke-linejoin="round"/><circle cx="32" cy="32" r="6" fill="currentColor"/></svg>
      <span>SC·Archiv</span>
    </a>
    {crumbs.length > 0 && (
      <nav class="snav__crumbs" aria-label={t('nav.path')}>
        <ol>
          {crumbs.map((c, i) => (
            <li class={i < crumbs.length - 1 ? 'snav__mid' : undefined}>
              {c.href ? <a href={c.href}>{c.label}</a> : <span aria-current="page">{c.label}</span>}
            </li>
          ))}
        </ol>
      </nav>
    )}
  </div>
  <div class="snav__right">
    <button class="snav__search" type="button" data-scs-open aria-label={t('nav.search.open')}>
      <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2.4"/><line x1="15.5" y1="15.5" x2="21" y2="21" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
      <span>{t('nav.search')}</span>
      <kbd>{t('nav.search.kbd')}</kbd>
    </button>
    {pill && <span class="snav__pill">{pill}</span>}
    <LangSwitcher hasEn={hasEn} />
    <details class="snav__dd snav__menu">
      <summary aria-label={t('nav.menu.open')}>
        <svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
        <span>{t('nav.menu')}</span>
      </summary>
      <div class="snav__panel">
        <div class="snav__group">
          <div class="snav__ghead">{t('nav.section')}</div>
          
          <!-- Schiffe -->
          <a href={L('/schiffe.html')} aria-current={current === L('/schiffe.html') || current.startsWith(L('/schiffe/')) ? 'page' : undefined}>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.55rem; display: inline-block; vertical-align: middle; flex-shrink: 0;"><path d="M12 2L2 22h9l1-6 1 6h9L12 2z"/></svg>
            <span>{t('nav.ships')}</span>
          </a>
          
          <!-- Evolution -->
          <a href={L('/evolution.html')} aria-current={current === L('/evolution.html') ? 'page' : undefined}>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.55rem; display: inline-block; vertical-align: middle; flex-shrink: 0;"><path d="M3 3v18h18M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>
            <span>{t('nav.evolution.long')}</span>
          </a>
          
          <!-- Wikelo's Emporium -->
          <a class="snav__feat" href={L('/topics/wikelo-emporium.html')} aria-current={current === L('/topics/wikelo-emporium.html') ? 'page' : undefined}>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.55rem; display: inline-block; vertical-align: middle; flex-shrink: 0;"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
            <span>Wikelo's Emporium</span>
          </a>
          
          <!-- Crafting -->
          <a class="snav__feat" href={L('/topics/crafting.html')} aria-current={current === L('/topics/crafting.html') ? 'page' : undefined}>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.55rem; display: inline-block; vertical-align: middle; flex-shrink: 0;"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
            <span>Crafting</span>
          </a>

          <!-- Item Finder -->
          <a class="snav__feat" href={L('/item-finder')} aria-current={current === L('/item-finder') ? 'page' : undefined}>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.55rem; display: inline-block; vertical-align: middle; flex-shrink: 0;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>Item Finder</span>
          </a>
          
          <!-- Mining Details -->
          <details class="snav__sub-details" open={current.includes('/topics/mining') ? true : undefined}>
            <summary class="snav__sub-summary">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.55rem; display: inline-block; vertical-align: middle; flex-shrink: 0;"><path d="M6 3h12l4 6-10 12L2 9z"/></svg>
              <span>Mining</span>
              <svg class="snav__sub-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; transition: transform 0.2s;"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="snav__sub-content">
              <a href={L('/topics/mining.html#db')} aria-current={current === L('/topics/mining.html#db') ? 'page' : undefined}>
                <span>└ {lang === 'en' ? 'Mineral Database' : 'Mineral-Datenbank'}</span>
              </a>
              <a href={L('/topics/mining.html#signatures')} aria-current={current === L('/topics/mining.html#signatures') ? 'page' : undefined}>
                <span>└ {lang === 'en' ? 'Signature Scanner' : 'Signatur-Scanner'}</span>
              </a>
              <a href={L('/topics/mining.html#fracturing')} aria-current={current === L('/topics/mining.html#fracturing') ? 'page' : undefined}>
                <span>└ {lang === 'en' ? 'Fracturing Calculator' : 'Fracturing-Rechner'}</span>
              </a>
              <a href={L('/topics/mining.html#refinery')} aria-current={current === L('/topics/mining.html#refinery') ? 'page' : undefined}>
                <span>└ {lang === 'en' ? 'Refinery Finder' : 'Refinery Finder'}</span>
              </a>
              <a href={L('/topics/mining.html#ships')} aria-current={current === L('/topics/mining.html#ships') ? 'page' : undefined}>
                <span>└ {lang === 'en' ? 'Mining Ships' : 'Mining-Schiffe'}</span>
              </a>
            </div>
          </details>

          <!-- All Topics -->
          <a href={L('/index.html#themen')}>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.55rem; display: inline-block; vertical-align: middle; flex-shrink: 0;"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/></svg>
            <span>{t('nav.allTopics')} ({topicCount})</span>
          </a>
        </div>

        <!-- Patches Details -->
        <details class="snav__sub-details" open={current.includes('/patches/') ? true : undefined}>
          <summary class="snav__sub-summary">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.55rem; display: inline-block; vertical-align: middle; flex-shrink: 0;"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82zM7 7h.01"/></svg>
            <span>{t('nav.patches')}</span>
            <svg class="snav__sub-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: auto; transition: transform 0.2s;"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="snav__sub-content-patches">
            {eras.map((era) => (
              <div class="snav__group" style="margin-top: 0.5rem; margin-bottom: 0.5rem;">
                <div class="snav__ghead" style="margin-bottom: 0.2rem;">{eraLabel(era, lang)}</div>
                {patches
                  .filter((p) => p.data.era === era)
                  .map((p) => {
                    const ph = L(`/patches/sc-${p.id}.html`);
                    return (
                      <a href={ph} aria-current={current === ph ? 'page' : undefined} style="padding: 0.3rem 1rem;">
                        <b>{p.data.version}</b>
                        <span>{p.data.codename}</span>
                      </a>
                    );
                  })}
              </div>
            ))}
          </div>
        </details>

        <div class="snav__group snav__langgroup">
          <div class="snav__ghead">{t('nav.langSwitch')}</div>
          <LangSwitcher hasEn={hasEn} />
        </div>
      </div>
    </details>
  </div>
</nav>
{crumbLd && <script type="application/ld+json" set:html={JSON.stringify(crumbLd)} />}
<SearchOverlay lang={lang} />

<style>
  .snav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem clamp(1rem, 4vw, 2.5rem);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent);
    backdrop-filter: blur(6px);
    transition: background 0.3s;
  }
  .snav.scrolled {
    background: rgba(0, 0, 0, 0.95);
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
  }
  .snav__left {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }
  .snav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text, #e8eefc);
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .snav__brand svg {
    color: var(--accent, #2dd4ff);
    flex: none;
  }
  .snav__crumbs ol {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }
  .snav__crumbs li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-ui, sans-serif);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
  }
  .snav__crumbs li + li::before {
    content: '›';
    color: var(--muted, #8a99b8);
    opacity: 0.6;
    flex: none;
  }
  .snav__crumbs a:hover {
    color: var(--accent, #2dd4ff);
  }
  .snav__crumbs [aria-current] {
    color: var(--text, #e8eefc);
  }
  /* long leaf crumbs (ship names) truncate instead of colliding with the
     nav actions — the whole flex chain must be allowed to shrink */
  .snav__crumbs {
    min-width: 0;
  }
  .snav__crumbs li:last-child {
    /* shrinkable, but never below a readable ellipsis stub */
    min-width: 96px;
    overflow: hidden;
  }
  .snav__crumbs li:last-child [aria-current] {
    display: block;
    max-width: min(320px, 100%);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .snav__right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .snav__search {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
    color: var(--muted, #8a99b8);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.42rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }
  .snav__search:hover {
    color: var(--accent, #2dd4ff);
    border-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
  }
  .snav__search kbd {
    font-family: inherit;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted, #8a99b8);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    background: rgba(0, 0, 0, 0.3);
    padding: 0.08rem 0.4rem;
    border-radius: 1px;
  }
  .snav__dd {
    position: relative;
  }
  .snav__dd summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text, #e8eefc);
    padding: 0.35rem 0.65rem;
    border: 1px solid transparent;
  }
  .snav__dd summary::-webkit-details-marker {
    display: none;
  }
  .snav__dd summary:hover {
    color: var(--accent, #2dd4ff);
  }
  .snav__dd[open] summary {
    color: var(--accent, #2dd4ff);
    border-color: var(--line, rgba(255, 255, 255, 0.14));
    background: rgba(0, 0, 0, 0.6);
  }
  .snav__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    z-index: 9200;
    min-width: 360px;
    max-height: 68vh;
    overflow-y: auto;
    background: var(--bg-2, #0a0e18);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    border-top: 2px solid var(--accent, #2dd4ff);
    padding: 0.9rem 0 1rem;
    box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.85);
  }
  /* Sub-details (Mining / Patches collapsible groups) */
  .snav__sub-details {
    display: block;
    margin: 0;
  }
  .snav__sub-summary {
    display: flex;
    align-items: center;
    padding: 0.4rem 1rem;
    font-size: 0.95rem;
    color: var(--text, #e8eefc);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background-color 0.15s, color 0.15s;
    outline: none;
  }
  .snav__sub-summary::-webkit-details-marker {
    display: none;
  }
  .snav__sub-summary:hover {
    background: color-mix(in srgb, var(--accent, #2dd4ff) 6%, transparent);
    color: var(--accent, #2dd4ff);
  }
  .snav__sub-details[open] > .snav__sub-summary {
    color: var(--accent, #2dd4ff);
  }
  .snav__sub-details[open] > .snav__sub-summary .snav__sub-arrow {
    transform: rotate(180deg);
  }
  .snav__sub-content {
    display: flex;
    flex-direction: column;
    padding-left: 1rem;
    margin: 0.2rem 0;
    border-left: 1px solid var(--line, rgba(255, 255, 255, 0.1));
  }
  .snav__sub-content-patches {
    padding-left: 0.5rem;
    max-height: 40vh;
    overflow-y: auto;
    border-left: 1px solid var(--line, rgba(255, 255, 255, 0.1));
    margin-top: 0.3rem;
  }
  .snav__group + .snav__group {
    margin-top: 0.9rem;
  }
  .snav__ghead {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
    padding: 0.5rem 1rem 0.35rem;
    margin-bottom: 0.35rem;
  }
  .snav__panel a {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.4rem 1rem;
    font-size: 0.95rem;
    color: var(--text, #e8eefc);
    border-left: 2px solid transparent;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }
  .snav__panel a span {
    font-size: 0.9rem;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }
  .snav__panel a:hover {
    background: color-mix(in srgb, var(--accent, #2dd4ff) 6%, transparent);
    border-left-color: var(--accent, #2dd4ff);
  }
  .snav__panel a:hover span {
    color: var(--text, #e8eefc);
  }
  .snav__panel a[aria-current] {
    border-left-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 10%, transparent);
  }
  .snav__panel a[aria-current] span {
    color: var(--text, #e8eefc);
  }
  /* Featured burger entry (Wikelo) — steht hervor, direkter Sprung zur Themenseite */
  .snav__feat {
    border-left-color: color-mix(in srgb, var(--accent, #2dd4ff) 55%, transparent);
  }
  .snav__feat span {
    color: var(--accent, #2dd4ff);
    font-weight: 700;
  }
  .snav__panel b {
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 0.82rem;
    color: color-mix(in srgb, var(--accent, #2dd4ff) 70%, var(--text, #e8eefc));
    min-width: 3.6rem;
    flex: none;
  }
  .snav__pill {
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    padding: 0.32rem 0.7rem;
    border-radius: 2px;
    white-space: nowrap;
  }
  /* the nav carries more links since Phase 1 (Schiffe, Evolution) — shed
     ballast in stages before anything can collide (breakpoints calibrated
     for the 18px root scale) */
  @media (max-width: 1280px) {
    .snav__pill {
      display: none;
    }
  }
  @media (max-width: 1120px) {
    /* must out-rank the `.snav__crumbs li` base rule (scoped specificity) */
    .snav__crumbs li.snav__mid {
      display: none;
    }
    /* a hidden mid still counts for `li + li` — suppress the orphaned › */
    .snav__crumbs li.snav__mid + li::before {
      display: none;
    }
  }
  @media (max-width: 860px) {
    .snav__panel {
      min-width: 270px;
    }
    .snav__search span,
    .snav__search kbd {
      display: none;
    }
    .snav__search {
      padding: 0.4rem 0.5rem;
    }
  }
  /* Menü — die eine Navigation für alle Breiten: Bereiche, Feature-Links
     (Wikelo/Crafting/Mining) und die Patch-Liste nach Ära */
  .snav__menu summary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  /* Desktop hat den Sprachumschalter schon im Header — im Menü-Panel wäre er
     doppelt; die Gruppe gehört zur Mobil-Ansicht (s. u.) */
  .snav__langgroup {
    display: none;
  }
  /* Sprachumschalter im Burger-Menü (nur mobil sichtbar, s. u.).
     :global(), weil .langsw von der Kind-Komponente LangSwitcher gerendert wird
     und Astros Scoped-Selektoren sie sonst nicht treffen. */
  .snav__langgroup :global(.langsw) {
    margin: 0.4rem 1rem 0.15rem;
  }
  @media (max-width: 760px) {
    /* Der Umschalter oben rechts überlappt sonst die Wortmarke — auf Mobil
       wandert er in den Burger (freier Platz, keine Überlappung). Nur der
       direkte Header-Switcher; der im Menü (tiefer verschachtelt) bleibt. */
    .snav__right > :global(.langsw) {
      display: none;
    }
    .snav__langgroup {
      display: block;
    }
    .snav__menu .snav__panel {
      position: fixed;
      left: 0.75rem;
      right: 0.75rem;
      top: 3.6rem;
      min-width: 0;
    }
  }
  /* very narrow: brand + actions only — the crumb would collide with the
     search/menu buttons, and the page hero already states the location */
  @media (max-width: 640px) {
    .snav__crumbs {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    if (window.__snavInit) return;
    window.__snavInit = true;
    var nav = document.getElementById('topbar');
    if (!nav) return;
    addEventListener('scroll', function () {
      nav.classList.toggle('scrolled', scrollY > 40);
    }, { passive: true });
    var dds = [].slice.call(nav.querySelectorAll('details.snav__dd'));
    dds.forEach(function (d) {
      d.addEventListener('toggle', function () {
        if (d.open) dds.forEach(function (o) { if (o !== d) o.open = false; });
      });
    });
    addEventListener('click', function (e) {
      if (!nav.contains(e.target)) dds.forEach(function (d) { d.open = false; });
    });
    addEventListener('keydown', function (e) {
      if (e.key === 'Escape') dds.forEach(function (d) { d.open = false; });
    });
  })();
</script>
