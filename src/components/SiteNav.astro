  .snav-orbit__gtag {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: rotate(var(--angle)) translate(calc(var(--r) + 42px)) rotate(calc(-1 * var(--angle))) translate(-50%, -50%);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--gc, var(--accent, #2dd4ff));
    padding: 0.18rem 0.55rem;
    border: 1px solid color-mix(in srgb, var(--gc, var(--accent, #2dd4ff)) 45%, transparent);
    background: color-mix(in srgb, var(--gc, var(--accent, #2dd4ff)) 10%, rgba(0, 0, 0, 0.4));
    pointer-events: none;
    opacity: 0;
    animation: orbitIn 0.4s ease forwards;
    animation-delay: 320ms;
  }
  .snav-orbit__node {
    position: absolute;
    top: 50%;
    left: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: clamp(64px, 9vmin, 92px);
    transform: rotate(var(--angle)) translate(var(--r)) rotate(calc(-1 * var(--angle))) translate(-50%, -50%);
    color: var(--muted, #8a99b8);
    text-decoration: none;
    background: none;
    border: 0;
    font: inherit;
    cursor: pointer;
    pointer-events: auto;
    opacity: 0;
    scale: 0.35;
    animation: orbitIn 0.45s cubic-bezier(0.2, 0.8, 0.3, 1.2) forwards;
    animation-delay: calc(60ms + var(--i) * 45ms);
  }
  @keyframes orbitIn {
    to {
      opacity: 1;
      scale: 1;
    }
  }
  /* Form (--shape) ist die zweite Unterscheidungs-Ebene: Hex/Kreis/Diamant/
     Rundquadrat je Gruppe statt für alle Cluster derselbe Kreis-Dot. */
  .snav-orbit__dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(40px, 5.4vmin, 50px);
    height: clamp(40px, 5.4vmin, 50px);
    flex: none;
    clip-path: var(--shape, circle(50% at 50% 50%));
    border: 1px solid color-mix(in srgb, var(--gc, var(--accent, #2dd4ff)) 38%, var(--line, rgba(255, 255, 255, 0.18)));
    background: color-mix(in srgb, var(--surface, #0e1626) 75%, transparent);
    color: var(--muted, #8a99b8);
    transition: color 0.15s, border-color 0.15s, background-color 0.15s, box-shadow 0.15s;
  }
  .snav-orbit__dot svg {
    width: 16px;
    height: 16px;
  }
  .snav-orbit__label {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-align: center;
    line-height: 1.15;
    white-space: nowrap;
    max-width: 9.5ch;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .snav-orbit__node:hover,
  .snav-orbit__node:focus-visible {
    color: var(--text, #e8eefc);
  }
  .snav-orbit__node:hover .snav-orbit__dot,
  .snav-orbit__node:focus-visible .snav-orbit__dot {
    color: var(--gc, var(--accent, #2dd4ff));
    border-color: var(--gc, var(--accent, #2dd4ff));
    background: color-mix(in srgb, var(--gc, var(--accent, #2dd4ff)) 16%, var(--surface, #0e1626));
    box-shadow: 0 0 22px -4px color-mix(in srgb, var(--gc, var(--accent, #2dd4ff)) 70%, transparent);
  }
  .snav-orbit__node[aria-current] {
    color: var(--text, #e8eefc);
  }
  .snav-orbit__node[aria-current] .snav-orbit__dot {
    color: var(--gc, var(--accent, #2dd4ff));
    border-color: var(--gc, var(--accent, #2dd4ff));
    background: color-mix(in srgb, var(--gc, var(--accent, #2dd4ff)) 22%, var(--surface, #0e1626));
  }
  .snav-orbit__lang {
    position: absolute;
    left: 50%;
    bottom: clamp(1rem, 3vw, 1.75rem);
    transform: translateX(-50%);
