  .snav-deck__ghead {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 0 0 0.45rem;
  }
  /* Gruppenname: klein, mono, weit gesperrt — liest als Registerkarte einer
     Akte, nicht als bunte Kategorie-Pille */
  .snav-deck__gname {
    font-family: var(--font-mono, 'Share Tech Mono', monospace);
    font-size: 0.7rem;
    letter-spacing: 0.24em;
