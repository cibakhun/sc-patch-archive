      display: none;
    }
  }

  /* ============================================================
     Menü-Overlay („Ops-Terminal") — Vollbild-Takeover statt Dropdown.
     Vier Gruppen-Panels nebeneinander, alles gleichzeitig lesbar. Die
     Reveal-Animation läuft über --seq (laufender Zeilenindex quer über
     alle Gruppen); Panels und Zeilen teilen sich dieselbe Kurve, damit
     das Öffnen als EINE Bewegung liest statt als vier Einzelanimationen.
     ============================================================ */
  .snav-deck {
    position: fixed;
    inset: 0;
    z-index: 9500;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.26s ease;
  }
  .snav-deck[hidden] {
    display: none;
  }
  .snav-deck.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .snav-deck__back {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 120% 90% at 50% 0%, rgba(8, 13, 24, 0.92), rgba(2, 3, 7, 0.975));
    backdrop-filter: blur(14px);
  }
  /* feine Scanlines + ein einmaliger Sweep beim Öffnen: gibt dem Takeover
     den „Terminal fährt hoch"-Moment, ohne dauerhaft zu flimmern */
  .snav-deck__back::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(180deg, rgba(255, 255, 255, 0.022) 0 1px, transparent 1px 3px);
    mix-blend-mode: overlay;
  }
  .snav-deck__back::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      color-mix(in srgb, var(--accent, #2dd4ff) 9%, transparent) 45%,
      color-mix(in srgb, var(--accent, #2dd4ff) 16%, transparent) 50%,
      color-mix(in srgb, var(--accent, #2dd4ff) 9%, transparent) 55%,
      transparent 100%
    );
    opacity: 0;
  }
  .snav-deck.is-open .snav-deck__back::after {
    animation: deckSweep 0.85s cubic-bezier(0.3, 0, 0.2, 1) 1;
  }
  @keyframes deckSweep {
    0% {
      opacity: 0.9;
      transform: translateY(-100%);
    }
    100% {
      opacity: 0;
      transform: translateY(100%);
    }
  }
  .snav-deck__frame {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(1.1rem, 2.4vh, 1.9rem);
    width: min(1180px, 100%);
    height: 100%;
    margin: 0 auto;
    padding: clamp(1.1rem, 3.5vh, 2.2rem) clamp(1.1rem, 4vw, 2.4rem);
    overflow-y: auto;
  }
  .snav-deck__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: clamp(0.7rem, 1.6vh, 1.05rem);
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
