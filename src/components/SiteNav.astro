    flex: 1;
  }
  .snav-deck__panel {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding: 0.9rem 0 0.35rem;
    background: linear-gradient(180deg, color-mix(in srgb, var(--gc) 7%, transparent), transparent 42%);
    border-top: 2px solid var(--gc);
    /* abgeschrägte untere Ecke — dieselbe HUD-Sprache wie Suche/Schiffsseiten */
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%);
  }
  .snav-deck__ghead {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
    margin: 0 0 0.55rem;
    padding: 0 0.8rem;
  }
  .snav-deck__gname {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gc);
  }
  .snav-deck__gcount {
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    color: color-mix(in srgb, var(--gc) 55%, var(--muted, #8a99b8));
    font-variant-numeric: tabular-nums;
  }
  .snav-deck__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .snav-deck__row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.55rem 0.8rem;
    color: var(--text, #e8eefc);
    text-decoration: none;
    border-left: 2px solid transparent;
    opacity: 0;
    animation: deckRise 0.4s cubic-bezier(0.2, 0.7, 0.25, 1) forwards;
    animation-delay: calc(90ms + var(--seq) * 26ms);
    transition: background-color 0.16s ease, border-color 0.16s ease;
  }
  /* Hover-Füllung wischt von links ein, statt nur die Hintergrundfarbe zu
     schalten — der Unterschied, der das Antippen „fühlbar" macht */
  .snav-deck__row::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, color-mix(in srgb, var(--gc) 16%, transparent), transparent 78%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.24s cubic-bezier(0.2, 0.7, 0.25, 1);
    pointer-events: none;
  }
  .snav-deck__row:hover::before,
  .snav-deck__row:focus-visible::before {
    transform: scaleX(1);
  }
  .snav-deck__row:hover,
  .snav-deck__row:focus-visible {
    border-left-color: var(--gc);
    outline: none;
  }
  .snav-deck__row:focus-visible {
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--gc) 55%, transparent);
  }
  .snav-deck__row[aria-current] {
    border-left-color: var(--gc);
    background: color-mix(in srgb, var(--gc) 11%, transparent);
  }
  @keyframes deckRise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  /* Icon-Rahmenform je Gruppe (--shape) — zweite Unterscheidungsebene
     neben der Farbe, damit die Cluster nicht rein farbcodiert sind */
  .snav-deck__icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    flex: none;
    clip-path: var(--shape);
    border: 1px solid color-mix(in srgb, var(--gc) 40%, var(--line, rgba(255, 255, 255, 0.18)));
    background: color-mix(in srgb, var(--surface, #0e1626) 80%, transparent);
    color: color-mix(in srgb, var(--gc) 70%, var(--muted, #8a99b8));
    transition: color 0.16s ease, border-color 0.16s ease, background-color 0.16s ease, box-shadow 0.16s ease;
  }
  .snav-deck__icon svg {
    width: 16px;
    height: 16px;
  }
  .snav-deck__row:hover .snav-deck__icon,
  .snav-deck__row:focus-visible .snav-deck__icon,
  .snav-deck__row[aria-current] .snav-deck__icon {
    color: var(--gc);
    border-color: var(--gc);
    background: color-mix(in srgb, var(--gc) 18%, var(--surface, #0e1626));
    box-shadow: 0 0 18px -5px color-mix(in srgb, var(--gc) 75%, transparent);
  }
  .snav-deck__text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
    flex: 1;
  }
  .snav-deck__label {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.94rem;
    line-height: 1.2;
    letter-spacing: 0.01em;
    color: var(--text, #e8eefc);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .snav-deck__sub {
    font-size: 0.76rem;
    line-height: 1.25;
    color: var(--muted, #8a99b8);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .snav-deck__go {
    flex: none;
    color: var(--gc);
    opacity: 0;
    transform: translateX(-5px);
    transition: opacity 0.16s ease, transform 0.16s ease;
  }
  .snav-deck__row:hover .snav-deck__go,
  .snav-deck__row:focus-visible .snav-deck__go,
  .snav-deck__row[aria-current] .snav-deck__go {
    opacity: 1;
    transform: none;
  }
  .snav-deck__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: clamp(0.6rem, 1.4vh, 0.95rem);
    border-top: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    opacity: 0;
    animation: deckRise 0.42s cubic-bezier(0.2, 0.7, 0.25, 1) 0.34s forwards;
  }
  .snav-deck__foot :global(.langsw) {
    background: rgba(0, 0, 0, 0.35);
  }
  .snav-deck__hints {
    display: flex;
    gap: 1.15rem;
    flex-wrap: wrap;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
  }
  .snav-deck__hints span {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .snav-deck__hints kbd {
    font-family: inherit;
    font-weight: 700;
    font-size: 0.66rem;
    color: var(--muted, #8a99b8);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    background: rgba(0, 0, 0, 0.3);
    padding: 0.04rem 0.34rem;
    border-radius: 1px;
  }
  /* Konto-Punkt sitzt am Icon-Rahmen; der Rahmen ist beschnitten (clip-path),
     der Punkt darf NICHT mitbeschnitten werden -> eigenes Offset am Row */
  .snav-deck__row .snav__acct-dot {
    top: 1px;
    right: 1px;
    border-color: var(--bg-2, #0a0e18);
  }
  @media (max-width: 720px) {
    .snav-deck__grid {
      grid-template-columns: 1fr;
      gap: 1.1rem;
    }
    .snav-deck__eyebrow {
      display: none;
    }
    .snav-deck__hints {
      display: none;
    }
    .snav-deck__foot {
      justify-content: center;
    }
  }
  /* Bewegung ist Zierde, nie Voraussetzung: bei reduzierter Bewegung sind
     alle Elemente sofort da (Reveal-Animationen setzen opacity:0 als
     Startwert — ohne dieses Override bliebe das Menü unsichtbar) */
  @media (prefers-reduced-motion: reduce) {
    .snav-deck,
    .snav-deck__head,
    .snav-deck__row,
    .snav-deck__foot {
      transition: none;
      animation: none;
      opacity: 1;
    }
    .snav-deck:not(.is-open) {
      opacity: 0;
    }
    .snav-deck.is-open .snav-deck__back::after {
      animation: none;
    }
    .snav-deck__row::before,
    .snav-deck__go {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    if (window.__snavInit) return;
    window.__snavInit = true;
    var nav = document.getElementById('topbar');
    if (!nav) return;
    addEventListener('scroll', function () {
      nav.classList.toggle('scrolled', scrollY > 40);
    }, { passive: true });

    // ---- Menü-Overlay: Öffnen/Schließen, Fokus-Falle, Pfeiltasten-Navigation
    // (gleiches Grundmuster wie SearchOverlay: lastFocus merken/wiederher-
    // stellen, Body-Scroll sperren) --------------------------------------
    var btn = document.getElementById('snavMenuBtn');
    var deck = document.getElementById('snavDeck');
    if (!btn || !deck) return;
    var lastFocus = null;

    function focusable() {
      return [].slice.call(deck.querySelectorAll('a[href], button')).filter(function (el) {
        return el.offsetParent !== null;
      });
    }

    /** Zeilen spaltenweise (ein Array je Gruppen-Panel) — Basis der 2D-Navigation */
    function columns() {
      return [].slice.call(deck.querySelectorAll('.snav-deck__panel')).map(function (panel) {
        return [].slice.call(panel.querySelectorAll('[data-deck-row]'));
      }).filter(function (col) { return col.length; });
    }

    function openDeck() {
      lastFocus = document.activeElement;
      deck.hidden = false;
      // erzwungener Reflow statt requestAnimationFrame: garantiert, dass der
      // Browser den hidden->visible-Wechsel VOR dem Klassenwechsel committet,
      // sonst startet die Opacity-Transition in manchen Rendering-Kontexten
      // nie (rAF kann in gedrosselten/eingebetteten Views ausbleiben).
      void deck.offsetHeight;
      deck.classList.add('is-open');
      document.documentElement.style.overflow = 'hidden';
      btn.setAttribute('aria-expanded', 'true');
      var close = deck.querySelector('.snav-deck__close');
      if (close) close.focus();
    }

    function closeDeck() {
      deck.classList.remove('is-open');
      document.documentElement.style.overflow = '';
      btn.setAttribute('aria-expanded', 'false');
      setTimeout(function () { deck.hidden = true; }, 260);
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    btn.addEventListener('click', function () {
      deck.hidden ? openDeck() : closeDeck();
    });
    deck.querySelectorAll('[data-deck-close]').forEach(function (el) {
      el.addEventListener('click', closeDeck);
    });

    var ARROWS = { ArrowUp: 1, ArrowDown: 1, ArrowLeft: 1, ArrowRight: 1 };

    addEventListener('keydown', function (e) {
      if (deck.hidden) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        closeDeck();
        return;
      }
      if (ARROWS[e.key]) {
        var cols = columns();
        if (!cols.length) return;
        e.preventDefault();
        var active = document.activeElement;
        var c = -1;
        var r = -1;
        for (var i = 0; i < cols.length; i++) {
          var idx = cols[i].indexOf(active);
          if (idx > -1) { c = i; r = idx; break; }
        }
        // noch keine Zeile fokussiert -> erste Zeile übernehmen
        if (c === -1) { cols[0][0].focus(); return; }
        if (e.key === 'ArrowDown') r = (r + 1) % cols[c].length;
        else if (e.key === 'ArrowUp') r = (r - 1 + cols[c].length) % cols[c].length;
        else {
          c = e.key === 'ArrowRight' ? (c + 1) % cols.length : (c - 1 + cols.length) % cols.length;
          // Spalten sind unterschiedlich lang: Zeilenindex klemmen statt springen
          r = Math.min(r, cols[c].length - 1);
        }
        cols[c][r].focus();
        return;
      }
      if (e.key !== 'Tab') return;
      // Fokus-Falle: Tab kreist innerhalb des Overlays statt in die Seite zu entkommen
      var items = focusable();
      if (!items.length) return;
      var first = items[0];
      var last = items[items.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  })();
</script>
