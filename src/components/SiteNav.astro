<script is:inline>
  (function () {
    if (window.__snavInit) return;
    window.__snavInit = true;
    var nav = document.getElementById('topbar');
    if (!nav) return;
    addEventListener('scroll', function () {
      nav.classList.toggle('scrolled', scrollY > 40);
    }, { passive: true });

    // ---- Orbital-Menü: Öffnen/Schließen + Fokus-Falle (gleiches Muster wie
    // SearchOverlay: lastFocus merken/wiederherstellen, Body-Scroll sperren) --
    var btn = document.getElementById('snavMenuBtn');
    var orbit = document.getElementById('snavOrbit');
    if (!btn || !orbit) return;
    var drawer = document.getElementById('snavPatchDrawer');
    var drawerScrim = orbit.querySelector('.snav-orbit__drawer-scrim');
    var patchToggle = orbit.querySelector('[data-patch-toggle]');
    var lastFocus = null;

    function focusable() {
      return [].slice.call(orbit.querySelectorAll('a[href], button')).filter(function (el) {
        return el.offsetParent !== null;
      });
    }

    function openOrbit() {
      lastFocus = document.activeElement;
      orbit.hidden = false;
      // erzwungener Reflow statt requestAnimationFrame: garantiert, dass der
      // Browser den hidden->visible-Wechsel VOR dem Klassenwechsel committet,
      // sonst startet die Opacity-Transition in manchen Rendering-Kontexten
      // nie (rAF kann in gedrosselten/eingebetteten Views ausbleiben).
      void orbit.offsetHeight;
      orbit.classList.add('is-open');
      document.documentElement.style.overflow = 'hidden';
      btn.setAttribute('aria-expanded', 'true');
      var close = orbit.querySelector('.snav-orbit__close');
      if (close) close.focus();
    }

    function closeOrbit() {
      closeDrawer();
      orbit.classList.remove('is-open');
      document.documentElement.style.overflow = '';
      btn.setAttribute('aria-expanded', 'false');
      setTimeout(function () { orbit.hidden = true; }, 280);
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    function openDrawer() {
      if (!drawer) return;
      drawer.hidden = false;
      if (drawerScrim) drawerScrim.hidden = false;
      if (patchToggle) patchToggle.setAttribute('aria-expanded', 'true');
    }

    function closeDrawer() {
      if (!drawer || drawer.hidden) return;
      drawer.hidden = true;
      if (drawerScrim) drawerScrim.hidden = true;
      if (patchToggle) patchToggle.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', function () {
      orbit.hidden ? openOrbit() : closeOrbit();
    });
    orbit.querySelectorAll('[data-orbit-close]').forEach(function (el) {
      el.addEventListener('click', closeOrbit);
    });
    if (patchToggle) {
      patchToggle.addEventListener('click', function () {
        drawer && drawer.hidden ? openDrawer() : closeDrawer();
      });
    }
    orbit.querySelectorAll('[data-patch-close]').forEach(function (el) {
      el.addEventListener('click', closeDrawer);
    });

    addEventListener('keydown', function (e) {
      if (e.key !== 'Escape' && e.key !== 'Tab') return;
      if (orbit.hidden) return;
      if (e.key === 'Escape') {
        e.preventDefault();
        if (drawer && !drawer.hidden) closeDrawer();
        else closeOrbit();
        return;
      }
      // Fokus-Falle: Tab kreist innerhalb des Overlays statt in die Seite zu entkommen
      var items = focusable();
      if (!items.length) return;
      var first = items[0];
      var last = items[items.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  })();
</script>
