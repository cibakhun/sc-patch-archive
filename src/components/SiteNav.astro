---
// Global sticky navigation: brand monogram + breadcrumbs (left),
// Patches/Themen dropdowns + context pill (right). Replaces the per-page
// topbar. Keeps id="topbar" so existing per-page scroll JS keeps working.
// Plumbing, not a reskin: themes itself via the page's palette variables,
// no motion beyond the existing scrolled-state.
import { getCollection } from 'astro:content';
import SearchOverlay from './SearchOverlay.astro';
import { SITE } from '../consts';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs?: Crumb[];
  pill?: string;
}
const { crumbs = [], pill } = Astro.props;

// BreadcrumbList JSON-LD — the nav already knows the trail (last item = page)
const siteBase = SITE.url.replace(/\/$/, '');
const crumbLd =
  crumbs.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.label,
          item: siteBase + (c.href ?? Astro.url.pathname),
        })),
      }
    : null;

const patches = (await getCollection('patches')).sort((a, b) =>
  a.data.date.localeCompare(b.data.date)
);
// eras in chronological order of first appearance
const eras: string[] = [];
for (const p of patches) if (!eras.includes(p.data.era)) eras.push(p.data.era);
const withTopics = patches.filter((p) => p.data.topics.length > 0);
const current = Astro.url.pathname;
---
<nav class="snav" id="topbar" aria-label="Hauptnavigation">
  <div class="snav__left">
    <a class="snav__brand" href="/index.html" aria-label="SC Archiv — Startseite">
      <svg viewBox="0 0 64 64" width="24" height="24" aria-hidden="true"><path d="M32 8 52 20v24L32 56 12 44V20z" fill="none" stroke="currentColor" stroke-width="5" stroke-linejoin="round"/><circle cx="32" cy="32" r="6" fill="currentColor"/></svg>
      <span>SC·Archiv</span>
    </a>
    {crumbs.length > 0 && (
      <nav class="snav__crumbs" aria-label="Pfad">
        <ol>
          {crumbs.map((c, i) => (
            <li class={i < crumbs.length - 1 ? 'snav__mid' : undefined}>
              {c.href ? <a href={c.href}>{c.label}</a> : <span aria-current="page">{c.label}</span>}
            </li>
          ))}
        </ol>
      </nav>
    )}
  </div>
  <div class="snav__right">
    <a
      class="snav__link"
      href="/schiffe.html"
      aria-current={current === '/schiffe.html' || current.startsWith('/schiffe/') ? 'page' : undefined}
    >Schiffe</a>
    <a
      class="snav__link"
      href="/evolution.html"
      aria-current={current === '/evolution.html' ? 'page' : undefined}
    >Evolution</a>
    <button class="snav__search" type="button" data-scs-open aria-label="Suche öffnen (Strg+K)">
      <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2.4"/><line x1="15.5" y1="15.5" x2="21" y2="21" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
      <span>Suche</span>
      <kbd>Strg K</kbd>
    </button>
    <details class="snav__dd">
      <summary>Patches <span class="snav__chev" aria-hidden="true">▾</span></summary>
      <div class="snav__panel">
        {eras.map((era) => (
          <div class="snav__group">
            <div class="snav__ghead">{era}</div>
            {patches
              .filter((p) => p.data.era === era)
              .map((p) => {
                const href = `/patches/sc-${p.id}.html`;
                return (
                  <a href={href} aria-current={current === href ? 'page' : undefined}>
                    <b>{p.data.version}</b>
                    <span>{p.data.codename}</span>
                  </a>
                );
              })}
          </div>
        ))}
      </div>
    </details>
    <details class="snav__dd">
      <summary>Themen <span class="snav__chev" aria-hidden="true">▾</span></summary>
      <div class="snav__panel">
        {withTopics.map((p) => (
          <div class="snav__group">
            <div class="snav__ghead">{p.data.version} · {p.data.codename}</div>
            {p.data.topics.map((t) => {
              const href = `/topics/${t.slug}.html`;
              return (
                <a href={href} aria-current={current === href ? 'page' : undefined}>
                  <span>{t.title}</span>
                </a>
              );
            })}
          </div>
        ))}
      </div>
    </details>
    {pill && <span class="snav__pill">{pill}</span>}
  </div>
</nav>
{crumbLd && <script type="application/ld+json" set:html={JSON.stringify(crumbLd)} />}
<SearchOverlay />

<style>
  .snav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem clamp(1rem, 4vw, 2.5rem);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent);
    backdrop-filter: blur(6px);
    transition: background 0.3s;
  }
  .snav.scrolled {
    background: rgba(0, 0, 0, 0.95);
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
  }
  .snav__left {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }
  .snav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text, #e8eefc);
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .snav__brand svg {
    color: var(--accent, #2dd4ff);
    flex: none;
  }
  .snav__crumbs ol {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }
  .snav__crumbs li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-ui, sans-serif);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
  }
  .snav__crumbs li + li::before {
    content: '›';
    color: var(--muted, #8a99b8);
    opacity: 0.6;
    flex: none;
  }
  .snav__crumbs a:hover {
    color: var(--accent, #2dd4ff);
  }
  .snav__crumbs [aria-current] {
    color: var(--text, #e8eefc);
  }
  /* long leaf crumbs (ship names) truncate instead of colliding with the
     nav actions — the whole flex chain must be allowed to shrink */
  .snav__crumbs {
    min-width: 0;
  }
  .snav__crumbs li:last-child {
    /* shrinkable, but never below a readable ellipsis stub */
    min-width: 96px;
    overflow: hidden;
  }
  .snav__crumbs li:last-child [aria-current] {
    display: block;
    max-width: min(320px, 100%);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .snav__right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .snav__link {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text, #e8eefc);
    padding: 0.35rem 0.55rem;
  }
  .snav__link:hover {
    color: var(--accent, #2dd4ff);
  }
  .snav__link[aria-current] {
    color: var(--accent, #2dd4ff);
    border-bottom: 2px solid var(--accent, #2dd4ff);
  }
  .snav__search {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
    color: var(--muted, #8a99b8);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.42rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }
  .snav__search:hover {
    color: var(--accent, #2dd4ff);
    border-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
  }
  .snav__search kbd {
    font-family: inherit;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted, #8a99b8);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    background: rgba(0, 0, 0, 0.3);
    padding: 0.08rem 0.4rem;
    border-radius: 1px;
  }
  .snav__dd {
    position: relative;
  }
  .snav__dd summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text, #e8eefc);
    padding: 0.35rem 0.65rem;
    border: 1px solid transparent;
  }
  .snav__dd summary::-webkit-details-marker {
    display: none;
  }
  .snav__dd summary:hover {
    color: var(--accent, #2dd4ff);
  }
  .snav__dd[open] summary {
    color: var(--accent, #2dd4ff);
    border-color: var(--line, rgba(255, 255, 255, 0.14));
    background: rgba(0, 0, 0, 0.6);
  }
  .snav__chev {
    font-size: 0.72rem;
    opacity: 0.7;
  }
  .snav__dd[open] .snav__chev {
    display: inline-block;
    transform: rotate(180deg);
  }
  .snav__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    z-index: 9200;
    min-width: 360px;
    max-height: 68vh;
    overflow-y: auto;
    background: var(--bg-2, #0a0e18);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    border-top: 2px solid var(--accent, #2dd4ff);
    padding: 0.9rem 0 1rem;
    box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.85);
  }
  .snav__group + .snav__group {
    margin-top: 0.9rem;
  }
  .snav__ghead {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
    padding: 0.5rem 1rem 0.35rem;
    margin-bottom: 0.35rem;
  }
  .snav__panel a {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.4rem 1rem;
    font-size: 0.95rem;
    color: var(--text, #e8eefc);
    border-left: 2px solid transparent;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }
  .snav__panel a span {
    font-size: 0.9rem;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }
  .snav__panel a:hover {
    background: color-mix(in srgb, var(--accent, #2dd4ff) 6%, transparent);
    border-left-color: var(--accent, #2dd4ff);
  }
  .snav__panel a:hover span {
    color: var(--text, #e8eefc);
  }
  .snav__panel a[aria-current] {
    border-left-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 10%, transparent);
  }
  .snav__panel a[aria-current] span {
    color: var(--text, #e8eefc);
  }
  .snav__panel b {
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 0.82rem;
    color: color-mix(in srgb, var(--accent, #2dd4ff) 70%, var(--text, #e8eefc));
    min-width: 3.6rem;
    flex: none;
  }
  .snav__pill {
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    padding: 0.32rem 0.7rem;
    border-radius: 2px;
    white-space: nowrap;
  }
  /* the nav carries more links since Phase 1 (Schiffe, Evolution) — shed
     ballast in stages before anything can collide (breakpoints calibrated
     for the 18px root scale) */
  @media (max-width: 1280px) {
    .snav__pill {
      display: none;
    }
  }
  @media (max-width: 1120px) {
    /* must out-rank the `.snav__crumbs li` base rule (scoped specificity) */
    .snav__crumbs li.snav__mid {
      display: none;
    }
    /* a hidden mid still counts for `li + li` — suppress the orphaned › */
    .snav__crumbs li.snav__mid + li::before {
      display: none;
    }
  }
  @media (max-width: 860px) {
    .snav__panel {
      min-width: 270px;
    }
    .snav__search span,
    .snav__search kbd {
      display: none;
    }
    .snav__search {
      padding: 0.4rem 0.5rem;
    }
  }
</style>

<script is:inline>
  (function () {
    if (window.__snavInit) return;
    window.__snavInit = true;
    var nav = document.getElementById('topbar');
    if (!nav) return;
    addEventListener('scroll', function () {
      nav.classList.toggle('scrolled', scrollY > 40);
    }, { passive: true });
    var dds = [].slice.call(nav.querySelectorAll('details.snav__dd'));
    dds.forEach(function (d) {
      d.addEventListener('toggle', function () {
        if (d.open) dds.forEach(function (o) { if (o !== d) o.open = false; });
      });
    });
    addEventListener('click', function (e) {
      if (!nav.contains(e.target)) dds.forEach(function (d) { d.open = false; });
    });
    addEventListener('keydown', function (e) {
      if (e.key === 'Escape') dds.forEach(function (d) { d.open = false; });
    });
  })();
</script>
