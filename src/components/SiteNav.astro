---
// Global sticky navigation: brand monogram + breadcrumbs (left),
// Suche + Sprachumschalter + Menü-Dropdown (right) — eine Leiste für alle
// Breiten, das Menü trägt Bereiche + Patch-Liste. Keeps id="topbar" so
// existing per-page scroll JS keeps working.
// Plumbing, not a reskin: themes itself via the page's palette variables,
// no motion beyond the existing scrolled-state.
import { readFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import { getCollection } from 'astro:content';
import SearchOverlay from './SearchOverlay.astro';
import LangSwitcher from './LangSwitcher.astro';
import { SITE } from '../consts';
import { localeFromPath, useTranslations, href } from '../i18n/ui';
import { eraLabel } from '../i18n/patchText';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs?: Crumb[];
  pill?: string;
  /** hat DIESE Seite ein EN-Gegenstück? -> steuert den Umschalter (kein 404) */
  hasEn?: boolean;
}
const { crumbs = [], pill, hasEn = false } = Astro.props;

// Locale aus dem Pfad; t() + L() halten Chrome/Links in der aktiven Sprache.
// Für DE liefern beide exakt die bisherigen Werte -> DE-Ausgabe unverändert.
const lang = localeFromPath(Astro.url.pathname);
const t = useTranslations(lang);
const L = (p: string) => href(p, lang);

// BreadcrumbList JSON-LD — the nav already knows the trail (last item = page)
const siteBase = SITE.url.replace(/\/$/, '');
const crumbLd =
  crumbs.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.label,
          item: siteBase + (c.href ?? Astro.url.pathname),
        })),
      }
    : null;

const patches = (await getCollection('patches')).sort((a, b) =>
  a.data.date.localeCompare(b.data.date)
);
// eras in chronological order of first appearance
const eras: string[] = [];
for (const p of patches) if (!eras.includes(p.data.era)) eras.push(p.data.era);
const topicCount = patches.reduce((n, p) => n + p.data.topics.length, 0);
const current = Astro.url.pathname;

// Cache-Busting für /assets/account-lite.js: die Datei hat eine FESTE URL und
// wird von Cloudflare 1 Tag gecacht (nginx-Map: application/javascript → 1d).
// Ohne Content-Hash im Query lieferte das CDN nach einem Deploy bis zu 24 h die
// ALTE Datei — kritisch, weil dieses Skript die Auth-Session refresht und die
// Favoriten bedient. Gleiche Technik wie /assets/holo-viewer.js (?v=hash).
let acctLiteVer = 'x';
try {
  acctLiteVer = createHash('sha1').update(readFileSync('assets/account-lite.js')).digest('hex').slice(0, 8);
} catch { /* dev-Fallback */ }
const acctLiteSrc = `/assets/account-lite.js?v=${acctLiteVer}`;
---
<nav class="snav" id="topbar" aria-label={t('nav.main')}>
  <div class="snav__left">
    <a class="snav__brand" href={L('/index.html')} aria-label={t('nav.home.aria')}>
      <svg viewBox="0 0 64 64" width="24" height="24" aria-hidden="true"><path d="M32 8 52 20v24L32 56 12 44V20z" fill="none" stroke="currentColor" stroke-width="5" stroke-linejoin="round"/><circle cx="32" cy="32" r="6" fill="currentColor"/></svg>
      <span>Verse·Base</span>
    </a>
    {crumbs.length > 0 && (
      <nav class="snav__crumbs" aria-label={t('nav.path')}>
        <ol>
          {crumbs.map((c, i) => (
            <li class={i < crumbs.length - 1 ? 'snav__mid' : undefined}>
              {c.href ? <a href={c.href}>{c.label}</a> : <span aria-current="page">{c.label}</span>}
            </li>
          ))}
        </ol>
      </nav>
    )}
  </div>
  <div class="snav__right">
    <button class="snav__search" type="button" data-scs-open aria-label={t('nav.search.open')}>
      <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2.4"/><line x1="15.5" y1="15.5" x2="21" y2="21" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
      <span>{t('nav.search')}</span>
      <kbd>{t('nav.search.kbd')}</kbd>
    </button>
    {pill && <span class="snav__pill">{pill}</span>}
    <a
      class="snav__acct js-nav-acct"
      href={L('/account/login.html')}
      data-login={L('/account/login.html')}
      data-dash={L('/account.html')}
      data-l-login={t('nav.account.login')}
      data-l-acct={t('nav.account')}
      aria-label={t('nav.account.aria')}
    >
      <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span class="js-nav-acct-txt">{t('nav.account.login')}</span>
    </a>
    <LangSwitcher hasEn={hasEn} />
    <details class="snav__dd snav__menu">
      <summary aria-label={t('nav.menu.open')}>
        <svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
        <span>{t('nav.menu')}</span>
      </summary>
      <div class="snav__panel">
        <!-- Werkzeuge — dieselben sechs Tools wie auf der Startseite, gleiche Reihenfolge -->
        <div class="snav__group">
          <div class="snav__ghead">{t('nav.grp.tools')}</div>
          <a href={L('/item-finder.html')} aria-current={current === L('/item-finder.html') ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>Item Finder</span>
          </a>
          <a href={L('/missionen.html')} aria-current={current.includes('/missionen') ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><path d="M12 1v4M12 19v4M1 12h4M19 12h4"/></svg>
            <span>{t('nav.missions')}</span>
          </a>
          <a href={L('/topics/mining.html')} aria-current={current.includes('/topics/mining') ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 12L2 9z"/></svg>
            <span>Mining</span>
          </a>
          <a href={L('/topics/crafting.html')} aria-current={current === L('/topics/crafting.html') ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
            <span>Crafting</span>
          </a>
          <a href={L('/topics/wikelo-emporium.html')} aria-current={current === L('/topics/wikelo-emporium.html') ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
            <span>Wikelo's Emporium</span>
          </a>
          <a href={L('/schiffe.html')} aria-current={current === L('/schiffe.html') || current.startsWith(L('/schiffe/')) ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h9l1-6 1 6h9L12 2z"/></svg>
            <span>{t('nav.ships')}</span>
          </a>
          <a href={L('/evolution.html')} aria-current={current === L('/evolution.html') ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>
            <span>{t('nav.evolution')}</span>
          </a>
        </div>

        <!-- Archiv — Themen-Verzeichnis + Patch-Liste (einklappbar) -->
        <div class="snav__group">
          <div class="snav__ghead">{t('nav.grp.archive')}</div>
          <a href={L('/archiv.html')} aria-current={current === L('/archiv.html') ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v13H3V8M1 3h22v5H1zM10 12h4"/></svg>
            <span>{t('nav.archive')}</span>
          </a>
          <a href={L('/archiv.html#themen')}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/></svg>
            <span>{t('nav.allTopics')} ({topicCount})</span>
          </a>
          <a href={L('/downloads.html')} aria-current={current === L('/downloads.html') ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
            <span>{t('nav.downloads')}</span>
          </a>
          <a href={L('/feedback.html')} aria-current={current === L('/feedback.html') ? 'page' : undefined}>
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
            <span>{t('nav.feedback')}</span>
          </a>
          <a
            class="js-nav-acct"
            href={L('/account/login.html')}
            data-login={L('/account/login.html')}
            data-dash={L('/account.html')}
            data-l-login={t('nav.account.login')}
            data-l-acct={t('nav.account')}
            aria-current={current.includes('/account/') ? 'page' : undefined}
          >
            <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span class="js-nav-acct-txt">{t('nav.account.login')}</span>
          </a>
          <details class="snav__sub-details" open={current.includes('/patches/') ? true : undefined}>
            <summary class="snav__sub-summary">
              <svg class="snav__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82zM7 7h.01"/></svg>
              <span>{t('nav.patches')}</span>
              <svg class="snav__sub-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="snav__sub-content-patches">
              {eras.map((era) => (
                <div class="snav__eragrp">
                  <div class="snav__eralabel">{eraLabel(era, lang)}</div>
                  {patches
                    .filter((p) => p.data.era === era)
                    .map((p) => {
                      const ph = L(`/patches/sc-${p.id}.html`);
                      return (
                        <a class="snav__patchrow" href={ph} aria-current={current === ph ? 'page' : undefined}>
                          <b>{p.data.version}</b>
                          <span>{p.data.codename}</span>
                        </a>
                      );
                    })}
                </div>
              ))}
            </div>
          </details>
        </div>

        <div class="snav__group snav__langgroup">
          <div class="snav__ghead">{t('nav.langSwitch')}</div>
          <LangSwitcher hasEn={hasEn} />
        </div>
      </div>
    </details>
  </div>
</nav>
{crumbLd && <script type="application/ld+json" set:html={JSON.stringify(crumbLd)} />}
<SearchOverlay lang={lang} />
{/* Konto-Status + Favoriten-Sterne (leichtgewichtig, ohne supabase-js).
    ?v=<contenthash> bricht den 1-Tag-CDN-Cache bei jeder Änderung. */}
<script is:inline src={acctLiteSrc} defer></script>

<style>
  .snav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem clamp(1rem, 4vw, 2.5rem);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent);
    backdrop-filter: blur(6px);
    transition: background 0.3s;
  }
  .snav.scrolled {
    background: rgba(0, 0, 0, 0.95);
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
  }
  .snav__left {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }
  .snav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text, #e8eefc);
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .snav__brand svg {
    color: var(--accent, #2dd4ff);
    flex: none;
  }
  .snav__crumbs ol {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }
  .snav__crumbs li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-ui, sans-serif);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    white-space: nowrap;
  }
  .snav__crumbs li + li::before {
    content: '›';
    color: var(--muted, #8a99b8);
    opacity: 0.6;
    flex: none;
  }
  .snav__crumbs a:hover {
    color: var(--accent, #2dd4ff);
  }
  .snav__crumbs [aria-current] {
    color: var(--text, #e8eefc);
  }
  /* long leaf crumbs (ship names) truncate instead of colliding with the
     nav actions — the whole flex chain must be allowed to shrink */
  .snav__crumbs {
    min-width: 0;
  }
  .snav__crumbs li:last-child {
    /* shrinkable, but never below a readable ellipsis stub */
    min-width: 96px;
    overflow: hidden;
  }
  .snav__crumbs li:last-child [aria-current] {
    display: block;
    max-width: min(320px, 100%);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .snav__right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .snav__search {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
    color: var(--muted, #8a99b8);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.42rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }
  /* Suchlabel + Lupe sind dauerhaft blau (Akzent); nur der Tastenkürzel-
     Hinweis (kbd) bleibt grau. */
  .snav__search svg,
  .snav__search span {
    color: var(--accent, #2dd4ff);
  }
  .snav__search:hover {
    color: var(--accent, #2dd4ff);
    border-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
  }
  .snav__search kbd {
    font-family: inherit;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted, #8a99b8);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    background: rgba(0, 0, 0, 0.3);
    padding: 0.08rem 0.4rem;
    border-radius: 1px;
  }
  /* Konto-Schaltfläche im Header — Optik wie die Suche; account-lite.js
     schaltet Ziel + Label (Login <-> Konto) und setzt .is-authed */
  .snav__acct {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
    color: var(--muted, #8a99b8);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.42rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }
  .snav__acct:hover {
    color: var(--accent, #2dd4ff);
    border-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
  }
  .snav__acct.is-authed {
    color: var(--accent, #2dd4ff);
  }
  .snav__acct.is-authed svg {
    color: var(--accent, #2dd4ff);
  }
  .snav__dd {
    position: relative;
  }
  /* nur die oberste Menü-Schaltfläche (direktes Kind) — verschachtelte
     Klapp-Summaries im Panel behalten ihren eigenen Zeilen-Stil */
  .snav__dd > summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text, #e8eefc);
    padding: 0.35rem 0.65rem;
    border: 1px solid transparent;
  }
  .snav__dd > summary::-webkit-details-marker {
    display: none;
  }
  .snav__dd > summary:hover {
    color: var(--accent, #2dd4ff);
  }
  .snav__dd[open] > summary {
    color: var(--accent, #2dd4ff);
    border-color: var(--line, rgba(255, 255, 255, 0.14));
    background: rgba(0, 0, 0, 0.6);
  }
  .snav__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    z-index: 9200;
    min-width: 360px;
    max-height: 68vh;
    overflow-y: auto;
    background: var(--bg-2, #0a0e18);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
    border-top: 2px solid var(--accent, #2dd4ff);
    padding: 0.9rem 0 1rem;
    box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.85);
  }
  /* Sub-details (Mining / Patches collapsible groups) */
  .snav__sub-details {
    display: block;
    margin: 0;
  }
  /* Klapp-Summary sieht aus wie eine normale Panel-Zeile (Icon links, Label,
     Chevron rechts) — keine Sonder-Pille mehr */
  .snav__sub-summary {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 1rem;
    font-size: 0.95rem;
    color: var(--text, #e8eefc);
    cursor: pointer;
    list-style: none;
    user-select: none;
    border-left: 2px solid transparent;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    outline: none;
  }
  .snav__sub-summary::-webkit-details-marker {
    display: none;
  }
  .snav__sub-summary span {
    font-size: 0.95rem;
    color: var(--text, #e8eefc);
  }
  .snav__sub-arrow {
    margin-left: auto;
    flex: none;
    transition: transform 0.2s;
  }
  .snav__sub-summary:hover {
    background: color-mix(in srgb, var(--accent, #2dd4ff) 6%, transparent);
    border-left-color: var(--accent, #2dd4ff);
  }
  .snav__sub-details[open] > .snav__sub-summary .snav__sub-arrow {
    transform: rotate(180deg);
  }
  .snav__sub-content {
    display: flex;
    flex-direction: column;
    padding-left: 1rem;
    margin: 0.2rem 0;
    border-left: 1px solid var(--line, rgba(255, 255, 255, 0.1));
  }
  .snav__sub-content-patches {
    padding-left: 0.5rem;
    max-height: 40vh;
    overflow-y: auto;
    border-left: 1px solid var(--line, rgba(255, 255, 255, 0.1));
    margin-top: 0.3rem;
  }
  .snav__group + .snav__group {
    margin-top: 0.9rem;
  }
  .snav__ghead {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
    padding: 0.5rem 1rem 0.35rem;
    margin-bottom: 0.35rem;
  }
