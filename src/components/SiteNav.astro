---
// Global sticky navigation: Burger-Menü + Suche (links), Marke mittig,
// Sprachumschalter + Konto (rechts) — eine Leiste für alle Breiten. Das Menü
// ist ein Vollbild-Overlay („Ops-Terminal") mit vier Gruppen-Panels; alle
// Einträge sind gleichzeitig sichtbar, mit Untertitel und Tastatur-Navigation.
// Keeps id="topbar" so existing per-page scroll JS keeps working. Breadcrumbs
// werden nicht mehr im Header angezeigt, das BreadcrumbList-JSON-LD für SEO
// bleibt aber (crumbLd). Themt sich über die Palette-Variablen der Seite.
import { readFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import { getCollection } from 'astro:content';
import SearchOverlay from './SearchOverlay.astro';
import LangSwitcher from './LangSwitcher.astro';
import { SITE } from '../consts';
import { localeFromPath, useTranslations, href } from '../i18n/ui';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs?: Crumb[];
  /**
   * @deprecated Wird NICHT mehr gerendert. Das kleine Rahmen-Label oben rechts
   * („TOPIC · DATABASE", „ACCOUNT" …) war redundant zu Breadcrumb + Menü und
   * wurde entfernt. Der Prop bleibt akzeptiert, damit die ~100 aufrufenden
   * Seiten nicht brechen — der Wert wird schlicht ignoriert.
   */
  pill?: string;
  /** hat DIESE Seite ein EN-Gegenstück? -> steuert den Umschalter (kein 404) */
  hasEn?: boolean;
}
const { crumbs = [], hasEn = false } = Astro.props;

// Locale aus dem Pfad; t() + L() halten Chrome/Links in der aktiven Sprache.
// Für DE liefern beide exakt die bisherigen Werte -> DE-Ausgabe unverändert.
const lang = localeFromPath(Astro.url.pathname);
const t = useTranslations(lang);
const L = (p: string) => href(p, lang);

// BreadcrumbList JSON-LD — the nav already knows the trail (last item = page)
const siteBase = SITE.url.replace(/\/$/, '');
const crumbLd =
  crumbs.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.label,
          item: siteBase + (c.href ?? Astro.url.pathname),
        })),
      }
    : null;

const patches = (await getCollection('patches')).sort((a, b) =>
  a.data.date.localeCompare(b.data.date)
);
const topicCount = patches.reduce((n, p) => n + p.data.topics.length, 0);
const current = Astro.url.pathname;

// Menü-Overlay („Ops-Terminal"): vier fachliche Gruppen, jede als eigenes
// Panel mit Kopfzeile, Zähler und Zeilen. Jede Zeile trägt Label UND einen
// kurzen Untertitel — das Menü erklärt sich damit selbst, statt nur Icons zu
// zeigen. Gruppen unterscheiden sich über Farbe (--gc) UND Icon-Rahmenform
// (--shape, clip-path), nicht nur über Farbe allein.
// `icon` ist der rohe <path>/<circle>-Rumpf (kompiliert, keine Nutzereingabe)
// -> via set:html in den <svg>-Slot injiziert.
interface DeckItem {
  href: string;
  label: string;
  sub: string;
  icon: string;
  current: boolean;
  /** Konto-Zeile: account-lite.js tauscht Label + Ziel je nach Session */
  account?: boolean;
}
interface DeckGroup {
  id: string;
  label: string;
  color: string;
  /** clip-path des Icon-Rahmens — zweite Unterscheidungsebene neben der Farbe */
  shape: string;
  items: DeckItem[];
}
const deckGroups: DeckGroup[] = [
  {
    id: 'mining',
    label: t('nav.deck.grp.mining'),
    color: 'var(--gold, #d4af37)',
    shape: 'polygon(25% 0%,75% 0%,100% 50%,75% 100%,25% 100%,0% 50%)',
    items: [
      {
        href: L('/topics/mining.html'),
        label: 'Mining',
        sub: t('nav.deck.sub.mining'),
        current: current.includes('/topics/mining'),
        icon: '<path d="M6 3h12l4 6-10 12L2 9z"/>',
      },
      {
        href: L('/refinery.html'),
        label: 'Refinery',
        sub: t('nav.deck.sub.refinery'),
        current: current === L('/refinery.html'),
        icon: '<path d="M9 3h6M10 3v5.5L4.6 19A1.4 1.4 0 0 0 5.8 21h12.4a1.4 1.4 0 0 0 1.2-2L14 8.5V3"/><path d="M7.5 15h9"/>',
      },
      {
        href: L('/precision-jump.html'),
        label: 'Precision Jump',
        sub: t('nav.deck.sub.jump'),
        current: current === L('/precision-jump.html'),
        icon: '<circle cx="12" cy="12" r="8"/><path d="M12 1.5v3M12 19.5v3M1.5 12h3M19.5 12h3"/><circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none"/>',
      },
    ],
  },
  {
    id: 'gear',
    label: t('nav.deck.grp.gear'),
    color: 'var(--accent, #2dd4ff)',
    shape: 'circle(50% at 50% 50%)',
    items: [
      {
        href: L('/schiffe.html'),
        label: t('nav.ships'),
        sub: t('nav.deck.sub.ships'),
        current: current === L('/schiffe.html') || current.startsWith(L('/schiffe/')),
        icon: '<path d="M12 2L2 22h9l1-6 1 6h9L12 2z"/>',
      },
      {
        href: L('/missionen.html'),
        label: t('nav.missions'),
        sub: t('nav.deck.sub.missions'),
        current: current.includes('/missionen'),
        icon: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><path d="M12 1v4M12 19v4M1 12h4M19 12h4"/>',
      },
      {
        href: L('/item-finder.html'),
        label: 'Item Finder',
        sub: t('nav.deck.sub.items'),
        current: current === L('/item-finder.html'),
        icon: '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
      },
      {
        href: L('/topics/crafting.html'),
        label: 'Crafting',
        sub: t('nav.deck.sub.crafting'),
        current: current === L('/topics/crafting.html'),
        icon: '<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>',
      },
      {
        href: L('/topics/wikelo-emporium.html'),
        label: "Wikelo's Emporium",
        sub: t('nav.deck.sub.wikelo'),
        current: current === L('/topics/wikelo-emporium.html'),
        icon: '<path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/>',
      },
    ],
  },
  {
    id: 'archive',
    label: t('nav.deck.grp.archive'),
    color: 'var(--accent-2, #6ea8ff)',
    shape: 'polygon(50% 0%,100% 50%,50% 100%,0% 50%)',
    items: [
      {
        href: L('/archiv.html'),
        label: t('nav.archive'),
        sub: t('nav.deck.sub.archive'),
        current: current === L('/archiv.html'),
        icon: '<path d="M21 8v13H3V8M1 3h22v5H1zM10 12h4"/>',
      },
      {
        href: L('/archiv.html#themen'),
        label: t('nav.allTopics'),
        sub: `${t('nav.deck.sub.topics')} · ${topicCount}`,
        current: false,
        icon: '<path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/>',
      },
      {
        href: L('/evolution.html'),
        label: t('nav.evolution'),
        sub: t('nav.deck.sub.evolution'),
        current: current === L('/evolution.html'),
        icon: '<path d="M3 3v18h18M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/>',
      },
    ],
  },
  {
    id: 'account',
    label: t('nav.deck.grp.account'),
    color: '#3ddc84',
    shape: 'inset(0% round 9px)',
    items: [
      {
        account: true,
        href: L('/account/login.html'),
        label: t('nav.account.login'),
        sub: t('nav.deck.sub.account'),
        current: current.includes('/account/'),
        icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
      },
      {
        href: L('/downloads.html'),
        label: t('nav.downloads'),
        sub: t('nav.downloads.sub'),
        current: current === L('/downloads.html'),
        icon: '<path d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/>',
      },
      {
        href: L('/feedback.html'),
        label: t('nav.feedback'),
        sub: t('nav.deck.sub.feedback'),
        current: current === L('/feedback.html'),
        icon: '<path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>',
      },
    ],
  },
];
// laufender Index über alle Gruppen hinweg -> treibt die gestaffelte
// Reveal-Animation (jede Zeile startet etwas später als die vorige)
let deckSeq = 0;

// Cache-Busting für /assets/account-lite.js: die Datei hat eine FESTE URL und
// wird von Cloudflare 1 Tag gecacht (nginx-Map: application/javascript → 1d).
// Ohne Content-Hash im Query lieferte das CDN nach einem Deploy bis zu 24 h die
// ALTE Datei — kritisch, weil dieses Skript die Auth-Session refresht und die
// Favoriten bedient. Gleiche Technik wie /assets/holo-viewer.js (?v=hash).
let acctLiteVer = 'x';
try {
  acctLiteVer = createHash('sha1').update(readFileSync('assets/account-lite.js')).digest('hex').slice(0, 8);
} catch { /* dev-Fallback */ }
const acctLiteSrc = `/assets/account-lite.js?v=${acctLiteVer}`;
---
<nav class="snav" id="topbar" aria-label={t('nav.main')}>
  <div class="snav__left">
    <button
      class="snav__menu-btn"
      id="snavMenuBtn"
      type="button"
      aria-haspopup="dialog"
      aria-expanded="false"
      aria-controls="snavDeck"
      aria-label={t('nav.menu.open')}
    >
      <svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
      <span>{t('nav.menu')}</span>
    </button>
    <button class="snav__search" type="button" data-scs-open aria-label={t('nav.search.open')}>
      <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2.4"/><line x1="15.5" y1="15.5" x2="21" y2="21" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
      <span>{t('nav.search')}</span>
      <kbd>{t('nav.search.kbd')}</kbd>
    </button>
  </div>
  <div class="snav__center">
    <a class="snav__brand" href={L('/index.html')} aria-label={t('nav.home.aria')}>
      <svg viewBox="0 0 64 64" width="24" height="24" aria-hidden="true"><path d="M32 8 52 20v24L32 56 12 44V20z" fill="none" stroke="currentColor" stroke-width="5" stroke-linejoin="round"/><circle cx="32" cy="32" r="6" fill="currentColor"/></svg>
      <span>Verse·Base</span>
    </a>
  </div>
  <div class="snav__right">
    <LangSwitcher hasEn={hasEn} />
    <a
      class="snav__acct js-nav-acct"
      href={L('/account/login.html')}
      data-login={L('/account/login.html')}
      data-dash={L('/account.html')}
      data-l-login={t('nav.account.login')}
      data-l-acct={t('nav.account')}
      aria-label={t('nav.account.aria')}
    >
      <span class="snav__acct-icon">
        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span class="snav__acct-dot" aria-hidden="true"></span>
      </span>
      <span class="js-nav-acct-txt">{t('nav.account.login')}</span>
    </a>
  </div>
</nav>

<!-- Menü-Overlay („Ops-Terminal"): Vollbild-Takeover mit vier Gruppen-Panels.
     Alles ist gleichzeitig sichtbar und horizontal lesbar (kein abgeschnittener
     Text), jede Zeile trägt Label + Untertitel. Reveal läuft gestaffelt über
     --seq (laufender Index quer über alle Gruppen). -->
<div class="snav-deck" id="snavDeck" hidden role="dialog" aria-modal="true" aria-label={t('nav.menu')}>
  <div class="snav-deck__back" data-deck-close></div>
  <div class="snav-deck__frame">
    <header class="snav-deck__head">
      <a class="snav-deck__brand" href={L('/index.html')} aria-label={t('nav.home.aria')}>
        <svg viewBox="0 0 64 64" width="26" height="26" aria-hidden="true"><path d="M32 8 52 20v24L32 56 12 44V20z" fill="none" stroke="currentColor" stroke-width="5" stroke-linejoin="round"/><circle cx="32" cy="32" r="6" fill="currentColor"/></svg>
        <span class="snav-deck__wordmark">Verse·Base</span>
        <span class="snav-deck__eyebrow">{t('nav.deck.title')}</span>
      </a>
      <button class="snav-deck__close" type="button" data-deck-close aria-label={t('nav.menu.close')}>
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 5l14 14M19 5L5 19" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
        <kbd>Esc</kbd>
      </button>
    </header>

    <div class="snav-deck__grid">
      {deckGroups.map((group) => (
        <section class="snav-deck__panel" style={`--gc:${group.color}; --shape:${group.shape}`}>
          <h2 class="snav-deck__ghead">
            <span class="snav-deck__gname">{group.label}</span>
            <span class="snav-deck__gcount">{String(group.items.length).padStart(2, '0')}</span>
          </h2>
          <ul class="snav-deck__list">
            {group.items.map((item) => {
              const seq = deckSeq++;
              const acct = item.account;
              return (
                <li>
                  <a
                    class={acct ? 'snav-deck__row js-nav-acct' : 'snav-deck__row'}
                    style={`--seq:${seq}`}
                    href={item.href}
                    data-deck-row
                    aria-current={item.current ? 'page' : undefined}
                    data-login={acct ? L('/account/login.html') : undefined}
                    data-dash={acct ? L('/account.html') : undefined}
                    data-l-login={acct ? t('nav.account.login') : undefined}
                    data-l-acct={acct ? t('nav.account') : undefined}
                  >
                    <span class={acct ? 'snav-deck__icon snav__acct-icon' : 'snav-deck__icon'}>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
                      {acct && <span class="snav__acct-dot" aria-hidden="true"></span>}
                    </span>
                    <span class="snav-deck__text">
                      <span class={acct ? 'snav-deck__label js-nav-acct-txt' : 'snav-deck__label'}>{item.label}</span>
                      <span class="snav-deck__sub">{item.sub}</span>
                    </span>
                    <svg class="snav-deck__go" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M12 5l7 7-7 7"/></svg>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </div>

    <footer class="snav-deck__foot">
      <LangSwitcher hasEn={hasEn} />
      <div class="snav-deck__hints" aria-hidden="true">
        <span><kbd>↑</kbd><kbd>↓</kbd><kbd>←</kbd><kbd>→</kbd> {t('nav.deck.hint.nav')}</span>
        <span><kbd>↵</kbd> {t('nav.deck.hint.open')}</span>
        <span><kbd>Esc</kbd> {t('nav.deck.hint.close')}</span>
      </div>
    </footer>
  </div>
</div>
{crumbLd && <script type="application/ld+json" set:html={JSON.stringify(crumbLd)} />}
<SearchOverlay lang={lang} />
{/* Konto-Status + Favoriten-Sterne (leichtgewichtig, ohne supabase-js).
    ?v=<contenthash> bricht den 1-Tag-CDN-Cache bei jeder Änderung. */}
<script is:inline src={acctLiteSrc} defer></script>

<style>
  .snav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9100;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 0.7rem clamp(1rem, 4vw, 2.5rem);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent);
    backdrop-filter: blur(6px);
    transition: background 0.3s;
  }
  .snav.scrolled {
    background: rgba(0, 0, 0, 0.95);
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
  }
  /* left = burger + search, center = brand (true visual center regardless of
     how wide the left/right groups are), right = lang + account */
  .snav__left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    justify-self: start;
  }
  .snav__center {
    justify-self: center;
  }
  .snav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text, #e8eefc);
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .snav__brand svg {
    color: var(--accent, #2dd4ff);
    flex: none;
  }
  .snav__right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    justify-self: end;
  }
  .snav__search {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
    color: var(--muted, #8a99b8);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.42rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }
  /* Suchlabel + Lupe sind dauerhaft blau (Akzent); nur der Tastenkürzel-
     Hinweis (kbd) bleibt grau. */
  .snav__search svg,
  .snav__search span {
    color: var(--accent, #2dd4ff);
  }
  .snav__search:hover {
    color: var(--accent, #2dd4ff);
    border-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
  }
  .snav__search kbd {
    font-family: inherit;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted, #8a99b8);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    background: rgba(0, 0, 0, 0.3);
    padding: 0.08rem 0.4rem;
    border-radius: 1px;
  }
  /* Konto-Schaltfläche im Header — Optik wie die Suche; account-lite.js
     schaltet Ziel + Label (Login <-> Konto) und setzt .is-authed */
  .snav__acct {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
    color: var(--muted, #8a99b8);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.42rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }
  .snav__acct:hover {
    color: var(--accent, #2dd4ff);
    border-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
  }
  .snav__acct.is-authed {
    color: var(--accent, #2dd4ff);
  }
  .snav__acct.is-authed svg {
    color: var(--accent, #2dd4ff);
  }
  /* Anzeigename statt "Konto" kann lang werden — nicht den Header sprengen */
  .snav__acct .js-nav-acct-txt {
    max-width: 12ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  /* kleiner "online"-Punkt am Konto-Icon — deutlicheres Signal für „eingeloggt"
     als nur die Textfarbe, bewusst grün statt Akzent-Cyan (kein Verwechseln
     mit Hover-Zustand) */
  .snav__acct-icon {
    position: relative;
    display: inline-flex;
  }
  .snav__acct-dot {
    display: none;
    position: absolute;
    top: -3px;
    right: -3px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #3ddc84;
    border: 1.5px solid var(--bg, #05070d);
  }
  .js-nav-acct.is-authed .snav__acct-dot {
    display: block;
  }
  /* Burger — schlichter Button (öffnet das Menü-Overlay, kein <details> mehr) */
  .snav__menu-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text, #e8eefc);
    padding: 0.35rem 0.65rem;
    border: 1px solid transparent;
    background: none;
  }
  .snav__menu-btn:hover {
    color: var(--accent, #2dd4ff);
  }
  .snav__menu-btn[aria-expanded='true'] {
    color: var(--accent, #2dd4ff);
    border-color: var(--line, rgba(255, 255, 255, 0.14));
    background: rgba(0, 0, 0, 0.6);
  }
  @media (max-width: 860px) {
    .snav__search span,
    .snav__search kbd {
      display: none;
    }
    .snav__search {
      padding: 0.4rem 0.5rem;
    }
    /* Konto wandert bei schmalen Breiten ins Orbital-Menü (innerer Ring) */
    .snav__acct {
      display: none;
    }
  }
  /* small phones: the burger keeps its icon, the label goes — otherwise
     brand + actions exceed the viewport and overlap */
  @media (max-width: 420px) {
    .snav__menu-btn span {
