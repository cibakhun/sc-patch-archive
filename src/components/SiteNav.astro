      flex: 1;
      min-width: 0;
      max-width: none;
      text-align: left;
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
      font-size: 0.92rem;
    }
    .snav-orbit__lang {
      position: static;
      transform: none;
      display: flex;
      justify-content: center;
      margin: 0.5rem auto 0;
