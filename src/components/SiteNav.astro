---
// Global sticky navigation: Burger-Menü + Suche (links), Marke mittig,
// Sprachumschalter + Konto (rechts) — eine Leiste für alle Breiten, das Menü
// trägt Bereiche + Patch-Liste. Keeps id="topbar" so existing per-page scroll
// JS keeps working. Breadcrumbs werden nicht mehr im Header angezeigt, das
// BreadcrumbList-JSON-LD für SEO bleibt aber (crumbLd).
// Plumbing, not a reskin: themes itself via the page's palette variables,
// no motion beyond the existing scrolled-state.
import { readFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import { getCollection } from 'astro:content';
import SearchOverlay from './SearchOverlay.astro';
import LangSwitcher from './LangSwitcher.astro';
import { SITE } from '../consts';
import { localeFromPath, useTranslations, href } from '../i18n/ui';
import { eraLabel } from '../i18n/patchText';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs?: Crumb[];
  /**
   * @deprecated Wird NICHT mehr gerendert. Das kleine Rahmen-Label oben rechts
   * („TOPIC · DATABASE", „ACCOUNT" …) war redundant zu Breadcrumb + Menü und
   * wurde entfernt. Der Prop bleibt akzeptiert, damit die ~100 aufrufenden
   * Seiten nicht brechen — der Wert wird schlicht ignoriert.
   */
  pill?: string;
  /** hat DIESE Seite ein EN-Gegenstück? -> steuert den Umschalter (kein 404) */
  hasEn?: boolean;
}
const { crumbs = [], hasEn = false } = Astro.props;

// Locale aus dem Pfad; t() + L() halten Chrome/Links in der aktiven Sprache.
// Für DE liefern beide exakt die bisherigen Werte -> DE-Ausgabe unverändert.
const lang = localeFromPath(Astro.url.pathname);
const t = useTranslations(lang);
const L = (p: string) => href(p, lang);

// BreadcrumbList JSON-LD — the nav already knows the trail (last item = page)
const siteBase = SITE.url.replace(/\/$/, '');
const crumbLd =
  crumbs.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.label,
          item: siteBase + (c.href ?? Astro.url.pathname),
        })),
      }
    : null;

const patches = (await getCollection('patches')).sort((a, b) =>
  a.data.date.localeCompare(b.data.date)
);
// eras in chronological order of first appearance
const eras: string[] = [];
for (const p of patches) if (!eras.includes(p.data.era)) eras.push(p.data.era);
const topicCount = patches.reduce((n, p) => n + p.data.topics.length, 0);
const current = Astro.url.pathname;

// Orbital-Menü: Items sind fachlich GRUPPIERT statt in Ad-hoc-Reihenfolge
// verteilt — pro Gruppe eine Winkel-Lücke (gapDeg) + eine Akzentfarbe (--gc),
// damit auf den ersten Blick erkennbar ist, welche Einträge zusammengehören.
// layoutRing() verteilt Items gleichmäßig INNERHALB einer Gruppe und reserviert
// gapDeg an jeder Gruppengrenze: stepDeg*(Items-Gruppen) + gapDeg*Gruppen = 360.
// `icon` ist der rohe <path>/<circle>-Rumpf (kompiliert, keine Nutzereingabe)
// -> via set:html in den <svg>-Slot injiziert.
interface OrbitItem {
  href: string;
  label: string;
  icon: string;
  current: boolean;
}
interface LaidOutItem extends OrbitItem {
  angle: number;
  group: number;
}
function layoutRing<T>(groups: T[][], gapDeg: number): (T & { angle: number; group: number })[] {
  const totalItems = groups.reduce((n, g) => n + g.length, 0);
  const intraEdges = totalItems - groups.length;
  const stepDeg = (360 - groups.length * gapDeg) / intraEdges;
  let angle = 0;
  const out: (T & { angle: number; group: number })[] = [];
  groups.forEach((group, gi) => {
    group.forEach((item, ii) => {
      if (gi > 0 && ii === 0) angle += gapDeg;
      else if (ii > 0) angle += stepDeg;
      out.push({ ...item, angle, group: gi });
    });
  });
  return out;
}
const GROUP_COLOR = ['var(--accent, #2dd4ff)', 'var(--accent-2, #6ea8ff)'];

// äußerer Ring: „Nachschlagen" (Datenbanken/Referenz) vs. „Vor Ort" (aktive
// Feld-/Wirtschaftswerkzeuge) — zwei fachliche Cluster statt Ad-hoc-Reihenfolge.
const toolLookupGroup: OrbitItem[] = [
  {
    href: L('/item-finder.html'),
    label: 'Item Finder',
    current: current === L('/item-finder.html'),
    icon: '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  },
  {
    href: L('/missionen.html'),
    label: t('nav.missions'),
    current: current.includes('/missionen'),
    icon: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><path d="M12 1v4M12 19v4M1 12h4M19 12h4"/>',
  },
  {
    href: L('/schiffe.html'),
    label: t('nav.ships'),
    current: current === L('/schiffe.html') || current.startsWith(L('/schiffe/')),
    icon: '<path d="M12 2L2 22h9l1-6 1 6h9L12 2z"/>',
  },
  {
    href: L('/topics/wikelo-emporium.html'),
    label: "Wikelo's Emporium",
    current: current === L('/topics/wikelo-emporium.html'),
    icon: '<path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/>',
  },
  {
    href: L('/evolution.html'),
    label: t('nav.evolution'),
    current: current === L('/evolution.html'),
    icon: '<path d="M3 3v18h18M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/>',
  },
];
const toolFieldGroup: OrbitItem[] = [
  {
    href: L('/topics/mining.html'),
    label: 'Mining',
    current: current.includes('/topics/mining'),
    icon: '<path d="M6 3h12l4 6-10 12L2 9z"/>',
  },
  {
    href: L('/refinery.html'),
    label: 'Refinery',
    current: current === L('/refinery.html'),
    icon: '<path d="M9 3h6M10 3v5.5L4.6 19A1.4 1.4 0 0 0 5.8 21h12.4a1.4 1.4 0 0 0 1.2-2L14 8.5V3"/><path d="M7.5 15h9"/>',
  },
  {
    href: L('/precision-jump.html'),
    label: 'Precision Jump',
    current: current === L('/precision-jump.html'),
    icon: '<circle cx="12" cy="12" r="8"/><path d="M12 1.5v3M12 19.5v3M1.5 12h3M19.5 12h3"/><circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none"/>',
  },
  {
    href: L('/topics/crafting.html'),
    label: 'Crafting',
    current: current === L('/topics/crafting.html'),
    icon: '<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>',
  },
];
const toolItems: LaidOutItem[] = layoutRing([toolLookupGroup, toolFieldGroup], 56);

// innerer Ring: „Archiv" (Patch-/Themen-Historie inkl. Patches-Drawer) vs.
// „Konto & mehr" (Downloads/Feedback/Konto). Konto + Patches bleiben
// Sonderfälle (`kind`), laufen aber durch denselben Render-Loop wie die Links.
interface InnerItem extends OrbitItem {
  kind: 'link' | 'account' | 'patches';
}
const archiveGroup: InnerItem[] = [
  {
    kind: 'link',
    href: L('/archiv.html'),
    label: t('nav.archive'),
    current: current === L('/archiv.html'),
    icon: '<path d="M21 8v13H3V8M1 3h22v5H1zM10 12h4"/>',
  },
  {
    kind: 'link',
    href: L('/archiv.html#themen'),
    label: `${t('nav.allTopics')} (${topicCount})`,
    current: false,
    icon: '<path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/>',
  },
  {
    kind: 'patches',
    href: '',
    label: t('nav.patches'),
    current: current.includes('/patches/'),
    icon: '<path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82zM7 7h.01"/>',
  },
];
const metaGroup: InnerItem[] = [
  {
    kind: 'link',
    href: L('/downloads.html'),
    label: t('nav.downloads'),
    current: current === L('/downloads.html'),
    icon: '<path d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/>',
  },
  {
    kind: 'link',
    href: L('/feedback.html'),
    label: t('nav.feedback'),
    current: current === L('/feedback.html'),
    icon: '<path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/>',
  },
  {
    kind: 'account',
    href: L('/account/login.html'),
    label: t('nav.account.login'),
    current: current.includes('/account/'),
    icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  },
];
const innerItems: (InnerItem & { angle: number; group: number })[] = layoutRing([archiveGroup, metaGroup], 76);

// Cache-Busting für /assets/account-lite.js: die Datei hat eine FESTE URL und
// wird von Cloudflare 1 Tag gecacht (nginx-Map: application/javascript → 1d).
// Ohne Content-Hash im Query lieferte das CDN nach einem Deploy bis zu 24 h die
// ALTE Datei — kritisch, weil dieses Skript die Auth-Session refresht und die
// Favoriten bedient. Gleiche Technik wie /assets/holo-viewer.js (?v=hash).
let acctLiteVer = 'x';
try {
  acctLiteVer = createHash('sha1').update(readFileSync('assets/account-lite.js')).digest('hex').slice(0, 8);
} catch { /* dev-Fallback */ }
const acctLiteSrc = `/assets/account-lite.js?v=${acctLiteVer}`;
---
<nav class="snav" id="topbar" aria-label={t('nav.main')}>
  <div class="snav__left">
    <button
      class="snav__menu-btn"
      id="snavMenuBtn"
      type="button"
      aria-haspopup="dialog"
      aria-expanded="false"
      aria-controls="snavOrbit"
      aria-label={t('nav.menu.open')}
    >
      <svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
      <span>{t('nav.menu')}</span>
    </button>
    <button class="snav__search" type="button" data-scs-open aria-label={t('nav.search.open')}>
      <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2.4"/><line x1="15.5" y1="15.5" x2="21" y2="21" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
      <span>{t('nav.search')}</span>
      <kbd>{t('nav.search.kbd')}</kbd>
    </button>
  </div>
  <div class="snav__center">
    <a class="snav__brand" href={L('/index.html')} aria-label={t('nav.home.aria')}>
      <svg viewBox="0 0 64 64" width="24" height="24" aria-hidden="true"><path d="M32 8 52 20v24L32 56 12 44V20z" fill="none" stroke="currentColor" stroke-width="5" stroke-linejoin="round"/><circle cx="32" cy="32" r="6" fill="currentColor"/></svg>
      <span>Verse·Base</span>
    </a>
  </div>
  <div class="snav__right">
    <LangSwitcher hasEn={hasEn} />
    <a
      class="snav__acct js-nav-acct"
      href={L('/account/login.html')}
      data-login={L('/account/login.html')}
      data-dash={L('/account.html')}
      data-l-login={t('nav.account.login')}
      data-l-acct={t('nav.account')}
      aria-label={t('nav.account.aria')}
    >
      <span class="snav__acct-icon">
        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span class="snav__acct-dot" aria-hidden="true"></span>
      </span>
      <span class="js-nav-acct-txt">{t('nav.account.login')}</span>
    </a>
  </div>
</nav>

<!-- Orbital-Menü: Hub (Marke) im Zentrum, Tools auf dem äußeren, Archiv/Konto/
     Patches auf dem inneren Ring. Jeder Ring ist fachlich in zwei Gruppen
     sortiert (layoutRing() im Frontmatter) — Winkel kommt vorgerechnet über
     --angle, reine CSS-Platzierung (rotate → translate → counter-rotate,
     "Uhrzeiger"-Trick), keine Client-Trigonometrie. --gc färbt Spoke+Dot je
     Gruppe ein. Patches ist ein Sonderfall: öffnet die Log-Drawer statt zu
     verlinken (Ären-Liste würde den Ring sprengen). -->
<div class="snav-orbit" id="snavOrbit" hidden role="dialog" aria-modal="true" aria-label={t('nav.menu')}>
  <div class="snav-orbit__back" data-orbit-close></div>
  <div class="snav-orbit__stage">
    <button class="snav-orbit__close" type="button" data-orbit-close aria-label={t('nav.menu.close')}>
      <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M5 5l14 14M19 5L5 19" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
    </button>
    <a class="snav-orbit__hub" href={L('/index.html')} aria-label={t('nav.home.aria')}>
      <svg viewBox="0 0 64 64" width="30" height="30" aria-hidden="true"><path d="M32 8 52 20v24L32 56 12 44V20z" fill="none" stroke="currentColor" stroke-width="5" stroke-linejoin="round"/><circle cx="32" cy="32" r="6" fill="currentColor"/></svg>
      <span>Verse·Base</span>
    </a>

    <div class="snav-orbit__ring snav-orbit__ring--outer">
      {toolItems.map((item, i) => (
        <span
          class="snav-orbit__spoke"
          style={`--angle:${item.angle}deg; --gc:${GROUP_COLOR[item.group]}`}
          aria-hidden="true"
        ></span>
      ))}
      {toolItems.map((item, i) => (
        <a
          class="snav-orbit__node"
          style={`--angle:${item.angle}deg; --gc:${GROUP_COLOR[item.group]}; --i:${i}`}
          href={item.href}
          aria-current={item.current ? 'page' : undefined}
        >
          <span class="snav-orbit__dot">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
          </span>
          <span class="snav-orbit__label">{item.label}</span>
        </a>
      ))}
    </div>

    <div class="snav-orbit__ring snav-orbit__ring--inner">
      {innerItems.map((item, i) => (
        <span
          class="snav-orbit__spoke"
          style={`--angle:${item.angle}deg; --gc:${GROUP_COLOR[item.group]}`}
          aria-hidden="true"
        ></span>
      ))}
      {innerItems.map((item, i) => {
        const style = `--angle:${item.angle}deg; --gc:${GROUP_COLOR[item.group]}; --i:${i}`;
        if (item.kind === 'patches') {
          return (
            <button
              type="button"
              class="snav-orbit__node snav-orbit__node--inner snav-orbit__node--patches"
              style={style}
              data-patch-toggle
              aria-expanded="false"
              aria-controls="snavPatchDrawer"
              aria-current={item.current ? 'page' : undefined}
            >
              <span class="snav-orbit__dot">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
              </span>
              <span class="snav-orbit__label">{item.label}</span>
            </button>
          );
        }
        if (item.kind === 'account') {
          return (
            <a
              class="js-nav-acct snav-orbit__node snav-orbit__node--inner"
              style={style}
              href={item.href}
              data-login={L('/account/login.html')}
              data-dash={L('/account.html')}
              data-l-login={t('nav.account.login')}
              data-l-acct={t('nav.account')}
              aria-current={item.current ? 'page' : undefined}
            >
              <span class="snav-orbit__dot snav__acct-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
                <span class="snav__acct-dot" aria-hidden="true"></span>
              </span>
              <span class="snav-orbit__label js-nav-acct-txt">{item.label}</span>
            </a>
          );
        }
        return (
          <a
            class="snav-orbit__node snav-orbit__node--inner"
            style={style}
            href={item.href}
            aria-current={item.current ? 'page' : undefined}
          >
            <span class="snav-orbit__dot">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
            </span>
            <span class="snav-orbit__label">{item.label}</span>
          </a>
        );
      })}
    </div>

    <div class="snav-orbit__lang">
      <LangSwitcher hasEn={hasEn} />
    </div>
  </div>

  <div class="snav-orbit__drawer-scrim" data-patch-close hidden></div>
  <div class="snav-orbit__drawer" id="snavPatchDrawer" hidden>
    <div class="snav-orbit__drawer-head">
      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82zM7 7h.01"/></svg>
      <span>{t('nav.patches')}</span>
      <button type="button" class="snav-orbit__drawer-x" data-patch-close aria-label={t('nav.menu.close')}>
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M5 5l14 14M19 5L5 19" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div class="snav-orbit__drawer-body">
      {eras.map((era) => (
        <div class="snav-orbit__eragrp">
          <div class="snav-orbit__eralabel">{eraLabel(era, lang)}</div>
          {patches
            .filter((p) => p.data.era === era)
            .map((p) => {
              const ph = L(`/patches/sc-${p.id}.html`);
              return (
                <a class="snav-orbit__patchrow" href={ph} aria-current={current === ph ? 'page' : undefined}>
                  <b>{p.data.version}</b>
                  <span>{p.data.codename}</span>
                </a>
              );
            })}
        </div>
      ))}
    </div>
  </div>
</div>
{crumbLd && <script type="application/ld+json" set:html={JSON.stringify(crumbLd)} />}
<SearchOverlay lang={lang} />
{/* Konto-Status + Favoriten-Sterne (leichtgewichtig, ohne supabase-js).
    ?v=<contenthash> bricht den 1-Tag-CDN-Cache bei jeder Änderung. */}
<script is:inline src={acctLiteSrc} defer></script>

<style>
  .snav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9100;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 0.7rem clamp(1rem, 4vw, 2.5rem);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.9), transparent);
    backdrop-filter: blur(6px);
    transition: background 0.3s;
  }
  .snav.scrolled {
    background: rgba(0, 0, 0, 0.95);
    border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.14));
  }
  /* left = burger + search, center = brand (true visual center regardless of
     how wide the left/right groups are), right = lang + account */
  .snav__left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    justify-self: start;
  }
  .snav__center {
    justify-self: center;
  }
  .snav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text, #e8eefc);
    font-family: var(--font-display, sans-serif);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .snav__brand svg {
    color: var(--accent, #2dd4ff);
    flex: none;
  }
  .snav__right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    justify-self: end;
  }
  .snav__search {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
    color: var(--muted, #8a99b8);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.42rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }
  /* Suchlabel + Lupe sind dauerhaft blau (Akzent); nur der Tastenkürzel-
     Hinweis (kbd) bleibt grau. */
  .snav__search svg,
  .snav__search span {
    color: var(--accent, #2dd4ff);
  }
  .snav__search:hover {
    color: var(--accent, #2dd4ff);
    border-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
  }
  .snav__search kbd {
    font-family: inherit;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted, #8a99b8);
    border: 1px solid var(--line, rgba(255, 255, 255, 0.2));
    background: rgba(0, 0, 0, 0.3);
    padding: 0.08rem 0.4rem;
    border-radius: 1px;
  }
  /* Konto-Schaltfläche im Header — Optik wie die Suche; account-lite.js
     schaltet Ziel + Label (Login <-> Konto) und setzt .is-authed */
  .snav__acct {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
