  @media (max-width: 900px), (max-height: 640px) {
    .snav-orbit__stage {
      position: static;
      display: block;
      overflow-y: auto;
      height: 100%;
      padding: 5.5rem 1.25rem 6rem;
    }
    .snav-orbit__hub {
      position: static;
      margin: 0 auto 1.75rem;
      animation: none;
    }
    .snav-orbit__ring {
      position: static;
      inset: auto;
      display: block;
      max-width: 420px;
      margin: 0 auto 1.5rem;
