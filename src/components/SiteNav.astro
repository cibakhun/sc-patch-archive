       Abschnitts-Überschrift, Items darunter als Zeilen */
    .snav-orbit__cluster {
      display: block;
      margin-bottom: 1.4rem;
    }
    .snav-orbit__cluster:last-child {
      margin-bottom: 0;
    }
    .snav-orbit__gtag {
      position: static;
      transform: none;
      display: inline-block;
      margin: 0 0 0.5rem;
      animation: none;
      opacity: 1;
    }
    .snav-orbit__spoke {
      display: none;
    }
    .snav-orbit__node {
      position: static;
      flex-direction: row;
      width: auto;
      transform: none;
      animation: none;
      opacity: 1;
      scale: 1;
      justify-content: flex-start;
      gap: 0.75rem;
      padding: 0.5rem 0.25rem;
      border-bottom: 1px solid var(--line, rgba(255, 255, 255, 0.08));
    }
