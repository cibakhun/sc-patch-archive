---
// "Mehr aus Alpha X" — auto-generated connective tissue on topic pages:
// parent patch + sibling topics, resolved entirely from the data layer.
// Plain cards, palette-aware, no motion (data register, not cinema).
import { getCollection } from 'astro:content';
import { useTranslations, href, localeFromPath } from '../i18n/ui';
import { mergePatchEn } from '../i18n/patchText';

interface Props {
  topicSlug: string;
}
const { topicSlug } = Astro.props;

const lang = localeFromPath(Astro.url.pathname);
const t = useTranslations(lang);
const L = (p: string) => href(p, lang);

const patches = await getCollection('patches');
const parentEntry = patches.find((p) => p.data.topics.some((tp) => tp.slug === topicSlug));
const parentData = parentEntry ? mergePatchEn(parentEntry.id, parentEntry.data, lang) : null;
const siblings = parentData ? parentData.topics.filter((tp) => tp.slug !== topicSlug) : [];
// Evergreen-Tools (z. B. Mining) sind vom Patch entkoppelt — kein "Mehr aus
// Alpha X" mit Patch-Geschwistern, das hier nur Fehlbezüge (z. B. zu Tactical
// Strike Groups) erzeugen würde.
const feats = parentData ? parentData.features.filter((f) => f.topicSlug === topicSlug) : [];
const evergreen = feats.some((f) => f.evergreen);
---
{parentEntry && parentData && !evergreen && (
  <section class="rel" aria-label={t('rel.aria')}>
    <div class="rel__in">
      <h2 class="rel__h">{t('rel.more').replace('%v%', parentData.version)}</h2>
      <div class="rel__grid">
        <a class="rel__card rel__patch" href={L(`/patches/sc-${parentEntry.id}.html`)}>
          <span class="rel__kind">{t('rel.kind.patch')}</span>
          <b>Alpha {parentData.version}</b>
          <span class="rel__t">{parentData.codename} · {parentData.dateDisplay}</span>
        </a>
        {siblings.map((s) => (
          <a class="rel__card" href={L(`/topics/${s.slug}.html`)}>
            <span class="rel__kind">{t('rel.kind.topic')}</span>
            <b>{s.title}</b>
            <span class="rel__t">{t('rel.detail')}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .rel {
    padding: clamp(2.5rem, 6vw, 4.5rem) clamp(1.25rem, 5vw, 4.5rem);border-top:1px solid var(--line, var(--line-soft));
  }
  .rel__in {
    max-width: var(--maxw, 1180px);
    margin: 0 auto;
  }
  .rel__h {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.88rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent, #2dd4ff);
    margin-bottom: 1rem;
  }
  .rel__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.9rem;
  }
  .rel__card {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;border:1px solid var(--line, var(--line-soft));background:var(--surface, var(--veil-2));
    padding: 1rem 1.1rem;
    color: var(--text, #e8eefc);
  }
  .rel__card:hover {
    border-color: var(--accent, #2dd4ff);
  }
  .rel__patch {
    border-left: 3px solid var(--accent, #2dd4ff);
  }
  .rel__kind {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
  }
  .rel__card b {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 1.08rem;
  }
  .rel__t {
    font-size: 0.85rem;
    color: var(--muted, #8a99b8);
  }</style>
