---
// MISSIONS — Datenbank-Browser (geteilt DE/EN, Prop `lang`).
// Rendert alle Familien serverseitig als Karten mit data-Attributen; das
// Client-JS blendet nur noch ein/aus und sortiert (kein Fetch, kein Framework —
// wie schiffe.astro / MiningApp).
//
// Spieldaten (Titel, Fraktionen, Orte) bleiben englisch: die deutsche global.ini
// enthaelt keine Missionstexte. Uebersetzt wird nur die Bedienoberflaeche.
import { db, missions, rewardLabel, repSummary, uec, cmpSign, bpCount, clip } from '../lib/missions';
import type { Mission } from '../lib/missions';
import { href } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props { lang: Locale }
const { lang } = Astro.props;
const L = (p: string) => href(p, lang);

const S = {
  de: {
    eyebrow: 'Missionsdatenbank',
    title: 'Missionen',
    lead: `${db.meta.counts.live.toLocaleString('de-DE')} Missionsangebote, zu ${db.meta.counts.families} Missionen gebündelt — mit Belohnung, Reputation, Auftraggeber und Orten.`,
    stMissions: 'Missionen', stVariants: 'Angebote', stBp: 'mit Blueprints', stRep: 'mit Reputationshürde',
    search: 'Suchen', searchPh: 'Titel, Auftraggeber, Fraktion, Ort …',
    fType: 'Typ', fGiver: 'Auftraggeber', fFaction: 'Fraktion', fLoc: 'Region', fLegal: 'Rechtslage',
    fGuild: 'Gilde', fBp: 'Blueprints', bpOnly: 'nur mit Blueprints',
    bp: 'Blueprints', bpT: 'Diese Mission kann Blueprints abwerfen — gezogen aus einem gewichteten Pool, also Zufall.',
    all: 'Alle', lawful: 'Legal', unlawful: 'Illegal',
    sort: 'Sortierung', sName: 'Name', sReward: 'Belohnung', sCount: 'Angebote',
    reset: 'Zurücksetzen', results: 'Treffer', none: 'Keine Mission passt zu diesen Filtern.',
    variants: 'Angebote', variant: 'Angebot',
    reward: 'Belohnung', rep: 'Reputation', region: 'Region', giver: 'Auftraggeber',
    internal: 'Interner Name', internalT: 'Diese Mission hat im Spiel keinen Titel — angezeigt wird ihr interner Name.',
    dynamic: 'Titel variiert', dynamicT: 'Der Titel wird im Spiel zur Laufzeit gefüllt; die Platzhalter stehen für Werte wie Rang oder Ziel.',
    noReward: 'keine', calcReward: 'wird berechnet', calcRewardT: 'Der Contract fuehrt keine feste Zahl — das Spiel berechnet den Lohn zur Laufzeit aus der Schwierigkeit.',
    srcH: 'Gut zu wissen',
    srcP: 'Spielgenau zur aktuellen Live-Version (Patch 4.9). Nichts davon ist abgeschrieben.',
    srcSys: `Zwei Systeme: das ältere <strong>Missionsbrett</strong> (${db.meta.counts.brokerLive.toLocaleString('de-DE')} Angebote) und der <strong>Contract-Manager</strong> (${db.meta.counts.contracts.toLocaleString('de-DE')}), in den CIG gerade migriert. ${db.meta.counts.legacyBridged} Angebote führen beide Systeme — die stehen hier nur einmal.`,
    srcBp: `Blueprints hängen ausschließlich am Contract-Manager: ${db.meta.counts.withBlueprints} Missionen ziehen aus ${db.meta.counts.blueprintPools} Pools. Ein Pool ist eine gewichtete Liste — welcher Blueprint fällt, ist Zufall.`,
    srcGuild: 'Die Gildenzuordnung ist abgeleitet und lesbar gemacht — keine offizielle Schreibweise.',
    srcDev: `${db.meta.counts.notForRelease} Einträge sind als Entwicklungsstände (Work in Progress) markiert und fehlen hier bewusst.`,
    srcLang: 'Missionstexte liegen im Spiel nur auf Englisch vor — deutsche Titel gibt es nicht. Übersetzt ist deshalb nur die Bedienoberfläche.',
    srcObj: 'Der Schritt-für-Schritt-Text der Missionsziele wird nicht an den Client ausgeliefert: die Missionslogik läuft serverseitig. Auf den Detailseiten steht daher der Ablauf mit den Entwicklerbezeichnungen statt erfundener Zieltexte.',
  },
  en: {
    eyebrow: 'Mission database',
    title: 'Missions',
    lead: `${db.meta.counts.live.toLocaleString('en-US')} mission offers, grouped into ${db.meta.counts.families} missions — with rewards, reputation, contractors and locations.`,
    stMissions: 'missions', stVariants: 'offers', stBp: 'with blueprints', stRep: 'with rep gate',
    search: 'Search', searchPh: 'Title, contractor, faction, location …',
    fType: 'Type', fGiver: 'Contractor', fFaction: 'Faction', fLoc: 'Region', fLegal: 'Legality',
    fGuild: 'Guild', fBp: 'Blueprints', bpOnly: 'with blueprints only',
    bp: 'Blueprints', bpT: 'This mission can drop blueprints — drawn from a weighted pool, so it is chance-based.',
    all: 'All', lawful: 'Lawful', unlawful: 'Unlawful',
    sort: 'Sort', sName: 'Name', sReward: 'Reward', sCount: 'Offers',
    reset: 'Reset', results: 'results', none: 'No mission matches these filters.',
    variants: 'offers', variant: 'offer',
    reward: 'Reward', rep: 'Reputation', region: 'Region', giver: 'Contractor',
    internal: 'Internal name', internalT: 'This mission has no title in the game — its internal name is shown instead.',
    dynamic: 'Title varies', dynamicT: 'The title is filled in at runtime; the placeholders stand for values like rank or target.',
    noReward: 'none', calcReward: 'calculated', calcRewardT: 'The contract carries no fixed number — the game computes the payout at runtime from the difficulty.',
    srcH: 'Good to know',
    srcP: 'Game-accurate to the current live build (patch 4.9). None of it is copied from elsewhere.',
    srcSys: `Two systems: the older <strong>mission board</strong> (${db.meta.counts.brokerLive.toLocaleString('en-US')} offers) and the <strong>Contract Manager</strong> (${db.meta.counts.contracts.toLocaleString('en-US')}) that CIG is migrating to. ${db.meta.counts.legacyBridged} offers exist in both — those are listed once.`,
    srcBp: `Blueprints hang off the Contract Manager only: ${db.meta.counts.withBlueprints} missions draw from ${db.meta.counts.blueprintPools} pools. A pool is a weighted list — which blueprint drops is chance.`,
    srcGuild: 'The guild grouping is derived and made readable — not an official spelling.',
    srcDev: `${db.meta.counts.notForRelease} entries are flagged as work in progress and are deliberately left out.`,
    srcLang: 'Mission text exists in English only in the game — there are no German titles. Only the interface is translated.',
    srcObj: 'The step-by-step objective text is not delivered to the client: mission logic runs server-side. The detail pages therefore show the flow with its developer labels instead of invented objective text.',
  },
}[lang];

// Platzhalter sichtbar machen: "{ReputationRank} Rank - ..." wird in Text/Chip-
// Teile zerlegt, statt die geschweiften Klammern roh anzuzeigen.
function titleParts(t: string): { t: string; ph: boolean }[] {
  return String(t).split(/(\{[^}]*\})/).filter(Boolean)
    .map((s) => (s.startsWith('{') ? { t: s.slice(1, -1), ph: true } : { t: s, ph: false }));
}

const nf = lang === 'de' ? 'de-DE' : 'en-US';
const cards = missions.map((m: Mission) => {
  const reps = repSummary(m);
  return {
    m,
    parts: titleParts(m.title),
    // Teaser statt Volltext: .mc__desc clampt auf 2 Zeilen — der volle
    // DataCore-Brief (bis ~2 KB) stand trotzdem im Markup und summierte sich
    // auf ~0,8 MB pro Sprachindex. clip() schneidet an der Wortgrenze und
    // zerreisst nie einen {Platzhalter} (Token enthalten keine Leerzeichen).
    descParts: m.desc ? titleParts(clip(m.desc, 200)) : null,
    reward: rewardLabel(m, lang),
    rep: reps[0] ?? null,
    repMore: Math.max(0, reps.length - 1),
    legal: m.lawful && m.unlawful ? 'both' : m.lawful ? 'lawful' : 'unlawful',
    bps: bpCount(m),
  };
});
---
<section class="mx" id="missions">
  <header class="mx__hero">
    <div class="mx__heroIn">
      <p class="mx__eyebrow">{S.eyebrow}</p>
      <h1 class="mx__h1">{S.title}</h1>
      <p class="mx__lead">{S.lead}</p>
      <div class="mx__stats">
        <div><b>{db.meta.counts.families}</b><span>{S.stMissions}</span></div>
        <div><b>{db.meta.counts.live.toLocaleString(nf)}</b><span>{S.stVariants}</span></div>
        <div><b>{db.meta.counts.withBlueprints.toLocaleString(nf)}</b><span>{S.stBp}</span></div>
        <div><b>{db.meta.counts.withRep.toLocaleString(nf)}</b><span>{S.stRep}</span></div>
      </div>
    </div>
  </header>

  <div class="mx__wrap">
    <!-- Filter -->
    <form class="mx__bar" id="mx-bar" role="search" onsubmit="return false">
      <div class="mx__f mx__f--grow">
        <label for="mx-q">{S.search}</label>
        <input type="search" id="mx-q" placeholder={S.searchPh} autocomplete="off" />
      </div>
      <div class="mx__f">
        <label for="mx-type">{S.fType}</label>
        <select id="mx-type"><option value="">{S.all}</option>{db.types.map((t) => <option value={t.id}>{t.name}</option>)}</select>
      </div>
      <div class="mx__f">
        <label for="mx-giver">{S.fGiver}</label>
        <select id="mx-giver"><option value="">{S.all}</option>{db.givers.map((g) => <option value={g.id}>{g.name}</option>)}</select>
      </div>
      <div class="mx__f">
        <label for="mx-faction">{S.fFaction}</label>
        <select id="mx-faction"><option value="">{S.all}</option>{db.factions.map((f) => <option value={f.id}>{f.name}</option>)}</select>
      </div>
      <div class="mx__f">
        <label for="mx-guild">{S.fGuild}</label>
        <select id="mx-guild"><option value="">{S.all}</option>{db.guilds.map((g) => <option value={g.id}>{g.name}</option>)}</select>
      </div>
      <div class="mx__f">
        <label for="mx-loc">{S.fLoc}</label>
        <select id="mx-loc"><option value="">{S.all}</option>{db.localities.map((l) => <option value={l.id}>{l.name}</option>)}</select>
      </div>
      <div class="mx__f">
        <label for="mx-bp">{S.fBp}</label>
        <select id="mx-bp">
          <option value="">{S.all}</option>
          <option value="1">{S.bpOnly}</option>
        </select>
      </div>
      <div class="mx__f">
        <label for="mx-legal">{S.fLegal}</label>
        <select id="mx-legal">
          <option value="">{S.all}</option>
          <option value="lawful">{S.lawful}</option>
          <option value="unlawful">{S.unlawful}</option>
        </select>
      </div>
      <div class="mx__f">
        <label for="mx-sort">{S.sort}</label>
        <select id="mx-sort">
          <option value="count">{S.sCount}</option>
          <option value="name">{S.sName}</option>
          <option value="reward">{S.sReward}</option>
        </select>
      </div>
      <button type="button" class="mx__reset" id="mx-reset">{S.reset}</button>
      <output class="mx__count" id="mx-count" aria-live="polite"></output>
    </form>

    <!-- Karten -->
    <div class="mx__grid" id="mx-grid">
      {/* HTML-Diät: data-search (~500 unsichtbare Zeichen je Karte — Blueprint-
          Namen, Orte, Titel-Varianten) liegt jetzt als 1-Tag-cachebarer Index
          unter /missions-search.json (siehe pages/missions-search.json.ts);
          data-name liest missions-app.js aus dem sichtbaren <h3>. Zusammen
          ~0,75 MB weniger pro Sprachindex. */}
      {cards.map(({ m, parts, descParts, reward, rep, repMore, legal, bps }) => (
        <article
          class="mc"
          data-type={m.types.join(' ')}
          data-giver={m.givers.join(' ')}
          data-faction={m.factions.join(' ')}
          data-loc={m.localities.join(' ')}
          data-guild={m.guilds.map((g) => g.toLowerCase().replace(/[^a-z0-9]+/g, '-')).join(' ')}
          data-legal={legal}
          data-bp={bps ? '1' : '0'}
          data-reward={m.rewardMax}
          data-count={m.count}
        >
          <a class="mc__link" href={L(`/missionen/${m.slug}.html`)}>
            <div class="mc__top">
              <h3 class="mc__h">
                {parts.map((p) => (p.ph ? <i class="mc__ph">{p.t}</i> : <span>{p.t}</span>))}
              </h3>
              {m.count > 1 && <span class="mc__n">{m.count}&thinsp;×</span>}
            </div>
            <div class="mc__chips">
              {bps > 0 && (
                <span class="mc__chip mc__chip--bp" title={S.bpT}>
                  <svg viewBox="0 0 24 24" width="9" height="9" fill="none" stroke="currentColor" stroke-width="2.6" aria-hidden="true"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 12l9 4 9-4M3 17l9 4 9-4"/></svg>
                  {bps}&thinsp;{S.bp}
                </span>
              )}
              {m.typeNames.slice(0, 2).map((t) => <span class="mc__chip">{t}</span>)}
              {m.guilds.slice(0, 1).map((g) => <span class="mc__chip mc__chip--guild">{g}</span>)}
              {legal === 'unlawful' && <span class="mc__chip mc__chip--il">{S.unlawful}</span>}
              {m.noTitle && <span class="mc__chip mc__chip--warn" title={S.internalT}>{S.internal}</span>}
              {m.titleDynamic && !m.noTitle && <span class="mc__chip mc__chip--dyn" title={S.dynamicT}>{S.dynamic}</span>}
            </div>
            {descParts && (
              <p class="mc__desc">
                {descParts.map((p) => (p.ph ? <i class="mc__ph">{p.t}</i> : <span>{p.t}</span>))}
              </p>
            )}
            <dl class="mc__facts">
              <div><dt>{S.reward}</dt><dd
                class={reward ? 'mc__uec' : 'mc__dim'}
                title={!reward && m.calcReward ? S.calcRewardT : undefined}
              >{reward ? `${reward} aUEC` : (m.calcReward ? S.calcReward : S.noReward)}</dd></div>
              <div><dt>{S.rep}</dt><dd>{rep
                ? <>{rep.factionName} <span class="mc__dim">{cmpSign(rep.comparison)} {rep.standing}</span>{repMore > 0 && <span class="mc__dim"> +{repMore}</span>}</>
                : <span class="mc__dim">—</span>}</dd></div>
              <div><dt>{S.region}</dt><dd>{m.localityNames.length ? m.localityNames.slice(0, 3).join(', ') : <span class="mc__dim">—</span>}</dd></div>
            </dl>
          </a>
        </article>
      ))}
    </div>
    <p class="mx__none" id="mx-none" hidden>{S.none}</p>

    <!-- Quelle / Vorbehalte -->
    <aside class="mx__src">
      <h2>{S.srcH}</h2>
      <ul>
        <li set:html={S.srcSys} />
        <li>{S.srcBp}</li>
        <li set:html={S.srcDev} />
        <li>{S.srcLang}</li>
        <li>{S.srcGuild}</li>
        <li>{S.srcObj}</li>
      </ul>
    </aside>
  </div>
</section>

{/* searchUrl versioniert mit dem DB-Stand: neuer Datamine-Lauf -> neue URL ->
    kein 1-Tag-alter Suchindex zu frischen Karten. */}
<script is:inline set:html={`window.__MX=${JSON.stringify({ lang, searchUrl: `/missions-search.json?v=${db.meta.generated}`, t: { results: S.results } })};`} />
{/* ?v=2: missions-app.js erwartet jetzt Karten ohne data-search/data-name —
    altes gecachtes JS (1 Tag) fände auf neuem HTML nur leere Suchtexte. */}
<script is:inline src="/assets/missions-app.js?v=2"></script>

{/* KEIN is:inline: Astro buendelt diesen Block und verlinkt ihn im <head>.
    Inline stuende er hinter 800 KB Karten-Markup — der Browser malt dann erst
    ungestylt und stylt nach (FOUC). Die :root-Palette der Seite bleibt inline,
    die muss detail.css ueberschreiben.
    is:global: ohne Scoping entfallen ~35.000 data-astro-cid-Attribute
    (~0,8 MB pro Sprachindex). Gefahrlos, weil JEDER Selektor hier mx__/mc__-
    praefixiert ist und die Klassen nur in dieser Komponente existieren. */}
<style is:global>
  .mx { position: relative; }

  /* ---------- Hero ---------- */
  .mx__hero {
    position: relative; min-height: clamp(320px, 42vh, 520px); display: flex; align-items: flex-end;
    padding: 6.5rem clamp(1rem, 4vw, 3rem) 2.4rem; overflow: hidden; border-bottom: 1px solid var(--line);
  }
  .mx__hero::before {
    content: ""; position: absolute; inset: 0; z-index: 0;
    background: url('/assets/t-tsg-4.jpg') center 38% / cover no-repeat; animation: mxKb 40s ease-in-out infinite alternate;
  }
  .mx__hero::after {
    content: ""; position: absolute; inset: 0; z-index: 1;background:linear-gradient(90deg, var(--veil-2) 0%, var(--veil-2) 46%, var(--veil) 100%),
      linear-gradient(180deg, var(--veil-2), transparent 30%, var(--veil) 62%, var(--bg) 99%);
  }
  @keyframes mxKb { from { transform: scale(1); } to { transform: scale(1.07); } }
  @media (prefers-reduced-motion: reduce) { .mx__hero::before { animation: none; } }
  .mx__heroIn { position: relative; z-index: 2; width: min(var(--maxw), 100%); margin: 0 auto; }
  .mx__eyebrow {
    font-family: var(--font-ui); text-transform: uppercase; letter-spacing: .3em; font-size: .7rem;
    color: var(--accent); margin-bottom: .7rem;
  }
  .mx__h1 {
    font-family: var(--font-display); font-size: clamp(2.4rem, 7vw, 5rem); line-height: .95; font-weight: 900;
    letter-spacing: -.01em; margin-bottom: .8rem;background:linear-gradient(180deg, var(--title-hi) 0%, #ffd79a 58%, var(--accent) 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;filter:drop-shadow(0 3px 18px var(--shadow-color));
  }
  .mx__lead { max-width: 62ch; color: var(--muted); font-size: clamp(.98rem, 1.6vw, 1.12rem); }
  .mx__stats { display: flex; flex-wrap: wrap; gap: 1.6rem 2.6rem; margin-top: 1.6rem; }
  .mx__stats b {
    display: block; font-family: var(--font-display); font-size: clamp(1.3rem, 2.6vw, 1.9rem);
    font-weight: 800; color: var(--accent); line-height: 1;
  }
  .mx__stats span {
    font-family: var(--font-ui); text-transform: uppercase; letter-spacing: .16em; font-size: .66rem; color: var(--muted);
  }

  .mx__wrap { width: min(var(--maxw), 100%); margin: 0 auto; padding: 2.2rem clamp(1rem, 4vw, 3rem) 4rem; }

  /* ---------- Filterleiste ---------- */
  /* top:68px = Hoehe der fixen SiteNav (z-index 9100). Bei top:0 klebt die
     Leiste hinter der Nav und ihre obere Zeile verschwindet. Gleiche Konstante
     wie .mdb-bar in MiningApp. */
  .mx__bar {
    position: sticky; top: 68px; z-index: 20; display: flex; flex-wrap: wrap; gap: .7rem 1rem; align-items: end;
    padding: .9rem 1rem; margin-bottom: 1.6rem; border: 1px solid var(--line); border-radius: 14px;
    background: color-mix(in srgb, var(--surface) 88%, transparent); backdrop-filter: blur(12px);
  }
  .mx__f { display: flex; flex-direction: column; gap: .25rem; min-width: 8.5rem; }
  .mx__f--grow { flex: 1 1 16rem; }
  .mx__f label {
    font-family: var(--font-ui); text-transform: uppercase; letter-spacing: .14em; font-size: .6rem; color: var(--muted);
  }
  .mx__bar input, .mx__bar select {
    font-family: var(--font-body); font-size: .9rem; color: var(--text); background: var(--bg-2);
    border: 1px solid var(--line); border-radius: 9px; padding: .5rem .7rem; width: 100%;
  }
  .mx__bar input:focus-visible, .mx__bar select:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }
  .mx__reset {
    font-family: var(--font-ui); text-transform: uppercase; letter-spacing: .1em; font-size: .7rem; cursor: pointer;
    color: var(--muted); background: transparent; border: 1px solid var(--line); border-radius: 9px; padding: .55rem .9rem;
  }
  .mx__reset:hover { color: var(--accent); border-color: var(--accent); }
  .mx__count { font-family: var(--font-ui); font-size: .75rem; color: var(--muted); margin-left: auto; }

  /* ---------- Karten ---------- */
  /* 17rem, nicht 19: die Wurzel steht auf 112,5 %, 1rem sind also 18px — bei
     19rem passen auf 1280er-Viewports nur zwei Spalten. */
  .mx__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr)); gap: 1rem; }
  .mc {
    border: 1px solid var(--line); border-radius: 14px; background: var(--surface);
    transition: border-color .18s, transform .18s, box-shadow .18s;
  }
  .mc:hover { border-color: var(--accent); transform: translateY(-2px);box-shadow:0 10px 34px var(--shadow-color); }
  .mc__link { display: flex; flex-direction: column; gap: .55rem; padding: 1rem 1.05rem 1.1rem; height: 100%; }
  .mc__top { display: flex; align-items: baseline; gap: .6rem; }
  .mc__h {
    font-family: var(--font-ui); font-size: 1.05rem; font-weight: 700; line-height: 1.25; letter-spacing: .01em; flex: 1;
  }
  /* Laufzeit-Platzhalter im Titel: sichtbar als Variable, nicht als Name */
  .mc__ph {
    font-style: normal; font-size: .82em; padding: .05em .4em; border-radius: 5px; white-space: nowrap;
    color: var(--accent); background: color-mix(in srgb, var(--accent) 14%, transparent);
    border: 1px dashed color-mix(in srgb, var(--accent) 45%, transparent);
  }
  .mc__n { font-family: var(--font-display); font-size: .8rem; font-weight: 700; color: var(--accent); }
  .mc__chips { display: flex; flex-wrap: wrap; gap: .3rem; }
  .mc__chip {
    font-family: var(--font-ui); text-transform: uppercase; letter-spacing: .1em; font-size: .58rem; padding: .2rem .5rem;
    border-radius: 50px; color: var(--muted); border: 1px solid var(--line-soft); background: var(--bg-2);
  }
  .mc__chip--il { color: #ff9d8a; border-color: rgba(255, 120, 90, .4); }
  /* Blueprint-Marker: der einzige gefuellte Chip — er beantwortet die haeufigste
     Frage an die Liste ("wirft die was ab?") und muss ohne Suchen auffindbar sein. */
  .mc__chip--bp {
    display: inline-flex; align-items: center; gap: .25rem; color: var(--ink);
    background: var(--accent-2); border-color: var(--accent-2); font-weight: 700;
  }
  .mc__chip--guild { color: #9fd8c8; border-color: rgba(159, 216, 200, .34); }
  .mc__chip--warn, .mc__chip--dyn { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 42%, transparent); border-style: dashed; }
  .mc__desc {
    font-size: .84rem; color: var(--muted); line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .mc__facts { display: grid; gap: .3rem; margin-top: auto; padding-top: .6rem; border-top: 1px solid var(--line-soft); }
  .mc__facts > div { display: grid; grid-template-columns: 6.2rem 1fr; gap: .5rem; align-items: baseline; }
  .mc__facts dt {
    font-family: var(--font-ui); text-transform: uppercase; letter-spacing: .1em; font-size: .58rem; color: var(--muted);
  }
  .mc__facts dd { font-size: .82rem; min-width: 0; overflow-wrap: anywhere; }
  .mc__uec { font-family: var(--font-display); font-weight: 700; color: var(--accent-2); }
