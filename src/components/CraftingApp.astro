---
// CraftingApp.astro — funktionale Blueprint-Datenbank (SSR-Liste + Client-App).
// Sprachneutrales Gerüst; UI-Chrome via `lang`, Game-Daten bleiben englisch.
import DB from '../../assets/crafting-db.json';

interface Props { lang: 'de' | 'en'; }
const { lang } = Astro.props;

// -- i18n (App-spezifische Chrome-Strings) --
const S = {
  de: {
    toolbarSearch: 'Suche: Blueprint oder Ressource…',
    filters: 'Filter', category: 'Kategorie', resource: 'Ressource', anyResource: 'Alle Ressourcen',
    missionOnly: 'Nur mit Missions-Quelle', ownedOnly: 'Nur „im Besitz"', reset: 'Zurücksetzen',
    sort: 'Sortierung', sortName: 'Name A→Z', sortNameDesc: 'Name Z→A',
    sortTimeAsc: 'Craft-Zeit ↑', sortTimeDesc: 'Craft-Zeit ↓', sortIngs: 'Zutaten (meiste)',
    view: 'Ansicht', grid: 'Raster', list: 'Liste', results: 'Blueprints', of: 'von',
    empty: 'Keine Blueprints für diese Auswahl.', planner: 'Planer', filterBtn: 'Filter',
    close: 'Schließen', craftTime: 'Craft-Zeit', ings: 'Zutaten', mission: 'Mission',
    plannerTitle: 'Fabricator-Planer', shoppingList: 'Einkaufsliste (Ressourcen)',
    totalTime: 'Gesamt-Craft-Zeit', clearPlan: 'Planer leeren', owned: 'Im Besitz', addToPlan: 'Zum Planer',
    calcSelectMats: '1. Rohstoffe wählen', calcParameters: '2. Parameter', calcTargetQty: 'Zielmenge (SCU)',
    calcYieldRate: 'Ausbeute-Rate', calcReset: 'Rechner zurücksetzen', calcTitle: 'Effiziente Items zum Zerlegen',
    calcTabDb: 'Blueprint-Datenbank', calcTabCalc: 'Zerlegungs-Rechner (Dismantle)',
  },
  en: {
    toolbarSearch: 'Search: blueprint or resource…',
    filters: 'Filters', category: 'Category', resource: 'Resource', anyResource: 'All resources',
    missionOnly: 'Only with mission source', ownedOnly: 'Only “owned”', reset: 'Reset',
    sort: 'Sort', sortName: 'Name A→Z', sortNameDesc: 'Name Z→A',
    sortTimeAsc: 'Craft time ↑', sortTimeDesc: 'Craft time ↓', sortIngs: 'Ingredients (most)',
    view: 'View', grid: 'Grid', list: 'List', results: 'blueprints', of: 'of',
    empty: 'No blueprints for this selection.', planner: 'Planner', filterBtn: 'Filters',
    close: 'Close', craftTime: 'Craft time', ings: 'Ingredients', mission: 'Mission',
    plannerTitle: 'Fabricator planner', shoppingList: 'Shopping list (resources)',
    totalTime: 'Total craft time', clearPlan: 'Clear planner', owned: 'Owned', addToPlan: 'Add to planner',
    calcSelectMats: '1. Select Raw Materials', calcParameters: '2. Parameters', calcTargetQty: 'Target Quantity (SCU)',
    calcYieldRate: 'Yield Rate', calcReset: 'Reset Calculator', calcTitle: 'Efficient Items to Dismantle',
    calcTabDb: 'Blueprint Database', calcTabCalc: 'Dismantling Calculator',
  },
}[lang];

// Strings, die das Client-JS braucht (window.__CRAFT.t)
const JS_T = {
  de: {
    craftTime: 'Craft-Zeit', tier: 'Tier', addPlan: 'Zum Planer', ingredients: 'Zutaten',
    minQ: 'min. Q', quality: 'Qualität', simOut: 'Simulierte Ausgabe-Werte',
    simNote: 'Absolute Werte live aus den quality_effects (Qualität 0–1000): multiplikativ = Basis × Faktor, additiv = Basis + Wert.',
    simIdxNote: 'kein absoluter Basiswert in den Daten — 100 = Standard-Item (Faktor 1,0).',
    itemStats: 'Item-Werte', missions: 'Missionen (Bezugsquelle)',
    missionHint: 'Mission anklicken → alle Blueprints, die sie droppen kann.',
    missionPoolLabel: 'Missions-Pool', poolIntro: 'Alle Blueprints, die diese Mission droppen kann — Blueprint anklicken für Details.',
    back: 'Zurück',
    noMission: 'Keine Missions-Quelle in den Daten — evtl. über andere Wege (Shop/Reputation) erhältlich.',
    fireMode: 'Feuermodus', added: 'hinzugefügt',
    planEmpty: 'Noch keine Blueprints im Planer. „＋" auf einer Karte fügt hinzu.',
    calcSearchPlaceholder: 'Material suchen...',
    calcSelectPrompt: 'Bitte wähle mindestens ein Material in der Seitenleiste aus.',
    calcWarningRareBycatch: 'Dieses Item enthält {name}, dieser kann jedoch nicht durch Zerlegen gewonnen werden.',
    calcCostUnit: 'Gesamtkosten',
    calcQtyBuy: '{qty}x kaufen',
    calcFound: '{count} kompatible Items gefunden',
    calcRareLabel: '(selten)',
  },
  en: {
    craftTime: 'Craft time', tier: 'Tier', addPlan: 'Add to planner', ingredients: 'Ingredients',
    minQ: 'min. Q', quality: 'Quality', simOut: 'Simulated output stats',
    simNote: 'Absolute values computed live from quality_effects (quality 0–1000): multiplicative = base × factor, additive = base + value.',
    simIdxNote: 'no absolute base value in the data — 100 = standard item (factor 1.0).',
    itemStats: 'Item stats', missions: 'Missions (source)',
    missionHint: 'Click a mission → all blueprints it can drop.',
    missionPoolLabel: 'Mission pool', poolIntro: 'All blueprints this mission can drop — click a blueprint for details.',
    back: 'Back',
    noMission: 'No mission source in the data — may be obtainable another way (shop/reputation).',
    fireMode: 'Fire mode', added: 'added',
    planEmpty: 'No blueprints in the planner yet. Use “＋” on a card to add.',
    calcSearchPlaceholder: 'Search material...',
    calcSelectPrompt: 'Please select at least one material in the sidebar.',
    calcWarningRareBycatch: 'This item contains {name}, but it cannot be obtained by dismantling.',
    calcCostUnit: 'Total Cost',
    calcQtyBuy: 'Buy {qty}x',
    calcFound: '{count} compatible items found',
    calcRareLabel: '(rare)',
  },
}[lang];

// -- Kategorie-Baum aus den Daten --
const tree: Record<string, Set<string>> = {};
for (const b of DB.blueprints) {
  const p = (b.category || '').split(' / ');
  const top = p[0] || '—';
  const sub = p[1] || '';
  (tree[top] = tree[top] || new Set()).add(sub);
}
const CAT_ORDER = ['Weapons', 'Armour', 'Vehiclegear', 'Ammo'];
const cats = Object.keys(tree).sort((a, b) => {
  const ia = CAT_ORDER.indexOf(a), ib = CAT_ORDER.indexOf(b);
  return (ia < 0 ? 99 : ia) - (ib < 0 ? 99 : ib);
});
const catList = cats.map((c) => ({
  top: c,
  subs: [...tree[c]].filter(Boolean).sort(),
  count: DB.blueprints.filter((b) => (b.category || '').split(' / ')[0] === c).length,
}));

// -- Ressourcen, die tatsächlich als Zutat vorkommen --
const resSet = new Set<string>();
for (const b of DB.blueprints)
  for (const ing of b.ingredients || [])
    for (const o of ing.options || []) if (o.name) resSet.add(o.name);
const resources = [...resSet].sort();

// -- SSR-Kartenmodell --
function fmtT(sec: number | null) {
  sec = Number(sec) || 0;
  if (!sec) return '—';
  const h = Math.floor(sec / 3600), m = Math.floor((sec % 3600) / 60);
  if (h) return `${h}h${m ? ' ' + m + 'm' : ''}`;
  if (m) return `${m}m`;
  return `${sec}s`;
}
const cardsData = DB.blueprints.map((b, i) => {
  const p = (b.category || '').split(' / ');
  const top = p[0] || '—';
  const sub = p[1] || '';
  const leaf = p[p.length - 1] || '';
  const resNames = [...new Set((b.ingredients || []).flatMap((ing) => (ing.options || []).map((o) => o.name)))];
  const nIng = (b.ingredients || []).length;
  const hasMis = !!(b.missions && b.missions.length);
  return {
    i, name: b.name, top, sub, leaf, resNames, nIng, hasMis,
    time: b.craft_time_seconds || 0, timeLabel: fmtT(b.craft_time_seconds),
    resLower: resNames.join('|').toLowerCase(),
  };
});

const snapDate = DB.snapshot_date;
const version = DB.version;
const total = DB.counts.blueprints;
---

<section class="cdb" id="cdb">
  <!-- Tab Switcher -->
  <div class="cdb-tabs">
    <button class="cdb-tab-btn active" data-tab="db">{S.calcTabDb}</button>
    <button class="cdb-tab-btn" data-tab="dismantle">{S.calcTabCalc}</button>
  </div>

  <div id="cdb-tab-db-content">
  <!-- Toolbar -->
  <div class="cdb-bar">
    <button class="cdb-filter-toggle" id="cdb-filter-toggle" aria-expanded="false">☰ {S.filterBtn}</button>
    <div class="cdb-search-wrap">
      <input type="search" id="cdb-search" class="cdb-search" placeholder={S.toolbarSearch} aria-label={S.toolbarSearch} autocomplete="off" />
    </div>
    <label class="cdb-sort">
      <span class="cdb-sr">{S.sort}</span>
      <select id="cdb-sort">
        <option value="name">{S.sortName}</option>
        <option value="name-desc">{S.sortNameDesc}</option>
        <option value="time-asc">{S.sortTimeAsc}</option>
        <option value="time-desc">{S.sortTimeDesc}</option>
        <option value="ings-desc">{S.sortIngs}</option>
      </select>
    </label>
    <div class="cdb-viewtog" role="group" aria-label={S.view}>
      <button class="cdb-view" data-view="grid" aria-pressed="true" title={S.grid}>▦</button>
      <button class="cdb-view" data-view="list" aria-pressed="false" title={S.list}>≡</button>
    </div>
    <button class="cdb-planner-open" id="cdb-planner-open" title={S.plannerTitle}>
      ⚙ {S.planner}<span class="cdb-badge" id="cdb-planner-badge" hidden>0</span>
    </button>
  </div>

  <div class="cdb-layout">
    <!-- Filter sidebar -->
    <aside class="cdb-sidebar" id="cdb-sidebar" aria-label={S.filters}>
      <div class="cdb-side-hd">
        <span>{S.filters}</span>
        <button id="cdb-filter-close" class="cdb-x" aria-label={S.close}>✕</button>
      </div>

      <div class="cdb-fgroup">
        <h4>{S.category}</h4>
        {catList.map((c) => (
          <details class="cdb-cat-details">
            <summary class="cdb-cat-summary">
              <label class="cdb-check cdb-check--top" onclick="event.stopPropagation()">
                <input type="checkbox" class="cdb-cat" value={c.top} />
                <span>{c.top} <em>{c.count}</em></span>
              </label>
            </summary>
            <div class="cdb-subs">
              {c.subs.map((s) => (
                <label class="cdb-check cdb-check--sub">
                  <input type="checkbox" class="cdb-sub" data-top={c.top} value={`${c.top}||${s}`} />
                  <span>{s}</span>
                </label>
              ))}
            </div>
          </details>
        ))}
      </div>

      <div class="cdb-fgroup">
        <h4>{S.resource}</h4>
        <div class="cdb-res-search-wrap">
          <input type="text" id="cdb-res-search" class="cdb-res-search" placeholder="Ressource suchen..." autocomplete="off" />
        </div>
        <div class="cdb-res-list">
          {resources.map((r) => (
            <label class="cdb-check">
              <input type="checkbox" class="cdb-res-cb" value={r.toLowerCase()} />
              <span>{r}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="cdb-fgroup">
        <label class="cdb-check"><input type="checkbox" id="cdb-mission" /><span>{S.missionOnly}</span></label>
        <label class="cdb-check"><input type="checkbox" id="cdb-owned" /><span>{S.ownedOnly}</span></label>
      </div>

      <button id="cdb-reset" class="cdb-reset">{S.reset}</button>
    </aside>

    <!-- Results -->
    <div class="cdb-main">
      <div class="cdb-count-row">
        <span><b id="cdb-count">{total}</b> / {total} {S.results}</span>
      </div>
      <div class="cdb-grid" id="cdb-grid">
        {cardsData.map((c) => (
          <article
            class="cbp"
            data-i={c.i}
            data-name={c.name.toLowerCase()}
            data-cat={c.top}
            data-sub={c.sub}
            data-leaf={c.leaf.toLowerCase()}
            data-res={c.resLower}
            data-mis={c.hasMis ? '1' : '0'}
            data-time={c.time}
            data-ings={c.nIng}
          >
            <div class="cbp__top">
              <span class="cbp__cat">{c.top}{c.sub && (<em>{c.sub}</em>)}</span>
              <div class="cbp__btns">
                <button class="cbp__own" aria-pressed="false" title={S.owned}>★</button>
                <button class="cbp__add" title={S.addToPlan}>＋</button>
              </div>
            </div>
            <h3 class="cbp__name">{c.name}</h3>
            <div class="cbp__meta">
              <span title={S.craftTime}>⏱ {c.timeLabel}</span>
              <span title={S.ings}>◆ {c.nIng}</span>
              {c.hasMis && (<span class="cbp__mis" title={S.mission}>◈</span>)}
            </div>
            {c.resNames.length > 0 && (
              <ul class="cbp__res">
                {c.resNames.slice(0, 5).map((r) => (<li>{r}</li>))}
                {c.resNames.length > 5 && (<li class="more">+{c.resNames.length - 5}</li>)}
              </ul>
            )}
          </article>
        ))}
      </div>
      <p class="cdb-empty" id="cdb-empty" hidden>{S.empty}</p>
    </div>
  </div>
  </div> <!-- End #cdb-tab-db-content -->

  <!-- Dismantling Calculator tab -->
  <div id="cdb-tab-dismantle-content" hidden>
    <div class="calc-layout">
      <!-- Inputs sidebar -->
      <aside class="calc-sidebar">
        <h4>{S.calcSelectMats}</h4>
        
        <!-- Material search & list -->
        <div class="calc-fgroup">
          <div class="cdb-res-search-wrap">
            <input type="text" id="calc-mat-search" class="cdb-res-search" placeholder={S.calcSearchPlaceholder} autocomplete="off" />
          </div>
          <div class="calc-mat-list">
            <!-- Loaded dynamically via JS -->
          </div>
        </div>

        <h4 style="margin-top:1.5rem;">{S.calcParameters}</h4>
        
        <!-- Target Quantity -->
        <div class="calc-fgroup">
          <label style="display:block;font-size:0.85rem;color:var(--muted,#9ba2ae);margin-bottom:0.4rem;">{S.calcTargetQty}</label>
          <input type="number" id="calc-target-qty" class="cdb-res-search" value="1.0" min="0.01" step="0.1" style="width:100%;" />
        </div>

        <!-- Yield Rate -->
        <div class="calc-fgroup">
          <div style="display:flex;justify-content:space-between;font-size:0.85rem;color:var(--muted,#9ba2ae);margin-bottom:0.4rem;">
            <span>{S.calcYieldRate}</span>
            <span id="calc-yield-val">50%</span>
          </div>
          <input type="range" id="calc-yield-rate" min="1" max="100" value="50" style="width:100%;accent-color:var(--accent,#FF5E1A);" />
        </div>
        
        <button id="calc-reset" class="cdb-reset" style="margin-top:1rem;">{S.calcReset}</button>
      </aside>

      <!-- Outputs list -->
      <div class="calc-results-wrap" style="flex:1 1 auto; min-width:0;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2rem;gap:1rem;flex-wrap:wrap;">
          <h2 style="font-family:var(--font-display,inherit);font-weight:900;font-size:1.4rem;color:#fff;margin:0;">{S.calcTitle}</h2>
          <span id="calc-results-count" style="font-size:0.85rem;color:var(--muted,#9ba2ae);">0 Items gefunden</span>
        </div>
        
        <div id="calc-results" class="calc-grid">
          <!-- Results rendered dynamically via JS -->
        </div>
      </div>
    </div>
  </div>

  <!-- Detail modal -->
  <div class="cdb-modal" id="cdb-modal" hidden>
    <div class="cdb-modal__box" role="dialog" aria-modal="true">
      <button class="cdb-modal__x" data-close aria-label={S.close}>✕</button>
      <div class="cdb-modal__body" id="cdb-modal-body"></div>
    </div>
  </div>

  <!-- Planner drawer -->
  <aside class="cdb-drawer" id="cdb-planner" aria-hidden="true" aria-label={S.plannerTitle}>
    <div class="cdb-drawer__hd">
      <span>{S.plannerTitle}</span>
      <button class="cdb-x" data-planner-close aria-label={S.close}>✕</button>
    </div>
    <ul class="cdb-plan-list" id="cdb-plan-list"></ul>
    <div class="cdb-plan-sum">
      <div class="cdb-plan-time-row"><span>{S.totalTime}</span><b id="cdb-plan-time">—</b></div>
      <h4>{S.shoppingList}</h4>
      <div id="cdb-plan-shop" class="cdb-plan-shop"></div>
      <button id="cdb-plan-clear" class="cdb-plan-clear">{S.clearPlan}</button>
    </div>
  </aside>
</section>

<script is:inline set:html={`window.__CRAFT=${JSON.stringify({ lang, dbUrl: '/assets/crafting-db.json', dismantleUrl: '/assets/dismantling-items.json', t: JS_T })};`} />
<script is:inline src="/assets/crafting-app.js"></script>

<style is:inline>
  /* ===== Crafting-DB — funktionale App ===== */
  .cdb{max-width:var(--maxw,1180px);margin:0 auto;padding:0 clamp(1rem,4vw,2rem)}
  .cdb *{box-sizing:border-box}
  /* Toolbar — klebt UNTER der fixen Site-Nav (~56px), sonst verschwindet sie dahinter */
  .cdb-bar{position:sticky;top:68px;z-index:20;display:flex;flex-wrap:wrap;gap:.6rem;align-items:center;padding:.7rem 0;background:linear-gradient(var(--bg,#16161a) 82%,color-mix(in srgb,var(--bg,#16161a) 88%,transparent));backdrop-filter:blur(6px)}
  .cdb-search-wrap{flex:1 1 240px;min-width:0}
  .cdb-search{width:100%;background:var(--surface,#232329);border:1px solid var(--line,rgba(255,94,26,.3));color:var(--text,#eef1f5);padding:.6rem .9rem;border-radius:6px;font-size:1rem;font-family:var(--font-ui,inherit)}
  .cdb-search:focus{outline:2px solid var(--accent,#FF5E1A);outline-offset:1px}
  .cdb-sort{display:flex;align-items:center;gap:.4rem}
  .cdb-sr{font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.62rem;color:var(--muted,#9ba2ae)}
  .cdb-sort select,.cdb-res{background:var(--surface,#232329);border:1px solid var(--line,rgba(255,94,26,.3));color:var(--text,#eef1f5);padding:.5rem .6rem;border-radius:6px;font-size:.9rem;font-family:var(--font-ui,inherit);max-width:100%}
  .cdb-viewtog{display:flex;border:1px solid var(--line,rgba(255,94,26,.3));border-radius:6px;overflow:hidden}
  .cdb-view{background:var(--surface,#232329);color:var(--muted,#9ba2ae);border:0;padding:.5rem .7rem;cursor:pointer;font-size:1rem;line-height:1}
  .cdb-view[aria-pressed="true"]{background:var(--accent,#FF5E1A);color:var(--ink,#16161a)}
  .cdb-filter-toggle{display:none;background:var(--surface,#232329);border:1px solid var(--line,rgba(255,94,26,.3));color:var(--text,#eef1f5);padding:.5rem .8rem;border-radius:6px;cursor:pointer;font-family:var(--font-ui,inherit);font-weight:700}
  .cdb-planner-open{position:relative;background:var(--surface,#232329);border:1px solid var(--accent-2,#1FA2FF);color:var(--accent-2,#1FA2FF);padding:.5rem .9rem;border-radius:6px;cursor:pointer;font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.04em}
  .cdb-planner-open.flash{animation:cdbflash .5s}
  @keyframes cdbflash{0%{box-shadow:0 0 0 0 var(--accent-2,#1FA2FF)}100%{box-shadow:0 0 0 12px transparent}}
  .cdb-badge{position:absolute;top:-8px;right:-8px;min-width:20px;height:20px;padding:0 5px;border-radius:10px;background:var(--accent,#FF5E1A);color:#fff;font-size:.72rem;font-weight:800;display:flex;align-items:center;justify-content:center}
  /* Layout */
  .cdb-layout{display:grid;grid-template-columns:250px 1fr;gap:1.4rem;align-items:start}
  .cdb-sidebar{position:sticky;top:146px;align-self:start;max-height:calc(100vh - 162px);overflow:auto;border:1px solid var(--line,rgba(255,94,26,.22));background:var(--surface,#232329);border-radius:8px;padding:1rem}
  .cdb-side-hd{display:none;justify-content:space-between;align-items:center;margin-bottom:.6rem;font-weight:800}
  .cdb-fgroup{margin-bottom:1.1rem;border-bottom:1px solid var(--line-soft,rgba(255,255,255,.08));padding-bottom:1rem}
  .cdb-fgroup:last-of-type{border-bottom:0}
  .cdb-fgroup h4{font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.66rem;color:var(--accent,#FF5E1A);margin:0 0 .6rem}
  .cdb-cat-details{margin-bottom:.5rem;border-bottom:1px solid var(--line-soft,rgba(255,255,255,.04));padding-bottom:.5rem}
  .cdb-cat-details:last-of-type{border-bottom:0;padding-bottom:0}
  .cdb-cat-summary{display:flex;align-items:center;justify-content:space-between;cursor:pointer;list-style:none;user-select:none}
  .cdb-cat-summary::-webkit-details-marker{display:none}
  .cdb-cat-summary::after{content:"▼";font-size:.65rem;color:var(--muted,#9ba2ae);transition:transform .2s;margin-left:.5rem}
  .cdb-cat-details[open] .cdb-cat-summary::after{transform:rotate(180deg)}
  .cdb-check{display:flex;align-items:center;gap:.5rem;cursor:pointer;padding:.22rem 0;font-size:.9rem;color:var(--text,#eef1f5);line-height:1.3}
  .cdb-check input{accent-color:var(--accent,#FF5E1A);flex:none;width:15px;height:15px}
  .cdb-check--top span{font-weight:700}
  .cdb-check--top em{color:var(--muted,#9ba2ae);font-style:normal;font-weight:600;font-size:.78rem;margin-left:.2rem}
  .cdb-subs{margin-left:1.4rem;display:flex;flex-direction:column}
  .cdb-check--sub span{font-size:.84rem;color:var(--muted,#9ba2ae)}
  .cdb-res-search-wrap{margin-bottom:.5rem;position:relative}
  .cdb-res-search{width:100%;background:var(--bg,#16161a);border:1px solid var(--line,rgba(255,94,26,.3));color:var(--text,#eef1f5);padding:.4rem .6rem;border-radius:4px;font-size:.84rem;font-family:var(--font-ui,inherit);transition:border-color .15s,box-shadow .15s}
  .cdb-res-search:focus{outline:none;border-color:var(--accent,#FF5E1A);box-shadow:0 0 8px rgba(255,94,26,.2)}
  .cdb-res-list{max-height:180px;overflow-y:auto;border:1px solid var(--line-soft,rgba(255,255,255,.08));padding:.4rem .6rem;border-radius:6px;background:var(--bg,#16161a);display:flex;flex-direction:column;gap:2px}
  .cdb-res-list::-webkit-scrollbar{width:6px}
  .cdb-res-list::-webkit-scrollbar-track{background:transparent}
  .cdb-res-list::-webkit-scrollbar-thumb{background:var(--line,rgba(255,94,26,.3));border-radius:3px}
  .cdb-res-list::-webkit-scrollbar-thumb:hover{background:var(--accent,#FF5E1A)}
