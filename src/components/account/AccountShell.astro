---
// Geteilter Rahmen aller /account/-Seiten: kompakter Hero + zentrierte Spalte
// + die acx-* Formular-Stilbasis (einmal global, Muster: FeedbackForm.fbx-*).
// Seiten sind dünne Wrapper; die eigentliche Logik lebt in den Auth-Komponenten.
interface Props {
  eyebrow: string;
  titleThin: string;
  title: string;
  lead?: string;
  /** breite Spalte (Dashboard) statt schmaler Formular-Spalte */
  wide?: boolean;
}
const { eyebrow, titleThin, title, lead, wide = false } = Astro.props;
---

<section class="hero hero--acct">
  <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/og-default.jpg')" aria-hidden="true"></div>
  <div class="hero__in">
    <div class="eyebrow">{eyebrow}</div>
    <h1><span class="thin">{titleThin}</span>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
  </div>
</section>

<div class:list={['acwrap', wide && 'acwrap--wide']}>
  <slot />
</div>

<style is:global>
  /* Kompakter Hero — Formulare gehören above the fold */
  .hero--acct { min-height: 44svh; padding-bottom: 2.4rem; }
  .hero--acct h1 { font-size: clamp(2rem, 7vw, 4.6rem); }

  .acwrap { max-width: 560px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 4rem) 4.5rem; }
  .acwrap--wide { max-width: 860px; }

  .acx-card {
    border: 1px solid var(--line);
    background: linear-gradient(180deg, var(--surface), var(--bg-2));
    padding: clamp(1.3rem, 4vw, 2.1rem);box-shadow:0 30px 80px -34px var(--shadow-color), var(--glow, 0 0 0 transparent);
  }
  .acx-card + .acx-card { margin-top: 1.6rem; }

  .acx-field { margin-bottom: 1.35rem; }
  .acx-field:last-of-type { margin-bottom: 0; }
  .acx-label {
    display: block; font-family: var(--font-ui, sans-serif); font-weight: 700;
    font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text); margin-bottom: 0.55rem;
  }
  .acx-label .opt { color: var(--muted); font-weight: 600; letter-spacing: 0.04em; text-transform: none; }
  .acx-label .reqm { color: var(--accent); }
  .acx-hint { font-size: 0.85rem; color: var(--muted); margin: 0.45rem 0 0; line-height: 1.5; }

  .acx-input {
    width: 100%; box-sizing: border-box;background:var(--veil); color: var(--text);
    border: 1px solid var(--line); padding: 0.72rem 0.9rem;
    font-family: var(--font-ui, sans-serif); font-size: 1rem; line-height: 1.5;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .acx-input::placeholder { color: color-mix(in srgb, var(--muted) 82%, transparent); }
  .acx-input:focus {
    outline: none; border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 22%, transparent);
  }
  .acx-input:user-invalid { border-color: #ff7a7a; }

  .acx-actions { display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap; margin-top: 1.7rem; }
  .acx-submit {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-family: var(--font-ui, sans-serif); font-weight: 700; font-size: 0.9rem;
    letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer;color:var(--ink, var(--ink)); background: var(--accent); border: 1px solid var(--accent);
    padding: 0.82rem 1.6rem; transition: filter 0.15s, opacity 0.15s;
  }
  .acx-submit:hover { filter: brightness(1.08); }
  .acx-submit[disabled] { opacity: 0.6; cursor: progress; }
  .acx-submit--ghost {
    color: var(--accent); background: none; border: 1px solid var(--line);
  }
  .acx-submit--ghost:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent); filter: none; }
  .acx-submit--danger {
    color: #ffd7d7; background: none; border: 1px solid rgba(255, 122, 122, 0.55);
  }
  .acx-submit--danger:hover { background: rgba(255, 122, 122, 0.12); filter: none; }

  .acx-status { margin-top: 1.1rem; font-size: 0.92rem; line-height: 1.5; color: #ff8a8a; }
  .acx-status--ok { color: #9be8a8; }

  .acx-links { margin-top: 1.4rem; display: flex; flex-wrap: wrap; gap: 0.4rem 1.4rem; font-size: 0.9rem; }
  .acx-links a { color: var(--accent); border-bottom: 1px solid var(--line); }
  .acx-links a:hover { border-color: var(--accent); }

  .acx-note {
    margin: 0 0 1.4rem; border: 1px solid var(--line-soft); border-left: 3px solid var(--accent-2);
    background: color-mix(in srgb, var(--accent-2) 8%, transparent); padding: 0.85rem 1.05rem;
    font-size: 0.88rem; color: var(--muted); line-height: 1.55;
  }
  .acx-note b { color: var(--text); }

  .acx-privacy { font-size: 0.82rem; color: var(--muted); line-height: 1.5; }
  .acx-privacy a { color: var(--accent); border-bottom: 1px solid var(--line); }

  /* Erfolgs-Panel (Muster fbx-done) */
  .acx-done { text-align: center; padding: 1.8rem 0.5rem; }
  .acx-done__mark {
    width: 66px; height: 66px; margin: 0 auto 1.2rem; border-radius: 50%;
    display: grid; place-items: center;color:var(--ink, var(--ink)); background: var(--accent-2);
    box-shadow: 0 0 44px color-mix(in srgb, var(--accent-2) 45%, transparent);
  }
  .acx-done h2 {
    font-family: var(--font-display, sans-serif); font-weight: 900; color: var(--text);
    font-size: clamp(1.4rem, 4vw, 1.9rem); margin: 0 0 0.55rem; outline: none;
  }
  .acx-done p { color: var(--muted); font-size: 1rem; line-height: 1.6; margin: 0 auto; max-width: 46ch; }
/* Hell-Entsprechungen — erzeugt von scripts/build-light-overrides.mjs. Nicht von Hand ändern. */
:root[data-theme="light"] .acx-input:user-invalid{border-color:#c84248}
:root[data-theme="light"] .acx-submit--danger{color:#734c4d}
:root[data-theme="light"] .acx-status{color:#a2172b}
:root[data-theme="light"] .acx-status--ok{color:#016b2b}
</style>
