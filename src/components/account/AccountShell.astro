---
// Geteilter Rahmen aller /account/-Seiten: kompakter Hero + zentrierte Spalte
// + die acx-* Formular-Stilbasis.
interface Props {
  eyebrow: string;
  titleThin: string;
  title: string;
  lead?: string;
  /** breite Spalte (Dashboard) statt schmaler Formular-Spalte */
  wide?: boolean;
}
const { eyebrow, titleThin, title, lead, wide = false } = Astro.props;
---

<section class="hero hero--acct">
  <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-polaris-1.jpg')" aria-hidden="true"></div>
  <div class="hero__in">
    <div class="eyebrow">{eyebrow}</div>
    <h1><span class="thin">{titleThin}</span>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
  </div>
</section>

<div class:list={['acwrap', wide && 'acwrap--wide']}>
  <slot />
</div>

<style is:global>
  .hero--acct { min-height: 40svh; padding-bottom: 2.4rem; }
  .hero--acct h1 { font-size: clamp(2.2rem, 7vw, 4.8rem); }

  .acwrap { max-width: 560px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 4rem) 4.5rem; }
  .acwrap--wide { max-width: 1180px; }

  .acx-card {
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--surface) 95%, transparent);
    backdrop-filter: blur(12px);
    border-radius: 12px;
    padding: clamp(1.4rem, 4vw, 2.2rem);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), var(--glow, 0 0 0 transparent);
    position: relative;
  }
  .acx-card + .acx-card { margin-top: 1.6rem; }

  .acx-field { margin-bottom: 1.35rem; }
  .acx-field:last-of-type { margin-bottom: 0; }
  .acx-label {
    display: block; font-family: var(--font-ui, sans-serif); font-weight: 700;
    font-size: 0.84rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--text); margin-bottom: 0.55rem;
  }
  .acx-label .opt { color: var(--muted); font-weight: 600; letter-spacing: 0.04em; text-transform: none; }
  .acx-label .reqm { color: var(--accent); }
  .acx-hint { font-size: 0.86rem; color: var(--muted); margin: 0.45rem 0 0; line-height: 1.55; }

  .acx-input {
    width: 100%; box-sizing: border-box; background: var(--surface-2); color: var(--text);
    border: 1px solid var(--line-soft); border-radius: 6px; padding: 0.75rem 0.95rem;
    font-family: var(--font-ui, sans-serif); font-size: 0.98rem; line-height: 1.5;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  }
  .acx-input::placeholder { color: color-mix(in srgb, var(--muted) 75%, transparent); }
  .acx-input:focus {
    outline: none; border-color: var(--accent); background: var(--surface);
    box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .acx-input:user-invalid { border-color: #ff7a7a; }

  .acx-actions { display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap; margin-top: 1.7rem; }
  .acx-submit {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-family: var(--font-ui, sans-serif); font-weight: 700; font-size: 0.88rem;
    letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; color: var(--ink, #05070d); background: var(--accent); border: 1px solid var(--accent);
    padding: 0.78rem 1.6rem; border-radius: 6px; transition: all 0.2s ease;
    box-shadow: 0 0 20px color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .acx-submit:hover { filter: brightness(1.12); transform: translateY(-1px); box-shadow: 0 0 28px color-mix(in srgb, var(--accent) 40%, transparent); }
  .acx-submit[disabled] { opacity: 0.6; cursor: progress; transform: none; filter: none; }
  .acx-submit--ghost {
    color: var(--accent); background: var(--surface-2); border: 1px solid var(--line);
    box-shadow: none;
  }
  .acx-submit--ghost:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 12%, transparent); }
  .acx-submit--danger {
    color: #ffd7d7; background: none; border: 1px solid rgba(255, 122, 122, 0.55);
    box-shadow: none;
  }
  .acx-submit--danger:hover { background: rgba(255, 122, 122, 0.15); border-color: #ff7a7a; }

  .acx-status { margin-top: 1.1rem; font-size: 0.92rem; line-height: 1.5; color: #ff8a8a; }
  .acx-status--ok { color: #9be8a8; }

  .acx-links { margin-top: 1.4rem; display: flex; flex-wrap: wrap; gap: 0.4rem 1.4rem; font-size: 0.9rem; }
  .acx-links a { color: var(--accent); border-bottom: 1px solid var(--line); }
  .acx-links a:hover { border-color: var(--accent); }

  .acx-note {
    margin: 0 0 1.4rem; border: 1px solid var(--line-soft); border-left: 3px solid var(--accent-2);
    background: color-mix(in srgb, var(--accent-2) 8%, transparent); padding: 0.85rem 1.05rem;
    font-size: 0.88rem; color: var(--muted); line-height: 1.55; border-radius: 6px;
  }
  .acx-note b { color: var(--text); }
</style>
