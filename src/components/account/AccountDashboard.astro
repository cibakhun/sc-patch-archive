        <a class="ov-jump" href={refineryHref}><span class="ov-jump__ic" aria-hidden="true">⬢</span><span class="ov-jump__tx"><b>{COPY.ovJRefinery}</b><span>{COPY.ovJRefinerySub}</span></span><span class="ov-jump__arr" aria-hidden="true">↗</span></a>
        <button type="button" class="ov-jump" id="ovBtnShare2"><span class="ov-jump__ic" aria-hidden="true">◈</span><span class="ov-jump__tx"><b>{COPY.ovJShare}</b><span>{COPY.ovJShareSub}</span></span><span class="ov-jump__arr" aria-hidden="true">↗</span></button>
