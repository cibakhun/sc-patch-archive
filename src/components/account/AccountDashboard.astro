    handle: 'Handle', optional: '— optional', handlePh: 'e.g. star_runner',
    handleHint: '3–24 characters: lowercase letters, digits, underscore. Unique on VerseBase.',
    bio: 'Bio / About me', bioPh: 'Tell the fleet about yourself, your ships, or missions …',
