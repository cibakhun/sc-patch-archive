            <a class="pv-chip" id="pvChipRsi" href="#" target="_blank" rel="noopener noreferrer" hidden></a>
            <span class="pv-chip" id="pvChipDiscord" hidden></span>
            <span class="pv-chip" id="pvChipOrg" hidden></span>
          </div>
        </div>
      </div>

      <div class="pv-public" id="pvPublicRow" hidden>
        <span class="pv-public__label">{COPY.publicPageLabel}</span>
        <a class="pv-public__link" id="pvPublicLink" href="#" target="_blank" rel="noopener noreferrer"></a>
        <button
          type="button"
          class="pv-public__copy"
          id="pvPublicCopy"
          data-label={COPY.publicPageCopy}
          data-done={COPY.publicPageCopied}
        >{COPY.publicPageCopy}</button>
      </div>
      <p class="acx-hint" id="pvPublicNoHandle" hidden>{COPY.publicPageNoHandle}</p>

      <div class="acx-actions" style="margin-top:1.2rem">
        <button type="button" class="acx-submit acx-submit--ghost" id="btnClosePreviewModal">{COPY.closeModal}</button>
      </div>
    </div>
  </dialog>

  <!-- Bild-Zuschnitt: Vorschau + Ausschnitt/Zoom vor dem Upload -->
  <dialog id="cropModal" class="acx-modal acx-modal--crop">
    <div class="acx-modal-content">
      <div class="acx-modal-head">
        <span class="acx-modal-icon">◈</span>
        <h3 id="cropTitle">{COPY.cropTitleAvatar}</h3>
      </div>

      <p class="acx-hint" style="margin-bottom:0.9rem">{COPY.cropHint}</p>

      <div class="crop-layout">
        <div class="crop-stage" id="cropStage" data-shape="circle">
          <img id="cropImg" alt="" draggable="false" />
          <div class="crop-grid" id="cropGrid" aria-hidden="true"></div>
          <div class="crop-frame" aria-hidden="true"></div>
        </div>

        <aside class="crop-side">
          <div class="crop-side__label">{COPY.cropPreview}</div>
          <div class="crop-previews" id="cropPreviews">
            <figure class="crop-pv">
              <canvas id="cropPvLg"></canvas>
            </figure>
            <figure class="crop-pv crop-pv--sm">
              <canvas id="cropPvSm"></canvas>
            </figure>
          </div>

          <dl class="crop-info">
            <div><dt>{COPY.cropSource}</dt><dd id="cropInfoSrc">—</dd></div>
            <div><dt>{COPY.cropOutput}</dt><dd id="cropInfoOut">—</dd></div>
            <div><dt>{COPY.cropEstSize}</dt><dd id="cropInfoSize">—</dd></div>
          </dl>

          <p class="crop-warn" id="cropWarn" hidden>{COPY.cropLowRes}</p>
        </aside>
      </div>

      <div class="crop-controls">
        <button type="button" class="crop-btn" id="cropZoomOut" aria-label="Zoom −">−</button>
        <input type="range" id="cropZoom" min="1" max="4" step="0.01" value="1" aria-label={COPY.cropZoom} />
        <button type="button" class="crop-btn" id="cropZoomIn" aria-label="Zoom +">+</button>
        <span class="crop-zoomval" id="cropZoomVal">100%</span>
      </div>

      <div class="crop-tools">
        <button type="button" class="crop-btn" id="cropRotL" title={COPY.cropRotateLeft} aria-label={COPY.cropRotateLeft}>↺</button>
        <button type="button" class="crop-btn" id="cropRotR" title={COPY.cropRotateRight} aria-label={COPY.cropRotateRight}>↻</button>
        <button type="button" class="crop-btn" id="cropFlip" title={COPY.cropFlip} aria-label={COPY.cropFlip}>⇄</button>
        <button type="button" class="acx-upload__remove" id="cropReset">{COPY.cropReset}</button>
      </div>

      <div class="acx-actions" style="margin-top:1.1rem">
        <button type="button" class="acx-submit" id="cropApply">{COPY.cropApply}</button>
        <button type="button" class="acx-submit acx-submit--ghost" id="cropCancel">{COPY.cropCancel}</button>
      </div>
    </div>
  </dialog>
</div>

<script>
import '../../scripts/account-dashboard';
</script>
