const loginHref = href('/account/login.html', lang);
const homeHref = lang === 'de' ? '/de.html' : '/';
const shipsHref = href('/schiffe.html', lang);
const refineryHref = href('/refinery.html', lang);
const confirmRedirect = loginHref + '?confirmed=1';
---

<div id="dashLoading" class="acx-hint" style="text-align:center">{COPY.loading}</div>

<div id="dash" hidden
  data-lang={lang}
  data-login={loginHref}
  data-home={homeHref}
  data-confirm-redirect={confirmRedirect}
  data-kinds={JSON.stringify(COPY.kind)}
  data-msg-handle-taken={COPY.errHandleTaken}
  data-msg-handle-format={COPY.errHandleFormat}
  data-msg-saved={COPY.savedProfile}
  data-msg-email-sent={COPY.emailSent}
  data-msg-pass-saved={COPY.passSaved}
  data-msg-short={COPY.errShort}
  data-msg-match={COPY.errMatch}
  data-msg-same={COPY.errSame}
  data-msg-net={COPY.errNet}
  data-msg-rate={COPY.errRate}
  data-msg-loaderr={COPY.loadError}
  data-retry={COPY.retry}
  data-danger-word={COPY.dangerWord}
  data-fav-remove={COPY.favRemove}
  data-msg-rsi-checking={COPY.rsiChecking}
  data-msg-rsi-no-handle={COPY.rsiNoHandle}
  data-msg-rsi-enter-handle={COPY.rsiEnterHandle}
  data-msg-rsi-not-found={COPY.rsiNotFound}
  data-msg-rsi-server-err={COPY.rsiServerErr}
  data-msg-rsi-success={COPY.rsiVerifySuccess}
  data-msg-rsi-reset-ok={COPY.rsiResetOk}
  data-rsi-copy={COPY.rsiCopy}
  data-rsi-copied={COPY.rsiCopied}
  data-msg-uploading={COPY.uploading}
  data-msg-upload-toobig={COPY.uploadTooBig}
  data-msg-upload-badtype={COPY.uploadBadType}
  data-msg-upload-err={COPY.uploadErr}
  data-crop-title-avatar={COPY.cropTitleAvatar}
  data-crop-title-banner={COPY.cropTitleBanner}
  data-crop-calc={COPY.cropCalc}
>
  <div class="acshell reveal">
    <!-- Sidebar-Rail -->
    <aside class="acnav" aria-label={COPY.ovNav}>
      <div class="acnav__brand">
        <span class="acnav__eye">System Access</span>
        <span class="acnav__name">VERSEBASE</span>
      </div>
      <nav class="acnav__list">
        <span class="acnav__group">{COPY.ovNav}</span>
        <button type="button" class="acnav__item active" data-tab="overview"><span class="g" aria-hidden="true">⬡</span> <span>{lang === 'de' ? 'Übersicht' : 'Overview'}</span></button>
        <button type="button" class="acnav__item" data-tab="profile"><span class="g" aria-hidden="true">◆</span> <span>{COPY.tabProfile}</span></button>
        <button type="button" class="acnav__item" data-tab="favs"><span class="g" aria-hidden="true">★</span> <span>{COPY.tabFavs}</span> <span class="badge" id="navFavCount" hidden>0</span></button>
        <button type="button" class="acnav__item" data-tab="friends"><span class="g" aria-hidden="true">◈</span> <span>{COPY.tabFriends}</span> <span class="badge" id="navFriendCount" hidden>0</span></button>
        <span class="acnav__group">{COPY.ovTools}</span>
        <a class="acnav__item" href={refineryHref}><span class="g" aria-hidden="true">⬢</span> <span>{COPY.ovJRefinery}</span> <span class="acnav__ext" aria-hidden="true">↗</span></a>
        <button type="button" class="acnav__item" data-tab="security"><span class="g" aria-hidden="true">▲</span> <span>{COPY.tabSecurity}</span></button>
      </nav>
      <div class="acnav__foot">
        <div class="acnav__mini" aria-hidden="true" id="idAvatar">◆</div>
        <div class="acnav__who"><b id="navWho">—</b><span id="idEmail">—</span></div>
        <button type="button" class="acnav__out" id="btnLogout" title={COPY.logout} aria-label={COPY.logout}>⏻</button>
      </div>
    </aside>

    <div class="acmain">
    <!-- SECTION: ÜBERSICHT (Default) -->
    <section id="tab-panel-overview" class="acx-tab-panel"
      data-l-pending={COPY.ovPending} data-l-pending1={COPY.ovPending1} data-l-nopending={COPY.ovNoPending}
      data-l-active={COPY.ovActive} data-l-active1={COPY.ovActive1} data-l-noactive={COPY.ovNoActive}
      data-l-missing={COPY.ovMissing} data-l-missing1={COPY.ovMissing1} data-l-complete={COPY.ovComplete}
      data-l-rsi-yes={COPY.ovRsiYes} data-l-rsi-no={COPY.ovRsiNo}
      data-l-act-fav={COPY.ovActFav} data-l-act-req={COPY.ovActReq} data-l-act-job={COPY.ovActJob} data-l-act-empty={COPY.ovActEmpty}>
      <div class="ov-head">
        <h2><span class="thin">{COPY.ovWelcome},</span><span id="ovHeadName">Citizen</span></h2>
        <p>{COPY.ovLead}</p>
      </div>

      <!-- Identitäts-Streifen -->
      <div class="ov-id">
        <div class="ov-id__banner" id="ovBanner"></div>
        <div class="ov-id__body">
          <div class="ov-id__avatar">
            <svg class="ov-id__ring" viewBox="0 0 132 132" width="106" height="106" aria-hidden="true">
              <circle cx="66" cy="66" r="62" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="22 12" opacity=".8" />
              <circle cx="66" cy="66" r="62" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="4 90" />
            </svg>
            <div class="ov-id__box" id="ovAvatarBox"><span id="ovAvatarText">◆</span><img id="ovAvatarImg" src="" alt="" hidden /></div>
            <span class="ov-id__dot" id="ovStatusDot"></span>
          </div>
          <div class="ov-id__meta">
            <div class="ov-id__name">
              <h3 id="ovName">Citizen</h3>
              <span class="ov-vbadge" id="ovVerified" hidden>
                <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
                RSI Verified
              </span>
            </div>
            <div class="ov-id__handle" id="ovHandle">@citizen</div>
            <div class="ov-id__row">
              <span class="ov-pill" id="ovRolePill" hidden><span class="g" id="ovRoleIcon" aria-hidden="true">◆</span> <span id="ovRoleText"></span></span>
              <span class="ov-pill" id="ovStatusPill"><span id="ovStatusLabel"></span></span>
              <span class="ov-pill" id="ovOrgPill" hidden><span class="g" aria-hidden="true">◈</span> <span id="ovOrgText"></span></span>
            </div>
            <div class="ov-id__row" style="margin-top:.4rem;font-size:.78rem">
              <span>{COPY.memberSince} <b id="idSince" style="color:var(--text)">—</b></span>
            </div>
          </div>
          <div class="ov-id__actions">
            <button type="button" class="acx-submit acx-submit--ghost" id="ovBtnShare"><span aria-hidden="true">◈</span> <span>{lang === 'de' ? 'Öffentliches Profil' : 'Public Profile'}</span></button>
          </div>
        </div>
      </div>

      <!-- Stat-Kacheln -->
      <div class="ov-label"><h4>{COPY.ovAtAGlance}</h4><span class="rule"></span></div>
      <div class="ov-stats">
        <button type="button" class="ov-tile" data-tab-jump="favs">
