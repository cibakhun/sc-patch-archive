const confirmRedirect = loginHref + '?confirmed=1';
---

<div id="dashLoading" class="acx-hint" style="text-align:center">{COPY.loading}</div>

<div id="dash" hidden
  data-lang={lang}
  data-login={loginHref}
  data-home={homeHref}
  data-confirm-redirect={confirmRedirect}
  data-kinds={JSON.stringify(COPY.kind)}
  data-msg-handle-taken={COPY.errHandleTaken}
  data-msg-handle-format={COPY.errHandleFormat}
  data-msg-saved={COPY.savedProfile}
  data-msg-email-sent={COPY.emailSent}
  data-msg-pass-saved={COPY.passSaved}
  data-msg-short={COPY.errShort}
  data-msg-match={COPY.errMatch}
  data-msg-same={COPY.errSame}
  data-msg-net={COPY.errNet}
  data-msg-rate={COPY.errRate}
  data-msg-loaderr={COPY.loadError}
  data-retry={COPY.retry}
  data-danger-word={COPY.dangerWord}
  data-fav-remove={COPY.favRemove}
  data-msg-rsi-checking={COPY.rsiChecking}
  data-msg-rsi-no-handle={COPY.rsiNoHandle}
  data-msg-rsi-enter-handle={COPY.rsiEnterHandle}
  data-msg-rsi-not-found={COPY.rsiNotFound}
  data-msg-rsi-server-err={COPY.rsiServerErr}
  data-msg-rsi-success={COPY.rsiVerifySuccess}
  data-msg-rsi-reset-ok={COPY.rsiResetOk}
  data-rsi-copy={COPY.rsiCopy}
  data-rsi-copied={COPY.rsiCopied}
  data-msg-uploading={COPY.uploading}
  data-msg-upload-toobig={COPY.uploadTooBig}
  data-msg-upload-badtype={COPY.uploadBadType}
  data-msg-upload-err={COPY.uploadErr}
  data-crop-title-avatar={COPY.cropTitleAvatar}
  data-crop-title-banner={COPY.cropTitleBanner}
  data-crop-calc={COPY.cropCalc}
>
  <!-- Icon-Sprite: ein kohärentes Linien-Set (ersetzt die Unicode-Glyphen) -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
    <symbol id="i-gauge" viewBox="0 0 24 24"><path d="M4 15a8 8 0 0 1 16 0"/><path d="M12 15l3.6-3.4"/><circle cx="12" cy="15" r="1.1"/></symbol>
    <symbol id="i-id" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="11" r="2"/><path d="M5.4 16.4c.5-1.4 1.7-2.1 3.1-2.1s2.6.7 3.1 2.1"/><path d="M14.5 10h4M14.5 13h3"/></symbol>
    <symbol id="i-star" viewBox="0 0 24 24"><path d="M12 3.6l2.5 5.2 5.7.8-4.1 4 1 5.6L12 16.9l-5.1 2.3 1-5.6-4.1-4 5.7-.8z"/></symbol>
    <symbol id="i-users" viewBox="0 0 24 24"><circle cx="9" cy="8" r="3"/><path d="M3.6 18.6c.6-2.9 2.8-4.3 5.4-4.3s4.8 1.4 5.4 4.3"/><path d="M16.2 5.3a3 3 0 0 1 0 5.4"/><path d="M17.6 14.5c1.9.6 3.2 1.9 3.8 4.1"/></symbol>
    <symbol id="i-hex" viewBox="0 0 24 24"><path d="M12 3l7.4 4.2v8.4L12 21l-7.4-4.2V7.2z"/><path d="M12 8l3.5 2v4L12 16l-3.5-2v-4z"/></symbol>
    <symbol id="i-shield" viewBox="0 0 24 24"><path d="M12 3l7 2.4v5.4c0 4.4-3 7.5-7 8.9-4-1.4-7-4.5-7-8.9V5.4z"/></symbol>
    <symbol id="i-verified" viewBox="0 0 24 24"><path d="M12 3l7 2.4v5.4c0 4.4-3 7.5-7 8.9-4-1.4-7-4.5-7-8.9V5.4z"/><path d="M8.6 12l2.2 2.2 4.4-4.7"/></symbol>
    <symbol id="i-power" viewBox="0 0 24 24"><path d="M12 3.5v7.5"/><path d="M7 6.8a7 7 0 1 0 10 0"/></symbol>
    <symbol id="i-out" viewBox="0 0 24 24"><path d="M8 16L16 8"/><path d="M9.5 8H16v6.5"/></symbol>
    <symbol id="i-chev" viewBox="0 0 24 24"><path d="M9.5 6l6 6-6 6"/></symbol>
    <symbol id="i-edit" viewBox="0 0 24 24"><path d="M4 20.5h16"/><path d="M14.5 5.5l4 4L9 19l-4.5 1 1-4.5z"/></symbol>
    <symbol id="i-org" viewBox="0 0 24 24"><path d="M4 20V6l6-2.5V20"/><path d="M10 8h6a2 2 0 0 1 2 2v10"/><path d="M13 12h2M13 15h2"/></symbol>
    <symbol id="i-pin" viewBox="0 0 24 24"><path d="M12 21c4-4.5 6-7.6 6-10.5A6 6 0 0 0 6 10.5C6 13.4 8 16.5 12 21z"/><circle cx="12" cy="10.5" r="2"/></symbol>
  </defs></svg>

  <div class="acshell reveal">
    <!-- Sidebar-Rail -->
    <aside class="acnav" aria-label={COPY.ovNav}>
      <div class="acnav__brand">
        <svg class="acnav__mk" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M12 2l9 5.2v9.6L12 22l-9-5.2V7.2z"/><path d="M12 7l4.5 2.6v5.3L12 17.5l-4.5-2.6V9.6z"/></svg>
        <span><span class="acnav__name">VERSEBASE</span><span class="acnav__eye">System Access</span></span>
      </div>
      <nav class="acnav__list">
        <span class="acnav__group">{COPY.ovNav}</span>
        <button type="button" class="acnav__item active" data-tab="overview"><svg class="ic" aria-hidden="true"><use href="#i-gauge" /></svg> <span>{lang === 'de' ? 'Übersicht' : 'Overview'}</span></button>
        <button type="button" class="acnav__item" data-tab="profile"><svg class="ic" aria-hidden="true"><use href="#i-id" /></svg> <span>{COPY.tabProfile}</span></button>
        <button type="button" class="acnav__item" data-tab="favs"><svg class="ic" aria-hidden="true"><use href="#i-star" /></svg> <span>{COPY.tabFavs}</span> <span class="badge" id="navFavCount" hidden>0</span></button>
        <button type="button" class="acnav__item" data-tab="friends"><svg class="ic" aria-hidden="true"><use href="#i-users" /></svg> <span>{COPY.tabFriends}</span> <span class="badge" id="navFriendCount" hidden>0</span></button>
        <span class="acnav__group">{COPY.ovTools}</span>
        <a class="acnav__item" href={refineryHref}><svg class="ic" aria-hidden="true"><use href="#i-hex" /></svg> <span>{COPY.ovJRefinery}</span> <svg class="ic acnav__ext" aria-hidden="true"><use href="#i-out" /></svg></a>
        <button type="button" class="acnav__item" data-tab="security"><svg class="ic" aria-hidden="true"><use href="#i-shield" /></svg> <span>{COPY.tabSecurity}</span></button>
      </nav>
      <div class="acnav__foot">
        <div class="acnav__mini" aria-hidden="true" id="idAvatar">◆</div>
        <div class="acnav__who"><b id="navWho">—</b><span id="idEmail">—</span></div>
