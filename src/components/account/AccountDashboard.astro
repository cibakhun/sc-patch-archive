---
// Account-Dashboard — Profil, Freunde/Social, Favoriten, Sicherheit
import { href } from '../../i18n/ui';
import ProfileCard from './ProfileCard.astro';
import FriendsManager from './FriendsManager.astro';
import { BANNER_PRESETS, AVATAR_PRESETS, ACCENT_COLORS, CITIZEN_ROLES, STATUS_STATES } from '../../lib/profilePresets';

interface Props {
