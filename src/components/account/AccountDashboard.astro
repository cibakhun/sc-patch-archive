    rsiVerifySuccess: 'RSI Account verified successfully!',
    rsiVerifyErr: 'Code could not be found on RSI profile yet. Please check your bio.',
    rsiReset: 'Revoke verification',
    rsiResetOk: 'RSI verification has been reset successfully.',
    rsiModalTitle: 'RSI Account Verification',
    rsiModalIntroPre: 'Verify your Star Citizen account',
    rsiModalIntroPost: 'on Roberts Space Industries.',
