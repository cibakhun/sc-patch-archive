    rsiNotFound: 'Code "%code%" was not found in @%handle%\'s bio on robertsspaceindustries.com yet. Please save your bio on RSI (it can take 1–2 minutes to show up).',
    rsiServerErr: 'The verification server is currently unreachable — please try again later.',
    discordTag: 'Discord Tag', discordPh: 'e.g. Pilot#1234 or @pilot',
    orgName: 'Organization & Rank', orgPh: 'e.g. VerseBase Fleet — Commander',
    saveProfile: 'Save profile changes', savingProfile: 'Saving profile …', savedProfile: 'Profile saved successfully.',
    errHandleTaken: 'This handle is already taken — please pick another one.',
    errHandleFormat: 'Handles may only use a–z, 0–9 and _ (3–24 characters).',
    favsEmpty: 'No favorites yet. Star ☆ ships in the database and they will show up here.',
    favsShips: 'Browse the ship database →',
    favRemove: 'Remove',
    kind: { ship: 'Ship', mission: 'Mission', mineral: 'Mineral', item: 'Item', patch: 'Patch', topic: 'Topic' } as Record<string, string>,
    email: 'Change e-mail address', emailPh: 'new@example.com',
    emailBtn: 'Change e-mail', emailBusy: 'Sending confirmation …',
    emailSent: 'Confirmation e-mails are on their way — the change takes effect after confirming.',
    pass: 'New password', passPh: 'At least 8 characters',
    pass2: 'Repeat password', pass2Ph: 'Same password again',
    passBtn: 'Change password', passBusy: 'Saving …', passSaved: 'Password changed.',
    errShort: 'The password needs at least 8 characters.',
    errMatch: 'The passwords do not match.',
    errSame: 'The new password must differ from the old one.',
    dangerBody: 'Permanently deletes your account including profile and favorites. This cannot be undone.',
    dangerConfirmLabel: 'Type “DELETE” to confirm',
    dangerWord: 'DELETE',
    dangerBtn: 'Delete account permanently', dangerBusy: 'Deleting account …',
    errNet: 'That did not work — please try again.',
    errRate: 'Too many requests — please wait a moment.',
    modalTitle: 'Public Profile Preview',
    closeModal: 'Close',
    previewHint: 'This is how other pilots see your profile.',
  },
}[lang];

const loginHref = href('/account/login.html', lang);
const homeHref = lang === 'de' ? '/de.html' : '/';
const shipsHref = href('/schiffe.html', lang);
const confirmRedirect = loginHref + '?confirmed=1';
---

<div id="dashLoading" class="acx-hint" style="text-align:center">{COPY.loading}</div>

<div id="dash" hidden
  data-lang={lang}
  data-login={loginHref}
  data-home={homeHref}
  data-confirm-redirect={confirmRedirect}
  data-kinds={JSON.stringify(COPY.kind)}
  data-msg-handle-taken={COPY.errHandleTaken}
  data-msg-handle-format={COPY.errHandleFormat}
  data-msg-saved={COPY.savedProfile}
  data-msg-email-sent={COPY.emailSent}
  data-msg-pass-saved={COPY.passSaved}
  data-msg-short={COPY.errShort}
  data-msg-match={COPY.errMatch}
  data-msg-same={COPY.errSame}
  data-msg-net={COPY.errNet}
  data-msg-rate={COPY.errRate}
  data-msg-loaderr={COPY.loadError}
  data-retry={COPY.retry}
  data-danger-word={COPY.dangerWord}
  data-fav-remove={COPY.favRemove}
  data-msg-rsi-checking={COPY.rsiChecking}
  data-msg-rsi-no-handle={COPY.rsiNoHandle}
  data-msg-rsi-enter-handle={COPY.rsiEnterHandle}
  data-msg-rsi-not-found={COPY.rsiNotFound}
  data-msg-rsi-server-err={COPY.rsiServerErr}
  data-msg-rsi-success={COPY.rsiVerifySuccess}
  data-msg-rsi-reset-ok={COPY.rsiResetOk}
  data-rsi-copy={COPY.rsiCopy}
  data-rsi-copied={COPY.rsiCopied}
>
  <!-- Identity Header -->
  <div class="acx-idcard reveal">
    <div class="acx-id">
      <div class="acx-id__avatar" aria-hidden="true" id="idAvatar">◆</div>
      <div class="acx-id__meta">
        <div class="acx-id__label">{COPY.signedInAs}</div>
        <div class="acx-id__email" id="idEmail">—</div>
        <div class="acx-id__since"><span>{COPY.memberSince}</span> <b id="idSince">—</b></div>
      </div>
    </div>
    <button class="acx-submit acx-submit--ghost" type="button" id="btnLogout">{COPY.logout}</button>
  </div>

  <!-- Main Navigation Tabs -->
  <nav class="acx-tabs-nav reveal" aria-label="Account Navigation">
    <button type="button" class="acx-tab-btn active" data-tab="profile">
      <span>◆</span> <span>{COPY.tabProfile}</span>
    </button>
    <button type="button" class="acx-tab-btn" data-tab="friends">
      <span>◈</span> <span>{COPY.tabFriends}</span>
    </button>
    <button type="button" class="acx-tab-btn" data-tab="favs">
      <span>★</span> <span>{COPY.tabFavs}</span>
    </button>
    <button type="button" class="acx-tab-btn" data-tab="security">
      <span>▲</span> <span>{COPY.tabSecurity}</span>
    </button>
  </nav>

  <!-- TAB 1: PROFIL & IDENTITÄT -->
  <section id="tab-panel-profile" class="acx-tab-panel">
    <!-- Live Profile Card -->
    <ProfileCard lang={lang} />

    <!-- Edit Profile Form -->
    <div class="acx-card reveal">
      <form id="profileForm" novalidate>
        <!-- Identity Basics -->
        <h3 class="acx-form-heading">{COPY.secProfile}</h3>
        <div class="acx-grid-2">
          <div class="acx-field">
            <label class="acx-label" for="pfName">{COPY.name}</label>
            <input class="acx-input" id="pfName" name="display_name" type="text" maxlength="60" autocomplete="nickname" placeholder={COPY.namePh} />
          </div>
          <div class="acx-field">
            <label class="acx-label" for="pfHandle">{COPY.handle} <span class="opt">{COPY.optional}</span></label>
            <input class="acx-input" id="pfHandle" name="handle" type="text" maxlength="24" autocapitalize="off" autocorrect="off" spellcheck="false" placeholder={COPY.handlePh} />
          </div>
        </div>

        <div class="acx-field">
          <label class="acx-label" for="pfBio">{COPY.bio}</label>
          <textarea class="acx-input acx-textarea" id="pfBio" name="bio" rows="3" maxlength="500" placeholder={COPY.bioPh}></textarea>
        </div>

        <hr class="acx-divider" />

        <!-- Visual Banner Grid Picker -->
        <h3 class="acx-form-heading">{COPY.secDesign}</h3>
        <div class="acx-field">
          <label class="acx-label">{COPY.bannerSelect}</label>
          <div class="banner-grid-picker" id="bannerGridPicker">
            {BANNER_PRESETS.map((b, idx) => (
              <button
                type="button"
                class={`banner-thumb-card ${idx === 0 ? 'selected' : ''}`}
                data-banner-url={b.url}
                style={`background-image: url('${b.thumb}')`}
              >
                <span class="banner-thumb-title">{b.name}</span>
              </button>
            ))}
          </div>
          <input class="acx-input" id="pfBannerUrl" type="hidden" />
        </div>

        <!-- Visual Avatar & Color Picker Grid -->
        <div class="acx-grid-2" style="margin-top:1.2rem">
          <div class="acx-field">
            <label class="acx-label">{COPY.avatarSelect}</label>
            <div class="avatar-grid-picker" id="avatarGridPicker">
              {AVATAR_PRESETS.map((a, idx) => (
                <button
                  type="button"
                  class={`avatar-thumb-card ${idx === 0 ? 'selected' : ''}`}
                  data-avatar-icon={a.symbol}
                  data-avatar-color={a.defaultColor}
                  title={a.name}
                >
                  <span>{a.symbol}</span>
                </button>
              ))}
            </div>
            <input class="acx-input" id="pfAvatarUrl" type="url" placeholder={COPY.avatarUrl} style="margin-top:0.8rem" />
          </div>

          <div class="acx-field">
            <label class="acx-label">{COPY.avatarColorSelect}</label>
            <div class="color-grid-picker" id="colorGridPicker">
              {ACCENT_COLORS.map((c, idx) => (
                <button
                  type="button"
                  class={`color-swatch ${idx === 0 ? 'selected' : ''}`}
                  data-color={c.hex}
                  style={`background: ${c.hex}; box-shadow: 0 0 10px ${c.hex}66`}
                  title={c.name}
                ></button>
              ))}
            </div>
          </div>
        </div>

        <hr class="acx-divider" />

        <!-- Status & Role -->
        <h3 class="acx-form-heading">{COPY.secRoleStatus}</h3>
        <div class="acx-grid-2">
          <div class="acx-field">
            <label class="acx-label" for="pfStatusState">{COPY.statusState}</label>
            <select class="acx-input" id="pfStatusState">
              {Object.entries(STATUS_STATES).map(([key, st]) => (
                <option value={key}>{lang === 'de' ? st.labelDe : st.labelEn}</option>
              ))}
            </select>
          </div>

          <div class="acx-field">
            <label class="acx-label" for="pfRole">{COPY.roleLabel}</label>
            <select class="acx-input" id="pfRole">
              <option value="">-- Keine Rolle gewählt --</option>
              {CITIZEN_ROLES.map(r => (
                <option value={r.id}>{r.symbol} {lang === 'de' ? r.labelDe : r.labelEn}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="acx-field">
          <label class="acx-label" for="pfStatusText">{COPY.statusText}</label>
          <input class="acx-input" id="pfStatusText" type="text" maxlength="60" placeholder={COPY.statusTextPh} />
        </div>

        <hr class="acx-divider" />

        <!-- RSI Verification -->
        <h3 class="acx-form-heading">{COPY.secRsi}</h3>
        <div class="acx-field">
          <label class="acx-label" for="pfRsiHandle">{COPY.rsiHandle}</label>
          <div class="acx-rsi-input-row">
            <input class="acx-input" id="pfRsiHandle" type="text" maxlength="32" placeholder={COPY.rsiPh} />
            <button type="button" class="acx-submit acx-submit--ghost" id="btnRsiVerifyModal">
              <span>✓</span> <span>{COPY.rsiVerifyBtn}</span>
            </button>
          </div>
          <div id="rsiVerifiedStatus" class="rsi-verified-indicator" hidden>
            <span>✓ {COPY.rsiVerifiedText}</span>
            <button type="button" id="btnResetRsiVerify" style="margin-left:0.8rem;background:none;border:none;color:var(--muted);cursor:pointer;font-size:0.8rem;text-decoration:underline">
              ({COPY.rsiReset})
            </button>
          </div>
        </div>

        <hr class="acx-divider" />

        <!-- Social & Org -->
        <h3 class="acx-form-heading">{COPY.secSocial}</h3>
        <div class="acx-grid-2">
          <div class="acx-field">
            <label class="acx-label" for="pfDiscord">{COPY.discordTag}</label>
            <input class="acx-input" id="pfDiscord" type="text" maxlength="40" placeholder={COPY.discordPh} />
          </div>

          <div class="acx-field">
            <label class="acx-label" for="pfOrg">{COPY.orgName}</label>
            <input class="acx-input" id="pfOrg" type="text" maxlength="60" placeholder={COPY.orgPh} />
          </div>
        </div>

        <div class="acx-actions" style="margin-top:1.5rem">
          <button class="acx-submit" type="submit" id="pfBtn"><span id="pfBtnTxt">{COPY.saveProfile}</span></button>
        </div>
        <p class="acx-status" id="pfStatus" role="status" aria-live="polite" hidden></p>
      </form>
    </div>
  </section>

  <!-- TAB 2: FREUNDE & SOCIAL -->
  <section id="tab-panel-friends" class="acx-tab-panel" hidden>
    <FriendsManager lang={lang} />
  </section>

  <!-- TAB 3: FAVORITEN -->
  <section id="tab-panel-favs" class="acx-tab-panel" hidden>
    <div class="sec-head reveal"><span class="num">02</span><h2>{COPY.secFavs}</h2><span class="rule"></span></div>
    <div class="acx-card reveal">
      <ul class="acx-favs" id="favList"></ul>
      <div id="favEmpty" hidden>
        <p class="acx-hint">{COPY.favsEmpty}</p>
        <div class="acx-links"><a href={shipsHref}>{COPY.favsShips}</a></div>
      </div>
    </div>
  </section>

  <!-- TAB 4: SICHERHEIT & KONTO -->
  <section id="tab-panel-security" class="acx-tab-panel" hidden>
    <div class="sec-head reveal"><span class="num">03</span><h2>{COPY.secSecurity}</h2><span class="rule"></span></div>
    <div class="acx-card reveal">
      <form id="emailForm" novalidate>
        <div class="acx-field">
          <label class="acx-label" for="seEmail">{COPY.email}</label>
          <input class="acx-input" id="seEmail" name="email" type="email" autocomplete="email" placeholder={COPY.emailPh} />
        </div>
        <div class="acx-actions">
          <button class="acx-submit acx-submit--ghost" type="submit" id="seEmailBtn" data-busy={COPY.emailBusy} data-idle={COPY.emailBtn}>{COPY.emailBtn}</button>
        </div>
        <p class="acx-status" id="seEmailStatus" role="status" aria-live="polite" hidden></p>
      </form>
    </div>

    <div class="acx-card reveal">
      <form id="passForm" novalidate>
        <div class="acx-field">
          <label class="acx-label" for="sePass">{COPY.pass}</label>
          <input class="acx-input" id="sePass" name="password" type="password" minlength="8" autocomplete="new-password" placeholder={COPY.passPh} />
        </div>
        <div class="acx-field">
          <label class="acx-label" for="sePass2">{COPY.pass2}</label>
          <input class="acx-input" id="sePass2" name="password2" type="password" minlength="8" autocomplete="new-password" placeholder={COPY.pass2Ph} />
        </div>
        <div class="acx-actions">
          <button class="acx-submit acx-submit--ghost" type="submit" id="sePassBtn" data-busy={COPY.passBusy} data-idle={COPY.passBtn}>{COPY.passBtn}</button>
        </div>
        <p class="acx-status" id="sePassStatus" role="status" aria-live="polite" hidden></p>
      </form>
    </div>

    <div class="sec-head reveal"><span class="num">04</span><h2>{COPY.secDanger}</h2><span class="rule"></span></div>
    <div class="acx-card acx-card--danger reveal">
      <p class="acx-hint" style="margin:0 0 1.1rem">{COPY.dangerBody}</p>
      <form id="deleteForm" novalidate>
        <div class="acx-field">
          <label class="acx-label" for="delConfirm">{COPY.dangerConfirmLabel}</label>
          <input class="acx-input" id="delConfirm" name="confirm" type="text" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder={COPY.dangerWord} />
        </div>
        <div class="acx-actions">
          <button class="acx-submit acx-submit--danger" type="submit" id="delBtn" disabled data-busy={COPY.dangerBusy} data-idle={COPY.dangerBtn}>{COPY.dangerBtn}</button>
        </div>
        <p class="acx-status" id="delStatus" role="alert" aria-live="assertive" hidden></p>
      </form>
    </div>
  </section>

  <!-- RSI Verification Wizard Modal -->
  <dialog id="rsiModal" class="acx-modal">
    <div class="acx-modal-content">
      <div class="acx-modal-head">
        <span class="acx-modal-icon">◆</span>
        <h3>{COPY.rsiModalTitle}</h3>
      </div>
      
