    closeModal: 'Schließen',
    previewHint: 'So sehen andere Piloten dein Profil.',
  },
  en: {
    loading: 'Loading your account …',
    loadError: 'Could not load your account — please check your connection.',
    retry: 'Reload',
    signedInAs: 'Signed in as',
    memberSince: 'Member since',
    logout: 'Sign out',
    tabProfile: 'Profile & Identity',
    tabFriends: 'Friends & Social',
    tabFavs: 'Favorites',
    tabSecurity: 'Security & Account',
    secProfile: 'Profile Customization',
    secDesign: 'Banner & Avatar Design',
    secRoleStatus: 'Status & Citizen Role',
    secRsi: 'RSI Account & Verification',
    secSocial: 'Social Links & Organization',
    secFavs: 'Your Favorites',
    secSecurity: 'Security',
    secDanger: 'Delete account',
