---
interface Props {
  lang?: 'de' | 'en';
}

const { lang = 'de' } = Astro.props;

const t = {
  registry: 'UEE CITIZEN REGISTRY // VERSEBASE',
  idLabel: 'ID',
  bioEmpty: lang === 'de' ? 'Noch keine Biografie angegeben.' : 'No bio provided yet.',
  copyTitle: lang === 'de' ? 'Handle kopieren' : 'Copy handle',
  publicProfile: lang === 'de' ? 'Öffentliches Profil' : 'Public Profile',
  statSince: lang === 'de' ? 'Dabei seit' : 'Member since',
  statFavs: lang === 'de' ? 'Favoriten' : 'Favorites',
  statFriends: lang === 'de' ? 'Freunde' : 'Friends',
  statComplete: lang === 'de' ? 'Profil' : 'Profile',
  transmission: 'TRANSMISSION',
  statusTitle: lang === 'de' ? 'Status: Online' : 'Status: Online',
  avatarAlt: lang === 'de' ? 'Profilbild' : 'Avatar',
  verifiedTitle: lang === 'de' ? 'RSI-verifizierter Account' : 'RSI Verified Account',
};
---

<article class="vp-card" id="pcCard" aria-label={t.registry}>
  <span class="vp-corner vp-corner--tl" aria-hidden="true"></span>
  <span class="vp-corner vp-corner--tr" aria-hidden="true"></span>
  <span class="vp-corner vp-corner--bl" aria-hidden="true"></span>
  <span class="vp-corner vp-corner--br" aria-hidden="true"></span>

  <!-- 1 · Registry-Chrome -->
  <header class="vp-chrome">
    <span class="vp-chrome__left">{t.registry}</span>
    <span class="vp-chrome__right">{t.idLabel} <b id="pcRegistryId">VB-••••••••</b></span>
  </header>

  <!-- 2 · Banner-Zone (dunkle Medien-Insel, bleibt im Light-Theme dunkel) -->
  <div class="vp-banner" id="pcBannerContainer">
    <div class="vp-banner__img" id="pcBannerImg"></div>
    <div class="vp-banner__grid" aria-hidden="true"></div>
    <div class="vp-banner__scrim" aria-hidden="true"></div>
    <div class="vp-banner__sweep" aria-hidden="true"></div>
    <span class="vp-bracket vp-bracket--tl" aria-hidden="true"></span>
    <span class="vp-bracket vp-bracket--tr" aria-hidden="true"></span>
    <span class="vp-bracket vp-bracket--bl" aria-hidden="true"></span>
    <span class="vp-bracket vp-bracket--br" aria-hidden="true"></span>
  </div>

  <!-- 3 · Avatar-Modul mit Holo-Ringen -->
  <div class="vp-avatar-row">
    <div class="vp-avatar-module">
      <svg class="vp-ring vp-ring--a" viewBox="0 0 132 132" aria-hidden="true">
        <circle cx="66" cy="66" r="62" fill="none" stroke="currentColor" stroke-width="1.5"
          stroke-dasharray="22 12" stroke-linecap="butt" opacity="0.85" />
        <circle cx="66" cy="66" r="62" fill="none" stroke="currentColor" stroke-width="3"
          stroke-dasharray="4 90" opacity="0.9" />
      </svg>
      <svg class="vp-ring vp-ring--b" viewBox="0 0 132 132" aria-hidden="true">
        <polygon points="66,6 118,36 118,96 66,126 14,96 14,36" fill="none"
          stroke="currentColor" stroke-width="1" stroke-dasharray="10 8" opacity="0.55" />
      </svg>
      <div class="vp-avatar-box" id="pcAvatarBox">
        <span id="pcAvatarText">◆</span>
        <img id="pcAvatarImg" src="" alt={t.avatarAlt} hidden />
        <span class="vp-avatar-scan" aria-hidden="true"></span>
      </div>
      <div class="vp-status-dot" id="pcStatusDot" title={t.statusTitle}></div>
    </div>

    <div class="vp-actions">
      <button type="button" class="vp-btn-ghost" id="btnPreviewModal">
        <span class="vp-btn-ghost__icon" aria-hidden="true">◈</span>
        <span>{t.publicProfile}</span>
      </button>
    </div>
  </div>

  <!-- 4 · Identity-Block -->
  <div class="vp-identity">
    <div class="vp-name-row">
      <h2 class="vp-name" id="pcName">Citizen</h2>
      <span class="rsi-verified-badge" id="pcRsiVerified" hidden title={t.verifiedTitle}>
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        RSI VERIFIED
      </span>
    </div>

    <div class="vp-handle-row">
      <span class="vp-handle" id="pcHandle">@citizen</span>
      <button type="button" class="vp-copy" id="pcCopyHandle" title={t.copyTitle} aria-label={t.copyTitle}>
        <span class="vp-copy__icon" aria-hidden="true">⧉</span>
        <span class="vp-copy__done" aria-hidden="true">✓</span>
      </button>
    </div>

    <!-- 5 · Meta-Zeile: Rolle + Transmission -->
    <div class="vp-meta">
      <div class="vp-role" id="pcRoleBadge" hidden>
        <span class="vp-role__icon" id="pcRoleIcon" aria-hidden="true">◆</span>
        <span class="vp-role__text" id="pcRoleText">Pilot</span>
      </div>

      <div class="vp-transmission" id="pcStatusBox">
        <span class="vp-transmission__tag">{t.transmission}</span>
        <span class="vp-transmission__state" id="pcStatusStateLabel">In-Verse</span>
        <span class="vp-transmission__sep" id="pcStatusSep" hidden>·</span>
        <span class="vp-transmission__text" id="pcStatusCustomText"></span>
      </div>
    </div>

    <!-- 6 · Stats-Readout -->
    <dl class="vp-stats">
      <div class="vp-stat">
        <dt>{t.statSince}</dt>
        <dd id="pcStatSince">—</dd>
      </div>
      <div class="vp-stat">
        <dt>{t.statFavs}</dt>
        <dd id="pcStatFavs">0</dd>
      </div>
      <div class="vp-stat">
        <dt>{t.statFriends}</dt>
        <dd id="pcStatFriends">0</dd>
      </div>
      <div class="vp-stat">
        <dt>{t.statComplete}</dt>
        <dd id="pcStatComplete">0%</dd>
        <span class="vp-stat-bar" aria-hidden="true"><span id="pcStatBar"></span></span>
      </div>
    </dl>

    <!-- 7 · Bio als Registry-Eintrag -->
    <p class="vp-bio" id="pcBio">
      <em class="bio-empty">{t.bioEmpty}</em>
    </p>

    <!-- 8 · Data-Chips -->
    <div class="vp-chips" id="pcSocialPills">
      <a id="pcLinkRsi" href="#" target="_blank" rel="noopener noreferrer" class="vp-chip vp-chip--rsi" hidden>
        <span class="vp-chip__dot" id="pcRsiDot" hidden aria-hidden="true"></span>
        <span class="vp-chip__icon" aria-hidden="true">◆</span>
        <span class="vp-chip__label">RSI: <strong id="pcTxtRsi"></strong></span>
        <span class="vp-chip__action">Spectrum →</span>
      </a>

      <span id="pcPillDiscord" class="vp-chip" hidden>
        <span class="vp-chip__icon" aria-hidden="true">💬</span>
        <span class="vp-chip__label">Discord: <strong id="pcTxtDiscord"></strong></span>
      </span>

      <span id="pcPillOrg" class="vp-chip" hidden>
        <span class="vp-chip__icon" aria-hidden="true">❖</span>
        <span class="vp-chip__label"><strong id="pcTxtOrg"></strong></span>
      </span>
    </div>
  </div>
</article>

<style>
  /* ---------- Card: Registry-Dokument mit Chamfer-Ecken ---------- */
  .vp-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    clip-path: polygon(14px 0, 100% 0, 100% calc(100% - 14px), calc(100% - 14px) 100%, 0 100%, 0 14px);
    filter: drop-shadow(0 16px 34px rgba(0, 0, 0, 0.45));
    margin-bottom: 2rem;
    will-change: transform;
  }

  .vp-corner {
    position: absolute;
    width: 10px;
    height: 10px;
    border: 2px solid var(--accent);
    z-index: 6;
    pointer-events: none;
  }
  .vp-corner--tl { top: 5px; left: 5px; border-right: 0; border-bottom: 0; }
  .vp-corner--tr { top: 5px; right: 5px; border-left: 0; border-bottom: 0; }
  .vp-corner--bl { bottom: 5px; left: 5px; border-right: 0; border-top: 0; }
  .vp-corner--br { bottom: 5px; right: 5px; border-left: 0; border-top: 0; }

  /* ---------- 1 · Registry-Chrome ---------- */
  .vp-chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.45rem 1rem;
    border-top: 2px solid var(--accent);
    border-bottom: 1px solid var(--line-soft);
    background:
      repeating-linear-gradient(-45deg, color-mix(in srgb, var(--accent) 6%, transparent) 0 6px, transparent 6px 12px),
      color-mix(in srgb, var(--accent) 4%, transparent);
    font-family: var(--font-mono, 'Share Tech Mono', monospace);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .vp-chrome__left {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .vp-chrome__right {
    flex: none;
    white-space: nowrap;
  }
  .vp-chrome__right b {
    color: var(--accent);
    font-weight: 400;
    letter-spacing: 0.1em;
  }

  /* ---------- 2 · Banner ---------- */
  .vp-banner {
    position: relative;
    height: 220px;
    background: var(--media-void, #05070d);
    overflow: hidden;
  }

  .vp-banner__img {
    position: absolute;
    inset: -6%;
    background-size: cover;
    background-position: center;
    animation: pcKb 26s ease-in-out infinite alternate;
    /* dezentes RGB-Fringing an den Rändern */
    filter: drop-shadow(2px 0 0 rgba(255, 64, 96, 0.10)) drop-shadow(-2px 0 0 rgba(45, 212, 255, 0.12));
  }

  @keyframes pcKb {
    from { transform: scale(1) translate(0, 0); }
    to   { transform: scale(1.08) translate(1.4%, -1.4%); }
  }

  .vp-banner__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(45, 212, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(45, 212, 255, 0.05) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
  }

  .vp-banner__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(5, 7, 13, 0.15) 0%,
      rgba(5, 7, 13, 0.35) 55%,
      color-mix(in srgb, var(--surface) 70%, transparent) 82%,
      var(--surface) 100%
    );
    pointer-events: none;
  }

  .vp-banner__sweep {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 34%;
    background: linear-gradient(
      100deg,
      transparent 0%,
      rgba(45, 212, 255, 0.14) 42%,
      rgba(122, 226, 255, 0.22) 50%,
      rgba(45, 212, 255, 0.14) 58%,
      transparent 100%
    );
    mix-blend-mode: screen;
    transform: translateX(-140%) skewX(-8deg);
    animation: pcSweep 6s linear infinite;
    pointer-events: none;
  }

  @keyframes pcSweep {
    0%   { transform: translateX(-140%) skewX(-8deg); }
    55%  { transform: translateX(360%) skewX(-8deg); }
    100% { transform: translateX(360%) skewX(-8deg); }
  }

  .vp-bracket {
    position: absolute;
    width: 10px;
    height: 10px;
    border: 2px solid var(--accent);
    opacity: 0.8;
    pointer-events: none;
    z-index: 3;
  }
  .vp-bracket--tl { top: 10px; left: 10px; border-right: 0; border-bottom: 0; }
  .vp-bracket--tr { top: 10px; right: 10px; border-left: 0; border-bottom: 0; }
  .vp-bracket--bl { bottom: 10px; left: 10px; border-right: 0; border-top: 0; }
  .vp-bracket--br { bottom: 10px; right: 10px; border-left: 0; border-top: 0; }

  /* ---------- 3 · Avatar-Modul ---------- */
  .vp-avatar-row {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 1.6rem;
    margin-top: -62px;
  }

  .vp-avatar-module {
    position: relative;
    flex: none;
    width: 132px;
    height: 132px;
    display: grid;
    place-items: center;
    color: var(--accent);
  }

  .vp-ring {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--accent) 45%, transparent));
  }
  .vp-ring--a { animation: pcSpin 24s linear infinite; }
  .vp-ring--b { animation: pcSpinRev 36s linear infinite; }

  @keyframes pcSpin    { to { transform: rotate(360deg); } }
  @keyframes pcSpinRev { to { transform: rotate(-360deg); } }

  .vp-avatar-box {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--surface-2);
    border: 3px solid var(--accent);
    box-shadow: 0 0 30px color-mix(in srgb, var(--accent) 35%, transparent);
    display: grid;
    place-items: center;
    font-size: 2.5rem;
    color: var(--accent);
    overflow: hidden;
    position: relative;
    transition: box-shadow 0.3s ease, border-color 0.3s ease, color 0.3s ease;
  }
  .vp-avatar-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .vp-avatar-scan {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg, rgba(45, 212, 255, 0.09) 0 1px, transparent 1px 3px);
    pointer-events: none;
  }

  .vp-status-dot {
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #38bdf8;
    border: 3px solid var(--surface);
    box-shadow: 0 0 12px #38bdf8;
    transition: background 0.3s ease, box-shadow 0.3s ease;
    z-index: 2;
  }
  .vp-status-dot.pulse { animation: statusPulse 2s infinite; }

  @keyframes statusPulse {
    0%   { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.8); }
    70%  { box-shadow: 0 0 0 12px rgba(34, 197, 94, 0); }
    100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
  }

  .vp-actions {
    margin-top: 62px;
    padding-bottom: 0.4rem;
  }

  .vp-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-family: var(--font-ui, sans-serif);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid var(--line);
    clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, filter 0.2s ease;
  }
  .vp-btn-ghost:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 20%, transparent);
    filter: drop-shadow(0 0 10px color-mix(in srgb, var(--accent) 35%, transparent));
  }
  .vp-btn-ghost:focus-visible,
  .vp-copy:focus-visible,
  .vp-chip:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ---------- 4 · Identity ---------- */
  .vp-identity {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 0.8rem 1.6rem 1.5rem;
  }

  .vp-name-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .vp-name {
    font-family: var(--font-display, sans-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .rsi-verified-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(34, 197, 94, 0.15);
    color: #4ade80;
    padding: 0.18rem 0.6rem;
    clip-path: polygon(6px 0, 100% 0, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0 100%, 0 6px);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    --rsi-line: rgba(34, 197, 94, 0.45);
  }
  /* Rahmen als 1px-Ring, der der abgeschrägten Kante folgt.
     Ein normaler `border` würde vom clip-path an den Diagonalen abgeschnitten
     — deshalb zeichnen wir die Linie als eigene Ring-Kontur (außen + innen). */
  .rsi-verified-badge::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: var(--rsi-line);
    clip-path: polygon(evenodd,
      6px 0, 100% 0, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0 100%, 0 6px,
      6px 0,
      7px 1px, calc(100% - 1px) 1px, calc(100% - 1px) calc(100% - 7px),
      calc(100% - 7px) calc(100% - 1px), 1px calc(100% - 1px), 1px 7px,
      7px 1px);
  }
  .rsi-verified-badge[hidden] { display: none !important; }

  .vp-handle-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: -0.35rem;
  }
  .vp-handle {
    font-family: var(--font-mono, 'Share Tech Mono', monospace);
    font-size: 0.95rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .vp-copy {
    position: relative;
    display: inline-grid;
    place-items: center;
    width: 32px;
    height: 32px;
    background: transparent;
    border: 1px solid var(--line-soft);
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  /* unsichtbare Hit-Area-Erweiterung (~44px Touch-Target) */
  .vp-copy::before {
    content: '';
    position: absolute;
    inset: -6px;
  }
  .vp-copy:hover { color: var(--accent); border-color: var(--accent); }
  .vp-copy__done { display: none; color: #4ade80; }
  .vp-copy.copied { border-color: rgba(34, 197, 94, 0.5); }
  .vp-copy.copied .vp-copy__icon { display: none; }
  .vp-copy.copied .vp-copy__done { display: inline; }

  /* ---------- 5 · Meta / Transmission ---------- */
  .vp-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .vp-role {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border: 1px solid var(--line);
    padding: 0.22rem 0.7rem;
    clip-path: polygon(7px 0, 100% 0, 100% calc(100% - 7px), calc(100% - 7px) 100%, 0 100%, 0 7px);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
  }
  .vp-role[hidden] { display: none !important; }

  .vp-transmission {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono, 'Share Tech Mono', monospace);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .vp-transmission__tag {
    color: var(--accent);
    border: 1px solid var(--line);
    padding: 0.02rem 0.4rem;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
  }
  .vp-transmission__state { color: var(--accent-2); font-weight: 700; }
  .vp-transmission__sep { color: var(--muted); }
  .vp-transmission__text { color: var(--muted); font-style: italic; text-transform: none; letter-spacing: 0.02em; }

  /* ---------- 6 · Stats-Readout ---------- */
  .vp-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.9rem;
    margin: 0.35rem 0 0;
    padding: 0.85rem 0 0;
    border-top: 1px solid var(--line-soft);
  }
  .vp-stat { min-width: 0; }
  .vp-stat dt {
    font-family: var(--font-ui, sans-serif);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .vp-stat dd {
    margin: 0.2rem 0 0;
    font-family: var(--font-mono, 'Share Tech Mono', monospace);
    font-size: 1.05rem;
    color: var(--accent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .vp-stat-bar {
    display: block;
    height: 2px;
    margin-top: 0.4rem;
    background: var(--line-soft);
  }
  .vp-stat-bar span {
    display: block;
    height: 100%;
    width: 0%;
    background: var(--accent);
    box-shadow: 0 0 8px color-mix(in srgb, var(--accent) 70%, transparent);
    transition: width 0.4s ease;
  }

  /* ---------- 7 · Bio ---------- */
  .vp-bio {
    font-size: 0.94rem;
    color: var(--text);
    line-height: 1.55;
    margin: 0.25rem 0 0.35rem;
    padding-left: 0.9rem;
    border-left: 2px solid var(--accent);
    white-space: pre-wrap;
  }
  /* :global, weil das Script das <em> bei leerer Bio per innerHTML neu injiziert */
  .vp-bio :global(.bio-empty) {
    color: var(--muted);
    font-size: 0.88rem;
  }

  /* ---------- 8 · Data-Chips ---------- */
  .vp-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.25rem;
  }
  .vp-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--surface-2);
    border: 1px solid var(--line-soft);
    padding: 0.35rem 0.7rem;
    clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);
    font-size: 0.82rem;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease, filter 0.2s ease;
  }
  .vp-chip[hidden] { display: none !important; }
  .vp-chip--rsi { border-color: var(--line); }
  a.vp-chip:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--accent) 30%, transparent));
  }
  .vp-chip__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
