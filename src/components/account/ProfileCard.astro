---
interface Props {
  lang?: 'de' | 'en';
  isEditable?: boolean;
}

const { lang = 'de', isEditable = true } = Astro.props;
---

<div class="profile-card-wrap">
  <div class="profile-banner-container" id="pcBannerContainer">
    <div class="profile-banner-img" id="pcBannerImg"></div>
    <div class="profile-banner-overlay"></div>
    {isEditable && (
      <div class="profile-banner-badge" id="pcBannerBadge">
        <span class="pc-badge-icon">📷</span>
        <span id="pcBannerLabel">{lang === 'de' ? 'Banner anpassen' : 'Customize Banner'}</span>
      </div>
    )}
  </div>

  <div class="profile-body">
    <div class="profile-avatar-row">
      <div class="profile-avatar-wrapper">
        <div class="profile-avatar-box" id="pcAvatarBox">
          <span id="pcAvatarText">◆</span>
          <img id="pcAvatarImg" src="" alt="Avatar" hidden />
        </div>
        <div class="profile-status-indicator" id="pcStatusDot" title="Status: Online"></div>
      </div>

      <div class="profile-actions-row">
        <button type="button" class="pc-btn pc-btn--ghost" id="btnPreviewModal">
          <span>👁️</span>
          <span>{lang === 'de' ? 'Öffentliches Profil' : 'Public Profile'}</span>
        </button>
      </div>
    </div>

    <div class="profile-info-block">
      <div class="profile-name-row">
        <h2 class="profile-name" id="pcName">Citizen</h2>
        <span class="profile-handle" id="pcHandle">@citizen</span>
        <span class="rsi-verified-badge" id="pcRsiVerified" hidden title="RSI Verified Account">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          RSI Verified
        </span>
      </div>

      <div class="profile-role-badge" id="pcRoleBadge" hidden>
        <span class="role-icon" id="pcRoleIcon">🎯</span>
        <span class="role-text" id="pcRoleText">Pilot</span>
      </div>

      <div class="profile-status-box" id="pcStatusBox">
        <span class="status-label" id="pcStatusStateLabel">In-Verse</span>
        <span class="status-sep" id="pcStatusSep" hidden>·</span>
        <span class="status-text" id="pcStatusCustomText"></span>
      </div>

      <p class="profile-bio" id="pcBio">
        <em class="bio-empty">{lang === 'de' ? 'Noch keine Biografie angegeben.' : 'No bio provided yet.'}</em>
      </p>

      <div class="profile-social-pills" id="pcSocialPills">
        <a id="pcLinkRsi" href="#" target="_blank" rel="noopener noreferrer" class="social-pill social-pill--rsi" hidden>
          <span class="pill-icon">🚀</span>
          <span class="pill-label">RSI: <strong id="pcTxtRsi"></strong></span>
          <span class="pill-action">Spectrum →</span>
        </a>

        <span id="pcPillDiscord" class="social-pill social-pill--discord" hidden>
          <span class="pill-icon">💬</span>
          <span class="pill-label">Discord: <strong id="pcTxtDiscord"></strong></span>
        </span>

        <span id="pcPillOrg" class="social-pill social-pill--org" hidden>
          <span class="pill-icon">⚜️</span>
          <span class="pill-label"><strong id="pcTxtOrg"></strong></span>
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  .profile-card-wrap {
    position: relative;
    border-radius: 12px;
    background: var(--surface);
    border: 1px solid var(--line);
    overflow: hidden;
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.4);
    margin-bottom: 2rem;
  }

  .profile-banner-container {
    position: relative;
    height: 180px;
    background: #090e1a;
    overflow: hidden;
  }

  .profile-banner-img {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.4s ease, filter 0.3s ease;
  }

  .profile-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(5, 7, 13, 0.1) 0%, rgba(5, 7, 13, 0.85) 100%);
  }

  .profile-banner-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(13, 19, 34, 0.75);
    backdrop-filter: blur(8px);
    border: 1px solid var(--line);
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    pointer-events: none;
  }

  .profile-body {
    position: relative;
    padding: 0 1.5rem 1.5rem 1.5rem;
    margin-top: -48px;
  }

  .profile-avatar-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .profile-avatar-wrapper {
    position: relative;
    flex: none;
  }

  .profile-avatar-box {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--surface-2);
    border: 3px solid var(--surface);
    box-shadow: 0 0 25px rgba(45, 212, 255, 0.3);
    display: grid;
    place-items: center;
    font-size: 2.5rem;
    color: var(--accent);
    overflow: hidden;
    position: relative;
  }

  .profile-avatar-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-status-indicator {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #38bdf8;
    border: 3px solid var(--surface);
    box-shadow: 0 0 10px #38bdf8;
  }

  .profile-status-indicator.pulse {
    animation: statusPulse 2s infinite;
  }

  @keyframes statusPulse {
    0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
    70% { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
    100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
  }

  .profile-actions-row {
    margin-top: 50px;
  }

  .pc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.9rem;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .pc-btn--ghost {
    background: var(--surface-2);
    border: 1px solid var(--line);
    color: var(--text);
  }

  .pc-btn--ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 14px rgba(45, 212, 255, 0.2);
  }

  .profile-info-block {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .profile-name-row {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .profile-name {
    font-family: var(--font-display, sans-serif);
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
  }

  .profile-handle {
    font-size: 0.92rem;
    color: var(--muted);
    font-family: monospace;
  }

  .rsi-verified-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.4);
    color: #4ade80;
    padding: 0.15rem 0.55rem;
    border-radius: 12px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .profile-role-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid var(--line);
    padding: 0.2rem 0.65rem;
    border-radius: 4px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
  }

  .profile-status-box {
    font-size: 0.88rem;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .status-label {
    font-weight: 600;
    color: var(--accent-2);
  }

  .status-sep {
    color: var(--muted);
  }

  .status-text {
    color: var(--muted);
    font-style: italic;
  }

  .profile-bio {
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0.3rem 0 0.5rem 0;
    white-space: pre-wrap;
  }

  .bio-empty {
    color: var(--muted);
    font-size: 0.85rem;
  }

  .profile-social-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.4rem;
  }

  .social-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--surface-2);
    border: 1px solid var(--line-soft);
    padding: 0.3rem 0.65rem;
    border-radius: 6px;
    font-size: 0.8rem;
    color: var(--text);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .social-pill--rsi {
    border-color: rgba(45, 212, 255, 0.3);
  }

  .social-pill--rsi:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .pill-action {
    color: var(--accent);
    font-weight: 700;
    margin-left: 0.2rem;
    font-size: 0.75rem;
  }
</style>
