---
// Neues Passwort setzen — Landeseite des Recovery-Links aus der Mail.
// supabase-js (detectSessionInUrl) übernimmt die Recovery-Session aus dem
// URL-Fragment; ohne gültige Session zeigt die Seite den „Link abgelaufen"-Weg.
import { href } from '../../i18n/ui';

interface Props {
  lang: 'de' | 'en';
}
const { lang } = Astro.props;

const COPY = {
  de: {
    pass: 'Neues Passwort', passPh: 'Mindestens 8 Zeichen',
    pass2: 'Passwort wiederholen', pass2Ph: 'Nochmal dasselbe Passwort',
    submit: 'Passwort speichern', busy: 'Speichere …',
    checking: 'Prüfe deinen Link …',
    invalidTitle: 'Link ungültig oder abgelaufen',
    invalidBody: 'Der Wiederherstellungs-Link ist nicht (mehr) gültig. Fordere einfach einen neuen an.',
    invalidCta: 'Neuen Link anfordern',
    doneTitle: 'Passwort geändert!',
    doneBody: 'Du bist angemeldet — weiter geht es in deinem Konto.',
    doneCta: 'Zum Dashboard',
    errShort: 'Das Passwort braucht mindestens 8 Zeichen.',
    errMatch: 'Die Passwörter stimmen nicht überein.',
    errSame: 'Das neue Passwort muss sich vom alten unterscheiden.',
    errNet: 'Das hat nicht geklappt — bitte erneut versuchen.',
  },
  en: {
    pass: 'New password', passPh: 'At least 8 characters',
    pass2: 'Repeat password', pass2Ph: 'Same password again',
    submit: 'Save password', busy: 'Saving …',
    checking: 'Checking your link …',
    invalidTitle: 'Link invalid or expired',
    invalidBody: 'This recovery link is no longer valid. Just request a new one.',
    invalidCta: 'Request a new link',
    doneTitle: 'Password changed!',
    doneBody: 'You are signed in — continue to your account.',
    doneCta: 'Go to dashboard',
    errShort: 'The password needs at least 8 characters.',
    errMatch: 'The passwords do not match.',
    errSame: 'The new password must differ from the old one.',
    errNet: 'That did not work — please try again.',
  },
}[lang];

const resetHref = href('/account/reset.html', lang);
const dashboardHref = href('/account.html', lang);
---

<div class="acx-card reveal">
  <p class="acx-hint" id="upChecking">{COPY.checking}</p>

  <form id="upForm" hidden novalidate
    data-dash={dashboardHref}
    data-msg-short={COPY.errShort}
    data-msg-match={COPY.errMatch}
    data-msg-same={COPY.errSame}
    data-msg-net={COPY.errNet}
    data-busy={COPY.busy}
    data-submit={COPY.submit}
  >
    <div class="acx-field">
      <label class="acx-label" for="upPass">{COPY.pass} <span class="reqm">*</span></label>
      <input class="acx-input" id="upPass" name="password" type="password" required minlength="8" autocomplete="new-password" placeholder={COPY.passPh} />
    </div>
    <div class="acx-field">
      <label class="acx-label" for="upPass2">{COPY.pass2} <span class="reqm">*</span></label>
      <input class="acx-input" id="upPass2" name="password2" type="password" required minlength="8" autocomplete="new-password" placeholder={COPY.pass2Ph} />
    </div>
    <div class="acx-actions">
      <button class="acx-submit" type="submit" id="upBtn"><span id="upBtnTxt">{COPY.submit}</span></button>
    </div>
    <p class="acx-status" id="upStatus" role="alert" aria-live="assertive" hidden></p>
  </form>

  <div class="acx-done" id="upInvalid" hidden>
    <h2 tabindex="-1">{COPY.invalidTitle}</h2>
    <p>{COPY.invalidBody}</p>
    <div class="acx-links" style="justify-content:center">
      <a href={resetHref}>{COPY.invalidCta}</a>
    </div>
  </div>

  <div class="acx-done" id="upDone" hidden>
    <div class="acx-done__mark" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <h2 tabindex="-1">{COPY.doneTitle}</h2>
    <p>{COPY.doneBody}</p>
    <div class="acx-links" style="justify-content:center">
      <a href={dashboardHref}>{COPY.doneCta}</a>
    </div>
  </div>
</div>

<script>
  import { supabase } from '../../lib/supabase';

  const form = document.getElementById('upForm') as HTMLFormElement | null;
  if (form) {
    const D = form.dataset;
    const checking = document.getElementById('upChecking')!;
    const invalid = document.getElementById('upInvalid')!;
    const doneEl = document.getElementById('upDone')!;
    const status = document.getElementById('upStatus')!;
    const btn = document.getElementById('upBtn') as HTMLButtonElement;
    const btnTxt = document.getElementById('upBtnTxt')!;

    // detectSessionInUrl übernimmt die Recovery-Session aus dem Fragment.
    // Nicht mit fixem Kurz-Timeout raten (auf langsamen Geräten war der Hash
    // nach 350 ms teils noch unverarbeitet -> fälschlich „Link ungültig"):
    // aufs erste Auth-Event warten; großzügiger Fallback für den Fehlerfall.
    // Abgelaufene Links landen mit #error=…&error_code=otp_expired hier.
    const hashHasError = /error(_code)?=/.test(location.hash);
    let decided = false;
    const decide = (session: unknown) => {
      if (decided) return;
      decided = true;
      checking.hidden = true;
      if (session && !hashHasError) form.hidden = false;
      else invalid.hidden = false;
    };
    supabase.auth.onAuthStateChange((event, session) => {
      if (event === 'INITIAL_SESSION' || event === 'PASSWORD_RECOVERY' || event === 'SIGNED_IN') {
        decide(session);
      }
    });
    setTimeout(async () => {
      const { data } = await supabase.auth.getSession();
      decide(data.session);
    }, 1500);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.hidden = true;
      const password = (form.elements.namedItem('password') as HTMLInputElement).value;
      const password2 = (form.elements.namedItem('password2') as HTMLInputElement).value;
      const setStatus = (m: string) => { status.textContent = m; status.hidden = false; };

      if (password.length < 8) { setStatus(D.msgShort!); return; }
      if (password !== password2) { setStatus(D.msgMatch!); return; }

      btn.disabled = true;
      btnTxt.textContent = D.busy!;
      try {
        const { error } = await supabase.auth.updateUser({ password });
        if (error) {
          const code = (error as { code?: string }).code || '';
          setStatus(code === 'same_password' ? D.msgSame! : D.msgNet!);
          return;
        }
        form.hidden = true;
        doneEl.hidden = false;
      } catch {
        setStatus(D.msgNet!);
      } finally {
        btn.disabled = false;
        btnTxt.textContent = D.submit!;
      }
    });
  }
</script>
