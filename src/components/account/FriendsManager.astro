---
// Freunde & Piloten-Verzeichnis — echte Daten aus Supabase.
//
// Tabellen: friends (eine Zeile je Freundschaft, beide Seiten sehen sie per RLS)
// und friend_requests (pending). Anzeige-Profile kommen aus der View
// social_profiles (nur Profile MIT Handle, nur fuer eingeloggte Nutzer).
// Annehmen laeuft ueber die SECURITY-DEFINER-Funktion accept_friend_request(),
// damit Status-Update und Freundschaft atomar zusammen passieren.
interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;

const COPY = {
  de: {
    title: 'Freunde & Piloten-Verzeichnis',
    subtitle: 'Vernetze dich mit anderen VerseBase-Piloten. Gefunden wird man über das Handle.',
    addPh: 'VerseBase-Handle eingeben (z. B. star_runner)',
    sendReq: 'Anfrage senden',
    searchPh: 'Freunde nach Name, Handle oder Rolle filtern …',
    tabFriends: 'Deine Freunde',
    tabRequests: 'Anfragen',
    emptyFriends: 'Noch keine Freunde. Füge andere Piloten über ihr Handle hinzu.',
    emptyFiltered: 'Kein Freund passt zu diesem Filter.',
    emptyRequests: 'Keine offenen Freundschaftsanfragen.',
    incoming: 'Eingehend',
    outgoing: 'Gesendet',
    accept: 'Annehmen',
    decline: 'Ablehnen',
    cancelReq: 'Zurückziehen',
    removeFriend: 'Entfernen',
    viewProfile: 'Profil ansehen',
    loading: 'Lade dein Netzwerk …',
    needHandle: 'Setze zuerst ein Handle in „Profil & Identität" — ohne Handle können andere Piloten dich nicht finden und du kannst keine Anfragen senden.',
    errSelf: 'Du kannst dir nicht selbst eine Anfrage senden.',
    errNotFound: 'Kein Pilot mit diesem Handle gefunden.',
    errAlreadyFriend: 'Ihr seid bereits Freunde.',
    errAlreadySent: 'Du hast diesem Piloten bereits eine Anfrage gesendet.',
    errNet: 'Das hat nicht geklappt — bitte erneut versuchen.',
    successSent: 'Freundschaftsanfrage gesendet.',
    successAccepted: 'Freundschaft bestätigt.',
    acceptedTheirs: 'Der Pilot hatte dir bereits geschrieben — ihr seid jetzt Freunde.',
    confirmRemove: 'Freundschaft mit %name% wirklich beenden?',
    friendSince: 'Freunde seit',
    requested: 'Angefragt',
  },
  en: {
    title: 'Friends & Pilot Directory',
    subtitle: 'Connect with fellow VerseBase pilots. Your handle is how others find you.',
    addPh: 'Enter VerseBase handle (e.g. star_runner)',
    sendReq: 'Send request',
    searchPh: 'Filter friends by name, handle or role …',
    tabFriends: 'Your friends',
    tabRequests: 'Requests',
    emptyFriends: 'No friends yet. Add other pilots by their handle.',
    emptyFiltered: 'No friend matches this filter.',
    emptyRequests: 'No pending friend requests.',
    incoming: 'Incoming',
    outgoing: 'Sent',
    accept: 'Accept',
    decline: 'Decline',
    cancelReq: 'Withdraw',
    removeFriend: 'Remove',
    viewProfile: 'View profile',
    loading: 'Loading your network …',
    needHandle: 'Set a handle in “Profile & Identity” first — without one other pilots cannot find you and you cannot send requests.',
    errSelf: 'You cannot send a friend request to yourself.',
    errNotFound: 'No pilot found with this handle.',
    errAlreadyFriend: 'You are already friends.',
    errAlreadySent: 'You already sent this pilot a request.',
    errNet: 'That did not work — please try again.',
    successSent: 'Friend request sent.',
    successAccepted: 'Friendship confirmed.',
    acceptedTheirs: 'This pilot had already sent you a request — you are friends now.',
    confirmRemove: 'Really end your friendship with %name%?',
    friendSince: 'Friends since',
    requested: 'Requested',
  },
}[lang];

const pilotBase = lang === 'de' ? '/de/pilot/' : '/pilot/';
---

<div
  class="friends-manager"
  data-lang={lang}
  data-pilot-base={pilotBase}
  data-msg-self={COPY.errSelf}
  data-msg-notfound={COPY.errNotFound}
  data-msg-already-friend={COPY.errAlreadyFriend}
  data-msg-already-sent={COPY.errAlreadySent}
  data-msg-net={COPY.errNet}
  data-msg-sent={COPY.successSent}
  data-msg-accepted={COPY.successAccepted}
  data-msg-accepted-theirs={COPY.acceptedTheirs}
  data-msg-confirm-remove={COPY.confirmRemove}
  data-lbl-accept={COPY.accept}
  data-lbl-decline={COPY.decline}
  data-lbl-cancel={COPY.cancelReq}
  data-lbl-remove={COPY.removeFriend}
  data-lbl-view={COPY.viewProfile}
  data-lbl-since={COPY.friendSince}
  data-lbl-requested={COPY.requested}
  data-txt-empty-friends={COPY.emptyFriends}
  data-txt-empty-filtered={COPY.emptyFiltered}
>
  <div class="acx-card fm-add-card">
    <div class="fm-add-head">
      <div class="fm-icon">◆</div>
      <div>
        <h3 class="fm-title">{COPY.title}</h3>
        <p class="acx-hint" style="margin:0">{COPY.subtitle}</p>
      </div>
    </div>

    <p class="fm-nohandle" id="fmNoHandle" hidden>{COPY.needHandle}</p>

    <form id="fmAddForm" class="fm-add-form" novalidate>
      <div class="fm-input-group">
        <input
          type="text"
          id="fmHandleInput"
          class="acx-input"
          placeholder={COPY.addPh}
          maxlength="24"
          autocapitalize="off"
          autocorrect="off"
          spellcheck="false"
        />
        <button type="submit" class="acx-submit" id="fmAddBtn">
          <span aria-hidden="true">+</span> <span>{COPY.sendReq}</span>
        </button>
      </div>
      <p id="fmStatusMsg" class="acx-status" role="status" aria-live="polite" hidden></p>
    </form>
  </div>

  <div class="fm-tabs-bar" role="tablist">
    <button type="button" class="fm-tab-btn active" id="fmTabBtnFriends" role="tab" aria-selected="true">
      <span>{COPY.tabFriends}</span>
      <span class="fm-badge" id="fmBadgeFriends">0</span>
    </button>
    <button type="button" class="fm-tab-btn" id="fmTabBtnRequests" role="tab" aria-selected="false">
      <span>{COPY.tabRequests}</span>
      <span class="fm-badge fm-badge--accent" id="fmBadgeRequests" hidden>0</span>
    </button>
  </div>

  <p class="acx-hint" id="fmLoading">{COPY.loading}</p>

  <div id="fmPanelFriends" class="fm-panel" role="tabpanel" hidden>
    <div class="fm-search-bar">
      <input type="search" id="fmFilterInput" class="acx-input" placeholder={COPY.searchPh} />
    </div>
    <div id="fmFriendsList" class="fm-grid"></div>
    <div id="fmFriendsEmpty" class="fm-empty-box" hidden>
      <div class="fm-empty-icon">◆</div>
      <p class="acx-hint" id="fmFriendsEmptyTxt">{COPY.emptyFriends}</p>
    </div>
  </div>

  <div id="fmPanelRequests" class="fm-panel" role="tabpanel" hidden>
    <h4 class="fm-sec-head" id="fmIncomingHead" hidden>
      <span>{COPY.incoming}</span><span class="fm-count" id="fmIncomingCount">0</span>
    </h4>
    <div id="fmIncomingList" class="fm-list"></div>

    <h4 class="fm-sec-head" id="fmOutgoingHead" hidden>
      <span>{COPY.outgoing}</span><span class="fm-count" id="fmOutgoingCount">0</span>
    </h4>
    <div id="fmOutgoingList" class="fm-list"></div>

    <div id="fmRequestsEmpty" class="fm-empty-box" hidden>
      <div class="fm-empty-icon">◈</div>
      <p class="acx-hint">{COPY.emptyRequests}</p>
    </div>
  </div>
</div>

<style is:global>
  .friends-manager {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .fm-add-card { display: flex; flex-direction: column; gap: 1.1rem; }

  .fm-add-head { display: flex; align-items: center; gap: 1.1rem; }

  .fm-icon {
    font-size: 1.5rem;
    width: 52px;
    height: 52px;
    flex: none;
    display: grid;
    place-items: center;
    color: var(--accent);
    border: 1px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
  }

  .fm-title {
    margin: 0 0 0.15rem;
    font-family: var(--font-display, sans-serif);
    font-size: 1.05rem;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .fm-nohandle {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.4;
    color: #fbbf24;
    border-left: 2px solid #fbbf24;
    padding-left: 0.6rem;
  }

  .fm-input-group { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .fm-input-group .acx-input { flex: 1; min-width: 200px; }

  .fm-search-bar { margin-bottom: 1rem; }

  .fm-tabs-bar {
    display: flex;
    gap: 0.6rem;
    border-bottom: 1px solid var(--line-soft);
    padding-bottom: 0.6rem;
    flex-wrap: wrap;
  }

  .fm-tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--surface-2);
    border: 1px solid var(--line-soft);
    color: var(--muted);
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.88rem;
    padding: 0.5rem 0.95rem;
    border-radius: 8px;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .fm-tab-btn:hover { color: var(--text); border-color: var(--line); }
  .fm-tab-btn.active {
    color: var(--accent);
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }

  .fm-badge {
    min-width: 1.5em;
    padding: 0.05rem 0.4rem;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--line);
    font-size: 0.75rem;
    text-align: center;
  }
  .fm-badge--accent {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--ink, #05070d);
  }

  .fm-sec-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1.2rem 0 0.7rem;
    font-family: var(--font-ui, sans-serif);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .fm-sec-head:first-child { margin-top: 0; }
  .fm-count { color: var(--muted); }

  .fm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0.9rem;
  }
  .fm-list { display: flex; flex-direction: column; gap: 0.7rem; }

  .fm-pilot-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.85rem 1rem;
    background: var(--surface-2);
    border: 1px solid var(--line-soft);
    border-left: 3px solid var(--accent);
    clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .fm-pilot-card:hover { border-color: var(--line); transform: translateY(-1px); }

  .fm-card-main { display: flex; align-items: center; gap: 0.85rem; min-width: 0; }

  .fm-avatar-box {
    position: relative;
    width: 46px;
    height: 46px;
    flex: none;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: var(--surface);
    display: grid;
    place-items: center;
    font-size: 1.15rem;
    color: var(--accent);
    overflow: hidden;
  }
  .fm-avatar-box img { width: 100%; height: 100%; object-fit: cover; }

  .fm-dot {
    position: absolute;
    right: -1px;
    bottom: -1px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--surface-2);
  }

  .fm-user-info { min-width: 0; }
  .fm-user-name {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    color: var(--text);
    font-size: 0.95rem;
  }
  .fm-user-handle {
    font-family: var(--font-mono, 'Share Tech Mono', monospace);
    font-size: 0.78rem;
    color: var(--accent);
  }
  .fm-user-status {
    font-size: 0.78rem;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 26ch;
  }

  .fm-verified { color: #4ade80; font-size: 0.75rem; }

  .fm-card-actions { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }

  .fm-btn {
    background: none;
    border: 1px solid var(--line);
    color: var(--muted);
    font-family: var(--font-ui, sans-serif);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.38rem 0.7rem;
    border-radius: 6px;
    cursor: pointer;
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .fm-btn:hover { color: var(--text); border-color: var(--accent); }
  .fm-btn:disabled { opacity: 0.55; cursor: default; }

  .fm-btn--primary {
    color: var(--accent);
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }
  .fm-btn--primary:hover { background: color-mix(in srgb, var(--accent) 22%, transparent); }

  .fm-btn--danger:hover { border-color: #f87171; color: #f87171; }

  .fm-empty-box {
    text-align: center;
    padding: 2rem 1rem;
    border: 1px dashed var(--line);
    border-radius: 10px;
  }
  .fm-empty-icon { font-size: 1.6rem; color: var(--accent); opacity: 0.6; margin-bottom: 0.5rem; }

  @media (max-width: 560px) {
    .fm-pilot-card { align-items: flex-start; }
    .fm-user-status { max-width: 18ch; }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase';
  import { STATUS_STATES } from '../../lib/profilePresets';

  const fmWrap = document.querySelector('.friends-manager') as HTMLElement | null;
  if (fmWrap) {
    const D = fmWrap.dataset;
    const lang = D.lang === 'de' ? 'de' : 'en';
    const pilotBase = D.pilotBase || '/pilot/';

    const $ = (id: string) => document.getElementById(id);
    const loadingEl = $('fmLoading')!;
    const noHandleEl = $('fmNoHandle')!;
    const panelFriends = $('fmPanelFriends')!;
    const panelRequests = $('fmPanelRequests')!;
    const tabFriendsBtn = $('fmTabBtnFriends')!;
    const tabRequestsBtn = $('fmTabBtnRequests')!;
    const badgeFriends = $('fmBadgeFriends')!;
    const badgeRequests = $('fmBadgeRequests')!;
    const listFriends = $('fmFriendsList')!;
    const emptyFriends = $('fmFriendsEmpty')!;
    const emptyFriendsTxt = $('fmFriendsEmptyTxt')!;
    const listIncoming = $('fmIncomingList')!;
    const listOutgoing = $('fmOutgoingList')!;
    const headIncoming = $('fmIncomingHead')!;
    const headOutgoing = $('fmOutgoingHead')!;
    const countIncoming = $('fmIncomingCount')!;
    const countOutgoing = $('fmOutgoingCount')!;
    const emptyRequests = $('fmRequestsEmpty')!;
    const filterInput = $('fmFilterInput') as HTMLInputElement;
    const addForm = $('fmAddForm') as HTMLFormElement;
    const handleInput = $('fmHandleInput') as HTMLInputElement;
    const addBtn = $('fmAddBtn') as HTMLButtonElement;
    const statusMsg = $('fmStatusMsg')!;

    type Prof = {
      id: string; handle: string; display_name: string | null;
      avatar_url: string | null; avatar_icon: string | null; avatar_color: string | null;
      role: string | null; status_state: string | null; status_text: string | null;
      rsi_verified: boolean | null;
    };

    let me = '';
    let myHandle: string | null = null;
    let friends: Array<{ rowId: string; since: string; p: Prof }> = [];
    let incoming: Array<{ reqId: string; at: string; p: Prof }> = [];
    let outgoing: Array<{ reqId: string; at: string; p: Prof }> = [];

    const say = (msg: string, ok = false) => {
      statusMsg.textContent = msg;
      statusMsg.classList.toggle('acx-status--ok', ok);
      statusMsg.hidden = false;
    };

    const fmtDate = (iso: string) => {
      try {
        return new Date(iso).toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-US',
          { day: '2-digit', month: 'short', year: 'numeric' });
      } catch { return ''; }
    };

    // ---- Laden ----------------------------------------------------------
    const loadAll = async () => {
      const { data: u } = await supabase.auth.getUser();
      if (!u?.user) return;
      me = u.user.id;

      const { data: myProf } = await supabase
        .from('profiles').select('handle').eq('id', me).maybeSingle();
      myHandle = (myProf as { handle?: string } | null)?.handle || null;
      noHandleEl.hidden = !!myHandle;
      handleInput.disabled = !myHandle;
      addBtn.disabled = !myHandle;

      const [{ data: fRows }, { data: rRows }] = await Promise.all([
        supabase.from('friends').select('id, user_id, friend_id, created_at'),
        supabase.from('friend_requests')
          .select('id, sender_id, receiver_id, created_at').eq('status', 'pending'),
      ]);

      const fr = (fRows || []) as Array<{ id: string; user_id: string; friend_id: string; created_at: string }>;
      const rr = (rRows || []) as Array<{ id: string; sender_id: string; receiver_id: string; created_at: string }>;

      const ids = new Set<string>();
      fr.forEach((r) => ids.add(r.user_id === me ? r.friend_id : r.user_id));
      rr.forEach((r) => ids.add(r.sender_id === me ? r.receiver_id : r.sender_id));

      let byId = new Map<string, Prof>();
      if (ids.size) {
        const { data: profs } = await supabase
          .from('social_profiles').select('*').in('id', [...ids]);
        byId = new Map(((profs || []) as Prof[]).map((p) => [p.id, p]));
      }

      const fallback = (id: string): Prof => ({
        id, handle: '', display_name: null, avatar_url: null, avatar_icon: null,
        avatar_color: null, role: null, status_state: null, status_text: null, rsi_verified: null,
      });

      friends = fr.map((r) => {
        const other = r.user_id === me ? r.friend_id : r.user_id;
        return { rowId: r.id, since: r.created_at, p: byId.get(other) || fallback(other) };
      });
      incoming = rr.filter((r) => r.receiver_id === me)
        .map((r) => ({ reqId: r.id, at: r.created_at, p: byId.get(r.sender_id) || fallback(r.sender_id) }));
      outgoing = rr.filter((r) => r.sender_id === me)
        .map((r) => ({ reqId: r.id, at: r.created_at, p: byId.get(r.receiver_id) || fallback(r.receiver_id) }));

      loadingEl.hidden = true;
      panelFriends.hidden = !tabFriendsBtn.classList.contains('active');
      panelRequests.hidden = !tabRequestsBtn.classList.contains('active');
      render();
    };

    // ---- Karten ---------------------------------------------------------
    const avatarNode = (p: Prof) => {
      const box = document.createElement('div');
      box.className = 'fm-avatar-box';
      const col = p.avatar_color || '#2dd4ff';
      box.style.borderColor = col;
      box.style.color = col;
      if (p.avatar_url) {
        const img = document.createElement('img');
        img.src = p.avatar_url;
        img.alt = '';
        box.appendChild(img);
      } else {
        const sp = document.createElement('span');
        sp.textContent = p.avatar_icon || (p.display_name || p.handle || '?').charAt(0).toUpperCase();
        box.appendChild(sp);
      }
      const st = (STATUS_STATES as Record<string, { color: string; labelDe: string; labelEn: string }>)[p.status_state || 'online'];
      if (st) {
        const dot = document.createElement('div');
        dot.className = 'fm-dot';
        dot.style.background = st.color;
        dot.title = lang === 'de' ? st.labelDe : st.labelEn;
        box.appendChild(dot);
      }
      return box;
    };

    const infoNode = (p: Prof, sub: string) => {
      const info = document.createElement('div');
      info.className = 'fm-user-info';

      const nameRow = document.createElement('div');
      nameRow.className = 'fm-user-name';
      const nm = document.createElement('span');
      nm.textContent = p.display_name || p.handle || '—';
      nameRow.appendChild(nm);
      if (p.rsi_verified) {
        const v = document.createElement('span');
        v.className = 'fm-verified';
        v.textContent = '✓';
        v.title = 'RSI verified';
        nameRow.appendChild(v);
      }

      const hd = document.createElement('div');
      hd.className = 'fm-user-handle';
      hd.textContent = p.handle ? '@' + p.handle : '—';

      const stt = document.createElement('div');
      stt.className = 'fm-user-status';
      stt.textContent = sub;

      info.append(nameRow, hd, stt);
      return info;
    };

    const mkBtn = (label: string, cls: string, fn: () => void) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'fm-btn ' + cls;
      b.textContent = label;
      b.addEventListener('click', async () => {
        b.disabled = true;
        try { await fn(); } finally { b.disabled = false; }
      });
      return b;
    };

    // ---- Aktionen -------------------------------------------------------
    const removeFriend = async (rowId: string, name: string) => {
      const q = (D.msgConfirmRemove || 'Remove %name%?').replace('%name%', name);
      if (!window.confirm(q)) return;
      const target = friends.find((f) => f.rowId === rowId);
      const { error } = await supabase.from('friends').delete().eq('id', rowId);
      if (error) { say(D.msgNet!); return; }
      // Alte Anfragen zwischen beiden entfernen, damit man sich spaeter erneut
      // anfragen kann (unique(sender,receiver) wuerde sonst blockieren).
      if (target?.p.id) {
        await supabase.from('friend_requests').delete()
          .or(`and(sender_id.eq.${me},receiver_id.eq.${target.p.id}),and(sender_id.eq.${target.p.id},receiver_id.eq.${me})`);
      }
      await loadAll();
    };

    const acceptReq = async (reqId: string) => {
      const { error } = await supabase.rpc('accept_friend_request', { req_id: reqId });
      if (error) { say(D.msgNet!); return; }
      say(D.msgAccepted!, true);
      await loadAll();
    };

    const dropReq = async (reqId: string) => {
      const { error } = await supabase.from('friend_requests').delete().eq('id', reqId);
      if (error) { say(D.msgNet!); return; }
      await loadAll();
    };

    // ---- Rendern --------------------------------------------------------
    const render = () => {
      const q = (filterInput?.value || '').trim().toLowerCase();
      const shown = friends.filter((f) => {
        if (!q) return true;
        const p = f.p;
        return [p.display_name, p.handle, p.role, p.status_text]
          .some((v) => (v || '').toLowerCase().includes(q));
      });

      badgeFriends.textContent = String(friends.length);
      badgeRequests.textContent = String(incoming.length + outgoing.length);
      badgeRequests.hidden = incoming.length + outgoing.length === 0;

      listFriends.innerHTML = '';
      emptyFriends.hidden = shown.length > 0;
      emptyFriendsTxt.textContent = friends.length === 0
        ? (D.txtEmptyFriends || '') : (D.txtEmptyFiltered || '');

      shown.forEach((f) => {
        const card = document.createElement('div');
        card.className = 'fm-pilot-card';
        const main = document.createElement('div');
        main.className = 'fm-card-main';
        const sub = f.p.status_text || f.p.role || `${D.lblSince || ''} ${fmtDate(f.since)}`.trim();
        main.append(avatarNode(f.p), infoNode(f.p, sub));

        const acts = document.createElement('div');
        acts.className = 'fm-card-actions';
        if (f.p.handle) {
          const a = document.createElement('a');
          a.className = 'fm-btn fm-btn--primary';
          a.href = pilotBase + f.p.handle;
          a.textContent = D.lblView || 'Profile';
          acts.appendChild(a);
        }
        acts.appendChild(mkBtn(D.lblRemove || 'Remove', 'fm-btn--danger',
          () => removeFriend(f.rowId, f.p.display_name || f.p.handle || '')));

        card.append(main, acts);
        listFriends.appendChild(card);
      });

      const reqCard = (r: { reqId: string; at: string; p: Prof }, kind: 'in' | 'out') => {
        const card = document.createElement('div');
        card.className = 'fm-pilot-card';
        const main = document.createElement('div');
        main.className = 'fm-card-main';
        main.append(avatarNode(r.p), infoNode(r.p, `${D.lblRequested || ''} ${fmtDate(r.at)}`.trim()));

        const acts = document.createElement('div');
        acts.className = 'fm-card-actions';
        if (kind === 'in') {
          acts.appendChild(mkBtn(D.lblAccept || 'Accept', 'fm-btn--primary', () => acceptReq(r.reqId)));
          acts.appendChild(mkBtn(D.lblDecline || 'Decline', 'fm-btn--danger', () => dropReq(r.reqId)));
        } else {
          acts.appendChild(mkBtn(D.lblCancel || 'Withdraw', 'fm-btn--danger', () => dropReq(r.reqId)));
        }
        card.append(main, acts);
        return card;
      };

      listIncoming.innerHTML = '';
      listOutgoing.innerHTML = '';
      incoming.forEach((r) => listIncoming.appendChild(reqCard(r, 'in')));
      outgoing.forEach((r) => listOutgoing.appendChild(reqCard(r, 'out')));
      headIncoming.hidden = incoming.length === 0;
      headOutgoing.hidden = outgoing.length === 0;
      countIncoming.textContent = String(incoming.length);
      countOutgoing.textContent = String(outgoing.length);
      emptyRequests.hidden = incoming.length + outgoing.length > 0;
    };

    // ---- Tabs + Filter --------------------------------------------------
    const showTab = (which: 'friends' | 'requests') => {
      const isF = which === 'friends';
      tabFriendsBtn.classList.toggle('active', isF);
      tabRequestsBtn.classList.toggle('active', !isF);
      tabFriendsBtn.setAttribute('aria-selected', String(isF));
      tabRequestsBtn.setAttribute('aria-selected', String(!isF));
      panelFriends.hidden = !isF;
      panelRequests.hidden = isF;
    };
    tabFriendsBtn.addEventListener('click', () => showTab('friends'));
    tabRequestsBtn.addEventListener('click', () => showTab('requests'));
    filterInput?.addEventListener('input', render);

    // ---- Anfrage senden -------------------------------------------------
    addForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusMsg.hidden = true;
      const h = handleInput.value.trim().toLowerCase().replace(/^@/, '');
      if (!h) return;
      if (h === (myHandle || '').toLowerCase()) { say(D.msgSelf!); return; }

      addBtn.disabled = true;
      try {
        const { data: found } = await supabase
          .from('social_profiles').select('id, handle').eq('handle', h).maybeSingle();
        const target = found as { id: string; handle: string } | null;
        if (!target) { say(D.msgNotfound!); return; }
        if (target.id === me) { say(D.msgSelf!); return; }
        if (friends.some((f) => f.p.id === target.id)) { say(D.msgAlreadyFriend!); return; }
        if (outgoing.some((r) => r.p.id === target.id)) { say(D.msgAlreadySent!); return; }

        // Hat der andere mir schon geschrieben? Dann direkt annehmen.
        const mine = incoming.find((r) => r.p.id === target.id);
        if (mine) {
          await acceptReq(mine.reqId);
          say(D.msgAcceptedTheirs!, true);
          handleInput.value = '';
          return;
        }

        const { error } = await supabase.from('friend_requests')
          .insert({ sender_id: me, receiver_id: target.id });
        if (error) { say(D.msgNet!); return; }

        handleInput.value = '';
        say(D.msgSent!, true);
        await loadAll();
      } catch {
        say(D.msgNet!);
      } finally {
        addBtn.disabled = !myHandle;
      }
    });

    loadAll().catch(() => { loadingEl.hidden = true; say(D.msgNet!); });
  }
</script>
