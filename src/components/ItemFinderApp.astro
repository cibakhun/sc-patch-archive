---
// Universal Item Finder — durchsuchbarer Katalog aller Items mit verifizierten
// Bezugsquellen (Shop-Snapshot, Loot-Recherche, UEX-Fahrzeugpreise). Ohne Quelle
// wird ein Item ehrlich als Katalog-Eintrag gezeigt — keine erfundenen Werte.
// Daten: assets/universal-items.json (scripts/build-universal-db.mjs).
//
// Jede Karte ist ein echter <a> auf /items/<id>.html (die statische Detailseite).
// Ein normaler Linksklick oeffnet weiterhin das Modal — Strg/Cmd/Mittelklick und
// Crawler folgen dem href. Ohne diese Links haengen die Detailseiten nur an der
// Sitemap und bekommen keinerlei internes Gewicht.
import { ICON_BLUEPRINT } from '../lib/icons';
import { ITEM_UI } from '../i18n/itemText';

interface Props { lang?: 'de' | 'en' }
const { lang = 'en' } = Astro.props;

const t = {
  de: {
    searchPlaceholder: 'Item, Waffe, Schiff, Fundort suchen…',
    hAvailability: 'Fundart', hCategories: 'Kategorien', hSize: 'Größe',
    loading: 'Datenbank wird geladen…',
    sortNameAsc: 'Name (A–Z)', sortNameDesc: 'Name (Z–A)',
    sortPriceAsc: 'Preis (aufsteigend)', sortPriceDesc: 'Preis (absteigend)',
    sortStat: 'Wert (hoch→niedrig)',
    modalClose: 'Schließen',
  },
  en: {
    searchPlaceholder: 'Search item, weapon, ship, location…',
    hAvailability: 'Availability', hCategories: 'Categories', hSize: 'Size',
    loading: 'Loading database…',
    sortNameAsc: 'Name (A–Z)', sortNameDesc: 'Name (Z–A)',
    sortPriceAsc: 'Price (low–high)', sortPriceDesc: 'Price (high–low)',
    sortStat: 'Value (high–low)',
    modalClose: 'Close',
  },
}[lang];

// Strings, die das Client-JS braucht (window.__UIF.t). Der Katalog liegt in
// i18n/itemText.ts, weil die statischen Item-Seiten DIESELBEN Labels rendern —
// zwei Kopien wuerden zwangslaeufig auseinanderlaufen.
const JS_T = ITEM_UI[lang];
---

<div class="uif-container" id="uif-app">
  <div class="uif-sidebar">
    <div class="uif-search">
      <input type="text" id="uif-search-input" placeholder={t.searchPlaceholder} autocomplete="off" />
    </div>

    <div class="uif-filters">
      <h3>{t.hAvailability}</h3>
      <div id="uif-kind-chips" class="uif-chips"><!-- Chips via JS --></div>
      <h3>{t.hSize}</h3>
      <div id="uif-size-chips" class="uif-chips"><!-- Größen via JS --></div>
      <h3>{t.hCategories}</h3>
      <div id="uif-category-list"><!-- Kategorien via JS --></div>
    </div>
  </div>

  <div class="uif-main">
    <div class="uif-header">
      <div class="uif-stats" id="uif-stats-count">{t.loading}</div>
      <div class="uif-sort">
        <select id="uif-sort-select" aria-label="Sort">
          <option value="name_asc">{t.sortNameAsc}</option>
          <option value="name_desc">{t.sortNameDesc}</option>
          <option value="stat_desc">{t.sortStat}</option>
          <option value="price_asc">{t.sortPriceAsc}</option>
          <option value="price_desc">{t.sortPriceDesc}</option>
        </select>
      </div>
    </div>

    <div class="uif-results" id="uif-results-grid"><!-- Items via JS --></div>

    <div class="uif-pagination" id="uif-pagination-container"><!-- Pagination via JS --></div>
  </div>
</div>

<div class="uif-modal-overlay" id="uif-item-modal" style="display: none;" role="dialog" aria-modal="true">
  <div class="uif-modal-container">
    <button class="uif-modal-close" id="uif-modal-close-btn" aria-label={t.modalClose}>&times;</button>
    <div class="uif-modal-body" id="uif-modal-body-content"><!-- Details via JS --></div>
  </div>
</div>

<style is:global>
  /* Universal Item Finder — nutzt die Seiten-Palette (--surface/--accent/--muted/--line),
     definiert bewusst KEINE :root-Variablen. */
  .uif-container {
    display: flex;
    max-width: var(--maxw, 1240px);
    margin: 0 auto;
    padding: 2rem 1rem;
    gap: 2rem;
    align-items: flex-start;
  }

  .uif-sidebar {
    width: 300px;
    flex-shrink: 0;background:var(--surface, var(--veil-2));
    border: 1px solid var(--line, rgba(255, 94, 26, 0.22));
    border-radius: 8px;
    padding: 1.5rem;
    position: sticky;
    top: 2rem;box-shadow:0 4px 12px var(--shadow-color);
  }

  .uif-search input {
    width: 100%;background:var(--veil);border:1px solid var(--line-soft, var(--line-soft));
    color: var(--text, #eef1f5);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .uif-search input:focus {
    outline: none;
    border-color: var(--accent, #ff5e1a);
    box-shadow: 0 0 8px color-mix(in srgb, var(--accent, #ff5e1a) 40%, transparent);
  }

  .uif-filters h3 {
    margin: 1.5rem 0 0.75rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--accent, #ff5e1a);
    border-bottom: 1px solid var(--line, rgba(255, 94, 26, 0.22));
    padding-bottom: 0.5rem;
  }

  .uif-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .uif-chip {
    background: transparent;border:1px solid var(--line-soft, var(--line-soft));
    color: var(--muted, #9ba2ae);
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-family: inherit;
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .uif-chip:hover {color:var(--text, var(--text)); border-color: var(--accent, #ff5e1a); }

  .uif-chip.active {
    background: var(--accent, #ff5e1a);
    border-color: var(--accent, #ff5e1a);color:var(--ink, var(--ink));
    font-weight: 700;
  }

  #uif-category-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .uif-category-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: transparent;
    border: 1px solid transparent;
    color: var(--muted, #9ba2ae);
    padding: 0.6rem 0.8rem;
    border-radius: 6px;
    text-align: left;
    font-family: inherit;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .uif-category-btn:hover {background:var(--veil-hi);color:var(--text, var(--text));
  }

  .uif-category-btn.active {
    background: color-mix(in srgb, var(--accent, #ff5e1a) 12%, transparent);color:var(--text, var(--text));
    border: 1px solid var(--accent, #ff5e1a);
  }

  .uif-category-btn-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
  }

  .uif-category-count {
    font-size: 0.8rem;background:var(--veil-hi);
    padding: 0.15rem 0.5rem;
    border-radius: 12px;
    color: var(--muted, #9ba2ae);
    flex-shrink: 0;
  }

  .uif-category-btn.active .uif-category-count {
    background: var(--accent, #ff5e1a);color:var(--ink, var(--ink));
  }

  .uif-main { flex-grow: 1; min-width: 0; }

  .uif-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line, rgba(255, 94, 26, 0.22));
  }

  .uif-stats { color: var(--muted, #9ba2ae); font-size: 0.95rem; }

  .uif-sort select {background:var(--surface, var(--veil-2));color:var(--text, var(--text));
    border: 1px solid var(--line, rgba(255, 94, 26, 0.22));
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-family: inherit;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .uif-sort select:focus { outline: none; border-color: var(--accent, #ff5e1a); }

  .uif-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    gap: 1.5rem;
  }

  .uif-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem;
    color: var(--muted, #9ba2ae);
  }

  /* Karten */
  .uif-card {background:var(--surface, var(--veil-2));
    border: 1px solid var(--line, rgba(255, 94, 26, 0.22));
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.25s, box-shadow 0.25s;
    cursor: pointer;box-shadow:0 4px 6px var(--shadow-color);
    position: relative;
    overflow: hidden;
  }

  /* Karten mit Detailseite sind <a> — Linkfarbe/Unterstreichung zurücksetzen,
     das Aussehen bleibt exakt wie bei den Karten ohne Seite. */
  a.uif-card { text-decoration: none; color: inherit; }

  .uif-card:hover,
  .uif-card:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent, #ff5e1a);
    box-shadow: 0 8px 20px color-mix(in srgb, var(--accent, #ff5e1a) 15%, transparent);
    outline: none;
  }

  .uif-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .uif-card-cat-wrapper {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--muted, #9ba2ae);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    min-width: 0;
  }

  .uif-card-cat-wrapper span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .uif-card-title {
    margin: 0.5rem 0 1rem;color:var(--text, var(--text));
    font-size: 1.1rem;
    line-height: 1.4;
    font-weight: 600;
  }

  .uif-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.6rem;border-top:1px solid var(--line-soft, var(--line-soft));
    padding-top: 0.75rem;
    margin-top: auto;
  }

  .uif-card-price {
    color: var(--accent, #ff5e1a);
    font-weight: 700;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  .uif-card-location {
    font-size: 0.8rem;
    color: var(--muted, #9ba2ae);
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: right;
  }

  .uif-loc-more {
    color: var(--accent-2, var(--accent, #ff5e1a));
    font-weight: 700;
  }

  .uif-loc-none { font-style: italic; opacity: 0.8; }

  .uif-icon { display: inline-block; vertical-align: middle; flex-shrink: 0; }

  /* Pagination */
  .uif-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .uif-page-btn {background:var(--surface, var(--veil-2));
    color: var(--muted, #9ba2ae);
    border: 1px solid var(--line, rgba(255, 94, 26, 0.22));
    padding: 0.5rem 0.85rem;
    border-radius: 6px;
    font-family: inherit;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    user-select: none;
  }

  .uif-page-btn:hover:not(:disabled) {color:var(--text, var(--text));
    border-color: var(--accent, #ff5e1a);
  }

  .uif-page-btn:disabled { opacity: 0.35; cursor: not-allowed; }

  .uif-page-info {
    color: var(--muted, #9ba2ae);
    font-size: 0.9rem;
    margin: 0 0.5rem;
    user-select: none;
  }

  /* Modal */
  .uif-modal-overlay {
    position: fixed;
    inset: 0;background:var(--veil-2);
    backdrop-filter: blur(6px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    padding: 1.5rem;
    animation: uif-fade-in 0.2s ease-out;
  }

  @keyframes uif-fade-in { from { opacity: 0; } to { opacity: 1; } }

  .uif-modal-container {background:var(--surface, var(--veil-2));
    border: 1px solid var(--accent, #ff5e1a);
    box-shadow: 0 0 30px color-mix(in srgb, var(--accent, #ff5e1a) 25%, transparent);
    border-radius: 12px;
    width: 100%;
    max-width: 800px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    padding: 2rem;
    animation: uif-slide-up 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes uif-slide-up { from { transform: translateY(15px); } to { transform: translateY(0); } }

  .uif-modal-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    background: transparent;
    border: none;
    color: var(--muted, #9ba2ae);
    font-size: 1.75rem;
    cursor: pointer;
    transition: color 0.2s;
    line-height: 1;
  }

  .uif-modal-close:hover { color: var(--accent, #ff5e1a); }

  .uif-modal-header {
    border-bottom: 1px solid var(--line, rgba(255, 94, 26, 0.22));
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  .uif-modal-title {
    margin: 0.25rem 0 0.5rem;color:var(--text, var(--text));
    font-size: 1.6rem;
    font-weight: 700;
  }

  .uif-modal-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.85rem;
    color: var(--muted, #9ba2ae);
    align-items: center;
  }

  .uif-modal-meta-item { display: flex; align-items: center; gap: 0.4rem; }

  .uif-modal-section { margin-bottom: 1.75rem; }

  .uif-modal-section h4 {
    color: var(--accent, #ff5e1a);
    font-size: 1.1rem;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;border-bottom:1px solid var(--line-soft, var(--line-soft));
    padding-bottom: 0.4rem;
  }

  .uif-table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--line, rgba(255, 94, 26, 0.22));
    border-radius: 6px;
  }

  .uif-locations-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.9rem;
  }

  .uif-locations-table th,
  .uif-locations-table td { padding: 0.75rem 1rem; }

  .uif-locations-table th {background:var(--surface-2, var(--veil-2));color:var(--text, var(--text));
    font-weight: 600;
    border-bottom: 1px solid var(--line, rgba(255, 94, 26, 0.22));
  }

  .uif-locations-table td {border-bottom:1px solid var(--line-soft);
    color: var(--muted, #9ba2ae);
  }

  .uif-locations-table tr:last-child td { border-bottom: none; }

  .uif-locations-table tr:hover td {background:var(--veil-hi);color:var(--text, var(--text));
  }

  .uif-td-kind { white-space: nowrap; }
  .uif-td-price { white-space: nowrap; font-weight: 700; color: var(--accent, #ff5e1a); }

  .uif-volatile-note,
  .uif-catalog-note {
    margin: 0.75rem 0 0;
    font-size: 0.85rem;
    color: var(--muted, #9ba2ae);
    line-height: 1.5;
  }

  .uif-guide-text {
    margin: 0;
    color: var(--text, #eef1f5);
    font-size: 0.95rem;
    line-height: 1.65;background:var(--veil-hi);border:1px solid var(--line-soft, var(--line-soft));
    border-left: 3px solid var(--accent, #ff5e1a);
    border-radius: 6px;
    padding: 0.9rem 1.1rem;
  }

  /* Technische Daten (Spieldaten aus dem DataCore) */
  .uif-spec-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
  .uif-spec-chip {
    font-size: 0.82rem; color: var(--muted, #9ba2ae);
    background: var(--surface-2, var(--veil-2));
    border: 1px solid var(--line-soft, var(--line-soft));
    border-radius: 999px; padding: 0.3rem 0.75rem; white-space: nowrap;
  }
  .uif-spec-chip b { color: var(--text, #eef1f5); font-weight: 600; margin-right: 0.3rem; }
  .uif-stat-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.6rem; margin-bottom: 1rem;
  }
  .uif-stat {
    display: flex; flex-direction: column; gap: 0.2rem;
    background: var(--veil-hi, var(--surface-2));
    border: 1px solid var(--line-soft, var(--line-soft));
    border-left: 3px solid var(--accent-2, var(--accent, #ff5e1a));
    border-radius: 6px; padding: 0.55rem 0.75rem;
  }
  .uif-stat-l { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted, #9ba2ae); }
  .uif-stat-v { font-size: 1.05rem; font-weight: 700; color: var(--text, #eef1f5); }
  .uif-item-desc { margin: 0; color: var(--muted, #9ba2ae); font-size: 0.92rem; line-height: 1.6; white-space: pre-line; }
  .uif-card-spec {
    font-size: 0.78rem; color: var(--muted, #9ba2ae); margin: -0.35rem 0 0.6rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .uif-card-stat {
    font-weight: 700; font-size: 0.8rem; white-space: nowrap; flex-shrink: 0; margin-left: 0.5rem;
    color: var(--accent-2, var(--accent, #ff5e1a));
    background: color-mix(in srgb, var(--accent-2, var(--accent, #ff5e1a)) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-2, var(--accent, #ff5e1a)) 35%, transparent);
    border-radius: 999px; padding: 0.15rem 0.55rem;
  }

  .uif-crafting-header {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;background:var(--surface-2, var(--veil-2));
    padding: 1rem;
    border-radius: 6px;
    border: 1px solid var(--line, rgba(255, 94, 26, 0.22));
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .uif-crafting-ingredients h5 {
    font-size: 0.9rem;color:var(--text, var(--text));
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .uif-crafting-ingredients ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .uif-crafting-ingredients li {background:var(--veil-hi);border:1px solid var(--line-soft, var(--line-soft));
    padding: 0.6rem 1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    color: var(--muted, #9ba2ae);
  }

  .uif-crafting-ingredients li strong {color:var(--text, var(--text)); }

  /* Cross-Link ins Crafting (Deep-Link zum Blueprint) */
  .uif-xlink {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.9rem;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--accent, #2dd4ff);
    border: 1px solid color-mix(in srgb, var(--accent, #2dd4ff) 45%, transparent);
    padding: 0.45rem 0.85rem;
    border-radius: 6px;
    transition: background-color 0.15s, border-color 0.15s;
  }
  .uif-xlink:hover {
    background: color-mix(in srgb, var(--accent, #2dd4ff) 12%, transparent);
    border-color: var(--accent, #2dd4ff);
  }
  /* Weg vom Schnellblick (Modal) zur verlinkbaren Detailseite */
  .uif-xlink--page { margin-top: 0.75rem; }

  /* Responsive */
  @media (max-width: 900px) {
    .uif-container { flex-direction: column; padding: 1rem; }

    .uif-sidebar {
      width: 100%;
      position: static;
      box-shadow: none;
    }

    #uif-category-list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.5rem;
    }

    .uif-category-btn { padding: 0.5rem; font-size: 0.85rem; }

    .uif-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .uif-sort, .uif-sort select { width: 100%; }

    .uif-modal-container { padding: 1.25rem; }
  }

  @media (max-width: 480px) {
    #uif-category-list { grid-template-columns: repeat(2, 1fr); }
    .uif-modal-title { font-size: 1.3rem; }
  }
</style>

<script is:inline set:html={`window.__UIF=${JSON.stringify({ lang, dbUrl: '/assets/universal-items.json', craftUrl: '/assets/crafting-db.json', itemBase: lang === 'de' ? '/de/items/' : '/items/', craftBase: lang === 'de' ? '/de/crafting/' : '/crafting/', icons: { bp: ICON_BLUEPRINT }, t: JS_T })};`} />
<script is:inline src="/assets/item-finder-app.js"></script>
