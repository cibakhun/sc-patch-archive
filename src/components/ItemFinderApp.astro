---
// Universal Item Finder — durchsuchbarer Katalog aller Items mit verifizierten
// Bezugsquellen (Shop-Snapshot, Loot-Recherche, UEX-Fahrzeugpreise). Ohne Quelle
// wird ein Item ehrlich als Katalog-Eintrag gezeigt — keine erfundenen Werte.
// Daten: assets/universal-items.json (scripts/build-universal-db.mjs).
// Optik folgt der Site-Sprache (scharfe Kanten, Clip-Ecken, Akzent-Oberkante,
// font-ui-Uppercase-Labels) und nutzt die Palette der einbettenden Seite.
interface Props { lang?: 'de' | 'en' }
const { lang = 'de' } = Astro.props;

const t = {
  de: {
    searchPlaceholder: 'Item, Waffe, Schiff, Fundort suchen…',
    hAvailability: 'Fundart', hCategories: 'Kategorien',
    loading: 'Datenbank wird geladen…',
    sortNameAsc: 'Name (A–Z)', sortNameDesc: 'Name (Z–A)',
    sortPriceAsc: 'Preis (aufsteigend)', sortPriceDesc: 'Preis (absteigend)',
    modalClose: 'Schließen',
  },
  en: {
    searchPlaceholder: 'Search item, weapon, ship, location…',
    hAvailability: 'Availability', hCategories: 'Categories',
    loading: 'Loading database…',
    sortNameAsc: 'Name (A–Z)', sortNameDesc: 'Name (Z–A)',
    sortPriceAsc: 'Price (low–high)', sortPriceDesc: 'Price (high–low)',
    modalClose: 'Close',
  },
}[lang];

// Strings, die das Client-JS braucht (window.__UIF.t)
const JS_T = {
  de: {
    kindAll: 'Alle', kindBuy: 'Kaufbar', kindLoot: 'Loot', kindCatalog: 'Nur Katalog',
    kindShop: 'Shop', kindVehicleShop: 'Schiffshändler',
    noResults: 'Keine passenden Items gefunden.',
    priceFrom: 'ab', lootOnly: 'Nur Loot', noTradeData: 'Keine Handelsdaten',
    noSourceData: 'Kein Fundort bekannt',
    showing: '{start}–{end} von {total} Einträgen', showingNone: '0 Einträge',
    pageFirst: 'Anfang', pagePrev: 'Zurück', pageNext: 'Weiter', pageLast: 'Ende',
    pageOf: 'Seite {p} von {t}',
    sectionObtain: 'Bezugsquellen', thLocation: 'Ort', thKind: 'Art', thPrice: 'Preis',
    volatileNote: 'Preise und Fundorte sind Patch-volatil — ingame prüfen.',
    catalogNote: 'Katalog-Eintrag aus den Spieldateien: Für dieses Item liegen keine verifizierten Shop- oder Loot-Daten vor.',
    sectionGuide: 'Fundort-Guide', sectionCrafting: 'Crafting-Rezept',
    craftTime: 'Dauer', craftTiers: 'Stufen', craftMaterials: 'Materialien',
    loadError: 'Die Item-Datenbank konnte nicht geladen werden. Bitte später erneut versuchen.',
    subline: '{total} Items aus den Spieldateien, {sourced} mit verifizierten Bezugsquellen',
    catArmour: 'Rüstung', catClothing: 'Kleidung', catWeapons: 'Waffen',
    catVehicle: 'Fahrzeuge', catVehiclegear: 'Schiffskomponenten', catAmmo: 'Munition',
    catAttachment: 'Aufsätze', catUtility: 'Werkzeug & Verbrauch', catOther: 'Sonstiges',
    catComponent: 'Komponenten', catCommodity: 'Handelswaren',
    openCrafting: 'Im Crafting-Tool öffnen',
    sectionWikelo: 'Wikelo-Tausch',
    wikeloGive: 'Bei Wikelo eintauschbar — gib dafür',
    wikeloUsedFor: 'Wird bei Wikelo gebraucht für',
    wikeloMoreTrades: '+{n} weitere Trades auf der Wikelo-Seite',
    openWikelo: 'Zur Wikelo-Seite öffnen',
  },
  en: {
    kindAll: 'All', kindBuy: 'Buyable', kindLoot: 'Loot', kindCatalog: 'Catalog only',
    kindShop: 'Shop', kindVehicleShop: 'Ship dealer',
    noResults: 'No matching items found.',
    priceFrom: 'from', lootOnly: 'Loot only', noTradeData: 'No trade data',
    noSourceData: 'No known source',
    showing: '{start}–{end} of {total} entries', showingNone: '0 entries',
    pageFirst: 'First', pagePrev: 'Prev', pageNext: 'Next', pageLast: 'Last',
    pageOf: 'Page {p} of {t}',
    sectionObtain: 'Where to get it', thLocation: 'Location', thKind: 'Kind', thPrice: 'Price',
    volatileNote: 'Prices and locations are patch-volatile — verify in game.',
    catalogNote: 'Catalog entry from the game files: no verified shop or loot data is available for this item.',
    sectionGuide: 'Loot guide', sectionCrafting: 'Crafting recipe',
    craftTime: 'Time', craftTiers: 'Tiers', craftMaterials: 'Materials',
    loadError: 'The item database could not be loaded. Please try again later.',
    subline: '{total} items from the game files, {sourced} with verified sources',
    catArmour: 'Armor', catClothing: 'Clothing', catWeapons: 'Weapons',
    catVehicle: 'Vehicles', catVehiclegear: 'Ship components', catAmmo: 'Ammo',
    catAttachment: 'Attachments', catUtility: 'Tools & consumables', catOther: 'Other',
    catComponent: 'Components', catCommodity: 'Commodities',
    openCrafting: 'Open in crafting tool',
    sectionWikelo: 'Wikelo trade',
    wikeloGive: 'Redeemable at Wikelo — give',
    wikeloUsedFor: 'Needed at Wikelo for',
    wikeloMoreTrades: '+{n} more trades on the Wikelo page',
    openWikelo: 'Open the Wikelo page',
  },
}[lang];
---

<div class="uif-container" id="uif-app">
  <div class="uif-sidebar">
    <div class="uif-search">
      <input type="text" id="uif-search-input" placeholder={t.searchPlaceholder} autocomplete="off" />
    </div>

    <div class="uif-filters">
      <h3>{t.hAvailability}</h3>
      <div id="uif-kind-chips" class="uif-chips"><!-- Chips via JS --></div>
      <h3>{t.hCategories}</h3>
      <div id="uif-category-list"><!-- Kategorien via JS --></div>
    </div>
  </div>

  <div class="uif-main">
    <div class="uif-header">
      <div class="uif-stats" id="uif-stats-count">{t.loading}</div>
      <div class="uif-sort">
        <select id="uif-sort-select" aria-label="Sort">
          <option value="name_asc">{t.sortNameAsc}</option>
          <option value="name_desc">{t.sortNameDesc}</option>
          <option value="price_asc">{t.sortPriceAsc}</option>
          <option value="price_desc">{t.sortPriceDesc}</option>
        </select>
      </div>
    </div>

    <div class="uif-results" id="uif-results-grid"><!-- Items via JS --></div>

    <div class="uif-pagination" id="uif-pagination-container"><!-- Pagination via JS --></div>
  </div>
</div>

<div class="uif-modal-overlay" id="uif-item-modal" style="display: none;" role="dialog" aria-modal="true">
  <div class="uif-modal-container">
    <button class="uif-modal-close" id="uif-modal-close-btn" aria-label={t.modalClose}>&times;</button>
    <div class="uif-modal-body" id="uif-modal-body-content"><!-- Details via JS --></div>
  </div>
</div>

<style is:global>
  /* Universal Item Finder — Site-Sprache: scharfe Kanten, Clip-Ecken,
     Akzent-Oberkante, font-ui-Uppercase-Labels. Nutzt die Seiten-Palette
     (--surface/--accent/--muted/--line), definiert bewusst KEINE :root-Variablen. */
  .uif-container {
    display: flex;
    max-width: var(--maxw, 1240px);
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 2rem) 2rem;
    gap: 1.4rem;
    align-items: flex-start;
  }

  /* ---- Sidebar (Muster: cdb-sidebar) ---- */
  .uif-sidebar {
    width: 280px;
    flex-shrink: 0;
    background: var(--surface, #17151f);
    border: 1px solid var(--line, rgba(167, 139, 250, 0.22));
    border-radius: 8px;
    padding: 1rem;
    position: sticky;
    top: 5rem;
  }

  .uif-search input {
    width: 100%;
    background: var(--bg, #0d0c14);
    border: 1px solid var(--line, rgba(167, 139, 250, 0.3));
    color: var(--text, #eef1f5);
    padding: 0.6rem 0.9rem;
    border-radius: 6px;
    font-family: var(--font-ui, inherit);
    font-size: 0.98rem;
  }

  .uif-search input:focus {
    outline: 2px solid var(--accent, #a78bfa);
    outline-offset: 1px;
    border-color: var(--accent, #a78bfa);
  }

  .uif-filters h3 {
    margin: 1.2rem 0 0.6rem;
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent, #a78bfa);
    border-bottom: 1px solid var(--line-soft, rgba(255, 255, 255, 0.08));
    padding-bottom: 0.45rem;
  }

  /* ---- Fundart-Chips (Muster: wk-pill) ---- */
  .uif-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .uif-chip {
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.68rem;
    color: var(--muted, #9ba2ae);
    border: 1px solid var(--line, rgba(167, 139, 250, 0.25));
    background: rgba(0, 0, 0, 0.25);
    padding: 0.34rem 0.75rem;
    border-radius: 50px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
  }

  .uif-chip:hover { color: var(--text, #fff); border-color: var(--accent, #a78bfa); }

  .uif-chip.active {
    background: var(--accent, #a78bfa);
    border-color: var(--accent, #a78bfa);
    color: var(--ink, #0d0c14);
  }

  #uif-category-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 0.5rem;
  }

  .uif-category-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: transparent;
    border: 1px solid transparent;
    color: var(--text, #eef1f5);
    padding: 0.42rem 0.55rem;
    border-radius: 4px;
    text-align: left;
    font-family: var(--font-ui, inherit);
    font-size: 0.92rem;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }

  .uif-category-btn:hover { background: rgba(255, 255, 255, 0.04); }

  .uif-category-btn.active {
    background: color-mix(in srgb, var(--accent, #a78bfa) 12%, transparent);
    border-color: color-mix(in srgb, var(--accent, #a78bfa) 50%, transparent);
  }

  .uif-category-btn.active .uif-category-btn-label { color: var(--accent, #a78bfa); font-weight: 700; }

  .uif-category-btn-label {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 0;
  }

  .uif-category-count {
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--muted, #9ba2ae);
    flex-shrink: 0;
  }

  .uif-category-btn.active .uif-category-count { color: var(--accent, #a78bfa); }

  .uif-main { flex-grow: 1; min-width: 0; }

  /* ---- Kopfzeile (Muster: cdb-count-row / cdb-sort) ---- */
  .uif-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--line, rgba(167, 139, 250, 0.22));
  }

  .uif-stats {
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.76rem;
    color: var(--muted, #9ba2ae);
  }

  .uif-sort select {
    background: var(--surface, #17151f);
    color: var(--text, #fff);
    border: 1px solid var(--line, rgba(167, 139, 250, 0.3));
    padding: 0.5rem 0.7rem;
    border-radius: 6px;
    font-family: var(--font-ui, inherit);
    font-size: 0.9rem;
    cursor: pointer;
  }

  .uif-sort select:focus { outline: 2px solid var(--accent, #a78bfa); outline-offset: 1px; }

  .uif-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 270px), 1fr));
    gap: 0.9rem;
  }

  .uif-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 1rem;
    color: var(--muted, #9ba2ae);
    font-size: 0.95rem;
    border: 1px dashed var(--line, rgba(167, 139, 250, 0.3));
    border-radius: 2px;
  }

  /* ---- Karten (Muster: cbp / wk-cell: Akzent-Oberkante + Clip-Ecken) ---- */
  .uif-card {
    position: relative;
    background: var(--surface, #17151f);
    border: 1px solid var(--line, rgba(167, 139, 250, 0.22));
    border-top: 2px solid var(--accent, #a78bfa);
    border-radius: 2px;
    clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
    padding: 0.9rem 0.95rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.55rem;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s, transform 0.1s, background-color 0.15s;
  }

  /* HUD-Ecke oben rechts + Licht-Sweep beim Hover */
  .uif-card::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 22px;
    height: 22px;
    background: linear-gradient(225deg, color-mix(in srgb, var(--accent, #a78bfa) 60%, transparent) 0 9px, transparent 9px);
    opacity: 0.45;
    transition: opacity 0.15s;
    pointer-events: none;
  }

  .uif-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 32%, rgba(255, 255, 255, 0.05) 46%, transparent 60%);
    transform: translateX(-130%);
    pointer-events: none;
  }

  .uif-card:hover,
  .uif-card:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent, #a78bfa);
    background: color-mix(in srgb, var(--accent, #a78bfa) 4%, var(--surface, #17151f));
    outline: none;
  }

  .uif-card:hover::before,
  .uif-card:focus-visible::before { opacity: 1; }

  .uif-card:hover::after,
  .uif-card:focus-visible::after {
    transform: translateX(130%);
    transition: transform 0.55s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .uif-card:hover::after, .uif-card:focus-visible::after { transition: none; transform: translateX(-130%); }
  }

  .uif-card-header { display: flex; align-items: center; justify-content: space-between; }

  .uif-card-cat-wrapper {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    font-size: 0.58rem;
    color: var(--accent, #a78bfa);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    min-width: 0;
  }

  .uif-card-cat-wrapper span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .uif-card-title {
    margin: 0;
    color: #fff;
    font-family: var(--font-display, inherit);
    font-weight: 800;
    font-size: 1.04rem;
    line-height: 1.2;
    overflow-wrap: break-word;
    flex: 1;
  }

  .uif-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.6rem;
    border-top: 1px solid var(--line-soft, rgba(255, 255, 255, 0.08));
    padding-top: 0.6rem;
  }

  .uif-card-price {
    font-family: var(--font-ui, inherit);
    color: var(--accent-2, var(--accent, #a78bfa));
    background: color-mix(in srgb, var(--accent-2, var(--accent, #a78bfa)) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-2, var(--accent, #a78bfa)) 28%, transparent);
    padding: 0.12rem 0.5rem;
    border-radius: 2px;
    font-weight: 700;
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .uif-card-location {
    font-size: 0.78rem;
    color: var(--muted, #9ba2ae);
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: right;
  }

  .uif-loc-more { color: var(--accent, #a78bfa); font-weight: 700; }

  .uif-loc-none { font-style: italic; opacity: 0.8; }

  .uif-icon { display: inline-block; vertical-align: middle; flex-shrink: 0; }

  /* ---- Pagination ---- */
  .uif-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
    margin-top: 2.2rem;
    flex-wrap: wrap;
  }

  .uif-page-btn {
    background: var(--surface, #17151f);
    color: var(--muted, #9ba2ae);
    border: 1px solid var(--line, rgba(167, 139, 250, 0.25));
    padding: 0.45rem 0.8rem;
    border-radius: 4px;
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.72rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    user-select: none;
  }

  .uif-page-btn:hover:not(:disabled) {
    color: var(--accent, #a78bfa);
    border-color: var(--accent, #a78bfa);
  }

  .uif-page-btn:disabled { opacity: 0.35; cursor: not-allowed; }

  .uif-page-info {
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted, #9ba2ae);
    font-size: 0.72rem;
    margin: 0 0.5rem;
    user-select: none;
  }

  /* ---- Modal (Muster: cdb-modal) ---- */
  .uif-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.72);
    display: flex;
    justify-content: center;
    align-items: flex-start;
    z-index: 9300;
    padding: clamp(0.5rem, 4vw, 3rem) 1rem;
    overflow: auto;
    animation: uif-fade-in 0.2s ease-out;
  }

  @keyframes uif-fade-in { from { opacity: 0; } to { opacity: 1; } }

  .uif-modal-container {
    background: var(--bg-2, #14121c);
    border: 1px solid var(--accent, #a78bfa);
    border-radius: 8px;
    width: 100%;
    max-width: 720px;
    position: relative;
    padding: clamp(1.2rem, 4vw, 2rem);
    overflow: hidden;
    animation: uif-slide-up 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Akzent-Leiste am Modal-Kopf */
  .uif-modal-container::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent, #a78bfa), var(--accent-2, var(--accent, #a78bfa)) 55%, transparent);
    pointer-events: none;
  }

  @keyframes uif-slide-up { from { transform: translateY(15px); } to { transform: translateY(0); } }

  .uif-modal-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--line, rgba(167, 139, 250, 0.3));
    color: var(--text, #eef1f5);
    width: 32px;
    height: 32px;
    border-radius: 6px;
    font-size: 1.15rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    line-height: 1;
  }

  .uif-modal-close:hover { color: var(--accent, #a78bfa); border-color: var(--accent, #a78bfa); }

  .uif-modal-header { margin-bottom: 0.4rem; }

  .uif-modal-title {
    margin: 0.15rem 0 0.4rem;
    color: #fff;
    font-family: var(--font-display, inherit);
    font-weight: 800;
    font-size: clamp(1.3rem, 4vw, 1.8rem);
    line-height: 1.1;
  }

  .uif-modal-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.62rem;
    color: var(--accent, #a78bfa);
    align-items: center;
  }

  .uif-modal-meta-item { display: flex; align-items: center; gap: 0.4rem; }

  .uif-modal-section { margin-bottom: 0.4rem; }

  .uif-modal-section h4 {
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.68rem;
    color: var(--accent, #a78bfa);
    margin: 1.2rem 0 0.55rem;
    border-top: 1px solid var(--line-soft, rgba(255, 255, 255, 0.08));
    padding-top: 0.9rem;
  }

  .uif-table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--line, rgba(167, 139, 250, 0.22));
    border-radius: 2px;
  }

  .uif-locations-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.88rem;
  }

  .uif-locations-table th,
  .uif-locations-table td { padding: 0.55rem 0.8rem; }

  .uif-locations-table th {
    background: var(--surface-2, #1e1b29);
    color: var(--muted, #9ba2ae);
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.62rem;
    border-bottom: 1px solid var(--line, rgba(167, 139, 250, 0.22));
  }

  .uif-locations-table td {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    color: var(--text, #eef1f5);
  }

  .uif-locations-table tr:last-child td { border-bottom: none; }

  .uif-locations-table tbody tr:nth-child(even) td { background: rgba(255, 255, 255, 0.018); }

  .uif-locations-table tr:hover td { background: rgba(255, 255, 255, 0.035); }

  .uif-td-kind { white-space: nowrap; color: var(--muted, #9ba2ae) !important; }
  .uif-td-price {
    white-space: nowrap;
    font-family: var(--font-ui, inherit);
    font-weight: 700;
    color: var(--accent-2, var(--accent, #a78bfa)) !important;
  }

  .uif-volatile-note,
  .uif-catalog-note {
    margin: 0.6rem 0 0;
    font-size: 0.78rem;
    color: var(--muted, #9ba2ae);
