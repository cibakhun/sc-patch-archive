---
// Startseiten-Launchpad — das große, zentrale Hauptmenü im Hero.
//
// Punkt 4 (Site-Verbesserungen): Auf der Startseite stehen die Hauptbereiche
// zunächst groß & zentral mit Icons in der Mitte. Beim Runterscrollen
// schrumpfen sie sauber weg (scroll-getrieben, transform-origin oben rechts →
// „wandern in die Ecke"), wo die persistente kompakte Top-Nav (SiteNav) sie
// weiterführt. Nur hier eingebunden (index DE/EN) — Unterseiten behalten die
// normale Top-Nav. Icons sind schlanke Inline-SVGs im Site-Stil (keine Emojis).
//
// Der Übergang läuft über eine CSS-Variable --lp (0 = oben/groß,
// 1 = weggescrollt), die ein rAF-gedrosselter Scroll-Listener setzt — kein
// Rubberband, respektiert prefers-reduced-motion.
import { useTranslations, href, type Locale } from '../i18n/ui';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const L = (p: string) => href(p, lang);

// Slim 24×24 stroke-Icons (fill:none, currentColor) — passend zum SiteNav-Stil.
const items = [
  {
    href: L('/schiffe.html'),
    label: t('nav.ships'),
    sub: t('home.launch.ships.sub'),
    // Rakete / Schiff
    icon: 'M12 2.6c2.4 2.3 3.6 5.3 3.6 8.8L15.2 17H8.8l-.4-5.6c0-3.5 1.2-6.5 3.6-8.8z M8.4 16.4 6 20l3.4-1.1 M15.6 16.4 18 20l-3.4-1.1 M12 11.4a1.7 1.7 0 1 0 0-3.4 1.7 1.7 0 0 0 0 3.4z',
  },
  {
    href: L('/evolution.html'),
    label: t('nav.evolution'),
    sub: t('home.launch.evolution.sub'),
    // Verzweigung (git-branch)
    icon: 'M6 3.5v11 M6 20.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M18 9.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M18 9.5a9 9 0 0 1-9 9',
  },
  {
    href: '#archiv',
    label: t('nav.patches'),
    sub: t('home.launch.patches.sub'),
    // Ebenen (layers)
    icon: 'M12 2.5 2.5 7.5 12 12.5l9.5-5z M2.5 12.5 12 17.5l9.5-5 M2.5 17 12 22l9.5-5',
  },
  {
    href: L('/topics/wikelo-emporium.html'),
    label: 'Wikelo',
    sub: t('home.launch.wikelo.sub'),
    // Facettierter Edelstein (Banu-Händler)
    icon: 'M7 3.5h10l3.5 5.5-8.5 11.5L3.5 9z M3.5 9h17 M12 3.5 9 9l3 11.5 M12 3.5 15 9l-3 11.5',
  },
  {
    href: L('/topics/crafting.html'),
    label: 'Crafting',
    sub: t('home.launch.crafting.sub'),
    // Werkzeug / Schraubenschlüssel
    icon: 'M14.6 6.4a3.8 3.8 0 0 0-5.1 4.9L3.5 17.3l3.2 3.2 6-6a3.8 3.8 0 0 0 4.9-5.1l-2.5 2.5-2-2 2.5-2.5z',
  },
  {
    href: L('/topics/mining.html'),
    label: 'Mining',
    sub: t('home.launch.mining.sub'),
    // Spitzhacke
    icon: 'M20.5 8.2C16.8 4.9 11 4.7 7.2 7.6 c1.9-1 5.6-.8 8.4 1 c2.8 1.8 4.4 5.1 4.9 7.2 M20.5 8.2c-.5-2.1-2.1-5.4-4.9-7.2 M11 12.5 3.5 20l1 1 7.5-7.5 M10 11l3 3',
  },
];
---
<nav class="lp" id="lp" aria-label={t('home.launch.aria')}>
  <span class="lp__hint" aria-hidden="true">{t('home.launch.hint')}</span>
  <ul class="lp__grid">
    {items.map((it) => (
      <li>
        <a class="lp__tile" href={it.href}>
          <span class="lp__ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="26" height="26"><path d={it.icon} /></svg>
          </span>
          <span class="lp__txt">
            <b>{it.label}</b>
            <i>{it.sub}</i>
          </span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .lp {
    /* --lp wird per JS gesetzt (0 = oben groß, 1 = weggescrollt). Fallback 0. */
    margin: 2.6rem auto 0;
    max-width: 920px;
    transform-origin: top right;
    transform: translate(calc(var(--lp, 0) * 6vw), calc(var(--lp, 0) * -3.2rem))
      scale(calc(1 - var(--lp, 0) * 0.34));
    opacity: calc(1 - var(--lp, 0) * 1.35);
    will-change: transform, opacity;
  }
  .lp[data-collapsed='1'] {
    pointer-events: none;
  }
  .lp__hint {
    display: block;
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
    margin-bottom: 1rem;
  }
  .lp__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.8rem;
  }
  .lp__tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    height: 100%;
    padding: 1.15rem 0.6rem 1rem;background:color-mix(in srgb, var(--surface, var(--veil-2)) 82%, transparent);
    border: 1px solid var(--line, rgba(110, 168, 255, 0.16));
    border-radius: 6px;
    transition: transform 0.18s ease, border-color 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;
  }
  .lp__tile:hover {
    transform: translateY(-4px);
    border-color: var(--accent, #2dd4ff);background:color-mix(in srgb, var(--accent, #2dd4ff) 8%, var(--surface, var(--veil-2)));
    box-shadow: 0 14px 34px -16px var(--accent, #2dd4ff);
  }
  .lp__ic {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    color: var(--accent, #2dd4ff);
    border: 1px solid color-mix(in srgb, var(--accent, #2dd4ff) 40%, transparent);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 7%, transparent);
    transition: border-color 0.18s ease, background-color 0.18s ease;
  }
  .lp__tile:hover .lp__ic {
    border-color: var(--accent, #2dd4ff);
    background: color-mix(in srgb, var(--accent, #2dd4ff) 15%, transparent);
  }
  .lp__ic svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .lp__txt {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    text-align: center;
  }
  .lp__txt b {
    font-family: var(--font-ui, sans-serif);
    font-weight: 700;
    font-size: 0.98rem;
    letter-spacing: 0.06em;
    color: var(--text, #e8eefc);
  }
  .lp__txt i {
    font-style: normal;
    font-family: var(--font-ui, sans-serif);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted, #8a99b8);
  }
  /* 3×2 auf Tablet, 2×3 auf Mobil — keine Überläufe bei 375px */
  @media (max-width: 900px) {
    .lp__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.7rem;
    }
  }
  @media (max-width: 560px) {
    .lp {
      margin-top: 2rem;
    }
    .lp__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .lp__tile {
      flex-direction: row;
      justify-content: flex-start;
      gap: 0.7rem;
      padding: 0.85rem 0.9rem;
    }
    .lp__ic {
      width: 42px;
      height: 42px;
    }
    .lp__ic svg {
      width: 22px;
      height: 22px;
    }
    .lp__txt {
      align-items: flex-start;
      text-align: left;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .lp {
      transform: none;
      opacity: 1;
      transition: none;
    }
  }</style>

<script is:inline>
  (function () {
    var lp = document.getElementById('lp');
    if (!lp) return;
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var hero = document.querySelector('.hero');
    var ticking = false;
    function update() {
      ticking = false;
      // Fortschritt über die untere Hälfte des Hero: 0 oben, 1 weggescrollt.
      var h = (hero ? hero.offsetHeight : innerHeight) * 0.62 || 1;
      var p = Math.min(1, Math.max(0, scrollY / h));
      lp.style.setProperty('--lp', p.toFixed(3));
      lp.setAttribute('data-collapsed', p > 0.92 ? '1' : '0');
    }
    addEventListener(
      'scroll',
      function () {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      },
      { passive: true }
    );
    addEventListener('resize', update, { passive: true });
    update();
  })();
</script>
