---
// MiningApp.astro — funktionale Mineral-Datenbank (SSR-Grid + Client-App).
// Sprachneutrales Gerüst; UI-Chrome via `lang`, Game-Daten bleiben englisch.
import DB from '../../assets/mining-db.json';

interface Props { lang: 'de' | 'en'; }
const { lang } = Astro.props;

// -- i18n (SSR-Chrome) --
const S = {
  de: {
    toolbarSearch: 'Suche: Mineral oder Fundort…',
    filters: 'Filter', system: 'System', method: 'Methode', type: 'Typ',
    anyType: 'Alle Typen', refineOnly: 'Nur raffinierbare Erze', gemOnly: 'Nur Hand-Edelsteine',
    reset: 'Zurücksetzen', sort: 'Sortierung',
    sortRarity: 'Seltenheit', sortLocs: 'Fundorte ↓', sortName: 'Name A→Z', sortNameDesc: 'Name Z→A',
    view: 'Ansicht', grid: 'Raster', list: 'Liste', results: 'Minerale', of: 'von',
    empty: 'Keine Minerale für diese Auswahl.', filterBtn: 'Filter', close: 'Schließen',
    locBtn: 'Fundorte', methShip: 'Schiff-Mining', methHand: 'Hand / ROC',
    refine: 'raffinierbar', gem: 'Edelstein', nLocs: 'Fundorte',
  },
  en: {
    toolbarSearch: 'Search: mineral or location…',
    filters: 'Filters', system: 'System', method: 'Method', type: 'Type',
    anyType: 'All types', refineOnly: 'Refinable ores only', gemOnly: 'Hand gems only',
    reset: 'Reset', sort: 'Sort',
    sortRarity: 'Rarity', sortLocs: 'Locations ↓', sortName: 'Name A→Z', sortNameDesc: 'Name Z→A',
    view: 'View', grid: 'Grid', list: 'List', results: 'minerals', of: 'of',
    empty: 'No minerals for this selection.', filterBtn: 'Filters', close: 'Close',
    locBtn: 'Locations', methShip: 'Ship mining', methHand: 'Hand / ROC',
    refine: 'refinable', gem: 'gem', nLocs: 'locations',
  },
}[lang];

// Strings fürs Client-JS (window.__MINE.t)
const JS_T = {
  de: {
    kind: 'Typ', method: 'Methode', scu: 'SCU-Gewicht', systems: 'Systeme', rarity: 'Seltenheit',
    locations: 'Fundorte', abundance: 'bis', ofRock: 'Erz-Anteil',
    chance: 'Chance', chanceHint: 'Fund-Wahrscheinlichkeit an diesem Ort (Anteil der Deposits dieses Mining-Typs) — die Hauptkennzahl.', abundHint: 'Maximaler Erz-Anteil im Rock, WENN du ihn findest (Nebenkennzahl, nicht die Fund-Chance).', bestMatch: 'Wertvollstes Erz hier + Fund-Chance', pointsHint: 'Reale Lagrange-Punkte für dieses Spawn-Profil (aus den Objekt-Containern) — dasselbe Profil liegt an mehreren L-Punkten.',
    methShip: 'Schiff-Mining (Prospector/MOLE)', methHand: 'Hand-Mining (Multitool)', methRoc: 'ROC / Bodenfahrzeug', methHarvest: 'Ernte',
    needsRefine: 'Rohform muss raffiniert werden', noRefine: 'wird ganz verkauft (kein Refining)',
    noLoc: 'Keine Fundorte in den Spieldaten.',
    locNote: 'Hauptzahl (%) = Fund-Wahrscheinlichkeit an diesem Ort (Balken, nach Chance sortiert). „bis Y %" = maximaler Erz-Anteil im Rock, wenn du ihn findest.',
    reverseTitle: 'Fundorte nach Himmelskörper', reverseIntro: 'Wähle einen Körper/eine Region — zeigt den ganzen Mineral-Mix dort mit Fund-Chance (%). ★ = wertvollstes Erz.',
    reverseSearch: 'Körper suchen…', mineralsHere: 'Minerale hier',
    rLegendary: 'Legendär', rEpic: 'Episch', rRare: 'Selten', rUncommon: 'Ungewöhnlich', rCommon: 'Häufig',
  },
  en: {
    kind: 'Type', method: 'Method', scu: 'SCU weight', systems: 'Systems', rarity: 'Rarity',
    locations: 'Locations', abundance: 'up to', ofRock: 'ore share',
    chance: 'chance', chanceHint: 'Find probability at this location (share of this mining type’s deposits) — the primary metric.', abundHint: 'Max ore share in a rock WHEN you find it (secondary metric, not the find chance).', bestMatch: 'Most valuable ore here + find chance', pointsHint: 'Real Lagrange points for this spawn profile (from the object containers) — the same profile sits at several L-points.',
    methShip: 'Ship mining (Prospector/MOLE)', methHand: 'Hand mining (multitool)', methRoc: 'ROC / ground vehicle', methHarvest: 'Harvest',
    needsRefine: 'Raw form must be refined', noRefine: 'sold whole (no refining)',
    noLoc: 'No locations in the game data.',
    locNote: 'Main number (%) = find probability at this location (bar, sorted by chance). “up to Y %” = max ore share in a rock when you find it.',
    reverseTitle: 'Locations by celestial body', reverseIntro: 'Pick a body/region — shows the full mineral mix there with find chance (%). ★ = most valuable ore.',
    reverseSearch: 'Search body…', mineralsHere: 'Minerals here',
    rLegendary: 'Legendary', rEpic: 'Epic', rRare: 'Rare', rUncommon: 'Uncommon', rCommon: 'Common',
  },
}[lang];

// -- SSR-Kartenmodell --
// Seltenheits-Rang für Sortierung + Chip-Farbe (Hand/ROC ohne Rarity ans Ende).
const RARITY_RANK = { legendary: 0, epic: 1, rare: 2, uncommon: 3, common: 4 };
const systemsAll = DB.live_systems;
const kinds = [...new Set(DB.minerals.map((m) => m.kind).filter(Boolean))].sort();

const cards = DB.minerals.map((m, i) => {
  const locBlob = (m.locations || []).map((l) => l.location).join(' ').toLowerCase();
  const rank = m.rarity != null ? (RARITY_RANK[m.rarity] ?? 5) : 6;
  return {
    i, name: m.name, kind: m.kind || '—', method: m.method,
    refine: !!m.needs_refine, scu: m.weight_scu || 0,
    rarity: m.rarity || null, rank,
    nLocs: (m.locations || []).length,
    systems: m.systems || [],
    systemsAttr: (m.systems || []).join('|').toLowerCase(),
    search: (m.name + ' ' + locBlob).toLowerCase(),
  };
});

const RARITY_LABEL = {
  legendary: JS_T.rLegendary, epic: JS_T.rEpic, rare: JS_T.rRare, uncommon: JS_T.rUncommon, common: JS_T.rCommon,
};
const total = DB.counts.minerals;
---

<section class="mdb" id="mdb">
  <div class="mdb-bar">
    <button class="mdb-filter-toggle" id="mdb-filter-toggle" aria-expanded="false">☰ {S.filterBtn}</button>
    <div class="mdb-search-wrap">
      <input type="search" id="mdb-search" class="mdb-search" placeholder={S.toolbarSearch} aria-label={S.toolbarSearch} autocomplete="off" />
    </div>
    <label class="mdb-sort">
      <span class="mdb-sr">{S.sort}</span>
      <select id="mdb-sort">
        <option value="rarity">{S.sortRarity}</option>
        <option value="locs">{S.sortLocs}</option>
        <option value="name">{S.sortName}</option>
        <option value="name-desc">{S.sortNameDesc}</option>
      </select>
    </label>
    <div class="mdb-viewtog" role="group" aria-label={S.view}>
      <button class="mdb-view" data-view="grid" aria-pressed="true" title={S.grid}>▦</button>
      <button class="mdb-view" data-view="list" aria-pressed="false" title={S.list}>≡</button>
    </div>
    <button class="mdb-loc-open" id="mdb-loc-open" title={S.locBtn}>◎ {S.locBtn}</button>
  </div>

  <div class="mdb-layout">
    <aside class="mdb-sidebar" id="mdb-sidebar" aria-label={S.filters}>
      <div class="mdb-side-hd"><span>{S.filters}</span><button id="mdb-filter-close" class="mdb-x" aria-label={S.close}>✕</button></div>

      <div class="mdb-fgroup">
        <h4>{S.system}</h4>
        {systemsAll.map((s) => (
          <label class="mdb-check"><input type="checkbox" class="mdb-sys" value={s.toLowerCase()} /><span>{s}</span></label>
        ))}
      </div>

      <div class="mdb-fgroup">
        <h4>{S.method}</h4>
        <label class="mdb-check"><input type="checkbox" class="mdb-meth" value="ship" /><span>{S.methShip}</span></label>
        <label class="mdb-check"><input type="checkbox" class="mdb-meth" value="hand" /><span>{JS_T.methHand}</span></label>
        <label class="mdb-check"><input type="checkbox" class="mdb-meth" value="roc" /><span>{JS_T.methRoc}</span></label>
      </div>

      <div class="mdb-fgroup">
        <h4>{S.type}</h4>
        <select id="mdb-kind" class="mdb-kind">
          <option value="">{S.anyType}</option>
          {kinds.map((k) => (<option value={k.toLowerCase()}>{k}</option>))}
        </select>
      </div>

      <div class="mdb-fgroup">
        <label class="mdb-check"><input type="checkbox" id="mdb-refine" /><span>{S.refineOnly}</span></label>
        <label class="mdb-check"><input type="checkbox" id="mdb-gem" /><span>{S.gemOnly}</span></label>
      </div>

      <button id="mdb-reset" class="mdb-reset">{S.reset}</button>
    </aside>

    <div class="mdb-main">
      <div class="mdb-count-row"><span><b id="mdb-count">{total}</b> / {total} {S.results}</span></div>
      <div class="mdb-grid" id="mdb-grid">
        {cards.map((c) => (
          <article
            class="mcd"
            data-i={c.i}
            data-name={c.name.toLowerCase()}
            data-search={c.search}
            data-systems={c.systemsAttr}
            data-method={c.method}
            data-kind={c.kind.toLowerCase()}
            data-refine={c.refine ? '1' : '0'}
            data-rank={c.rank}
            data-locs={c.nLocs}
          >
            <div class="mcd__top">
              <span class={`mcd__kind mcd__kind--${c.method}`}>{c.kind}</span>
              <span class="mcd__badges">
                {c.method === 'hand' ? (<span class="mcd__tag mcd__tag--gem" title={JS_T.methHand}>◆ {S.gem}</span>) : null}
                {c.refine ? (<span class="mcd__tag" title={S.refine}>⚗ {S.refine}</span>) : null}
              </span>
            </div>
            <h3 class="mcd__name">{c.name}</h3>
            <div class="mcd__sys">
              {c.systems.length ? c.systems.map((s) => (<span class="mcd__chip">{s}</span>)) : (<span class="mcd__chip mcd__chip--muted">Asteroids</span>)}
            </div>
            <div class="mcd__foot">
              {c.rarity ? (<span class={`mcd__rar mcd__rar--${c.rarity}`}>{RARITY_LABEL[c.rarity]}</span>) : (<span class="mcd__rar mcd__rar--none">{JS_T[c.method === 'roc' ? 'methRoc' : 'methHand']}</span>)}
              <span class="mcd__locs">{c.nLocs} {S.nLocs}</span>
            </div>
          </article>
        ))}
      </div>
      <p class="mdb-empty" id="mdb-empty" hidden>{S.empty}</p>
    </div>
  </div>

  <!-- Detail modal -->
  <div class="mdb-modal" id="mdb-modal" hidden>
    <div class="mdb-modal__box" role="dialog" aria-modal="true">
      <button class="mdb-modal__x" data-close aria-label={S.close}>✕</button>
      <div class="mdb-modal__body" id="mdb-modal-body"></div>
    </div>
  </div>

  <!-- Reverse-Lookup drawer -->
  <aside class="mdb-drawer" id="mdb-loc" aria-hidden="true" aria-label={S.locBtn}>
    <div class="mdb-drawer__hd"><span id="mdb-loc-title">◎</span><button class="mdb-x" data-loc-close aria-label={S.close}>✕</button></div>
    <div class="mdb-drawer__body" id="mdb-loc-body"></div>
  </aside>
</section>

<script is:inline set:html={`window.__MINE=${JSON.stringify({ lang, dbUrl: '/assets/mining-db.json?v=' + DB.snapshot_date + '-c4', t: JS_T })};`} />
<script is:inline src={`/assets/mining-app.js?v=${DB.snapshot_date}-c4`}></script>

<style is:inline>
  .mdb{max-width:var(--maxw,1240px);margin:0 auto;padding:0 clamp(1rem,4vw,2rem)}
  .mdb *{box-sizing:border-box}
  /* klebt UNTER der fixen Site-Nav (~68px), sonst verschwindet sie dahinter */
  .mdb-bar{position:sticky;top:68px;z-index:20;display:flex;flex-wrap:wrap;gap:.6rem;align-items:center;padding:.7rem 0;background:linear-gradient(var(--bg,#14181a) 82%,color-mix(in srgb,var(--bg,#14181a) 88%,transparent));backdrop-filter:blur(6px)}
  .mdb-search-wrap{flex:1 1 240px;min-width:0}
  .mdb-search{width:100%;background:var(--surface,#1e2427);border:1px solid var(--line,rgba(47,191,164,.3));color:var(--text,#eaf2f1);padding:.6rem .9rem;border-radius:6px;font-size:1rem;font-family:var(--font-ui,inherit)}
  .mdb-search:focus{outline:2px solid var(--accent,#2FBFA4);outline-offset:1px}
  .mdb-sort{display:flex;align-items:center;gap:.4rem}
  .mdb-sr{font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.62rem;color:var(--muted,#8fa3a0)}
  .mdb-sort select,.mdb-kind{background:var(--surface,#1e2427);border:1px solid var(--line,rgba(47,191,164,.3));color:var(--text,#eaf2f1);padding:.5rem .6rem;border-radius:6px;font-size:.9rem;font-family:var(--font-ui,inherit);max-width:100%}
  .mdb-viewtog{display:flex;border:1px solid var(--line,rgba(47,191,164,.3));border-radius:6px;overflow:hidden}
  .mdb-view{background:var(--surface,#1e2427);color:var(--muted,#8fa3a0);border:0;padding:.5rem .7rem;cursor:pointer;font-size:1rem;line-height:1}
  .mdb-view[aria-pressed="true"]{background:var(--accent,#2FBFA4);color:var(--ink,#0e1214)}
  .mdb-filter-toggle{display:none;background:var(--surface,#1e2427);border:1px solid var(--line,rgba(47,191,164,.3));color:var(--text,#eaf2f1);padding:.5rem .8rem;border-radius:6px;cursor:pointer;font-family:var(--font-ui,inherit);font-weight:700}
  .mdb-loc-open{background:var(--surface,#1e2427);border:1px solid var(--accent-2,#E0A526);color:var(--accent-2,#E0A526);padding:.5rem .9rem;border-radius:6px;cursor:pointer;font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.04em}
  .mdb-layout{display:grid;grid-template-columns:250px 1fr;gap:1.4rem;align-items:start}
  .mdb-sidebar{position:sticky;top:146px;align-self:start;max-height:calc(100vh - 162px);overflow:auto;border:1px solid var(--line,rgba(47,191,164,.22));background:var(--surface,#1e2427);border-radius:8px;padding:1rem}
  .mdb-side-hd{display:none;justify-content:space-between;align-items:center;margin-bottom:.6rem;font-weight:800}
  .mdb-fgroup{margin-bottom:1.1rem;border-bottom:1px solid var(--line-soft,rgba(255,255,255,.08));padding-bottom:1rem}
  .mdb-fgroup:last-of-type{border-bottom:0}
  .mdb-fgroup h4{font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.66rem;color:var(--accent,#2FBFA4);margin:0 0 .6rem}
  .mdb-check{display:flex;align-items:center;gap:.5rem;cursor:pointer;padding:.24rem 0;font-size:.9rem;color:var(--text,#eaf2f1);line-height:1.3}
  .mdb-check input{accent-color:var(--accent,#2FBFA4);flex:none;width:15px;height:15px}
  .mdb-kind{width:100%}
  .mdb-reset{width:100%;background:transparent;border:1px solid var(--line,rgba(47,191,164,.3));color:var(--text,#eaf2f1);padding:.55rem;border-radius:6px;cursor:pointer;font-family:var(--font-ui,inherit);font-weight:700}
  .mdb-reset:hover{border-color:var(--accent,#2FBFA4);color:var(--accent,#2FBFA4)}
  .mdb-count-row{font-family:var(--font-ui,inherit);font-size:.82rem;color:var(--muted,#8fa3a0);margin-bottom:.7rem;letter-spacing:.04em}
  .mdb-count-row b{color:var(--accent,#2FBFA4);font-size:1rem}
  .mdb-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:.8rem}
  .mdb-grid.is-list{grid-template-columns:1fr}
  .mcd{border:1px solid var(--line-soft,rgba(255,255,255,.09));background:var(--surface,#1e2427);padding:.8rem .9rem;display:flex;flex-direction:column;gap:.42rem;cursor:pointer;transition:border-color .15s,transform .1s;border-radius:6px}
  .mcd:hover{border-color:var(--accent,#2FBFA4);transform:translateY(-2px)}
  .mcd[data-method="hand"]:hover{border-color:var(--accent-2,#E0A526)}
  .mcd[hidden]{display:none}
  .mcd__top{display:flex;justify-content:space-between;align-items:center;gap:.4rem}
  .mcd__kind{display:inline-flex;align-items:center;gap:.36rem;font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.58rem;color:var(--muted,#8fa3a0)}
  .mcd__kind::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent,#2FBFA4);flex:none}
  .mcd__kind--hand::before,.mcd__kind--roc::before{background:var(--accent-2,#E0A526)}
  .mcd__badges{display:flex;gap:.45rem;flex-wrap:wrap;justify-content:flex-end}
  .mcd__tag{font-family:var(--font-ui,inherit);font-weight:700;font-size:.56rem;letter-spacing:.06em;text-transform:uppercase;color:var(--muted,#8fa3a0);white-space:nowrap}
  .mcd__tag--gem{color:var(--accent-2,#E0A526)}
  .mcd__name{font-family:var(--font-display,inherit);font-weight:800;font-size:1.02rem;line-height:1.14;color:#fff;margin:0;overflow-wrap:break-word}
  .mcd__sys{font-size:.7rem;color:var(--muted,#8fa3a0);font-family:var(--font-ui,inherit);letter-spacing:.02em;line-height:1.4}
  .mcd__chip{color:var(--muted,#8fa3a0)}
  .mcd__chip:not(:last-child)::after{content:" · ";opacity:.5}
  .mcd__chip--muted{opacity:.72}
  .mcd__foot{display:flex;align-items:center;justify-content:space-between;gap:.5rem;margin-top:auto;padding-top:.15rem}
  .mcd__rar{--rar:#8fa3a0;font-family:var(--font-ui,inherit);font-weight:800;font-size:.6rem;letter-spacing:.07em;text-transform:uppercase;color:var(--rar)}
  .mcd__rar--legendary{--rar:#e0564b}.mcd__rar--epic{--rar:#b06ae0}.mcd__rar--rare{--rar:var(--accent-2,#E0A526)}
  .mcd__rar--uncommon{--rar:var(--accent,#2FBFA4)}.mcd__rar--common{--rar:#8fa3a0}.mcd__rar--none{--rar:#8fa3a0;font-weight:700;opacity:.8}
  .mcd__locs{font-size:.72rem;color:var(--muted,#8fa3a0);font-variant-numeric:tabular-nums;white-space:nowrap}
  .mdb-grid.is-list .mcd{flex-direction:row;flex-wrap:wrap;align-items:center;gap:.5rem 1rem}
  .mdb-grid.is-list .mcd__name{flex:1 1 160px;font-size:1rem}
  .mdb-grid.is-list .mcd__foot{margin-top:0;flex:0 0 auto;gap:1rem}
  .mdb-empty{text-align:center;color:var(--muted,#8fa3a0);padding:2rem;font-size:.95rem}
  /* Modal */
  /* App-Overlays über der fixen Site-Nav (z 9100), unter der Suche (9600) */
  .mdb-modal{position:fixed;inset:0;z-index:9300;background:rgba(0,0,0,.72);display:flex;align-items:flex-start;justify-content:center;padding:clamp(.5rem,4vw,3rem) 1rem;overflow:auto}
  .mdb-modal[hidden]{display:none}
  .mdb-modal__box{position:relative;max-width:660px;width:100%;background:var(--bg-2,#181d1f);border:1px solid var(--accent,#2FBFA4);border-radius:8px;padding:clamp(1.2rem,4vw,2rem)}
  .mdb-modal__x{position:absolute;top:.6rem;right:.6rem;background:rgba(0,0,0,.4);border:1px solid var(--line,rgba(47,191,164,.3));color:var(--text,#eaf2f1);width:32px;height:32px;border-radius:6px;cursor:pointer;font-size:1rem}
  .mm__kind{font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.62rem;color:var(--accent,#2FBFA4)}
  .mm__kind.hand{color:var(--accent-2,#E0A526)}
  .mm__name{font-family:var(--font-display,inherit);font-weight:800;font-size:clamp(1.4rem,4vw,2rem);color:#fff;margin:.2rem 0 .5rem;line-height:1.1}
  .mm__meta{display:flex;flex-wrap:wrap;gap:.5rem 1.2rem;font-size:.86rem;color:var(--muted,#8fa3a0);margin-bottom:.3rem}
  .mm__meta b{color:var(--text,#eaf2f1)}
  .mm__h{font-family:var(--font-ui,inherit);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.66rem;color:var(--accent,#2FBFA4);margin:1.2rem 0 .5rem;border-top:1px solid var(--line-soft,rgba(255,255,255,.08));padding-top:.9rem}
  .mm__loc{display:flex;flex-direction:column;gap:.7rem}
  .mm__locsys{background:color-mix(in srgb,var(--surface,#1e2427) 50%,transparent);border:1px solid var(--line-soft,rgba(255,255,255,.07));border-left:2px solid var(--accent-2,#E0A526);border-radius:6px;padding:.65rem .75rem}
  .mm__locsys-hd{display:flex;justify-content:space-between;align-items:baseline;gap:.6rem;font-family:var(--font-ui,inherit);font-weight:800;text-transform:uppercase;letter-spacing:.14em;font-size:.64rem;color:var(--accent-2,#E0A526);margin-bottom:.35rem}
  .mm__locsys-hd > span:first-child::before{content:"◆ ";opacity:.85}
  .mm__locn{font-weight:600;letter-spacing:.02em;text-transform:none;font-size:.62rem;color:var(--muted,#8fa3a0);white-space:nowrap}
  /* Fundort-Zeile: Typ-Icon · Name/Typ · Erz-Anteil-Balken · % (nach Anteil sortiert) */
  .mm__locrow{display:grid;grid-template-columns:1.1rem minmax(0,1fr) 74px 2.7rem;gap:.5rem;align-items:center;padding:.26rem 0}
  .mm__locrow + .mm__locrow{border-top:1px solid var(--line-soft,rgba(255,255,255,.05))}
  .mm__lt{color:var(--accent-2,#E0A526);font-size:.72rem;text-align:center;line-height:1}
  .mm__lt--space{color:var(--accent,#2FBFA4)}
  .mm__ln{font-size:.8rem;color:var(--text,#eaf2f1);min-width:0;overflow-wrap:anywhere;line-height:1.25}
  .mm__ln em{font-style:normal;color:var(--muted,#8fa3a0);font-size:.66rem;margin-left:.4rem;white-space:nowrap}
  .mm__bar{height:6px;background:var(--bg-2,#0d1113);border:1px solid var(--line-soft,rgba(255,255,255,.06));border-radius:3px;overflow:hidden}
  .mm__bar i{display:block;height:100%;border-radius:3px;min-width:3px}
  .mm__pct{font-size:.74rem;font-weight:700;font-variant-numeric:tabular-nums;text-align:right}
