---
// EVOLUTION — the signature feature no other SC site has: every game system
// (rows) × every patch (columns), each cell colored in its patch's palette.
// Click a cell to expand the actual changes with deep-links into the archive.
// Fed entirely by the data layer. Calm data page: no starfield, no scanlines,
// no motion — the per-patch color system itself is the spectacle here.
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import { getCollection } from 'astro:content';

const patches = (await getCollection('patches')).sort((a, b) =>
  a.data.date.localeCompare(b.data.date)
);

// rows: systems ordered by how often they were touched
const counts = new Map<string, number>();
for (const p of patches)
  for (const f of p.data.features)
    counts.set(f.system ?? 'Sonstiges', (counts.get(f.system ?? 'Sonstiges') ?? 0) + 1);
const systems = [...counts.entries()].sort((a, b) => b[1] - a[1]).map(([s]) => s);

// cells: system × patch -> features
type Feat = (typeof patches)[number]['data']['features'][number];
const cell = (sys: string, p: (typeof patches)[number]): Feat[] =>
  p.data.features.filter((f) => (f.system ?? 'Sonstiges') === sys);

const total = [...counts.values()].reduce((a, b) => a + b, 0);
---
<Layout
  title="Evolution — Systeme × Patches | SC Patch-Archiv"
  description={`Wie sich jedes Star-Citizen-System von Alpha 4.0.0 bis ${patches[patches.length - 1].data.version} entwickelt hat: ${total} dokumentierte Änderungen in ${systems.length} Systemen über ${patches.length} Patches.`}
  themeColor="#05070d"
  footer={true}
>
<style is:inline>
:root{
  --bg:#05070d;--bg-2:#0a0e18;--surface:#0f1524;--surface-2:#141c30;
  --accent:#2dd4ff;--accent-2:#6ea8ff;--gold:#d4af37;
  --text:#e8eefc;--muted:#8a99b8;--line:rgba(110,168,255,.16);
  --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;
  --maxw:1400px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
::selection{background:var(--accent);color:#05070d}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
</style>

<SiteNav crumbs={[{ label: 'Archiv', href: '/index.html' }, { label: 'Evolution' }]} pill={`${total} ÄNDERUNGEN`} />

<main class="evo">
  <header class="evo__head">
    <h1>Evolution</h1>
    <p class="evo__sub">
      Wie sich jedes Spielsystem von Alpha 4.0.0 bis {patches[patches.length - 1].data.version} entwickelt hat —
      {total} dokumentierte Änderungen, {systems.length} Systeme, {patches.length} Patches.
      Jede Spalte trägt die Farbe ihres Patches. Zelle anklicken für die Details.
    </p>
  </header>

  <div class="evo__scroll" tabindex="0" aria-label="Evolutions-Matrix (horizontal scrollbar)">
    <table class="evo__table">
      <thead>
        <tr>
          <th class="evo__syshead" scope="col">System</th>
          {patches.map((p) => (
            <th scope="col" class="evo__col" style={`--c:${p.data.palette.accent}`}>
              <a href={`/patches/sc-${p.id}.html`} title={`${p.data.codename} · ${p.data.dateDisplay}`}>
                {p.data.version}
              </a>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {systems.map((sys, si) => (
          <tr>
            <th scope="row" class="evo__sys">{sys}</th>
            {patches.map((p, pi) => {
              const feats = cell(sys, p);
              return (
                <td class="evo__td">
                  {feats.length > 0 ? (
                    <button
                      class="evo__cell"
                      style={`--c:${p.data.palette.accent}`}
                      data-ed={`ed-${si}-${pi}`}
                      aria-expanded="false"
                      aria-label={`${sys} in Alpha ${p.data.version}: ${feats.length} Änderung${feats.length > 1 ? 'en' : ''}`}
                    >{feats.length}</button>
                  ) : (
                    <span class="evo__dot" aria-hidden="true">·</span>
                  )}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="evo__detail" id="evo-detail" hidden>
    {systems.map((sys, si) =>
      patches.map((p, pi) => {
        const feats = cell(sys, p);
        if (!feats.length) return null;
        return (
          <div class="edet" id={`ed-${si}-${pi}`} hidden style={`--c:${p.data.palette.accent}`}>
            <header class="edet__head">
              <span class="edet__sys">{sys}</span>
              <a class="edet__patch" href={`/patches/sc-${p.id}.html`}>
                Alpha {p.data.version} — {p.data.codename} · {p.data.dateDisplay} →
              </a>
            </header>
            {feats.map((f) => (
              <article class="edet__feat">
                <h3>{f.name}{f.unverified && <abbr class="edet__unv" title="unbestätigt">*</abbr>}</h3>
                <p>{f.desc}</p>
                {(f.facts?.length ?? 0) > 0 && (
                  <dl class="edet__facts">
                    {f.facts!.map((x) => (
                      <div><dt>{x.label}</dt><dd>{x.value}</dd></div>
                    ))}
                  </dl>
                )}
                {f.topicSlug && <a class="edet__link" href={`/topics/${f.topicSlug}.html`}>Deep-Dive ansehen →</a>}
              </article>
            ))}
          </div>
        );
      })
    )}
  </div>
</main>

<style is:inline>
.evo{max-width:var(--maxw);margin:0 auto;padding:7rem clamp(1rem,3vw,2.5rem) 4rem}
.evo__head{margin-bottom:2.2rem}
.evo__head h1{font-family:var(--font-display);font-weight:900;font-size:clamp(2.2rem,6vw,3.6rem);
  background:linear-gradient(180deg,#fff,var(--accent-2) 70%,var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent}
.evo__sub{max-width:72ch;color:var(--muted);margin-top:.7rem;font-size:1.02rem}

.evo__scroll{overflow-x:auto;border:1px solid var(--line);background:var(--bg-2)}
.evo__table{border-collapse:collapse;width:max-content;min-width:100%}
.evo__table th,.evo__table td{border-bottom:1px solid var(--line)}
.evo__syshead{position:sticky;left:0;z-index:3;background:var(--bg-2);text-align:left;
  font-family:var(--font-ui);font-weight:700;font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);
  padding:.7rem .9rem;min-width:200px;border-right:1px solid var(--line)}
.evo__col{padding:.55rem .35rem .5rem;min-width:74px;border-bottom:2px solid var(--c)}
.evo__col a{font-family:var(--font-display);font-weight:700;font-size:.72rem;letter-spacing:.04em;color:var(--c);white-space:nowrap}
.evo__col a:hover{text-decoration:underline}
.evo__sys{position:sticky;left:0;z-index:2;background:var(--bg-2);text-align:left;
  font-family:var(--font-ui);font-weight:700;font-size:.9rem;color:var(--text);
  padding:.55rem .9rem;border-right:1px solid var(--line);white-space:nowrap}
.evo__td{text-align:center;padding:.3rem .25rem}
.evo__cell{font-family:var(--font-ui);font-weight:700;font-size:.85rem;
  width:2.1rem;height:2.1rem;cursor:pointer;color:var(--c);
  background:color-mix(in srgb,var(--c) 16%,transparent);
  border:1px solid color-mix(in srgb,var(--c) 55%,transparent);border-radius:3px}
.evo__cell:hover{background:color-mix(in srgb,var(--c) 30%,transparent)}
.evo__cell.sel{background:var(--c);color:#05070d;border-color:var(--c)}
.evo__dot{color:var(--muted);opacity:.28}

.evo__detail{margin-top:1.4rem}
.edet{border:1px solid var(--line);border-left:3px solid var(--c);background:var(--surface);padding:1.3rem 1.5rem}
.edet__head{display:flex;flex-wrap:wrap;align-items:baseline;justify-content:space-between;gap:.6rem 1.2rem;margin-bottom:1rem}
.edet__sys{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.18em;text-transform:uppercase;color:var(--c)}
.edet__patch{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
.edet__patch:hover{color:var(--c)}
.edet__feat{padding:.85rem 0;border-top:1px solid var(--line)}
.edet__feat:first-of-type{border-top:0}
.edet__feat h3{font-family:var(--font-ui);font-weight:700;font-size:1.05rem}
.edet__feat p{font-size:.93rem;color:var(--text);opacity:.85;max-width:88ch}
.edet__facts{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.5rem 1.2rem;margin:.6rem 0 0}
.edet__facts div{border-left:2px solid var(--line);padding-left:.6rem}
.edet__facts dt{font-family:var(--font-ui);font-weight:700;font-size:.62rem;letter-spacing:.13em;text-transform:uppercase;color:var(--muted)}
.edet__facts dd{margin:.05rem 0 0;font-size:.88rem}
.edet__link{display:inline-block;margin-top:.55rem;font-family:var(--font-ui);font-weight:700;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--c)}
.edet__link:hover{text-decoration:underline}
.edet__unv{color:var(--c);text-decoration:none;cursor:help;margin-left:.15rem}
</style>

<script is:inline>
(function () {
  var detail = document.getElementById('evo-detail');
  if (!detail) return;
  var open = null;
  document.querySelectorAll('.evo__cell').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.getAttribute('data-ed');
      var d = document.getElementById(id);
      if (!d) return;
      document.querySelectorAll('.edet').forEach(function (x) { x.hidden = true; });
      document.querySelectorAll('.evo__cell.sel').forEach(function (x) {
        x.classList.remove('sel');
        x.setAttribute('aria-expanded', 'false');
      });
      if (open === id) { detail.hidden = true; open = null; return; }
      detail.hidden = false;
      d.hidden = false;
      btn.classList.add('sel');
      btn.setAttribute('aria-expanded', 'true');
      open = id;
      d.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    });
  });
})();
</script>
</Layout>
