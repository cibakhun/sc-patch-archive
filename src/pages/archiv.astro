---
// Patch archive hub (EN). Body lives in PatchArchive.astro — shared verbatim
// with /de/archiv.astro so the two languages cannot drift.
import Layout from '../layouts/Layout.astro';
import PatchArchive from '../components/PatchArchive.astro';
import { getCollection } from 'astro:content';

const patches = await getCollection('patches');
const patchCount = patches.length;
const topicCount = patches.reduce((n, p) => n + p.data.topics.length, 0);
---

<Layout
  title="Star Citizen Patch Archive — Alpha 4.0 to 4.9 | VerseBase"
  description={`The complete Star Citizen patch archive of the Alpha 4 era: ${patchCount} patches from Destination Pyro (4.0.0) to Frontier Tensions (4.9.0), with ${topicCount} topic deep dives.`}
  themeColor="#05070d"
  footer={true}
  translated={true}
  ogImage="/assets/trailer-4-9-0.jpg"
>
  <link slot="head" rel="stylesheet" href="/assets/archive.css" />
  <PatchArchive />
</Layout>
