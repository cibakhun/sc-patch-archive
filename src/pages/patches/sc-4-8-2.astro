---
import Layout from '../../layouts/Layout.astro';
---
<Layout title={"Star Citizen Alpha 4.8.2 — Gatac & Alien Week | SC Patch-Archiv"} description={"Alpha 4.8.2: Zwei Gatac-Schiffe und die Alien Week 2956 rund um den First Contact Day."} themeColor="#0c0a16">
<style is:inline>

/* 4.8.2 "Gatac & Alien Week" — media-first / low-text / MAXIMAL */
:root{
  --bg:#0c0a16;--bg-2:#140f24;--surface:#1a1330;--surface-2:#231a3e;
  --accent:#1FB8A6;--accent-2:#C79A4B;--hot:#FF7847;
  --text:#eef2f1;--muted:#a79fc0;
  --line:rgba(31,184,166,.24);--line-soft:rgba(238,242,241,.10);
  --glow:0 0 44px rgba(31,184,166,.35);
  --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;
  --maxw:1280px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
::selection{background:var(--accent);color:#0c0a16}
:focus-visible{outline:2px solid var(--accent-2);outline-offset:3px}
.skip{position:absolute;left:-999px;top:0;z-index:200;background:var(--accent);color:#0c0a16;padding:.6rem 1rem;font-family:var(--font-ui);font-weight:700}.skip:focus{left:0}

/* Effekt-Overlays */
body::after{content:"";position:fixed;inset:0;z-index:9000;pointer-events:none;background:radial-gradient(130% 115% at 50% 42%,transparent 54%,rgba(0,0,0,.62) 100%),repeating-linear-gradient(0deg,rgba(0,0,0,.14) 0 1px,transparent 1px 3px);opacity:.5}
.cursorglow{position:fixed;inset:0;z-index:8800;pointer-events:none;background:radial-gradient(440px circle at var(--mx,50%) var(--my,28%),rgba(31,184,166,.13),transparent 60%)}

/* Topbar */
.topbar{position:fixed;top:0;left:0;right:0;z-index:9100;display:flex;align-items:center;justify-content:space-between;padding:.85rem clamp(1rem,4vw,2.5rem);background:linear-gradient(180deg,rgba(0,0,0,.9),transparent);backdrop-filter:blur(6px);transition:background .3s}
.topbar.scrolled{background:rgba(0,0,0,.95);border-bottom:1px solid var(--line)}
.back{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--font-ui);font-weight:600;letter-spacing:.05em;text-transform:uppercase;font-size:.85rem;color:var(--muted);transition:color .2s}.back:hover{color:var(--accent)}
.back .arrow{transition:transform .2s}.back:hover .arrow{transform:translateX(-4px)}
.vpill{font-family:var(--font-display);font-weight:700;font-size:.78rem;letter-spacing:.18em;color:var(--accent);border:1px solid var(--line);padding:.35rem .8rem;border-radius:2px}

/* HERO */
.hero{position:relative;min-height:100svh;display:flex;flex-direction:column;justify-content:flex-end;padding:7rem clamp(1.25rem,5vw,4.5rem) 4rem;overflow:hidden}
.hero__photo{position:absolute;inset:0;z-index:0;background:url('/assets/img-railen.jpg') center/cover;animation:kb 30s ease-in-out infinite alternate}
@keyframes kb{from{transform:scale(1.06)}to{transform:scale(1.18) translate(-1.5%,-1.5%)}}
.hero__photo::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.35),rgba(0,0,0,.55) 55%,var(--bg)),radial-gradient(120% 90% at 80% 20%,transparent,var(--bg) 85%)}
#stars{position:absolute;inset:0;z-index:1;opacity:.55}
.hero__in{position:relative;z-index:2;max-width:var(--maxw);margin:0 auto;width:100%}
.eyebrow{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;font-size:.8rem;color:var(--accent-2)}
.hero h1{position:relative;font-family:var(--font-display);font-weight:900;line-height:.82;letter-spacing:-.02em;margin:.6rem 0 .1rem;font-size:clamp(4.5rem,22vw,18rem);
  background:linear-gradient(180deg,#fff,var(--accent) 75%,#0f6e63);-webkit-background-clip:text;background-clip:text;color:transparent;filter:drop-shadow(0 0 36px rgba(31,184,166,.5));animation:flick 7s steps(1) infinite}
@keyframes flick{0%,90%,100%{opacity:1}91%{opacity:.5}92%{opacity:1}94%{opacity:.75}95%{opacity:1}}
.hero h1::after{content:attr(data-text);position:absolute;left:3px;top:0;-webkit-text-fill-color:var(--hot);color:var(--hot);opacity:0;mix-blend-mode:screen;animation:rgbs 7s steps(1) infinite}
@keyframes rgbs{0%,90%,100%{opacity:0;transform:translate(0,0)}91%{opacity:.7;transform:translate(-4px,2px)}93%{opacity:0}}
.hero .codename{font-family:var(--font-display);font-weight:700;font-size:clamp(1.3rem,4vw,2.6rem);color:#fff}
.hero .codename span{color:var(--accent-2)}
.hero .tagline{font-family:var(--font-ui);font-weight:600;font-size:clamp(1rem,2vw,1.4rem);color:var(--accent);letter-spacing:.02em;margin-top:.7rem}
.tags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1.4rem}
.tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.74rem;padding:.4rem .8rem;border:1px solid var(--line);border-radius:50px;background:rgba(0,0,0,.4);color:var(--text)}
.tag.hot{border-color:rgba(255,120,71,.55);color:#ff9a78}
.scrollcue{position:absolute;bottom:1.3rem;left:50%;transform:translateX(-50%);z-index:2;font-family:var(--font-ui);letter-spacing:.2em;text-transform:uppercase;font-size:.7rem;color:var(--muted);animation:bob 2s ease-in-out infinite}
@keyframes bob{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,7px)}}

/* Marquee */
.marquee{overflow:hidden;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:linear-gradient(90deg,var(--bg-2),var(--surface),var(--bg-2));padding:.8rem 0}
.mtrack{display:flex;gap:2.4rem;white-space:nowrap;width:max-content;animation:scrollx 30s linear infinite;font-family:var(--font-display);font-weight:700;font-size:1.05rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent)}
.mtrack .dot{color:var(--accent-2)}
@keyframes scrollx{to{transform:translateX(-50%)}}

/* Section */
section{position:relative;padding:clamp(3rem,7vw,6rem) clamp(1.25rem,5vw,4.5rem)}
.wrap{max-width:var(--maxw);margin:0 auto}
.sec-head{display:flex;align-items:center;gap:1rem;margin-bottom:2rem}
.sec-head .num{font-family:var(--font-display);font-weight:900;font-size:.95rem;color:var(--accent);opacity:.8}
.sec-head h2{font-family:var(--font-display);font-weight:700;font-size:clamp(1.4rem,3.5vw,2.3rem)}
.sec-head .rule{flex:1;height:1px;background:var(--line)}

/* BENTO */
.bento{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:185px;gap:.8rem}
@media(max-width:820px){.bento{grid-template-columns:repeat(2,1fr)}}
.tile{position:relative;border:1px solid var(--line);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;padding:1.2rem}
.tile .tbg{position:absolute;inset:0;z-index:0;background-size:cover;background-position:center;transition:transform .9s ease}
.tile:hover .tbg{transform:scale(1.09)}
.tile.img::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(0deg,rgba(0,0,0,.9),rgba(0,0,0,.1) 65%)}
.tile>*{position:relative;z-index:2}
.tile .lbl{font-family:var(--font-ui);font-weight:700;letter-spacing:.04em;font-size:1rem;text-shadow:0 1px 8px #000}
.tile .sub{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.12em;font-size:.68rem;color:var(--accent);margin-top:.2rem}
.tile.word{background:linear-gradient(140deg,var(--surface),var(--bg-2));justify-content:center}
.tile.word b{font-family:var(--font-display);font-weight:900;font-size:clamp(1.5rem,2.6vw,2.3rem);line-height:.95;color:var(--accent)}
.tile.word.hot b{color:#ff9a78}
.tile.word small{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.12em;font-size:.7rem;color:var(--muted);margin-top:.5rem}
.tile.stat{background:linear-gradient(140deg,var(--surface-2),var(--bg-2));align-items:center;justify-content:center;text-align:center}
.tile.stat .num{font-family:var(--font-display);font-weight:900;font-size:clamp(2.2rem,5vw,3.6rem);color:var(--accent);line-height:1}
.tile.stat .cap{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.14em;font-size:.7rem;color:var(--muted);margin-top:.5rem}
.w2{grid-column:span 2}.h2{grid-row:span 2}.b2{grid-column:span 2;grid-row:span 2}
@media(max-width:820px){.b2{grid-column:span 2}.h2{grid-row:span 1}}

/* SHOT */
.shot{position:relative;min-height:90vh;display:flex;align-items:flex-end;padding:clamp(2.5rem,7vw,7rem) clamp(1.25rem,5vw,4.5rem);overflow:hidden}
.shot .sbg{position:absolute;inset:0;z-index:0;background-size:cover;background-position:center;animation:kb2 26s ease-in-out infinite alternate}
@keyframes kb2{from{transform:scale(1.08)}to{transform:scale(1.24) translate(-3%,-2%)}}
.shot::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(0,0,0,.15),rgba(0,0,0,.5) 60%,var(--bg)),linear-gradient(90deg,rgba(0,0,0,.6),transparent 55%)}
.shot__in{position:relative;z-index:2;max-width:var(--maxw);margin:0 auto;width:100%}
.shot .kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.32em;text-transform:uppercase;color:var(--accent-2);font-size:.82rem}
.shot .big{font-family:var(--font-display);font-weight:900;font-size:clamp(4rem,20vw,15rem);line-height:.8;color:#fff;text-shadow:0 6px 70px rgba(0,0,0,.8),0 0 50px rgba(31,184,166,.28)}
.shot .big.outline{color:transparent;-webkit-text-stroke:2px var(--accent)}
.shot p{max-width:46ch;color:#eef3ff;font-size:clamp(1rem,1.6vw,1.25rem);margin-top:.6rem;text-shadow:0 2px 14px #000}

/* Ship garage */
.garage{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:1.2rem}
.ship{position:relative;border-radius:12px;overflow:hidden;border:1px solid var(--line);aspect-ratio:4/3;display:flex;align-items:flex-end;transition:transform .3s,border-color .3s,box-shadow .3s}
.ship .sbg{position:absolute;inset:0;z-index:0;background-size:cover;background-position:center;transition:transform .9s}
.ship:hover{transform:translateY(-6px);border-color:var(--accent);box-shadow:var(--glow)}
.ship:hover .sbg{transform:scale(1.1)}
.ship::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(0deg,rgba(0,0,0,.92),rgba(0,0,0,.05) 60%)}
.ship.foe::after{background:linear-gradient(0deg,rgba(45,20,8,.93),rgba(45,20,8,.05) 60%)}
.ship__in{position:relative;z-index:2;padding:1.5rem 1.6rem}
.ship .role{display:inline-block;font-family:var(--font-ui);font-weight:700;font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent-2);margin-bottom:.35rem}
.ship.foe .role{color:#ff9a78}
.ship h3{font-family:var(--font-display);font-weight:800;font-size:clamp(1.4rem,2.6vw,2rem);line-height:1}

/* Video wall */
.vwall{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:1rem}
.video{position:relative;aspect-ratio:16/9;border:1px solid var(--line);border-radius:10px;overflow:hidden;background:#000 center/cover no-repeat;cursor:pointer}
.video::after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,rgba(0,0,0,.6),transparent 55%);pointer-events:none}
.video iframe{position:absolute;inset:0;width:100%;height:100%;border:0;z-index:3}
.video .play{position:absolute;inset:0;margin:auto;width:74px;height:74px;z-index:2;border:0;border-radius:50%;background:rgba(0,0,0,.55);color:#fff;font-size:26px;cursor:pointer;display:grid;place-items:center;transition:transform .2s,background .2s;backdrop-filter:blur(2px)}
.video:hover .play{transform:scale(1.12);background:var(--accent);color:#0c0a16}
.video .vlbl{position:absolute;left:14px;bottom:12px;z-index:2;font-family:var(--font-ui);font-weight:700;font-size:.9rem;color:#fff;text-shadow:0 1px 8px #000}
.vsrc{margin-top:1rem;font-size:.8rem;color:var(--muted)}.vsrc a{color:var(--accent);border-bottom:1px solid var(--line)}

/* Mosaic gallery */
.mosaic{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:160px;gap:.7rem}
@media(max-width:820px){.mosaic{grid-template-columns:repeat(2,1fr)}}
.mosaic figure{position:relative;margin:0;overflow:hidden;border-radius:10px;border:1px solid var(--line)}
.mosaic img{width:100%;height:100%;object-fit:cover;transition:transform .6s,filter .6s;filter:saturate(.92)}
.mosaic figure:hover img{transform:scale(1.1);filter:saturate(1.2)}
.mosaic figcaption{position:absolute;left:0;right:0;bottom:0;padding:.6rem .7rem;font-family:var(--font-ui);font-weight:600;font-size:.78rem;background:linear-gradient(0deg,rgba(0,0,0,.85),transparent)}

/* Footer */
footer{border-top:1px solid var(--line);background:var(--bg-2);padding:clamp(2.5rem,6vw,4rem) clamp(1.25rem,5vw,4.5rem) 3rem}
.pager{display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;max-width:var(--maxw);margin-inline:auto}
.pager a,.pager span{flex:1;min-width:200px;border:1px solid var(--line);border-radius:8px;padding:1.1rem 1.3rem;background:var(--surface);transition:border-color .2s,transform .2s}
.pager a:hover{border-color:var(--accent);transform:translateY(-2px)}
.pager .dir{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.16em;font-size:.7rem;color:var(--muted)}
.pager .ttl{font-family:var(--font-display);font-weight:700;font-size:1rem;margin-top:.3rem}
.pager .next{text-align:right}
.pager .disabled{opacity:.35}
.foot-meta{max-width:var(--maxw);margin:0 auto;display:flex;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;font-size:.85rem;color:var(--muted)}
.foot-meta a{color:var(--accent)}
.home-link{font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.8rem}
.disclaimer{max-width:var(--maxw);margin:1.6rem auto 0;font-size:.72rem;color:var(--muted);opacity:.65;border-top:1px solid var(--line-soft);padding-top:1.2rem}

/* Klickbar-Affordance + Lightbox */
.ship,.tile.img,.tile.word,.tile.stat,.mosaic figure{cursor:pointer}
.zoomic{position:absolute;top:.7rem;right:.7rem;z-index:3;width:34px;height:34px;border-radius:50%;background:rgba(0,0,0,.55);border:1px solid var(--line);display:grid;place-items:center;font-size:.9rem;color:#fff;opacity:.55;transition:opacity .2s,background .2s,transform .2s}
.ship:hover .zoomic,.tile.img:hover .zoomic,.tile.word:hover .zoomic,.tile.stat:hover .zoomic,.mosaic figure:hover .zoomic{opacity:1;background:var(--accent);color:#0c0a16;transform:scale(1.12)}
.lb{position:fixed;inset:0;z-index:9500;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,.93);backdrop-filter:blur(5px);padding:3vh 3vw}
.lb.open{display:flex}
.lb__body{position:relative;max-width:1120px;width:100%}
.lb__body img{display:block;width:100%;height:auto;max-height:88vh;object-fit:contain;border:1px solid var(--line);border-radius:8px}
.lb__body .ratio{position:relative;aspect-ratio:16/9}
.lb__body .ratio iframe{position:absolute;inset:0;width:100%;height:100%;border:0;border-radius:8px}
.lb__x{position:absolute;top:-3.4rem;right:0;background:none;border:1px solid var(--line);color:#fff;width:46px;height:46px;border-radius:50%;font-size:1.2rem;cursor:pointer;transition:background .2s,color .2s}
.lb__x:hover{background:var(--accent);color:#0c0a16}
.lb__info{background:var(--surface);border:1px solid var(--line);border-radius:8px;overflow:hidden;max-height:88vh;overflow-y:auto}
.lb__info img{display:block;width:100%;max-height:46vh;object-fit:cover}
.lb__txt{padding:1.4rem 1.7rem}
.lb__txt h3{font-family:var(--font-display);font-weight:800;font-size:1.4rem;color:var(--accent);margin-bottom:.5rem}
.lb__txt p{color:var(--text);font-size:1rem;line-height:1.6}
.reveal{opacity:0;transform:translateY(26px);transition:opacity .7s,transform .7s}.reveal.in{opacity:1;transform:none}
@media (prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none}*{animation:none!important}}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<div class="topbar" id="topbar">
  <a class="back" href="/index.html"><span class="arrow">←</span> Patch-Archiv</a>
  <span class="vpill">ALPHA 4.8.2</span>
</div>

<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow">17. Juni 2026 · Schiffs- &amp; Event-Patch</div>
      <h1 data-text="4.8.2">4.8.2</h1>
      <div class="codename">Gatac &amp; <span>Alien Week</span></div>
      <div class="tags">
        <span class="tag">Gatac</span><span class="tag hot">Alien Week</span><span class="tag">First Contact</span><span class="tag">Grav-Lev</span>
      </div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee" aria-hidden="true">
    <div class="mtrack">
      <span>ALIEN WEEK 2956</span><span class="dot">◆</span><span>GATAC RAILEN</span><span class="dot">◆</span><span>GATAC TYILUI</span><span class="dot">◆</span><span>FIRST CONTACT</span><span class="dot">◆</span><span>XENO</span><span class="dot">◆</span><span>GRAV-LEV</span><span class="dot">◆</span>
      <span>ALIEN WEEK 2956</span><span class="dot">◆</span><span>GATAC RAILEN</span><span class="dot">◆</span><span>GATAC TYILUI</span><span class="dot">◆</span><span>FIRST CONTACT</span><span class="dot">◆</span><span>XENO</span><span class="dot">◆</span><span>GRAV-LEV</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- BENTO HIGHLIGHTS -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">01</span><h2>Highlights</h2><span class="rule"></span></div>
      <div class="bento reveal">
        <div class="tile img b2" data-lb="img:/assets/img-railen.jpg"><div class="tbg" style="background-image:url('/assets/img-railen.jpg')"></div><span class="zoomic">⤢</span><div class="lbl">Gatac Railen</div><div class="sub">Grav-Lev-Frachter</div></div>
        <a class="tile word hot" href="/topics/4-8-2-alien-week.html"><span class="zoomic">→</span><b>ALIEN<br>WEEK</b><small>Detailseite ansehen</small></a>
        <div class="tile img w2" data-lb="img:/assets/img-tyilui.jpg"><div class="tbg" style="background-image:url('/assets/img-tyilui.jpg')"></div><span class="zoomic">⤢</span><div class="lbl">Gatac Tyilui</div><div class="sub">Snub-Carrier</div></div>
        <div class="tile stat" data-info data-title="~640 SCU" data-text="Die Gatac Railen ist ein großer Xi'an-Frachter mit rund 640 SCU Ladekapazität, verteilt auf die charakteristischen dreieckigen Frachtpods. Damit zählt sie zu den groß dimensionierten Haulern im Spiel." data-img="/assets/img-railen.jpg"><span class="zoomic">+</span><div class="num">~640</div><div class="cap">SCU · Railen</div></div>
        <div class="tile word" data-info data-title="First Contact Day" data-text="Gedenktag an den Erstkontakt zwischen Menschheit und dem Xi'an-Imperium im Jahr 2530. Aus einem anfänglich angespannten Kalten Krieg wurde eine wohlhabende Allianz — Alien Week feiert dieses Erbe."><span class="zoomic">+</span><b>FIRST<br>CONTACT</b><small>Day</small></div>
        <div class="tile word" data-info data-title="Grav-Lev-Antrieb" data-text="Die Gatac-Schiffe nutzen Xi'an-Grav-Lev-Technologie (Graviton-Levitation) statt klassischer Triebwerke. Sie prägt das alien-typische Design und Flugverhalten der Railen und ihrer Schwesterschiffe." data-img="/assets/img-railen.jpg"><span class="zoomic">+</span><b>GRAV-LEV</b><small>Antrieb</small></div>
      </div>
    </div>
  </section>

  <!-- SHOT GATAC -->
  <section class="shot">
    <div class="sbg" style="background-image:url('/assets/img-railen.jpg')" aria-hidden="true"></div>
    <div class="shot__in reveal">
      <div class="kx">Alien Week · First Contact</div>
      <div class="big">GATAC</div>
    </div>
  </section>

  <!-- SHIP GARAGE -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">02</span><h2>Schiffe</h2><span class="rule"></span></div>
      <div class="garage">
        <article class="ship reveal" data-lb="yt:Xh35kuWo0a4"><div class="sbg" style="background-image:url('/assets/img-railen.jpg')"></div><span class="zoomic">▶</span><div class="ship__in"><span class="role">Gatac · Frachter</span><h3>Gatac Railen</h3></div></article>
        <article class="ship reveal" data-lb="yt:oulQmbwN87M"><div class="sbg" style="background-image:url('/assets/img-tyilui.jpg')"></div><span class="zoomic">▶</span><div class="ship__in"><span class="role">Gatac · Snub-Carrier</span><h3>Gatac Tyilui</h3></div></article>
      </div>
    </div>
  </section>

  <!-- VIDEO WALL -->
