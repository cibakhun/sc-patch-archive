---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import QuickFacts from '../../components/dossier/QuickFacts.astro';
import PatchDossier from '../../components/dossier/PatchDossier.astro';
import PatchSeo from '../../components/dossier/PatchSeo.astro';
import { mergePatchEn } from '../../i18n/patchText';
import { getEntry } from 'astro:content';

const entry = await getEntry('patches', '4-0-2');
if (!entry) throw new Error('Patch-Daten 4-0-2 fehlen in src/data/patches/');
const patch = mergePatchEn('4-0-2', entry.data, 'en');
---
<Layout title={"Star Citizen Alpha 4.0.2 — Supply or Die | VerseBase"} description={"Alpha 4.0.2 “Supply or Die”: Pyro's supply war — Citizens for Prosperity vs. the Headhunters, PvPvE depot battles over the key resource Detatrine, with the Ravager-212 as the event reward."} themeColor="#1a1d20" ogType="article" ogImage="/assets/t-pyro-3.jpg" translated={true}>
<PatchSeo patch={patch} image="/assets/t-pyro-3.jpg" lang="en" />
<style is:inline>

/* 4.0.2 "Supply or Die" — Gunmetal/Rot · media-first / low-text / MAXIMAL */
:root{
  --bg:#1a1d20;--bg-2:#21252a;--surface:#2a2e33;--surface-2:#33373b;
  --accent:#c0271f;--accent-2:#e8771a;--hot:#c0271f;
  --text:#ece6da;--muted:#9aa0a6;
  --line:rgba(192,39,31,.26);--line-soft:rgba(236,230,218,.10);
  --glow:0 0 44px rgba(192,39,31,.32);
  --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;
  --maxw:1280px;
}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f4f8fc;--bg-2:#e9eef5;--surface:#fcfdff;--surface-2:#eef3f8;--text:#231f16;--muted:#53595e;--accent:#ac0507;--accent-2:#853f02;--hot:#9e0004;--ink:#ffffff;--accent-media:#c0271f;--accent-2-media:#e8771a;--line:rgba(164,89,79,.3);--line-soft:rgba(50,45,36,.12);--glow:0 6px 22px rgba(173,83,72,.18)}


*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
::selection{background:var(--accent);color:var(--ink)}
:focus-visible{outline:2px solid var(--accent-2);outline-offset:3px}
.skip{position:absolute;left:-999px;top:0;z-index:200;background:var(--accent);color:var(--ink);padding:.6rem 1rem;font-family:var(--font-ui);font-weight:700}.skip:focus{left:0}

/* Effekt-Overlays */
body::after{content:"";position:fixed;inset:0;z-index:9000;pointer-events:none;background:radial-gradient(130% 115% at 50% 42%,transparent 54%,var(--vignette) 100%),repeating-linear-gradient(0deg,var(--scanline) 0 1px,transparent 1px 3px);opacity:.5}
.cursorglow{position:fixed;inset:0;z-index:8800;pointer-events:none;background:radial-gradient(280px circle at var(--mx,50%) var(--my,28%),rgba(192,39,31,.13),transparent 60%)}


/* HERO */
.hero{position:relative;min-height:100svh;display:flex;flex-direction:column;justify-content:flex-end;padding:7rem clamp(1.25rem,5vw,4.5rem) 4rem;overflow:hidden}
.hero__photo{position:absolute;inset:0;z-index:0;background:url('/assets/t-pyro-3.jpg') center/cover;animation:kb 30s ease-in-out infinite alternate}
@keyframes kb{from{transform:scale(1.06)}to{transform:scale(1.18) translate(-1.5%,-1.5%)}}
.hero__photo::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,var(--scrim-2),var(--scrim-4) 55%,var(--bg)),radial-gradient(120% 90% at 80% 20%,transparent,var(--bg) 85%)}
#stars{position:absolute;inset:0;z-index:1;opacity:.55}
.hero__in{position:relative;z-index:2;max-width:var(--maxw);margin:0 auto;width:100%}
.eyebrow{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;font-size:.8rem;color:var(--accent-2)}
.hero h1{position:relative;font-family:var(--font-display);font-weight:900;line-height:.82;letter-spacing:-.02em;margin:.6rem 0 .1rem;font-size:clamp(4.5rem,22vw,18rem);background:linear-gradient(180deg,var(--title-hi),var(--accent-2) 70%,var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent;filter:drop-shadow(0 0 36px rgba(192,39,31,.5));animation:flick 7s steps(1) infinite}
@keyframes flick{0%,90%,100%{opacity:1}91%{opacity:.5}92%{opacity:1}94%{opacity:.75}95%{opacity:1}}
.hero h1::after{content:attr(data-text);position:absolute;left:3px;top:0;-webkit-text-fill-color:var(--hot);color:var(--hot);opacity:0;mix-blend-mode:screen;animation:rgbs 7s steps(1) infinite}
@keyframes rgbs{0%,90%,100%{opacity:0;transform:translate(0,0)}91%{opacity:.7;transform:translate(-4px,2px)}93%{opacity:0}}
.hero .codename{font-family:var(--font-display);font-weight:700;font-size:clamp(1.3rem,4vw,2.6rem);color:var(--on-media)}
.hero .codename span{color:var(--accent)}
.hero .tagline{font-family:var(--font-ui);font-weight:600;font-size:clamp(1rem,2vw,1.4rem);color:var(--accent-2);letter-spacing:.02em;margin-top:.7rem}
.tags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1.4rem}
.tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.74rem;padding:.4rem .8rem;border:1px solid var(--line);border-radius:50px;background:var(--veil);color:var(--text)}
.tag.hot{border-color:rgba(192,39,31,.55);color:#ff6a5e}
.scrollcue{position:absolute;bottom:1.3rem;left:50%;transform:translateX(-50%);z-index:2;font-family:var(--font-ui);letter-spacing:.2em;text-transform:uppercase;font-size:.7rem;color:var(--muted);animation:bob 2s ease-in-out infinite}
@keyframes bob{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,7px)}}

/* Marquee */
.marquee{overflow:hidden;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:linear-gradient(90deg,var(--bg-2),var(--surface),var(--bg-2));padding:.8rem 0}
.mtrack{display:flex;gap:2.4rem;white-space:nowrap;width:max-content;animation:scrollx 30s linear infinite;font-family:var(--font-display);font-weight:700;font-size:1.05rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent)}
.mtrack .dot{color:var(--accent-2)}
@keyframes scrollx{to{transform:translateX(-50%)}}

/* Section */
section{position:relative;padding:clamp(3rem,7vw,6rem) clamp(1.25rem,5vw,4.5rem)}
.wrap{max-width:var(--maxw);margin:0 auto}
.sec-head{display:flex;align-items:center;gap:1rem;margin-bottom:2rem}
.sec-head .num{font-family:var(--font-display);font-weight:900;font-size:.95rem;color:var(--accent-2);opacity:.8}
.sec-head h2{font-family:var(--font-display);font-weight:700;font-size:clamp(1.4rem,3.5vw,2.3rem)}
.sec-head .rule{flex:1;height:1px;background:var(--line)}

/* BENTO */
.bento{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:185px;gap:.8rem}
@media(max-width:820px){.bento{grid-template-columns:repeat(2,1fr)}}
.tile{position:relative;border:1px solid var(--line);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;padding:1.2rem}
.tile .tbg{position:absolute;inset:0;z-index:0;background-size:cover;background-position:center;transition:transform .9s ease}
.tile:hover .tbg{transform:scale(1.09)}
.tile.img::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(0deg,var(--scrim-6),var(--scrim-0) 65%)}
.tile>*{position:relative;z-index:2}
.tile .lbl{font-family:var(--font-ui);font-weight:700;letter-spacing:.04em;font-size:1rem;text-shadow:0 1px 8px var(--on-media-shadow)}
.tile .sub{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.12em;font-size:.68rem;color:var(--accent-2);margin-top:.2rem}
.tile.word{background:linear-gradient(140deg,var(--surface),var(--bg-2));justify-content:center}
.tile.word b{font-family:var(--font-display);font-weight:900;font-size:clamp(1.5rem,2.6vw,2.3rem);line-height:.95;color:var(--accent)}
.tile.word.hot b{color:#ff6a5e}
.tile.word small{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.12em;font-size:.7rem;color:var(--muted);margin-top:.5rem}
.tile.stat{background:linear-gradient(140deg,var(--surface-2),var(--bg-2));align-items:center;justify-content:center;text-align:center}
.tile.stat .num{font-family:var(--font-display);font-weight:900;font-size:clamp(2.2rem,5vw,3.6rem);color:var(--accent);line-height:1}
.tile.stat .cap{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.14em;font-size:.7rem;color:var(--muted);margin-top:.5rem}
.w2{grid-column:span 2}.h2{grid-row:span 2}.b2{grid-column:span 2;grid-row:span 2}
@media(max-width:820px){.b2{grid-column:span 2}.h2{grid-row:span 1}}

/* SHOT */
.shot{position:relative;min-height:90vh;display:flex;align-items:flex-end;padding:clamp(2.5rem,7vw,7rem) clamp(1.25rem,5vw,4.5rem);overflow:hidden}
.shot .sbg{position:absolute;inset:0;z-index:0;background-size:cover;background-position:center;animation:kb2 26s ease-in-out infinite alternate}
@keyframes kb2{from{transform:scale(1.08)}to{transform:scale(1.24) translate(-3%,-2%)}}
.shot::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,var(--scrim-0),var(--scrim-3) 60%,var(--bg)),linear-gradient(90deg,var(--scrim-4),transparent 55%)}
.shot__in{position:relative;z-index:2;max-width:var(--maxw);margin:0 auto;width:100%}
.shot .kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.32em;text-transform:uppercase;color:var(--accent-2);font-size:.82rem}
.shot .big{font-family:var(--font-display);font-weight:900;font-size:clamp(3rem,16vw,12.2rem);line-height:.8;color:var(--on-media);text-shadow:0 6px 70px var(--on-media-shadow),0 0 50px rgba(192,39,31,.28);overflow-wrap:normal;text-wrap:balance}
.shot .big.outline{color:transparent;-webkit-text-stroke:2px var(--accent)}
.shot p{max-width:46ch;color:var(--on-media-dim);font-size:clamp(1rem,1.6vw,1.25rem);margin-top:.6rem;text-shadow:0 2px 14px var(--on-media-shadow)}

/* Video wall */
.vwall{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:1rem}
.video{position:relative;aspect-ratio:16/9;border:1px solid var(--line);border-radius:10px;overflow:hidden;background:var(--media-void) center/cover no-repeat;cursor:pointer}
.video::after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,var(--scrim-4),transparent 55%);pointer-events:none}
.video iframe{position:absolute;inset:0;width:100%;height:100%;border:0;z-index:3}
.video .play{position:absolute;inset:0;margin:auto;width:74px;height:74px;z-index:2;border:0;border-radius:50%;background:var(--scrim-4);color:var(--on-media);font-size:26px;cursor:pointer;display:grid;place-items:center;transition:transform .2s,background .2s;backdrop-filter:blur(2px)}
.video:hover .play{transform:scale(1.12);background:var(--accent);color:var(--ink-media)}
.video .vlbl{position:absolute;left:14px;bottom:12px;z-index:2;font-family:var(--font-ui);font-weight:700;font-size:.9rem;color:var(--on-media);text-shadow:0 1px 8px var(--on-media-shadow)}
.vsrc{margin-top:1rem;font-size:.8rem;color:var(--muted)}.vsrc a{color:var(--accent-2);border-bottom:1px solid var(--line)}

/* Mosaic gallery */
.mosaic{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:160px;gap:.7rem}
@media(max-width:820px){.mosaic{grid-template-columns:repeat(2,1fr)}}
.mosaic figure{position:relative;margin:0;overflow:hidden;border-radius:10px;border:1px solid var(--line)}
.mosaic img{width:100%;height:100%;object-fit:cover;transition:transform .6s,filter .6s;filter:saturate(.92)}
.mosaic figure:hover img{transform:scale(1.1);filter:saturate(1.2)}
.mosaic figcaption{position:absolute;left:0;right:0;bottom:0;padding:.6rem .7rem;font-family:var(--font-ui);font-weight:600;font-size:.78rem;background:linear-gradient(0deg,var(--scrim-6),transparent)}

/* Footer */
footer{border-top:1px solid var(--line);background:var(--bg-2);padding:clamp(2.5rem,6vw,4rem) clamp(1.25rem,5vw,4.5rem) 3rem}
.pager{display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;max-width:var(--maxw);margin-inline:auto}
.pager>a,.pager>span{flex:1;min-width:min(200px,100%);display:flex;flex-direction:column;border:1px solid var(--line);border-radius:8px;padding:1.1rem 1.3rem;background:var(--surface);transition:border-color .2s,transform .2s}
.pager a:hover{border-color:var(--accent-2);transform:translateY(-2px)}
.pager .dir{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.16em;font-size:.7rem;color:var(--muted)}
.pager .ttl{font-family:var(--font-display);font-weight:700;font-size:1rem;margin-top:.3rem;overflow-wrap:break-word}
.pager .next{text-align:right}
.foot-meta{max-width:var(--maxw);margin:0 auto;display:flex;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;font-size:.85rem;color:var(--muted)}
.foot-meta a{color:var(--accent-2)}
.home-link{font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.8rem}
.disclaimer{max-width:var(--maxw);margin:1.6rem auto 0;font-size:.72rem;color:var(--muted);opacity:.65;border-top:1px solid var(--line-soft);padding-top:1.2rem}

/* Klickbar-Affordance + Lightbox */
.tile.img,.tile.word,.tile.stat,.mosaic figure{cursor:pointer}
.zoomic{position:absolute;top:.7rem;right:.7rem;z-index:3;width:34px;height:34px;border-radius:50%;background:var(--scrim-4);border:1px solid var(--line);display:grid;place-items:center;font-size:.9rem;color:var(--on-media);opacity:.55;transition:opacity .2s,background .2s,transform .2s}
.tile.img:hover .zoomic,.tile.word:hover .zoomic,.tile.stat:hover .zoomic,.mosaic figure:hover .zoomic{opacity:1;background:var(--accent);color:var(--ink-media);transform:scale(1.12)}
.lb{position:fixed;inset:0;z-index:9500;display:none;align-items:center;justify-content:center;background:var(--lb-backdrop);backdrop-filter:blur(5px);padding:3vh 3vw}
.lb.open{display:flex}
.lb__body{position:relative;max-width:1120px;width:100%}
.lb__body img{display:block;width:100%;height:auto;max-height:88vh;object-fit:contain;border:1px solid var(--line);border-radius:8px}
.lb__body .ratio{position:relative;aspect-ratio:16/9}
.lb__body .ratio iframe{position:absolute;inset:0;width:100%;height:100%;border:0;border-radius:8px}
.lb__x{position:absolute;top:-3.4rem;right:0;background:none;border:1px solid var(--line);color:var(--on-media);width:46px;height:46px;border-radius:50%;font-size:1.2rem;cursor:pointer;transition:background .2s,color .2s}
.lb__x:hover{background:var(--accent);color:var(--ink-media)}
.lb__info{background:var(--surface);border:1px solid var(--line);border-radius:8px;overflow:hidden;max-height:88vh;overflow-y:auto}
.lb__info img{display:block;width:100%;max-height:46vh;object-fit:cover}
.lb__txt{padding:1.4rem 1.7rem}
.lb__txt h3{font-family:var(--font-display);font-weight:800;font-size:1.4rem;color:var(--accent);margin-bottom:.5rem}
.lb__txt p{color:var(--text);font-size:1rem;line-height:1.6}
.reveal{opacity:0;transform:translateY(26px);transition:opacity .7s,transform .7s}.reveal.in{opacity:1;transform:none}
@media (prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none}*{animation:none!important}}
/* Hell-Entsprechungen — erzeugt von scripts/build-light-overrides.mjs. Nicht von Hand ändern. */
:root[data-theme="light"] .tag.hot{color:#a7030f}
:root[data-theme="light"] .tile.word.hot b{color:#a7030f}
</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.0.2' }]} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow">February 28, 2025 · Point Release &amp; Event</div>
      <h1 data-text="4.0.2">4.0.2</h1>
      <div class="codename">Supply or <span>Die</span></div>
      <div class="tagline">Pyro's supply war: Citizens for Prosperity vs. Headhunters.</div>
      <div class="tags">
        <span class="tag">Supply or Die</span><span class="tag">Citizens for Prosperity</span><span class="tag hot">Headhunters</span><span class="tag">PvPvE</span>
      </div>
      <a href="/topics/4-0-2-supply-or-die.html" style="display:inline-flex;align-items:center;gap:.5rem;margin-top:1.4rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.06em;text-transform:uppercase;font-size:.82rem;color:var(--bg);background:var(--accent);padding:.75rem 1.4rem;border-radius:4px;box-shadow:0 6px 20px -6px rgba(0,0,0,.5)">Supply or Die · Detail page →</a>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee" aria-hidden="true">
    <div class="mtrack">
      <span>SUPPLY OR DIE</span><span class="dot">◆</span><span>CITIZENS FOR PROSPERITY</span><span class="dot">◆</span><span>HEADHUNTERS</span><span class="dot">◆</span><span>DETATRINE</span><span class="dot">◆</span><span>PVPVE</span><span class="dot">◆</span><span>RAVAGER-212</span><span class="dot">◆</span>
      <span>SUPPLY OR DIE</span><span class="dot">◆</span><span>CITIZENS FOR PROSPERITY</span><span class="dot">◆</span><span>HEADHUNTERS</span><span class="dot">◆</span><span>DETATRINE</span><span class="dot">◆</span><span>PVPVE</span><span class="dot">◆</span><span>RAVAGER-212</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AT A GLANCE (Daten-Register, uniform) -->
  <QuickFacts facts={patch.keyFacts} stand={`Alpha ${patch.version} · ${patch.dateDisplay}`} lang="en" />

  <!-- BENTO HIGHLIGHTS -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">01</span><h2>Highlights</h2><span class="rule"></span></div>
      <div class="bento reveal">
        <div class="tile img b2" data-lb="img:/assets/t-supply-1.jpg"><div class="tbg" style="background-image:url('/assets/t-supply-1.jpg')"></div><span class="zoomic">⤢</span><div class="lbl">Secure the supplies</div><div class="sub">Depot battlefield</div></div>
        <div class="tile word" data-info data-title="Citizens for Prosperity" data-text="One of the two factions in the „Supply or Die“ event. They gather industrial goods and the rare chemical Detatrine to replenish their depleted reserves and produce medical relief supplies to stabilize Pyro." data-img="/assets/t-supply-2.jpg"><span class="zoomic">+</span><b>CITIZENS FOR PROSPERITY</b><small>Faction A</small></div>
        <div class="tile word hot" data-info data-title="Headhunters" data-text="The rival faction in the „Supply or Die“ event. They acquire salvage and mining resources by any means — including combat and piracy — to arm their forces." data-img="/assets/cz-combat.jpg"><span class="zoomic">+</span><b>HEADHUNTERS</b><small>Faction B</small></div>
        <div class="tile word" data-info data-title="PvPvE depot battles" data-text="Material for the factions is fought over partly in PvPvE-focused depots: there, players face both NPC enemies and other players while securing supplies."><span class="zoomic">+</span><b>PVPVE</b><small>Depot battles</small></div>
        <div class="tile word" data-info data-title="Ravager-212 „Outcast“" data-text="The Ravager-212 „Outcast“ is a Twin Shotgun and reward of event tier 2. Higher tiers also granted „Outcast“ paints for the Vulture and Prospector."><span class="zoomic">+</span><b>RAVAGER-212</b><small>Outcast reward</small></div>
        <div class="tile stat" data-info data-title="Two factions" data-text="„Supply or Die“ pitted two rival factions against each other — Citizens for Prosperity and Headhunters. Players picked a side and supplied it." data-img="/assets/vid-supplyordie.jpg"><span class="zoomic">+</span><div class="num">2</div><div class="cap">Factions</div></div>
      </div>
    </div>
  </section>

  <!-- SHOT -->
  <section class="shot">
    <div class="sbg" style="background-image:url('/assets/t-pyro-2.jpg')" aria-hidden="true"></div>
    <div class="shot__in reveal">
      <div class="kx">Supply war in Pyro</div>
      <div class="big outline">SUPPLY OR DIE</div>
      <p>Supply a faction in Pyro's contested depots.</p>
    </div>
  </section>

  <!-- VIDEO WALL -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">02</span><h2>Video</h2><span class="rule"></span></div>
      <div class="vwall reveal">
        <div class="video" data-yt="R9p2q5fFUJk" style="background-image:url('/assets/vid-supplyordie.jpg')"><span class="vlbl">Supply or Die — Event</span><button class="play" aria-label="Play">▶</button></div>
      </div>
      <p class="vsrc reveal">Official Star Citizen YouTube channel (© Cloud Imperium Games). Click loads the video. · <a href="https://www.youtube.com/watch?v=R9p2q5fFUJk" target="_blank" rel="noopener">YouTube ↗</a></p>
    </div>
  </section>

  <!-- MOSAIC -->
  <section>
    <div class="wrap">
