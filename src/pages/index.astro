---
// VerseBase-Startseite — ein Landing-Screen mit der Kino-DNA der Patch-Seiten:
// Ambient-Video-Loop hinter dem Hero, Glitch-Titel, Terminal-Suche,
// Bento-Tool-Kacheln, Archiv-Banner, Marquee. Das Patch-Archiv
// (Ären, Schlüsselthemen, Themen-Verzeichnis) lebt auf /archiv.html.
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../consts';

const patches = (await getCollection('patches')).sort((a, b) =>
  a.data.date.localeCompare(b.data.date)
);
const latest = patches[patches.length - 1];
const patchCount = patches.length;
const topicCount = patches.reduce((n, p) => n + p.data.topics.length, 0);

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url.replace(/\/$/, '') + '/',
  inLanguage: 'de',
  description: SITE.defaultDescription,
  publisher: { '@type': 'Organization', name: SITE.name },
};
---
<Layout title={"VerseBase — das Star-Citizen-Kompendium"} description={"VerseBase — das inoffizielle Star-Citizen-Kompendium: Item Finder mit Preisen & Fundorten, Mining-Tools, Crafting-Datenbank, Wikelo-Trades, Schiffs-Datenbank und das komplette Patch-Archiv der Alpha-4-Ära. Game-akkurat, zweisprachig."} themeColor="#05070d" footer={true} translated={true}>
<script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>
/* VerseBase-Landing — Kino-DNA der Patch-Seiten auf einem Screen. */
:root{--bg:#05070d;--bg-2:#0a0e18;--surface:#0f1524;--surface-2:#141c30;--accent:#2dd4ff;--accent-2:#6ea8ff;--hot:#d4af37;--gold:#d4af37;--text:#e8eefc;--muted:#8a99b8;--line:rgba(110,168,255,.18);--line-soft:rgba(232,238,252,.10);--glow:0 0 44px rgba(45,212,255,.28);--ink:#05070d;--maxw:1240px;}

/* --- Hero: bottom-anchored wie die Patch-Seiten, Video-Loop dahinter --- */
.hero{min-height:100svh;padding:6.5rem clamp(1.25rem,5vw,4rem) 3.2rem}
.hero h1{position:relative;font-family:var(--font-display);font-weight:900;line-height:.82;letter-spacing:-.02em;margin:.55rem 0 .2rem;font-size:clamp(2.6rem,10.2vw,7.6rem);overflow-wrap:normal;white-space:nowrap;
  background:linear-gradient(180deg,#fff,var(--accent) 72%,#1a7fa0);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;filter:drop-shadow(0 0 36px rgba(45,212,255,.45));animation:flick 7s steps(1) infinite}
@keyframes flick{0%,90%,100%{opacity:1}91%{opacity:.5}92%{opacity:1}94%{opacity:.75}95%{opacity:1}}
.hero h1::after{content:attr(data-text);position:absolute;left:3px;top:0;-webkit-text-fill-color:var(--hot);color:var(--hot);opacity:0;mix-blend-mode:screen;animation:rgbs 7s steps(1) infinite}
@keyframes rgbs{0%,90%,100%{opacity:0;transform:translate(0,0)}91%{opacity:.7;transform:translate(-4px,2px)}93%{opacity:0}}
.hero .tagline{font-family:var(--font-ui);font-weight:600;font-size:clamp(1rem,2vw,1.35rem);color:var(--accent);letter-spacing:.02em}

/* --- Terminal-Suche --- */
.hero-search{display:flex;align-items:center;gap:.8rem;width:100%;max-width:620px;margin:1.3rem 0 0;padding:.9rem 1.1rem;background:rgba(0,0,0,.55);border:1px solid var(--line);border-left:3px solid var(--accent);border-radius:2px;clip-path:polygon(0 0,100% 0,100% calc(100% - 10px),calc(100% - 10px) 100%,0 100%);color:var(--muted);font-family:var(--font-ui);font-size:1rem;cursor:pointer;text-align:left;transition:border-color .2s,box-shadow .2s,background-color .2s}
.hero-search:hover,.hero-search:focus-visible{border-color:var(--accent);box-shadow:0 0 22px color-mix(in srgb,var(--accent) 28%,transparent);background:rgba(0,0,0,.7);outline:none}
.hero-search .hs__prompt{color:var(--accent);font-weight:700;flex:none;animation:hsblink 1.4s steps(1) infinite}
@keyframes hsblink{0%,100%{opacity:1}50%{opacity:.35}}
.hero-search .hs__hint{flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.hero-search .hs__kbd{display:flex;gap:.25rem;flex:none}
.hero-search kbd{font-family:var(--font-ui);font-size:.7rem;font-weight:700;letter-spacing:.06em;color:var(--muted);border:1px solid var(--line);border-bottom-width:2px;border-radius:4px;padding:.1rem .4rem;background:rgba(255,255,255,.04)}

/* --- Tool-Kacheln — Bento-Stil der Patch-Seiten: Artwork trägt, Name unten --- */
.tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin-top:1.5rem;width:100%}
.tcard{--c:var(--accent);position:relative;display:flex;flex-direction:column;justify-content:flex-end;gap:.18rem;padding:.9rem 1.05rem;min-height:150px;
  background-color:var(--surface);
  background-image:linear-gradient(0deg,rgba(5,7,13,.92),rgba(5,7,13,.55) 42%,rgba(5,7,13,.12) 75%),var(--img,none);
  background-size:cover;background-position:center;
  border:1px solid var(--line);border-top:2px solid var(--c);border-radius:2px;
  clip-path:polygon(10px 0,100% 0,100% calc(100% - 10px),calc(100% - 10px) 100%,0 100%,0 10px);
  overflow:hidden;transition:transform .22s,border-color .22s,box-shadow .22s}
.tcard::before{content:"";position:absolute;top:0;right:0;width:22px;height:22px;background:linear-gradient(225deg,color-mix(in srgb,var(--c) 65%,transparent) 0 9px,transparent 9px);opacity:.5;transition:opacity .2s;pointer-events:none}
.tcard::after{content:"";position:absolute;inset:0;background:radial-gradient(80% 60% at 85% 0%,color-mix(in srgb,var(--c) 22%,transparent),transparent 70%);opacity:0;transition:opacity .25s;pointer-events:none}
.tcard:hover{transform:translateY(-3px);border-color:var(--c);box-shadow:0 14px 36px -14px var(--c)}
.tcard:hover::before{opacity:1}
.tcard:hover::after{opacity:1}
.tcard>*{position:relative;z-index:1}
.tcard b{font-family:var(--font-display);font-weight:800;font-size:1.08rem;color:#fff;text-shadow:0 1px 10px rgba(0,0,0,.85)}
.tcard .tsub{font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.68rem;color:var(--c);text-shadow:0 1px 6px rgba(0,0,0,.8);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tcard .tgo{position:absolute;right:.9rem;bottom:.8rem;font-family:var(--font-ui);font-weight:700;font-size:.9rem;color:var(--c);opacity:0;transform:translateX(-6px);transition:opacity .2s,transform .2s}
.tcard:hover .tgo{opacity:1;transform:none}
@media(max-width:860px){.tgrid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.tcard{min-height:104px;padding:.75rem .85rem}}

/* --- Archiv-Banner (Gold, Kino-Zeile) --- */
.arcband{--c:var(--gold);display:flex;align-items:center;gap:1.1rem;flex-wrap:wrap;width:100%;margin-top:.75rem;padding:.9rem 1.2rem;
  background:linear-gradient(90deg,color-mix(in srgb,var(--c) 10%,rgba(0,0,0,.5)),rgba(0,0,0,.45));
  border:1px solid color-mix(in srgb,var(--c) 45%,transparent);border-left:3px solid var(--c);border-radius:2px;
  clip-path:polygon(0 0,100% 0,100% calc(100% - 10px),calc(100% - 10px) 100%,0 100%);
  transition:border-color .2s,box-shadow .2s}
.arcband:hover{border-color:var(--c);box-shadow:0 0 26px color-mix(in srgb,var(--c) 25%,transparent)}
.arcband .at{font-family:var(--font-display);font-weight:900;font-size:1.1rem;letter-spacing:.04em;color:transparent;-webkit-text-stroke:1.2px var(--c)}
.arcband .am{font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.7rem;color:var(--muted)}
.arcband .anew{margin-left:auto;display:inline-flex;align-items:center;gap:.55rem;font-family:var(--font-ui);font-weight:600;font-size:.88rem;color:var(--text)}
.arcband .anew .ntag{font-family:var(--font-ui);font-weight:800;font-size:.64rem;letter-spacing:.16em;text-transform:uppercase;background:var(--c);color:var(--ink);padding:.12rem .45rem}
.arcband .ar{color:var(--c);transition:transform .2s}
.arcband:hover .ar{transform:translateX(5px)}
@media(max-width:720px){.arcband .anew{margin-left:0;width:100%}}

footer{border-top:1px solid var(--line);padding:3rem clamp(1.25rem,5vw,3rem);text-align:center}
footer .disclaimer{max-width:80ch;margin:0 auto;font-size:.78rem;color:var(--muted);opacity:.75}
footer .credit{font-family:var(--font-ui);letter-spacing:.1em;text-transform:uppercase;font-size:.75rem;color:var(--muted);margin-bottom:1rem}
</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav hasEn={true} />

<main id="main">

  <!-- HERO — Ambient-Loop (Nyx) hinter Glitch-Titel, wie die Patch-Seiten -->
  <section class="hero">
    <div class="hero__photo" data-bgvid="/assets/loops/loop-nyx.mp4" style="background-image:url('/assets/img-nyx.jpg')" aria-hidden="true"></div>
    <script is:inline src="/assets/hero-video.js"></script>
    <canvas id="stars" aria-hidden="true"></canvas>
    <script is:inline>if(location.search.indexOf('nofx')>-1){document.documentElement.style.setProperty('scroll-behavior','auto');var c=document.getElementById('stars');if(c)c.remove();}</script>
    <div class="hero__in">
      <div class="eyebrow">Das inoffizielle Star-Citizen-Kompendium</div>
      <h1 data-text="VERSEBASE">VERSEBASE</h1>
      <div class="tagline">Preise · Fundorte · Blueprints · Trades · Schiffe — game-akkurat aus den Spieldaten.</div>

      <button class="hero-search" type="button" data-scs-open aria-label="Suche öffnen">
        <span class="hs__prompt" aria-hidden="true">&gt;_</span>
        <span class="hs__hint">Items, Schiffe, Patches, Themen durchsuchen…</span>
        <span class="hs__kbd" aria-hidden="true"><kbd>Strg</kbd><kbd>K</kbd></span>
      </button>

      <div class="tgrid" aria-label="Werkzeuge & Datenbanken">
        <a class="tcard" style="--c:#A78BFA;--img:url('/assets/cz-loot.jpg')" href="/item-finder.html">
          <b>Item Finder</b>
          <span class="tsub">Preise · Fundorte · Loot-Guides</span>
          <span class="tgo" aria-hidden="true">→</span>
        </a>
        <a class="tcard" style="--c:#2FBFA4;--img:url('/assets/img-mole.jpg')" href="/topics/mining.html">
          <b>Mining</b>
          <span class="tsub">Minerale · Scanner · Rechner</span>
          <span class="tgo" aria-hidden="true">→</span>
        </a>
        <a class="tcard" style="--c:#FF5E1A;--img:url('/assets/t-craft-1.jpg')" href="/topics/crafting.html">
          <b>Crafting</b>
          <span class="tsub">Blueprints · Simulator · Planer</span>
          <span class="tgo" aria-hidden="true">→</span>
        </a>
        <a class="tcard" style="--c:#1FB8A6;--img:url('/assets/wk-emporium.jpg')" href="/topics/wikelo-emporium.html">
          <b>Wikelo</b>
          <span class="tsub">Trades · Favor · Belohnungen</span>
          <span class="tgo" aria-hidden="true">→</span>
        </a>
        <a class="tcard" style="--c:#6ea8ff;--img:url('/assets/img-hammerhead.jpg')" href="/schiffe.html">
          <b>Schiffe</b>
          <span class="tsub">Datenblätter · Loadouts · Preise</span>
          <span class="tgo" aria-hidden="true">→</span>
        </a>
        <a class="tcard" style="--c:#d4af37;--img:repeating-linear-gradient(90deg,rgba(212,175,55,.5) 0 1px,transparent 1px 22px),repeating-linear-gradient(0deg,rgba(212,175,55,.5) 0 1px,transparent 1px 22px)" href="/evolution.html">
          <b>Evolution</b>
          <span class="tsub">Systeme × Versionen</span>
          <span class="tgo" aria-hidden="true">→</span>
        </a>
      </div>

      <a class="arcband" href="/archiv.html">
        <span class="at">PATCH-ARCHIV</span>
        <span class="am">{patchCount} Patches · {topicCount} Deep-Dives · 2024 – 2026</span>
        <span class="anew"><span class="ntag">Neu</span>Alpha {latest.data.version} — {latest.data.tagline}<span class="ar">→</span></span>
      </a>
    </div>
  </section>

  <!-- MARQUEE — Patch-Ticker als Abschluss -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>4.0 DESTINATION PYRO</span><span class="dot">◆</span><span>4.2 STORM BREAKER</span><span class="dot">◆</span><span>4.3 DARK TERRITORY</span><span class="dot">◆</span><span>4.4 WELCOME TO NYX</span><span class="dot">◆</span><span>4.5 DAWN OF ENGINEERING</span><span class="dot">◆</span><span>4.6 LIFELINE FOR LEVSKI</span><span class="dot">◆</span><span>4.7 WELCOME TO THE ROCK</span><span class="dot">◆</span><span>4.8 TACTICAL STRIKE</span><span class="dot">◆</span>
      <span>4.0 DESTINATION PYRO</span><span class="dot">◆</span><span>4.2 STORM BREAKER</span><span class="dot">◆</span><span>4.3 DARK TERRITORY</span><span class="dot">◆</span><span>4.4 WELCOME TO NYX</span><span class="dot">◆</span><span>4.5 DAWN OF ENGINEERING</span><span class="dot">◆</span><span>4.6 LIFELINE FOR LEVSKI</span><span class="dot">◆</span><span>4.7 WELCOME TO THE ROCK</span><span class="dot">◆</span><span>4.8 TACTICAL STRIKE</span><span class="dot">◆</span>
    </div>
  </div>

</main>

<script is:inline src="/assets/detail.js"></script>
</Layout>
