import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../consts';

const patches = (await getCollection('patches')).sort((a, b) =>
  a.data.date.localeCompare(b.data.date)
);

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url.replace(/\/$/, '') + '/',
  inLanguage: 'de',
  description: SITE.defaultDescription,
  publisher: { '@type': 'Organization', name: SITE.name },
};
const latest = patches[patches.length - 1];
const patchCount = patches.length;
const topicCount = patches.reduce((n, p) => n + p.data.topics.length, 0);

// topic index: slug -> title/version/palette/desc (desc = its feature text)
const topicIndex = new Map<string, { slug: string; title: string; version: string; accent: string; desc: string }>();
for (const p of patches)
  for (const t of p.data.topics)
    topicIndex.set(t.slug, {
      slug: t.slug,
      title: t.title,
      version: p.data.version,
      accent: p.data.palette.accent,
      desc: p.data.features.find((f) => f.topicSlug === t.slug)?.desc ?? p.data.tagline,
    });

// curated key topics — spread across eras & palettes
const CURATED = [
  '4-0-0-server-meshing',
  '4-0-0-contested-zones',
  '4-3-1-medical-overhaul',
  '4-4-0-vanduul',
  '4-5-0-engineering',
  '4-7-0-crafting',
];
const keyTopics = CURATED.map((s) => topicIndex.get(s)).filter(Boolean);
const allTopics = [...topicIndex.values()];

// hub: one directory block per patch line (4.0.x, 4.1.x, …)
const lineOf = (v: string) => v.split('.').slice(0, 2).join('.');
const hubGroups: { line: string; accent: string; topics: typeof allTopics }[] = [];
for (const t of allTopics) {
  const line = lineOf(t.version);
  let g = hubGroups.find((x) => x.line === line);
  if (!g) {
    g = { line, accent: t.accent, topics: [] };
    hubGroups.push(g);
  }
  g.topics.push(t);
}
---
<Layout title={"Star Citizen Patch-Archiv · 4.0 → 4.8.2"} description={"Star Citizen Patches von Alpha 4.0.0 bis 4.8.2."} themeColor="#05070d" footer={true}>
<script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
<style is:inline>

:root{
  --bg:#05070d;--bg-2:#0a0e18;--surface:#0f1524;--surface-2:#141c30;
  --accent:#2dd4ff;--accent-2:#6ea8ff;--gold:#d4af37;
  --text:#e8eefc;--muted:#8a99b8;--line:rgba(110,168,255,.16);
  --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;
  --maxw:1240px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
::selection{background:var(--accent);color:#05070d}
:focus-visible{outline:2px solid var(--accent);outline-offset:3px}
.skip{position:absolute;left:-999px;top:0;z-index:200;background:var(--accent);color:#05070d;padding:.6rem 1rem;font-weight:700}
.skip:focus{left:0}

/* ===== Wild-Overlays ===== */
body::after{content:"";position:fixed;inset:0;z-index:9000;pointer-events:none;background:radial-gradient(130% 115% at 50% 40%,transparent 56%,rgba(0,0,0,.6) 100%),repeating-linear-gradient(0deg,rgba(0,0,0,.13) 0 1px,transparent 1px 3px);opacity:.5}
.cursorglow{position:fixed;inset:0;z-index:8800;pointer-events:none;background:radial-gradient(440px circle at var(--mx,50%) var(--my,25%),rgba(45,212,255,.12),transparent 60%)}
.marquee{position:relative;z-index:2;overflow:hidden;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:linear-gradient(90deg,var(--bg-2),var(--surface),var(--bg-2));padding:.8rem 0}
.marquee__track{display:flex;gap:2.4rem;white-space:nowrap;width:max-content;animation:scrollx 36s linear infinite;font-family:var(--font-display);font-weight:700;font-size:1rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent)}
.marquee__track .dot{color:var(--gold)}
@keyframes scrollx{to{transform:translateX(-50%)}}
@keyframes flick{0%,93%,100%{opacity:1}94%{opacity:.6}95%{opacity:1}97%{opacity:.82}}
.hero h1{animation:flick 8s steps(1) infinite}

/* HERO */
.hero{position:relative;min-height:88svh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:6rem 1.5rem 4rem;overflow:hidden}
#stars{position:absolute;inset:0;z-index:0}
.hero__glow{position:absolute;top:-30%;left:50%;transform:translateX(-50%);width:120vmax;height:90vmax;z-index:0;
  background:radial-gradient(ellipse at 50% 40%,rgba(45,212,255,.12),rgba(110,168,255,.05) 40%,transparent 70%)}
.hero__inner{position:relative;z-index:2;max-width:900px}
.kicker{font-family:var(--font-ui);font-weight:700;letter-spacing:.35em;text-transform:uppercase;font-size:.82rem;color:var(--accent)}
.hero h1{font-family:var(--font-display);font-weight:900;line-height:1;margin:1.2rem 0;font-size:clamp(2.6rem,8vw,6rem);
  background:linear-gradient(180deg,#fff,var(--accent-2) 70%,var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent}
.hero h1 small{display:block;font-size:clamp(1rem,3vw,1.8rem);letter-spacing:.1em;color:var(--text);-webkit-text-fill-color:var(--text);margin-top:.4rem;font-weight:700}
.hero p{max-width:60ch;margin:0 auto;color:var(--muted);font-size:clamp(1.05rem,1.6vw,1.25rem)}
.stat-row{display:flex;gap:2.5rem;justify-content:center;flex-wrap:wrap;margin-top:2.6rem}
.stat .n{font-family:var(--font-display);font-weight:900;font-size:clamp(1.6rem,4vw,2.4rem);color:var(--accent)}
.stat .l{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.14em;font-size:.72rem;color:var(--muted)}
.scrollcue{position:absolute;bottom:1.6rem;left:50%;transform:translateX(-50%);z-index:2;font-family:var(--font-ui);letter-spacing:.2em;text-transform:uppercase;font-size:.72rem;color:var(--muted);animation:bob 2s ease-in-out infinite}
@keyframes bob{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,8px)}}

/* TIMELINE / GRID */
main{position:relative;z-index:2;max-width:var(--maxw);margin:0 auto;padding:2rem clamp(1.25rem,5vw,3rem) 5rem}
.era{margin:3.5rem 0 1.4rem;display:flex;align-items:center;gap:1.2rem}
.era h2{font-family:var(--font-display);font-weight:700;font-size:clamp(1.1rem,2.6vw,1.5rem);letter-spacing:.04em;white-space:nowrap}
.era .yr{font-family:var(--font-ui);font-weight:700;letter-spacing:.12em;color:var(--accent);font-size:.85rem;border:1px solid var(--line);padding:.25rem .7rem;border-radius:2px}
.era .rule{flex:1;height:1px;background:linear-gradient(90deg,var(--line),transparent)}

.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:1.2rem}
.pcard{--c:var(--accent);position:relative;display:flex;flex-direction:column;
  background-color:var(--surface);
  background-image:linear-gradient(180deg,rgba(7,10,18,.80),rgba(7,10,18,.93)),var(--img,none);
  background-size:cover;background-position:center;
  border:1px solid var(--line);border-radius:6px;padding:1.6rem 1.5rem;overflow:hidden;min-height:200px;transition:transform .25s,border-color .25s,box-shadow .25s}
.pcard::before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--c);z-index:2}
.pcard::after{content:"";position:absolute;right:-40px;top:-40px;width:140px;height:140px;border-radius:50%;background:radial-gradient(circle,var(--c),transparent 70%);opacity:.16;transition:opacity .25s}
.pcard:hover{transform:translateY(-5px);border-color:var(--c);box-shadow:0 14px 40px -12px var(--c)}
.pcard:hover::after{opacity:.3}
.pcard>*{position:relative;z-index:1}
.pcard .ver{font-family:var(--font-display);font-weight:900;font-size:1.9rem;color:var(--c);letter-spacing:.01em;text-shadow:0 2px 12px rgba(0,0,0,.6)}
.pcard .date{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.14em;font-size:.72rem;color:var(--muted);margin-top:.2rem}
.pcard .name{font-family:var(--font-ui);font-weight:700;font-size:1.18rem;margin-top:.9rem;color:var(--text);text-shadow:0 1px 8px rgba(0,0,0,.7)}
.pcard .desc{color:var(--text);opacity:.82;font-size:.92rem;margin-top:.4rem;flex:1;text-shadow:0 1px 6px rgba(0,0,0,.7)}
.pcard .go{font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.75rem;color:var(--c);margin-top:1.1rem;display:inline-flex;gap:.4rem;align-items:center}
.pcard .go .ar{transition:transform .2s}
.pcard:hover .go .ar{transform:translateX(5px)}
.pcard .badge{position:absolute;top:1.2rem;right:1.3rem;z-index:2;font-family:var(--font-ui);font-weight:700;font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--c);border:1px solid var(--c);padding:.15rem .45rem;border-radius:2px;background:rgba(0,0,0,.45)}

footer{border-top:1px solid var(--line);padding:3rem clamp(1.25rem,5vw,3rem);text-align:center}
footer .disclaimer{max-width:80ch;margin:0 auto;font-size:.78rem;color:var(--muted);opacity:.75}
footer .credit{font-family:var(--font-ui);letter-spacing:.1em;text-transform:uppercase;font-size:.75rem;color:var(--muted);margin-bottom:1rem}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .6s ease,transform .6s ease}
.reveal.in{opacity:1;transform:none}
/* Hero-Rhythmus (REGISTRATUR): Erzählung oben, Archiv-Umfang unten */
.vp{max-width:60ch;margin:.8rem auto 0;color:var(--text);font-weight:500;font-size:clamp(1.15rem,2vw,1.3rem)}
.hero-rule{width:min(560px,80%);height:1px;background:var(--line);margin:1.6rem auto}
.hero-lower{display:flex;flex-direction:column;align-items:center;gap:1.4rem}
@media(min-width:768px){.hero-lower{flex-direction:row;justify-content:center;align-items:center;gap:3rem}}
.fresh{display:inline-flex;align-items:center;gap:.7rem;padding:.55rem 1rem;border:1px solid var(--accent);background:color-mix(in srgb,var(--accent) 8%,transparent);font-family:var(--font-ui);font-weight:600;font-size:1rem;color:var(--text);transition:background-color .15s}
.fresh:hover{background:color-mix(in srgb,var(--accent) 14%,transparent)}
.fresh__dot{width:7px;height:7px;border-radius:50%;background:var(--accent);flex:none}
.fresh__tag{font-family:var(--font-ui);font-weight:800;font-size:0.78rem;letter-spacing:.18em;text-transform:uppercase;background:var(--accent);color:var(--bg);padding:.16rem .5rem;flex:none}
.fresh__txt{text-align:left;max-width:44ch}
.stat-row{margin-top:0;border-top:2px solid var(--accent);border-bottom:1px solid var(--line);padding:1.2rem 1.6rem;gap:2.5rem}
.stat .n{font-size:clamp(1.8rem,3.5vw,2.4rem);font-variant-numeric:tabular-nums}
.stat .l{font-weight:700;letter-spacing:.16em;font-size:0.78rem}

/* Schlüsselthemen — kuratiertes Inhaltsverzeichnis, keine Karten-Wand */
.ktgrid{display:grid;grid-template-columns:1fr;gap:.9rem}
@media(min-width:768px){.ktgrid{grid-template-columns:1fr 1fr;gap:.9rem 1.4rem}}
.ktcard{--c:var(--accent);display:grid;grid-template-columns:2.2rem 1fr;gap:0 .9rem;padding:1.1rem 1.3rem;background:var(--surface);border:1px solid var(--line);border-left:3px solid var(--c);transition:background-color .15s,border-color .15s}
.ktcard:hover{background:color-mix(in srgb,var(--c) 6%,transparent);border-color:color-mix(in srgb,var(--c) 55%,transparent);border-left-color:var(--c)}
.ktnum{font-family:var(--font-display);font-weight:700;font-size:0.88rem;color:color-mix(in srgb,var(--c) 70%,transparent);padding-top:.3rem}
.ktbody{display:flex;flex-direction:column;gap:.1rem;min-width:0}
.ktcard b{font-family:var(--font-ui);font-weight:700;font-size:1.25rem;color:var(--text)}
.ktbadge{font-family:var(--font-ui);font-weight:700;font-size:0.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.ktcard p{color:var(--muted);font-size:1rem;line-height:1.5;margin-top:.3rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}

/* Themen-Hub — Registratur-Verzeichnis statt Karten-Wand */
.hub{display:flex;flex-direction:column;gap:1.2rem}
.hubgroup{border:1px solid var(--line);padding:1rem 1.3rem}
.hubhead{display:flex;align-items:center;gap:.6rem;border-bottom:1px solid var(--line);padding-bottom:.5rem;margin-bottom:.6rem}
.hubsw{width:8px;height:8px;flex:none}
.hubline{font-family:var(--font-ui);font-weight:700;font-size:0.78rem;letter-spacing:.16em;text-transform:uppercase;color:var(--text)}
.hubn{font-family:var(--font-ui);font-weight:700;font-size:0.78rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
.hubrows{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0 1.5rem}
.hubrows a{display:flex;justify-content:space-between;align-items:baseline;gap:.8rem;padding:.4rem .3rem;border-bottom:1px solid rgba(255,255,255,.08);transition:background-color .15s,color .15s}
.hubrows a:hover{color:var(--accent);background:color-mix(in srgb,var(--accent) 5%,transparent)}
.hubrows .ht{font-weight:500;font-size:1rem}
.hubrows .hv{font-family:var(--font-ui);font-weight:700;font-size:0.78rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}

@media (prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none}*{animation:none!important}}

</style>
