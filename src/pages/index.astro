---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import { getCollection } from 'astro:content';
import { mergePatchEn } from '../i18n/patchText';

const patches = (await getCollection('patches')).sort((a, b) => a.data.date.localeCompare(b.data.date)).map((p) => ({ ...p, data: mergePatchEn(p.id, p.data, 'en') }));

const latest = patches[patches.length - 1];

// Hero still image: cinematic wide render (ship, station, planet)
const HERO_IMG = '/assets/t-polaris-5.jpg';

// Tools as image tiles (bento). No text ballast, no number soup — each tile
// just a name + short label, the image carries the visual weight.
const tools = [
  { name: 'Item Finder', href: '/item-finder.html', sub: 'Prices & locations', img: '/assets/cz-loot.jpg', size: 'xl' },
  { name: 'Missions', href: '/missionen.html', sub: 'Rewards & reputation', img: '/assets/t-tsg-4.jpg', size: 'w' },
  { name: 'Mining', href: '/topics/mining.html', sub: 'Minerals & calculators', img: '/assets/t-align-1.jpg', size: 'w' },
  { name: 'Crafting', href: '/topics/crafting.html', sub: 'Blueprints & planner', img: '/assets/t-craft-1.jpg', size: 't' },
  { name: "Wikelo's Emporium", href: '/topics/wikelo-emporium.html', sub: 'Banu trades', img: '/assets/img-railen.jpg', size: 't' },
  { name: 'Ships', href: '/schiffe.html', sub: 'Data sheets & specs', img: '/assets/t-hangar-1.jpg', size: 't' },
  { name: 'Evolution', href: '/evolution.html', sub: 'Systems × patches', img: '/assets/t-mesh-1.jpg', size: 't' },
];
---
<Layout title={"VerseBase — the Star Citizen compendium"} description={"VerseBase — the unofficial Star Citizen compendium: item finder with prices & locations, mining tools, crafting database, Wikelo trades, ship database and the complete patch archive of the Alpha 4 era. Game-accurate, bilingual."} themeColor="#04060c" footer={true} translated={true}>
<style is:inline>
  :root{
    --bg:#04060c;--bg-2:#080d18;--surface:#0e1626;
    --accent:#2dd4ff;--text:#eef3fb;--muted:#8ea0be;
    --line:rgba(150,180,220,.14);--line-2:rgba(150,180,220,.26);
    --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;
    --maxw:1280px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--text);font-family:var(--font-body);line-height:1.6;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--accent);color:#04060c}
  :focus-visible{outline:2px solid var(--accent);outline-offset:3px}
  .skip{position:absolute;left:-999px;top:0;z-index:200;background:var(--accent);color:#04060c;padding:.6rem 1rem;font-weight:700}
  .skip:focus{left:0}

  /* ========== HERO ========== */
  .hero{position:relative;min-height:94svh;display:flex;align-items:flex-end;overflow:hidden;isolation:isolate}
  .hero__img{position:absolute;inset:0;z-index:-2;background:#04060c center right/cover no-repeat;
    background-image:var(--hero);transform:scale(1.06);animation:kenburns 34s ease-in-out infinite alternate}
  @keyframes kenburns{from{transform:scale(1.06)}to{transform:scale(1.15) translate3d(-1.5%,-1%,0)}}
  .hero__scrim{position:absolute;inset:0;z-index:-1;background:
    linear-gradient(90deg,rgba(4,6,12,.92) 0%,rgba(4,6,12,.6) 40%,rgba(4,6,12,.08) 78%,transparent 100%),
    linear-gradient(0deg,var(--bg) 1%,rgba(4,6,12,.4) 24%,transparent 58%)}
  .hero__inner{position:relative;width:100%;max-width:var(--maxw);margin:0 auto;padding:9rem clamp(1.25rem,5vw,3.5rem) clamp(3.5rem,8vw,6rem)}
  .hero__kicker{display:inline-flex;align-items:center;gap:.7rem;font-family:var(--font-ui);font-weight:700;
    letter-spacing:.3em;text-transform:uppercase;font-size:.74rem;color:var(--accent)}
  .hero__kicker::before{content:"";width:28px;height:1px;background:var(--accent)}
  .hero h1{font-family:var(--font-display);font-weight:900;line-height:.92;margin:1.1rem 0 .5rem;
    font-size:clamp(2.9rem,12vw,8.5rem);letter-spacing:-.02em;
    background:linear-gradient(180deg,#fff 52%,#c4dae6);-webkit-background-clip:text;background-clip:text;color:transparent;
    text-shadow:0 10px 60px rgba(4,6,12,.5)}
  .hero__lede{max-width:40ch;color:#d3ddef;font-size:clamp(1.05rem,1.8vw,1.3rem);font-weight:500;
    text-shadow:0 2px 22px rgba(4,6,12,.85)}
  .hero__search{display:flex;align-items:center;gap:.8rem;width:100%;max-width:520px;margin:1.9rem 0 0;
    padding:.95rem 1.15rem;background:rgba(6,10,20,.68);border:1px solid var(--line-2);border-radius:9px;
    color:var(--muted);font-family:var(--font-ui);font-size:1rem;cursor:pointer;text-align:left;
    backdrop-filter:blur(8px);transition:border-color .2s,box-shadow .2s,background-color .2s}
  .hero__search:hover,.hero__search:focus-visible{border-color:var(--accent);background:rgba(6,10,20,.82);
    box-shadow:0 0 30px rgba(45,212,255,.2);outline:none}
  .hero__search .p{color:var(--accent);font-weight:800;flex:none}
  .hero__search .h{flex:1;min-width:0;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
  .hero__search .k{display:flex;gap:.3rem;flex:none}
  .hero__search kbd{font-family:var(--font-ui);font-size:.7rem;font-weight:700;letter-spacing:.06em;color:var(--muted);
    border:1px solid var(--line-2);border-bottom-width:2px;border-radius:4px;padding:.1rem .42rem;background:rgba(255,255,255,.05)}
  .hero__cue{position:absolute;bottom:1.3rem;left:50%;transform:translateX(-50%);z-index:1;
    font-family:var(--font-ui);letter-spacing:.24em;text-transform:uppercase;font-size:.66rem;color:var(--muted);
    animation:bob 2.2s ease-in-out infinite}
  @keyframes bob{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,7px)}}

  /* ========== Layout ========== */
  main{position:relative;z-index:1;max-width:var(--maxw);margin:0 auto;padding:0 clamp(1.25rem,5vw,3.5rem)}
  .sec{margin:clamp(3.5rem,7vw,6rem) 0 0}
  .sec__head{display:flex;align-items:center;gap:1.1rem;margin-bottom:1.5rem}
  .sec__head h2{font-family:var(--font-display);font-weight:800;font-size:clamp(1.15rem,2.6vw,1.6rem);letter-spacing:.02em;white-space:nowrap}
  .sec__head .rule{flex:1;height:1px;background:linear-gradient(90deg,var(--line-2),transparent)}

  /* ========== Tools — bento of image tiles ========== */
  .tools{display:grid;gap:.85rem;grid-template-columns:1fr}
  .tool{position:relative;display:flex;flex-direction:column;justify-content:flex-end;isolation:isolate;
    min-height:210px;padding:1.4rem 1.5rem;border-radius:14px;overflow:hidden;border:1px solid var(--line);
    background:#0a0e18;color:#fff;transition:border-color .3s,box-shadow .3s,transform .3s cubic-bezier(.2,.7,.3,1)}
  .tool::before{content:"";position:absolute;inset:0;z-index:-2;background:var(--img) center/cover no-repeat;
    filter:saturate(.8) brightness(.66);transform:scale(1.03);transition:transform .7s ease,filter .7s ease}
  .tool::after{content:"";position:absolute;inset:0;z-index:-1;
    background:linear-gradient(to top,rgba(4,6,12,.95) 4%,rgba(4,6,12,.55) 42%,rgba(4,6,12,.1) 100%)}
  .tool:hover,.tool:focus-visible{transform:translateY(-4px);border-color:var(--accent);
    box-shadow:0 22px 50px -24px rgba(0,0,0,.9);outline:none}
  .tool:hover::before,.tool:focus-visible::before{transform:scale(1.09);filter:saturate(1.02) brightness(.82)}
  .tool__name{font-family:var(--font-display);font-weight:800;font-size:1.45rem;line-height:1.04;letter-spacing:.01em;
    text-shadow:0 2px 18px rgba(4,6,12,.85)}
  .tool__sub{margin-top:.3rem;font-family:var(--font-ui);font-weight:600;letter-spacing:.04em;color:#c6d4ec;font-size:.9rem}
  .tool__arrow{position:absolute;top:1.15rem;right:1.25rem;width:38px;height:38px;display:grid;place-items:center;
    border:1px solid rgba(255,255,255,.28);border-radius:50%;font-size:1.05rem;color:#fff;line-height:1;
    background:rgba(4,6,12,.28);backdrop-filter:blur(4px);opacity:.85;transition:.25s}
  .tool:hover .tool__arrow,.tool:focus-visible .tool__arrow{background:var(--accent);color:#04060c;
    border-color:var(--accent);opacity:1;transform:translate(2px,-2px)}
  .tool--xl .tool__name{font-size:clamp(1.9rem,4vw,2.7rem)}
  .tool--xl .tool__sub{font-size:1rem}
  @media(min-width:600px){
    .tools{grid-template-columns:1fr 1fr}
    .tool--xl{grid-column:1 / -1}
  }
  @media(min-width:980px){
    .tools{grid-template-columns:repeat(6,1fr);grid-auto-rows:230px}
    .tool--xl{grid-column:span 3;grid-row:span 2}
    .tool--w{grid-column:span 3}
    .tool--t{grid-column:span 2}
  }

  /* ========== Latest patch ========== */
  .fresh{position:relative;display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--line);
    border-radius:14px;overflow:hidden;background:var(--surface)}
  .fresh__body{padding:clamp(1.5rem,3vw,2.4rem);display:flex;flex-direction:column;gap:.5rem;min-width:0}
  .fresh__ey{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--font-ui);font-weight:800;
    letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent)}
  .fresh__dot{width:8px;height:8px;border-radius:50%;background:var(--accent);box-shadow:0 0 12px var(--accent);flex:none}
  .fresh__ver{font-family:var(--font-display);font-weight:900;font-size:clamp(2rem,5vw,3.1rem);line-height:1;margin-top:.2rem}
  .fresh__name{font-family:var(--font-ui);font-weight:700;font-size:1.2rem;color:var(--text)}
  .fresh__go{align-self:flex-start;margin-top:.8rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;
    text-transform:uppercase;font-size:.78rem;color:#04060c;background:var(--accent);padding:.6rem 1.15rem;border-radius:7px;
    display:inline-flex;gap:.5rem;align-items:center;transition:filter .18s,transform .18s}
  .fresh__go:hover{filter:brightness(1.08);transform:translateX(2px)}
  .fresh__media{position:relative;background:#04060c center/cover no-repeat;min-height:180px}
  .fresh__media::after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,var(--surface),transparent 42%)}

  .reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
  .reveal.in{opacity:1;transform:none}

  @media(max-width:820px){
    .fresh{grid-template-columns:1fr}
    .fresh__media{min-height:160px;order:-1}
    .fresh__media::after{background:linear-gradient(0deg,var(--surface),transparent 55%)}
  }
  @media(max-width:520px){.hero__inner{padding-top:7.5rem}}
  @media(max-width:360px){.hero h1{font-size:2.5rem}}
  @media (prefers-reduced-motion:reduce){
    .reveal{opacity:1;transform:none}
    .hero__img{animation:none}
    *{animation:none!important;scroll-behavior:auto!important}
  }
</style>

<a class="skip" href="#tools">Skip to tools</a>

<SiteNav />

<header class="hero">
  <div class="hero__img" style={`--hero:url('${HERO_IMG}')`} aria-hidden="true"></div>
  <div class="hero__scrim" aria-hidden="true"></div>
  <div class="hero__inner">
    <span class="hero__kicker">Star Citizen compendium</span>
    <h1>VerseBase</h1>
    <p class="hero__lede">Game-accurate tools, data and the patch archive of the Alpha 4 era.</p>
    <button class="hero__search" type="button" data-scs-open aria-label="Open search">
      <span class="p" aria-hidden="true">&gt;_</span>
      <span class="h">Search items, ships, patches…</span>
      <span class="k" aria-hidden="true"><kbd>Ctrl</kbd><kbd>K</kbd></span>
    </button>
  </div>
  <div class="hero__cue" aria-hidden="true">Tools ↓</div>
</header>

<main>
  <!-- TOOLS — image bento -->
  <section class="sec" id="tools">
    <div class="sec__head"><h2>Tools</h2><span class="rule"></span></div>
    <div class="tools">
      {tools.map((t) => (
        <a class={`tool tool--${t.size}`} style={`--img:url('${t.img}')`} href={t.href}>
          <span class="tool__arrow" aria-hidden="true">→</span>
          <span class="tool__name">{t.name}</span>
          <span class="tool__sub">{t.sub}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- LATEST -->
  <section class="sec reveal">
    <div class="sec__head"><h2>Latest</h2><span class="rule"></span></div>
    <a class="fresh" href={`/patches/sc-${latest.id}.html`}>
      <div class="fresh__body">
        <span class="fresh__ey"><span class="fresh__dot" aria-hidden="true"></span>Live · {latest.data.dateDisplay}</span>
        <span class="fresh__ver">Alpha {latest.data.version}</span>
        <span class="fresh__name">{latest.data.codename ?? latest.data.tagline}</span>
        <span class="fresh__go">Open patch <span aria-hidden="true">→</span></span>
      </div>
      <div class="fresh__media" style={`background-image:url('${latest.data.heroImage ?? `/assets/trailer-${latest.id}.jpg`}')`} aria-hidden="true"></div>
    </a>
  </section>
</main>

<script is:inline>
  const io = new IntersectionObserver((es) => es.forEach((e) => {
    if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
  }), { threshold: .08 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
</Layout>
