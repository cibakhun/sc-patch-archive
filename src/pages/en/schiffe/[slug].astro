---
// Ship data sheet (EN) — /en/schiffe/<slug>.html
// Stufe-1-Beweis des datengetriebenen Hebels: dieselbe geteilte Ansicht
// (ShipDetail) wie DE, nur lang="en". getStaticPaths baut vorerst NUR die in
// I18N_EN_SHIPS gelisteten Fahrzeuge (Stufe 2 öffnet das auf alle 226).
import { getCollection } from 'astro:content';
import ShipDetail from '../../../components/ShipDetail.astro';
import { buildVisuals } from '../../../lib/shipVisuals';
import { buildProfile, similarShips } from '../../../lib/shipExtras';
import { I18N_EN_SHIPS } from '../../../consts';

export async function getStaticPaths() {
  const vs = await getCollection('vehicles');
  return vs
    .filter((v) => I18N_EN_SHIPS.includes(v.id))
    .map((v) => ({
      params: { slug: v.id },
      props: {
        d: v.data,
        id: v.id,
        similar: similarShips(vs, v),
        profile: buildProfile(vs, v.data),
        viz: buildVisuals(vs, v.data),
      },
    }));
}

const { d, id, similar, profile, viz } = Astro.props;
---
<ShipDetail d={d} id={id} similar={similar} profile={profile} viz={viz} lang="en" hasEn={true} />
