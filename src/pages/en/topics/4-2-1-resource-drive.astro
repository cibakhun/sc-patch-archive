---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import TopicFacts from '../../../components/TopicFacts.astro';
import RelatedTopics from '../../../components/RelatedTopics.astro';
import Attribution from '../../../components/Attribution.astro';
---
<Layout title={"Resource Drive — Star Citizen 4.2.1 | VerseBase"} description={"Resource Drive: the Verse's first true global event. Imperator Addison calls Stanton's four megacorporations to compete — progress converges across all shards. Introduced with Alpha 4.2.1."} themeColor="#0e1620" ogType="article" ogImage="/assets/t-rd-1.jpg" translated={true}>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Resource-Drive-Theme (4.2.1) — Second Life green / Addison gold */
:root{
  --bg:#0e1620;--bg-2:#16202e;--surface:#1b2838;--surface-2:#22344a;
  --accent:#2E8B57;--accent-2:#E6952A;--hot:#D94A38;
  --text:#eaf1ee;--muted:#9db1b2;
  --line:rgba(46,139,87,.22);--line-soft:rgba(234,241,238,.10);
  --glow:0 0 44px rgba(46,139,87,.30);--ink:#0e1620;
  --maxw:1180px;
}
/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10.5rem)}
.lede-kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}
.corp-strip{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:0;border-block:1px solid var(--line);background:linear-gradient(90deg,var(--bg-2),var(--surface),var(--bg-2))}
.corp-strip .cc{padding:clamp(1.4rem,3vw,2.2rem) 1.2rem;text-align:center;border-right:1px solid var(--line-soft)}
.corp-strip .cc:last-child{border-right:0}
.corp-strip .nm{font-family:var(--font-display);font-weight:900;font-size:clamp(1rem,2vw,1.45rem);color:var(--accent);line-height:1}
.corp-strip .pl{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.14em;font-size:.68rem;color:var(--muted);margin-top:.5rem}

</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/en.html' }, { label: 'Alpha 4.2.1', href: '/en/patches/sc-4-2-1.html' }, { label: "Resource Drive" }]} pill={"EVENT · ALPHA 4.2.1"} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-rd-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/en/patches/sc-4-2-1.html">Alpha 4.2.1 · Second Life</a> &nbsp;·&nbsp; Global Event</div>
      <h1><span class="thin">The first global event</span>Resource Drive</h1>
      <p class="lead">Imperator Addison calls Stanton's four megacorporations to compete: whoever delivers the most material wins the research contract. The first event whose progress converges across all shards.</p>
      <div class="tags"><span class="tag hot">Global Event</span><span class="tag">4 Megacorporations</span><span class="tag">Hauling</span><span class="tag">Convoy</span><span class="tag">Event Tracking</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>RESOURCE DRIVE</span><span class="dot">◆</span><span>HURSTON</span><span class="dot">◆</span><span>CRUSADER</span><span class="dot">◆</span><span>ARCCORP</span><span class="dot">◆</span><span>MICROTECH</span><span class="dot">◆</span><span>GLOBAL EVENT</span><span class="dot">◆</span>
      <span>RESOURCE DRIVE</span><span class="dot">◆</span><span>HURSTON</span><span class="dot">◆</span><span>CRUSADER</span><span class="dot">◆</span><span>ARCCORP</span><span class="dot">◆</span><span>MICROTECH</span><span class="dot">◆</span><span>GLOBAL EVENT</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-2-1-resource-drive" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="4">0</div><div class="c">Competing megacorporations</div></div>
    <div class="s"><div class="n count" data-to="337">0</div><div class="c">Million SCU · winner's delivery total</div></div>
    <div class="s"><div class="n count" data-to="5">0</div><div class="c">Reward tiers</div></div>
    <div class="s"><div class="n">Cross-shard</div><div class="c">First global event tracking</div></div>
  </div>

  <!-- FULL-BLEED BAND (parallax) — the premise -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/cz-ruin.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">Imperator Addison's call</div>
      <div class="big outline">ONE VERSE.<br>ONE GOAL.</div>
      <p>The Second Life Resource Drive is the Verse's first true global event: Imperator Addison calls Stanton's four megacorporations — <b style="color:var(--accent-2)">Hurston Dynamics, Crusader Industries, ArcCorp and microTech</b> — to gather research material. Every pilot picks a side.</p>
    </div>
  </section>

  <!-- CORP STRIP — the four contenders -->
  <div class="corp-strip reveal">
    <div class="cc"><div class="nm">Hurston Dynamics</div><div class="pl">Weapons · Hurston</div></div>
    <div class="cc"><div class="nm">Crusader Industries</div><div class="pl">Spaceflight · Crusader</div></div>
    <div class="cc"><div class="nm">ArcCorp</div><div class="pl">Energy · ArcCorp</div></div>
    <div class="cc"><div class="nm">microTech</div><div class="pl">Technology · microTech</div></div>
  </div>

  <!-- MANIFESTO pull-quote -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Whoever <span class="hl">delivers</span> the most wins the research contract.</blockquote>
    <cite>Resource Drive · Second Life</cite>
  </section>

  <!-- ROLLEN — Versus trägt den Loop allein. Bewusst KEIN Scrollytelling:
       die vier alten Schritte duplizierten Corp-Strip und Versus 1:1. -->
  <section style="padding:0">
    <div class="wrap" style="padding:clamp(3rem,7vw,5.5rem) clamp(1.25rem,5vw,4rem) 0">
      <div class="sec-head reveal"><span class="num">01</span><h2>How to support your corporation</h2><span class="rule"></span></div>
    </div>
    <div class="versus reveal">
      <div class="side a">
        <h3>⚙ Deliver &amp; Salvage</h3>
        <ul>
          <li>Haul cargo from the mining bases to the collection point.</li>
          <li>Recover lost freight through reclaim missions.</li>
          <li>Every SCU counts directly toward the corporation total.</li>
          <li>Routes run through Stanton and Pyro.</li>
        </ul>
      </div>
      <div class="vs">&amp;</div>
      <div class="side b">
        <h3>★ Protect &amp; Escort</h3>
        <ul>
          <li>Escort your corporation's convoys along the delivery routes.</li>
          <li>Defend transports against attackers and raiders.</li>
          <li>Safe passage keeps the flow of material moving.</li>
          <li>Without an escort the freight never reaches the collection point.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SPLIT — the single framed section: Global Event Tracking Service -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-rd-2.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">02 · mobiGlas journal</div>
        <h3>A first: the Global Event Tracking Service</h3>
        <p>Resource Drive is the <b>first activity to use the new Global Event Tracking Service</b>. A unified status page in the mobiGlas journal consolidates progress across multiple shards.</p>
        <p>Instead of isolated server instances, all players see the same converging standings — and, for the first time, who leads across the entire Verse.</p>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND — the winner -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-hh-3.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">03 · The result</div>
      <div class="big" style="font-size:clamp(2.4rem,9vw,6.5rem)">HURSTON WINS</div>
      <p>Hurston Dynamics claimed the research contract with roughly <b style="color:var(--accent-2)">337 million SCU</b> in total deliveries. The corporation with the highest total at the end wins — and Hurston was ahead.</p>
    </div>
  </section>

  <!-- BAND — the reward -->
  <section class="band band--center">
    <div class="bbg" data-par="0.13" style="background-image:url('/assets/cz-loot.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal" style="text-align:center;margin-inline:auto">
      <div class="kx" style="text-align:center">Tier 5 reward</div>
      <div class="big outline" style="font-size:clamp(2rem,7vw,5rem)">STRATA HURSTON BLACK</div>
      <p style="margin-inline:auto">The highest reward tier delivered an exclusive <b style="color:var(--accent-2)">Strata Hurston Black armor</b> — plus a permanent 5% discount for everyone who carried their corporation to victory.</p>
    </div>
  </section>

  <!-- CLOSING GALLERY (mixed, full-bleed lead tile) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">04</span><h2>Gallery</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-rd-1.jpg"><img src="/assets/t-rd-1.jpg" alt="Resource Drive — hauling run" loading="lazy"><span class="zoomic">⤢</span><figcaption>Hauling run for the corporation</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-rd-2.jpg"><img src="/assets/t-rd-2.jpg" alt="RSI ship in combat in the asteroid field" loading="lazy"><span class="zoomic">⤢</span><figcaption>Escort combat · asteroid field</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-meteor.jpg"><img src="/assets/img-meteor.jpg" alt="RSI Meteor — the patch's new ship" loading="lazy"><span class="zoomic">⤢</span><figcaption>RSI Meteor</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/cz-ruin.jpg"><img src="/assets/cz-ruin.jpg" alt="Destroyed station ruin in orbit" loading="lazy"><span class="zoomic">⤢</span><figcaption>Station ruin · orbit</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/img-hammerhead.jpg"><img src="/assets/img-hammerhead.jpg" alt="Aegis Hammerhead as convoy escort" loading="lazy"><span class="zoomic">⤢</span><figcaption>Convoy escort</figcaption></figure>
      </div>
      <p class="src reveal">Source: Star Citizen Wiki &amp; official community sources (© Cloud Imperium Games). Fan content use.</p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-2-1-resource-drive" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
