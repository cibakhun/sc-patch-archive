---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import TopicFacts from '../../../components/TopicFacts.astro';
import RelatedTopics from '../../../components/RelatedTopics.astro';
import Attribution from '../../../components/Attribution.astro';
---
<Layout title={"Medical Overhaul — Star Citizen 4.3.1 | SC Patch Archive"} description={"Medical Overhaul: Alpha 4.3.1 rebuilds the medical system — wounds, healing, rescue and revival reimagined, led by the RSI Apollo and the MedGel system."} themeColor="#0f2336" ogType="article" ogImage="/assets/t-med-1.jpg" translated={true}>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Medical-Theme (4.3.1 "Virtue's Descent") */
:root{--bg:#0f2336;--bg-2:#13304a;--surface:#19395a;--surface-2:#21466b;--accent:#1FAA8C;--accent-2:#9bdfce;--hot:#D7263D;--text:#F2F5F7;--muted:#a9c0d4;--line:rgba(31,170,140,.22);--line-soft:rgba(242,245,247,.10);--glow:0 0 44px rgba(31,170,140,.30);--ink:#0f2336;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.vitals{font-family:var(--font-ui);font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--accent-2);font-size:.74rem}

</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/en/index.html' }, { label: 'Alpha 4.3.1', href: '/en/patches/sc-4-3-1.html' }, { label: "Medical Overhaul" }]} pill={"FEATURE · ALPHA 4.3.1"} hasEn={true} />


<main id="main">

  <!-- HERO (full-bleed lead media) -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-med-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/en/patches/sc-4-3-1.html">Alpha 4.3.1 · Virtue's Descent</a> &nbsp;·&nbsp; Feature</div>
      <h1><span class="thin">Healing, reimagined</span>Medical Overhaul</h1>
      <p class="lead">4.3.1 rebuilds the medical system: wounds, healing, rescue and revival work in new ways — led by the RSI Apollo and the MedGel system.</p>
      <div class="tags"><span class="tag">Medical</span><span class="tag">MedGel</span><span class="tag">Bed tiers</span><span class="tag">RSI Apollo</span><span class="tag">Site B</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>MEDICAL OVERHAUL</span><span class="dot">◆</span><span>MEDGEL</span><span class="dot">◆</span><span>BED TIERS T1-T3</span><span class="dot">◆</span><span>RSI APOLLO</span><span class="dot">◆</span><span>SITE B</span><span class="dot">◆</span><span>REVIVAL</span><span class="dot">◆</span>
      <span>MEDICAL OVERHAUL</span><span class="dot">◆</span><span>MEDGEL</span><span class="dot">◆</span><span>BED TIERS T1-T3</span><span class="dot">◆</span><span>RSI APOLLO</span><span class="dot">◆</span><span>SITE B</span><span class="dot">◆</span><span>REVIVAL</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-3-1-medical-overhaul" />

  <!-- FULL-BLEED BAND — opening statement over the medbay (parallax) -->
  <section class="band band--center">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/img-apollo.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">A system rebuilt from the ground up</div>
      <div class="big outline">VITALS.</div>
      <p>Alpha 4.3.1 fundamentally reworks the medical system — how wounds occur and heal and how players are rescued and revived. What was once a side topic becomes a loop of its own.</p>
    </div>
  </section>

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Bed tiers · T1 to T3</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Ship of the hour · RSI Apollo</div></div>
    <div class="s"><div class="n">MedGel</div><div class="c">Consumable for the beds</div></div>
    <div class="s"><div class="n">Site B</div><div class="c">Onyx story · Dr. Jorrit's lab</div></div>
  </div>

  <!-- SCROLLYTELLING — die neue Versorgungs-Schleife (full-bleed, process fits) -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">01</span><h2>The new care loop</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-med-3.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-med-4.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-med-5.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-med-6.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Wounding</h3><p>Wounds now follow new rules — the first building block of the reworked medical system determines how a player takes damage in the first place.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>MedGel supply</h3><p>Medical beds draw MedGel charges for their functions. MedGel is a consumable — when it runs out, the bed goes idle.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Bed tiers T1-T3</h3><p>Beds range from T1 to T3 with adjusted respawn distances — T1 for instance the hospital in New Babbage with premium care, T3 for instance the Cutlass Red.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Revival</h3><p>Rescue and revival work in new ways — the final step of the loop decides where and how a player returns to the 'verse.</p></div>
    </div>
  </div>

  <!-- SPLIT — RSI Apollo (the ONE framed/split section) -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/img-apollo2.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">02 · The ship of the hour</div>
        <h3>RSI Apollo — Medivac &amp; Triage</h3>
        <p>With the medical rework, the <b>RSI Apollo</b> moves to center stage: a dedicated medical ship in two variants — <b>Medivac</b> for retrieval, <b>Triage</b> for care.</p>
        <p>Its medical beds gain <b>regeneration capabilities</b> and turn the Apollo into a flying base for teams operating deep in the 'verse — where the nearest hospital is far away.</p>
      </div>
    </div>
  </section>

  <!-- VERSUS — die zwei Ausrichtungen des Apollo (full-bleed dual pane) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>✚ Medivac</h3>
        <ul>
          <li>Built to retrieve the wounded from the field.</li>
          <li>Brings fallen players to where they can be treated.</li>
          <li>One of two medical RSI Apollo variants.</li>
          <li>Strength: quickly recover the wounded from the field.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>✚ Triage</h3>
        <ul>
          <li>Built for on-board care.</li>
          <li>Medical beds with regeneration capabilities.</li>
          <li>Flying base for ongoing operations.</li>
          <li>Full care on board — no flight back to the hospital.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND — Bett-Stufen (parallax, big overlaid text) -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-med-2.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">03 · Bed tiers</div>
      <div class="big" style="font-size:clamp(2.4rem,8vw,6rem)">T1 → T3</div>
      <p>Medical beds have tiers from <b style="color:var(--accent-2)">T1 to T3</b> with adjusted respawn distances. <b style="color:var(--accent-2)">T1</b> stands for instance for the hospital in New Babbage with premium care, <b style="color:var(--accent-2)">T3</b> for instance for the Cutlass Red — the higher the tier, the closer the return.</p>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Who rescues you decides <span class="hl">where you wake up again.</span></blockquote>
    <cite>Medical Overhaul · Alpha 4.3.1</cite>
  </section>

  <!-- FULL-BLEED BAND — Site B / Onyx-Story (parallax) -->
  <section class="band">
    <div class="bbg" data-par="0.13" style="background-image:url('/assets/trailer-4-3-1.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · The Onyx story continues</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">SITE B</div>
      <p>The Onyx story continues with <b style="color:var(--accent-2)">Site B</b>: <b style="color:var(--accent-2)">Dr. Jorrit's lab</b>, where players recover biological samples — another layer to explore, tightly woven into the patch's medical theme.</p>
    </div>
  </section>

  <!-- MEDIA (mixed gallery — full-bleed close, no video embed) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">05</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/vid-apollo.jpg"><img src="/assets/vid-apollo.jpg" alt="RSI Apollo — medical bay" loading="lazy"><span class="zoomic">⤢</span><figcaption>RSI Apollo · Medical bay</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-med-1.jpg"><img src="/assets/t-med-1.jpg" alt="Medical care" loading="lazy"><span class="zoomic">⤢</span><figcaption>Care · Medical Overhaul</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-med-2.jpg"><img src="/assets/t-med-2.jpg" alt="Medical bed" loading="lazy"><span class="zoomic">⤢</span><figcaption>Medical bed · Bed tiers</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-apollo.jpg"><img src="/assets/img-apollo.jpg" alt="RSI Apollo in flight" loading="lazy"><span class="zoomic">⤢</span><figcaption>RSI Apollo</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/img-apollo2.jpg"><img src="/assets/img-apollo2.jpg" alt="RSI Apollo — Triage" loading="lazy"><span class="zoomic">⤢</span><figcaption>Apollo · Triage</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/trailer-4-3-1.jpg"><img src="/assets/trailer-4-3-1.jpg" alt="Virtue's Descent — Site B" loading="lazy"><span class="zoomic">⤢</span><figcaption>Site B · Onyx story</figcaption></figure>
      </div>
      <p class="src reveal">Source: official Star Citizen channel &amp; Star Citizen Wiki (© Cloud Imperium Games). Images for illustration, fan-content use.</p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-3-1-medical-overhaul" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
