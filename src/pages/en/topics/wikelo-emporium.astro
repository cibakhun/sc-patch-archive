  { cat:'capital', name:'A2 Hercules Starlifter', favor:50, mats:['20× Polaris Bit','20× MG Scrip','6× ASD Secure Drive','6× Valakkar Pearl (AAA)','6× Tevarin War Service Marker (Pristine)','6× DCHS-05 Comp-Board','6× Carinite (Pure)'], c:'solid' },

