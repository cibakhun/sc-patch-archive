---
<Layout title={"Wikelo's Emporium — Star Citizen 4.1 | SC Patch Archive"} description={"Wikelo's Emporium: the Banu trader Wikelo — the first playable alien NPC in Star Citizen. Barter instead of money: deliver items, earn Wikelo Favor, trade for rewards from his stock. Three asteroid stations in Stanton, since Alpha 4.1."} themeColor="#0d1513" ogType="article" translated={true}>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Wikelo / Banu Emporium theme (4.1) — turquoise & brass */
:root{--bg:#0d1513;--bg-2:#111d1a;--surface:#152420;--surface-2:#1c302b;--accent:#1FB8A6;--accent-2:#E8A33D;--hot:#C0392B;--text:#eef4f2;--muted:#93a7a1;--line:rgba(31,184,166,.22);--line-soft:rgba(238,244,242,.10);--glow:0 0 44px rgba(31,184,166,.28);--ink:#0d1513;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(2.8rem,12vw,9rem)}
.hero{background:radial-gradient(120% 90% at 78% 12%,rgba(31,184,166,.18),transparent 60%),radial-gradient(90% 80% at 12% 90%,rgba(232,163,61,.12),transparent 55%),var(--bg)}
.banu-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}
.wk-lede{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

/* ---- Bento (stations + reward categories) ---- */
.wk-bento{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-cell{border:1px solid var(--line);border-top:2px solid var(--accent);background:var(--surface);padding:1.3rem 1.4rem;display:flex;flex-direction:column;gap:.5rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px)}
.wk-cell .wk-ic{color:var(--accent);line-height:0;width:34px;height:34px}
.wk-cell.alt .wk-ic{color:var(--accent-2)}
.wk-cell .wk-ic svg{width:100%;height:100%;display:block}
.wk-cell h3{font-family:var(--font-display);font-weight:800;font-size:1.25rem;color:#fff;line-height:1.1}
.wk-cell .wk-sub{font-family:var(--font-ui);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.68rem;color:var(--accent)}
.wk-cell p{color:var(--muted);font-size:.98rem;line-height:1.5;margin:0}
.wk-cell.alt{border-top-color:var(--accent-2)}
.wk-cell.alt .wk-sub{color:var(--accent-2)}

/* ---- Two interaction types (mini-split) ---- */
.wk-duo{display:grid;grid-template-columns:1fr 1fr;gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-duo .wk-cell b{color:var(--text)}
@media(max-width:640px){.wk-duo{grid-template-columns:1fr}}

/* ---- Warning / as-of banner ---- */
.wk-note{max-width:var(--maxw);margin:0 auto 1.1rem;display:flex;align-items:flex-start;gap:.75rem;border:1px solid var(--accent-2);border-left-width:3px;background:color-mix(in srgb,var(--accent-2) 8%,transparent);padding:.9rem 1.1rem;border-radius:4px;color:var(--text);font-size:.95rem;line-height:1.55}
.wk-note .wk-ic{color:var(--accent-2);flex:none;line-height:0;width:18px;height:18px;margin-top:.1rem}
.wk-note .wk-ic svg{width:100%;height:100%;display:block}
.wk-note a{color:var(--accent-2);border-bottom:1px solid var(--line);white-space:nowrap}

/* ---- "patch-dependent" badge ---- */
.wk-badge{display:inline-flex;align-items:center;gap:.3rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.62rem;color:var(--accent-2);border:1px solid color-mix(in srgb,var(--accent-2) 45%,transparent);background:color-mix(in srgb,var(--accent-2) 10%,transparent);padding:.12rem .45rem;border-radius:2px;white-space:nowrap}

/* ---- Trade overview: GIVE → GET cards ---- */
.wk-filters{max-width:var(--maxw);margin:0 auto 1.2rem;display:flex;flex-wrap:wrap;gap:.5rem}
.wk-pill{font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.72rem;color:var(--muted);border:1px solid var(--line);background:rgba(0,0,0,.25);padding:.42rem .9rem;border-radius:50px;cursor:pointer;transition:color .18s,border-color .18s,background-color .18s}
.wk-pill:hover{color:var(--text);border-color:var(--accent)}
.wk-pill[aria-pressed="true"]{color:var(--ink);background:var(--accent);border-color:var(--accent)}
.wk-tc-grid{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1rem}
.wk-tc{border:1px solid var(--line);border-top:2px solid var(--accent);background:var(--surface);padding:1.1rem 1.15rem;display:flex;flex-direction:column;gap:.85rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px)}
.wk-tc[data-cat="conv"]{border-top-color:var(--accent-2)}
.wk-tc[hidden]{display:none}
.wk-tc__hd{display:flex;align-items:center;justify-content:space-between;gap:.6rem}
.wk-tc__cat{font-family:var(--font-ui);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.64rem;color:var(--accent)}
.wk-tc[data-cat="conv"] .wk-tc__cat{color:var(--accent-2)}
.wk-conf{font-family:var(--font-ui);font-weight:700;letter-spacing:.06em;text-transform:uppercase;font-size:.58rem;padding:.14rem .5rem;border-radius:2px;white-space:nowrap;border:1px solid}
.wk-conf.solid{color:var(--accent);border-color:color-mix(in srgb,var(--accent) 45%,transparent);background:color-mix(in srgb,var(--accent) 10%,transparent)}
.wk-conf.chk{color:var(--accent-2);border-color:color-mix(in srgb,var(--accent-2) 45%,transparent);background:color-mix(in srgb,var(--accent-2) 10%,transparent)}
.wk-tc__body{display:grid;grid-template-columns:1fr auto minmax(9rem,.9fr);align-items:stretch;gap:.6rem}
.wk-side-h{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.6rem;color:var(--muted);margin-bottom:.4rem}
.wk-mats{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:.28rem}
.wk-mats li{position:relative;padding-left:.85rem;font-size:.86rem;line-height:1.35;color:var(--text)}
.wk-mats li::before{content:"";position:absolute;left:0;top:.5em;width:5px;height:5px;background:var(--accent);transform:rotate(45deg)}
.wk-tc[data-cat="conv"] .wk-mats li::before{background:var(--accent-2)}
.wk-favor{display:inline-flex;align-items:center;gap:.35rem;margin-top:.6rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.04em;font-size:.8rem;color:var(--accent-2);border:1px solid color-mix(in srgb,var(--accent-2) 40%,transparent);background:color-mix(in srgb,var(--accent-2) 9%,transparent);padding:.22rem .55rem;border-radius:3px;width:max-content}
.wk-favor svg{width:14px;height:14px;flex:none}
.wk-tc__note{margin-top:.5rem;font-size:.74rem;line-height:1.4;color:var(--muted)}
.wk-arrow{color:var(--accent);align-self:center;line-height:0}
.wk-arrow svg{width:26px;height:26px;display:block}
.wk-get{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:.5rem;border-left:1px solid var(--line-soft);padding-left:.6rem}
.wk-get-ic{color:var(--accent);width:38px;height:38px;line-height:0;border:1px solid var(--line);background:rgba(0,0,0,.25);display:grid;place-items:center;padding:6px}
.wk-tc[data-cat="conv"] .wk-get-ic{color:var(--accent-2)}
.wk-get-ic svg{width:100%;height:100%}
.wk-get-name{font-family:var(--font-display);font-weight:800;font-size:.98rem;line-height:1.15;color:#fff}
.wk-tc-empty{max-width:var(--maxw);margin:.5rem auto 0;color:var(--muted);font-size:.9rem}
@media(max-width:560px){
  .wk-tc-grid{grid-template-columns:1fr}
  .wk-tc__body{grid-template-columns:1fr;gap:.5rem}
  .wk-arrow{justify-self:center;transform:rotate(90deg);margin:.15rem 0}
  .wk-get{border-left:0;border-top:1px solid var(--line-soft);padding-left:0;padding-top:.7rem;flex-direction:row;justify-content:flex-start}
  .wk-get-name{text-align:left}
}

/* ---- Timeline ---- */
.wk-time{max-width:var(--maxw);margin:0 auto;display:grid;gap:0}
.wk-trow{display:grid;grid-template-columns:auto 1fr;gap:1.2rem;padding:1.1rem 0;border-bottom:1px solid var(--line-soft)}
.wk-trow:last-child{border-bottom:0}
.wk-ver{font-family:var(--font-display);font-weight:900;font-size:clamp(1.4rem,3vw,2rem);color:transparent;-webkit-text-stroke:1.5px var(--accent);line-height:1;min-width:3.2em}
.wk-tbody h3{font-family:var(--font-display);font-weight:800;font-size:1.15rem;color:#fff;margin:0 0 .25rem}
.wk-tbody p{color:var(--muted);font-size:.98rem;line-height:1.55;margin:0;max-width:64ch}

</style>
