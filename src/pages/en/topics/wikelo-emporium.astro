// Trade categories (filter pills)
const TCATS = [
  { key: 'all', label: 'All' },
  { key: 'conv', label: 'Favor exchange' },
  { key: 'capital', label: 'Capital ships' },
  { key: 'fighter', label: 'Fighters' },
  { key: 'industrial', label: 'Industrial & cargo' },
  { key: 'vehicle', label: 'Vehicles' },
];
const CAT_LABEL = { conv: 'Favor exchange', capital: 'Capital ship', fighter: 'Fighter', industrial: 'Industrial/cargo', vehicle: 'Vehicle' };
const CAT_ICON = { conv: 'favor', capital: 'ship', fighter: 'ship', industrial: 'ship', vehicle: 'vehicle' };

// Sourcing: c='solid' (ExpCarry + Wikelo Tracker v4.8 agree), c='chk' (single source · verify in-game).
// As of ~Alpha 4.8 / late May 2026 — recipes are patch-volatile.
const TRADES = [
