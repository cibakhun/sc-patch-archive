---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import TopicFacts from '../../../components/TopicFacts.astro';
import RelatedTopics from '../../../components/RelatedTopics.astro';
import Attribution from '../../../components/Attribution.astro';
---
<Layout title={"Wikelo's Emporium — Star Citizen 4.1 | SC Patch Archive"} description={"Wikelo's Emporium: the Banu trader Wikelo — the first playable alien NPC in Star Citizen. Barter instead of money: deliver items, earn Wikelo Favor, trade for rewards from his stock. Three asteroid stations in Stanton, since Alpha 4.1."} themeColor="#0d1513" ogType="article" translated={true}>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Wikelo / Banu Emporium theme (4.1) — turquoise & brass */
:root{--bg:#0d1513;--bg-2:#111d1a;--surface:#152420;--surface-2:#1c302b;--accent:#1FB8A6;--accent-2:#E8A33D;--hot:#C0392B;--text:#eef4f2;--muted:#93a7a1;--line:rgba(31,184,166,.22);--line-soft:rgba(238,244,242,.10);--glow:0 0 44px rgba(31,184,166,.28);--ink:#0d1513;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(2.8rem,12vw,9rem)}
.hero{background:radial-gradient(120% 90% at 78% 12%,rgba(31,184,166,.18),transparent 60%),radial-gradient(90% 80% at 12% 90%,rgba(232,163,61,.12),transparent 55%),var(--bg)}
.banu-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}
.wk-lede{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

/* ---- Bento (stations + reward categories) ---- */
.wk-bento{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-cell{border:1px solid var(--line);border-top:2px solid var(--accent);background:var(--surface);padding:1.3rem 1.4rem;display:flex;flex-direction:column;gap:.5rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px)}
.wk-cell .wk-ic{font-size:1.6rem;line-height:1}
.wk-cell h3{font-family:var(--font-display);font-weight:800;font-size:1.25rem;color:#fff;line-height:1.1}
.wk-cell .wk-sub{font-family:var(--font-ui);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.68rem;color:var(--accent)}
.wk-cell p{color:var(--muted);font-size:.98rem;line-height:1.5;margin:0}
.wk-cell.alt{border-top-color:var(--accent-2)}
.wk-cell.alt .wk-sub{color:var(--accent-2)}

/* ---- Two interaction types (mini-split) ---- */
.wk-duo{display:grid;grid-template-columns:1fr 1fr;gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-duo .wk-cell b{color:var(--text)}
@media(max-width:640px){.wk-duo{grid-template-columns:1fr}}

/* ---- Warning / as-of banner ---- */
.wk-note{max-width:var(--maxw);margin:0 auto 1.1rem;display:flex;align-items:flex-start;gap:.75rem;border:1px solid var(--accent-2);border-left-width:3px;background:color-mix(in srgb,var(--accent-2) 8%,transparent);padding:.9rem 1.1rem;border-radius:4px;color:var(--text);font-size:.95rem;line-height:1.55}
.wk-note .wk-ic{color:var(--accent-2);font-size:1.1rem;flex:none;line-height:1.4}
.wk-note a{color:var(--accent-2);border-bottom:1px solid var(--line);white-space:nowrap}

/* ---- "patch-dependent" badge ---- */
.wk-badge{display:inline-flex;align-items:center;gap:.3rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.62rem;color:var(--accent-2);border:1px solid color-mix(in srgb,var(--accent-2) 45%,transparent);background:color-mix(in srgb,var(--accent-2) 10%,transparent);padding:.12rem .45rem;border-radius:2px;white-space:nowrap}

/* ---- Trade table: the core piece. Horizontally scrollable on mobile, no overflow. ---- */
.wk-tradewrap{max-width:var(--maxw);margin:0 auto;border:1px solid var(--line);border-radius:8px;overflow-x:auto;-webkit-overflow-scrolling:touch;background:var(--surface)}
.wk-trade{width:100%;min-width:720px;border-collapse:collapse;font-size:clamp(.86rem,1.4vw,.98rem)}
.wk-trade caption{caption-side:top;text-align:left;padding:.9rem 1.1rem .2rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.06em;color:var(--muted);font-size:.8rem}
.wk-trade thead th{position:sticky;top:0;text-align:left;font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.68rem;color:var(--accent);background:var(--bg-2);padding:.75rem 1rem;border-bottom:1px solid var(--line);white-space:nowrap}
.wk-trade tbody th[scope="rowgroup"]{text-align:left;font-family:var(--font-ui);font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.7rem;color:var(--accent-2);background:var(--bg-2);padding:.6rem 1rem;border-top:1px solid var(--line);border-bottom:1px solid var(--line-soft)}
.wk-trade td{padding:.7rem 1rem;border-bottom:1px solid var(--line-soft);vertical-align:top;color:var(--text)}
.wk-trade tbody tr:last-child td{border-bottom:0}
.wk-trade .wk-rw{font-weight:600}
.wk-trade .wk-mat{color:var(--muted);line-height:1.45}
.wk-trade .wk-var{color:var(--accent-2);font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.04em}
.wk-trade .wk-stand{color:var(--muted);font-size:.8rem;white-space:nowrap}
.wk-trade tbody tr:hover td{background:color-mix(in srgb,var(--accent) 5%,transparent)}

/* ---- Timeline ---- */
.wk-time{max-width:var(--maxw);margin:0 auto;display:grid;gap:0}
.wk-trow{display:grid;grid-template-columns:auto 1fr;gap:1.2rem;padding:1.1rem 0;border-bottom:1px solid var(--line-soft)}
.wk-trow:last-child{border-bottom:0}
.wk-ver{font-family:var(--font-display);font-weight:900;font-size:clamp(1.4rem,3vw,2rem);color:transparent;-webkit-text-stroke:1.5px var(--accent);line-height:1;min-width:3.2em}
.wk-tbody h3{font-family:var(--font-display);font-weight:800;font-size:1.15rem;color:#fff;margin:0 0 .25rem}
.wk-tbody p{color:var(--muted);font-size:.98rem;line-height:1.55;margin:0;max-width:64ch}

</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/en.html' }, { label: 'Alpha 4.1.0', href: '/en/patches/sc-4-1-0.html' }, { label: "Wikelo" }]} pill={"TOPIC · ALPHA 4.1"} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/en/patches/sc-4-1-0.html">Alpha 4.1 · Orbital Assault</a> &nbsp;·&nbsp; <span class="banu-tag">Banu trader</span></div>
      <h1><span class="thin">The first playable alien trader</span>Wikelo's Emporium</h1>
      <p class="lead">Wikelo is a <b>Banu</b> — and the first playable alien NPC in Star Citizen. His Emporium has no money: you deliver the items he wants, earn <b>Wikelo Favor</b> and trade it for rewards from his stock.</p>
      <div class="tags"><span class="tag">Banu</span><span class="tag">Barter</span><span class="tag">Wikelo Favor</span><span class="tag">3 stations</span><span class="tag">since Alpha 4.1</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>WIKELO</span><span class="dot">◆</span><span>BANU TRADER</span><span class="dot">◆</span><span>EMPORIUM</span><span class="dot">◆</span><span>DASI</span><span class="dot">◆</span><span>SELO</span><span class="dot">◆</span><span>KINGA</span><span class="dot">◆</span><span>WIKELO FAVOR</span><span class="dot">◆</span><span>BARTER</span><span class="dot">◆</span>
      <span>WIKELO</span><span class="dot">◆</span><span>BANU TRADER</span><span class="dot">◆</span><span>EMPORIUM</span><span class="dot">◆</span><span>DASI</span><span class="dot">◆</span><span>SELO</span><span class="dot">◆</span><span>KINGA</span><span class="dot">◆</span><span>WIKELO FAVOR</span><span class="dot">◆</span><span>BARTER</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AT A GLANCE -->
  <TopicFacts topicSlug="wikelo-emporium" />

  <!-- STAT STRIP -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Asteroid stations in Stanton</div></div>
    <div class="s"><div class="n">Banu</div><div class="c">First playable alien NPC</div></div>
    <div class="s"><div class="n">4.1<span class="u">Alpha</span></div><div class="c">Introduced</div></div>
    <div class="s"><div class="n">0<span class="u">aUEC</span></div><div class="c">Pure barter — no money</div></div>
  </div>

  <!-- BAND 01 — barter principle -->
  <section class="band band--center" style="min-height:auto;padding-block:clamp(3rem,8vw,6rem)">
    <div class="band__in reveal">
      <div class="kx">01 · The barter principle</div>
      <div class="big outline" style="font-size:clamp(2rem,8vw,6rem)">DELIVER · RECEIVE</div>
      <p>Wikelo's Emporium is <b style="color:var(--accent-2)">barter without a conventional currency</b>. Instead of paying aUEC, you fulfil contracts: you bring the requested materials and items — and receive rewards from Wikelo's stock in return. The intermediate step is <b style="color:var(--accent-2)">Wikelo Favor</b>, tokens you earn from contracts and trade for equipment, components or even ships.</p>
    </div>
  </section>

  <!-- PROCESS — the flow -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>How a trade works</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background:radial-gradient(80% 80% at 30% 30%,rgba(31,184,166,.35),transparent),var(--bg-2)"></div>
      <div class="frame" style="background:radial-gradient(80% 80% at 70% 40%,rgba(232,163,61,.32),transparent),var(--bg-2)"></div>
      <div class="frame" style="background:radial-gradient(80% 80% at 40% 70%,rgba(31,184,166,.30),transparent),var(--bg-2)"></div>
      <div class="frame" style="background:radial-gradient(80% 80% at 60% 60%,rgba(232,163,61,.30),transparent),var(--bg-2)"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Accept a contract</h3><p>At one of the three Emporium stations you accept a contract from Wikelo. It tells you which materials or items he wants — the basis of every trade.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Collect the items</h3><p>You source the requested goods: mine, salvage, buy or craft them. This is the actual grind — the loop that sends you out into the 'verse.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Deliver at the freight elevator</h3><p>Back at the station you hand the goods over via the freight elevator. Wikelo logs the delivery and credits you <b>Wikelo Favor</b>.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Trade for a reward</h3><p>With enough Favor (plus further materials if required) you trade for a reward. It lands in the local station inventory — that's where you collect it.</p></div>
    </div>
  </div>

  <!-- TWO INTERACTION TYPES -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">03</span><h2>Two interaction types</h2><span class="rule"></span></div></div>
    <div class="wk-duo reveal">
      <div class="wk-cell">
        <div class="wk-ic">🔁</div>
        <div class="wk-sub">Favor conversion</div>
        <h3>Raw materials → Favors</h3>
        <p>You deliver requested <b>raw materials</b> and receive <b>Wikelo Favor</b> in return. Building up your balance — the tokens you pay with later.</p>
      </div>
      <div class="wk-cell alt">
        <div class="wk-ic">🎁</div>
        <div class="wk-sub">Reward trade</div>
        <h3>Favors + materials → gear</h3>
        <p>You spend <b>Favors together with additional materials</b> and get a concrete reward: gear, components or a ship from Wikelo's stock.</p>
      </div>
    </div>
  </section>

  <!-- THE THREE STATIONS -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">04</span><h2>The three Emporium stations</h2><span class="rule"></span></div></div>
    <div class="wk-bento reveal">
      <div class="wk-cell">
        <div class="wk-ic">🪨</div>
        <div class="wk-sub">near Hurston</div>
        <h3>Dasi</h3>
        <p>Asteroid station within Hurston's sphere of influence. One of the three points of contact for contracts and rewards.</p>
      </div>
      <div class="wk-cell">
        <div class="wk-ic">🪨</div>
        <div class="wk-sub">near Crusader / Yela</div>
        <h3>Selo</h3>
        <p>Asteroid station close to Crusader and the moon Yela. The Emporium's second location in Stanton.</p>
      </div>
      <div class="wk-cell">
        <div class="wk-ic">🪨</div>
        <div class="wk-sub">near microTech</div>
        <h3>Kinga</h3>
        <p>Asteroid station in microTech's vicinity. The third location — rewards land in the local station inventory each time.</p>
      </div>
    </div>
  </section>

  <!-- TRADE TABLE — the core -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">05</span><h2>Deliver → Receive</h2><span class="rule"></span></div></div>
    <div class="wk-note reveal">
      <span class="wk-ic" aria-hidden="true">⚠</span>
      <span>Exact quantities, Favor costs and the available ship/reward pool <b>change with every patch</b>. The rows below are <b>curated examples by category</b>, not fixed prices. Always verify precise, current values <b>in game</b> or via a live tracker: <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com ↗</a></span>
    </div>
    <div class="wk-tradewrap reveal">
      <table class="wk-trade">
        <caption>Example trades by reward category · as-of noted · quantities/Favor patch-dependent</caption>
        <thead>
          <tr>
            <th scope="col">Reward</th>
            <th scope="col">Category</th>
            <th scope="col">Materials required (quantity)</th>
            <th scope="col">Favor cost</th>
            <th scope="col">As of / patch</th>
          </tr>
        </thead>
        <tbody>
          <tr><th scope="rowgroup" colspan="5">Ships &amp; vehicles <span class="wk-badge">patch-dependent</span></th></tr>
          <tr>
            <td class="wk-rw">Ship from Wikelo's pool</td>
            <td>Ships/vehicles</td>
            <td class="wk-mat">Extensive material delivery + multiple contract tiers — <span class="wk-var">verify quantity</span></td>
            <td class="wk-var">variable · tracker</td>
            <td class="wk-stand">Example · to verify</td>
          </tr>

          <tr><th scope="rowgroup" colspan="5">Weapons &amp; armor <span class="wk-badge">patch-dependent</span></th></tr>
          <tr>
            <td class="wk-rw">Handheld weapon</td>
            <td>Weapons</td>
            <td class="wk-mat">Raw materials/refined goods — <span class="wk-var">verify quantity</span></td>
            <td class="wk-var">variable · tracker</td>
            <td class="wk-stand">Example · to verify</td>
          </tr>
          <tr>
            <td class="wk-rw">Armor set</td>
            <td>Armor</td>
            <td class="wk-mat">Raw materials + Favor balance — <span class="wk-var">verify quantity</span></td>
            <td class="wk-var">variable · tracker</td>
            <td class="wk-stand">Example · to verify</td>
          </tr>

          <tr><th scope="rowgroup" colspan="5">Cosmetics &amp; components <span class="wk-badge">patch-dependent</span></th></tr>
          <tr>
            <td class="wk-rw">Paint / skin</td>
            <td>Paints/skins</td>
            <td class="wk-mat">Favor balance (+ material if any) — <span class="wk-var">verify quantity</span></td>
            <td class="wk-var">variable · tracker</td>
            <td class="wk-stand">Example · to verify</td>
          </tr>
          <tr>
            <td class="wk-rw">Ship component</td>
            <td>Ship components</td>
            <td class="wk-mat">Raw materials + Favor balance — <span class="wk-var">verify quantity</span></td>
            <td class="wk-var">variable · tracker</td>
            <td class="wk-stand">Example · to verify</td>
          </tr>
          <tr>
            <td class="wk-rw">Crafting recipe</td>
            <td>Crafting recipes</td>
            <td class="wk-mat">Favor balance — <span class="wk-var">verify quantity</span></td>
            <td class="wk-var">variable · tracker</td>
            <td class="wk-stand">Example · to verify</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="src reveal">The categories are documented; the individual row values are deliberately marked as example / "to verify" because they change per patch. Live data: <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com ↗</a></p>
  </section>

  <!-- REWARD CATEGORIES -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">06</span><h2>Reward categories</h2><span class="rule"></span></div></div>
    <div class="wk-bento reveal">
      <div class="wk-cell"><div class="wk-ic">🚀</div><div class="wk-sub">Category</div><h3>Ships &amp; vehicles</h3><p>Selected ships and ground vehicles from Wikelo's rotating pool.</p></div>
      <div class="wk-cell"><div class="wk-ic">🔫</div><div class="wk-sub">Category</div><h3>Weapons</h3><p>Handheld and ship weapons as trade rewards.</p></div>
      <div class="wk-cell"><div class="wk-ic">🛡️</div><div class="wk-sub">Category</div><h3>Armor</h3><p>Armor sets and gear pieces.</p></div>
      <div class="wk-cell alt"><div class="wk-ic">🎨</div><div class="wk-sub">Category</div><h3>Paints / skins</h3><p>Cosmetic liveries for ships and gear.</p></div>
      <div class="wk-cell alt"><div class="wk-ic">⚙️</div><div class="wk-sub">Category</div><h3>Ship components</h3><p>Components for upgrading and outfitting ships.</p></div>
      <div class="wk-cell alt"><div class="wk-ic">📜</div><div class="wk-sub">Category</div><h3>Crafting recipes</h3><p>Recipes that feed into the crafting system.</p></div>
    </div>
  </section>

  <!-- PATCH TIMELINE -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">07</span><h2>Wikelo across the patches</h2><span class="rule"></span></div></div>
    <div class="wrap"><div class="wk-time reveal">
      <div class="wk-trow">
        <div class="wk-ver">4.1</div>
        <div class="wk-tbody"><h3>Introduction — the first alien</h3><p>Wikelo enters the game: the Banu trader and first playable alien NPC. The Emporium launches with the barter principle and Wikelo Favor contracts.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.1.1</div>
        <div class="wk-tbody"><h3>Second floor</h3><p>The Emporium is expanded — a second floor is added, growing the on-site offering.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.2 / 4.2.1</div>
        <div class="wk-tbody"><h3>Reward rework — deterministic</h3><p>Rewards are reworked: random loot is removed and rewards become <b>deterministic</b> — you know in advance what a trade yields.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.8</div>
        <div class="wk-tbody"><h3>Reset &amp; economy cleanup</h3><p>A reset / economy cleanup tidies up the Emporium system — part of the ongoing balancing work on Wikelo's economy.</p></div>
      </div>
    </div></div>
  </section>

  <!-- LORE QUOTE -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>No money changes hands — only <span class="hl">goods for favor</span>, and favor for the stock of a Banu.</blockquote>
    <cite>Wikelo's Emporium · Banu barter</cite>
  </section>

  <!-- SOURCES -->
  <section>
    <div class="wrap">
      <p class="src reveal">Sources: Star Citizen Wiki — <a href="https://starcitizen.tools/Wikelo" target="_blank" rel="noopener">Wikelo</a>, <a href="https://starcitizen.tools/Wikelo_Emporium" target="_blank" rel="noopener">Wikelo Emporium</a>, <a href="https://starcitizen.tools/Wikelo_Favor" target="_blank" rel="noopener">Wikelo Favor</a> (CC-BY-SA 4.0) · live trades: <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com ↗</a>. Trade details change with every patch.</p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="wikelo-emporium" />

