  <!-- ALL TOPICS — directory -->
  <section class="sec reveal" id="themen">
    <div class="sec__head">
      <h2>All topics</h2>
      <span class="tag">{topicCount} deep-dives</span>
      <span class="rule"></span>
    </div>
    <div class="hub">
      {hubGroups.map((g) => (
        <div class="hubgroup">
          <div class="hubhead">
            <span class="hubsw" style={`background:${g.accent}`} aria-hidden="true"></span>
            <span class="hubline">Alpha {g.line}.x</span>
            <span class="hubn">· {g.topics.length} {g.topics.length === 1 ? 'entry' : 'entries'}</span>
          </div>
          <div class="hubrows">
            {g.topics.map((t) => (
              <a href={`/en/topics/${t.slug}.html`}>
                <span class="ht">{t.title}</span>
                <span class="hv">{t.version}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
    <p class="intro-note">VerseBase is an unofficial fan project and is not affiliated with Cloud Imperium Games. All data comes from the game files and public community sources; prices and locations are patch-volatile.</p>
  </section>
</main>

<script is:inline>
  const io = new IntersectionObserver((es) => es.forEach((e) => {
    if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
  }), { threshold: .08 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
</Layout>
