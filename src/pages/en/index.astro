    <div class="grid">
      <a class="pcard" style="--c:#3da5d9" href="/en/patches/sc-4-1-0.html"><div class="ver">4.1.0</div><div class="date">Mar 27, 2025</div><div class="name">Orbital Assault</div><div class="desc">Orbital laser platforms & deep asteroid mining.</div><span class="go">Open <span class="ar">→</span></span></a>
      <a class="pcard" style="--c:#ff7a1a" href="/en/patches/sc-4-1-1.html"><div class="ver">4.1.1</div><div class="date">May 13, 2025</div><div class="name">Balancing &amp; Fleet Week</div><div class="desc">Weapon tuning, recoil and "Hunt The Polaris".</div><span class="go">Open <span class="ar">→</span></span></a>
      <a class="pcard" style="--c:#36e2f0" href="/en/patches/sc-4-2-0.html"><span class="badge">Major</span><div class="ver">4.2.0</div><div class="date">Jun 19, 2025</div><div class="name">Storm Breaker</div><div class="desc">Into the storm — dynamic rain & radiation.</div><span class="go">Open <span class="ar">→</span></span></a>
      <a class="pcard" style="--c:#2ea36a" href="/en/patches/sc-4-2-1.html"><div class="ver">4.2.1</div><div class="date">Jul 17, 2025</div><div class="name">Resource Drive</div><div class="desc">Cooperative convoy event & the RSI Meteor.</div><span class="go">Open <span class="ar">→</span></span></a>
