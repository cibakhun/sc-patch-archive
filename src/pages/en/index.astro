    <div class="grid">
      <a class="pcard" style="--c:#e8a317" href="/en/patches/sc-4-3-0.html"><span class="badge">Major</span><div class="ver">4.3.0</div><div class="date">Aug 16, 2025</div><div class="name">Dark Territory</div><div class="desc">Personal Hangars as home port & the Onyx Facilities.</div><span class="go">Open <span class="ar">→</span></span></a>
