<script is:inline>

const tb=document.getElementById('topbar');
addEventListener('scroll',()=>tb.classList.toggle('scrolled',scrollY>40),{passive:true});
addEventListener('pointermove',e=>{document.documentElement.style.setProperty('--mx',e.clientX+'px');document.documentElement.style.setProperty('--my',e.clientY+'px');},{passive:true});
const io=new IntersectionObserver((es)=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
document.querySelectorAll('.video[data-yt]').forEach(v=>{v.addEventListener('click',()=>{const id=v.getAttribute('data-yt');v.innerHTML='<iframe src="https://www.youtube-nocookie.com/embed/'+id+'?autoplay=1&rel=0" title="Video" allow="autoplay; encrypted-media; fullscreen; picture-in-picture" allowfullscreen></iframe>';},{once:true});});
/* Lightbox: Karten/Bilder klickbar */
(function(){const lb=document.getElementById('lb'),lbc=lb.querySelector('.lb__content');
function show(h){lbc.innerHTML=h;lb.classList.add('open');lb.setAttribute('aria-hidden','false');}
function close(){lb.classList.remove('open');lbc.innerHTML='';lb.setAttribute('aria-hidden','true');}
function esc(s){return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
document.querySelectorAll('[data-lb]').forEach(el=>el.addEventListener('click',()=>{const v=el.getAttribute('data-lb');if(v.startsWith('yt:')){show('<div class="ratio"><iframe src="https://www.youtube-nocookie.com/embed/'+v.slice(3)+'?autoplay=1&rel=0" title="Video" allow="autoplay; encrypted-media; fullscreen; picture-in-picture" allowfullscreen></iframe></div>');}else{show('<img src="'+v.slice(4)+'" alt="">');}}));
document.querySelectorAll('[data-info]').forEach(el=>el.addEventListener('click',()=>{const img=el.getAttribute('data-img'),ti=esc(el.getAttribute('data-title')),tx=esc(el.getAttribute('data-text'));show('<div class="lb__info">'+(img?'<img src="'+img+'" alt="">':'')+'<div class="lb__txt"><h3>'+ti+'</h3><p>'+tx+'</p></div></div>');}));
lb.addEventListener('click',e=>{if(e.target===lb||e.target.closest('.lb__x'))close();});
addEventListener('keydown',e=>{if(e.key==='Escape')close();});})();
/* Sturm-Canvas (themed: fallender Regen + gelegentliche Blitze) */
(function(){
  const c=document.getElementById('stars');if(!c)return;
  const x=c.getContext('2d');let w,h,drops;
  function size(){w=c.width=innerWidth;h=c.height=Math.max(innerHeight,1);
    drops=Array.from({length:Math.min(260,Math.floor(w/4))},()=>mk());}
  function mk(){return{x:Math.random()*w,y:Math.random()*h,len:Math.random()*16+10,sp:Math.random()*6+7,a:Math.random()*.4+.2};}
  let flash=0,nextFlash=performance.now()+rand(2500,6000),boltPts=[];
  function rand(a,b){return a+Math.random()*(b-a);}
  function makeBolt(){
    const pts=[],sx=rand(w*.15,w*.85);let cx=sx,cy=0;pts.push([cx,cy]);
    const segs=Math.floor(rand(7,12));
    for(let i=0;i<segs;i++){cx+=rand(-40,40);cy+=h/segs*rand(.7,1.2);pts.push([cx,Math.min(cy,h)]);}
    return pts;
  }
  function tick(t){
    x.clearRect(0,0,w,h);
    if(t>nextFlash){flash=1;boltPts=makeBolt();nextFlash=t+rand(3000,8000);}
    if(flash>0){
      x.fillStyle='rgba(54,226,240,'+(flash*.10)+')';x.fillRect(0,0,w,h);
      x.strokeStyle='rgba(210,250,255,'+(flash)+')';x.lineWidth=2.2;x.shadowColor='#36e2f0';x.shadowBlur=18;
      x.beginPath();boltPts.forEach((p,i)=>i?x.lineTo(p[0],p[1]):x.moveTo(p[0],p[1]));x.stroke();
      x.shadowBlur=0;flash-=.06;if(flash<0)flash=0;
    }
    x.strokeStyle='rgba(54,226,240,.5)';x.lineWidth=1.1;
    for(const d of drops){
      x.globalAlpha=d.a;x.beginPath();x.moveTo(d.x,d.y);x.lineTo(d.x-2,d.y+d.len);x.stroke();
      d.y+=d.sp;d.x-=.6;
      if(d.y>h){d.y=-d.len;d.x=Math.random()*w;}
    }
    x.globalAlpha=1;
    requestAnimationFrame(tick);
  }
  size();addEventListener('resize',size);
  if(!matchMedia('(prefers-reduced-motion:reduce)').matches)requestAnimationFrame(tick);
})();

</script>
