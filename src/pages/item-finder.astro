---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import Attribution from '../components/Attribution.astro';
import ItemFinderApp from '../components/ItemFinderApp.astro';
import DB from '../../assets/universal-items.json';

const total = DB.counts.items;
const sourced = DB.counts.withObtain;
const snap = DB.generatedAt;
---
<Layout title={"Universal Item Finder — Star Citizen 4.8 | SC Patch-Archiv"} description={`Universal Item Finder für Star Citizen 4.8: ${total} Items aus den Spieldateien durchsuchen — ${sourced} davon mit verifizierten Bezugsquellen (Shop-Preise, Loot-Fundorte, Schiffshändler). Ohne erfundene Daten.`} themeColor="#16161a" ogType="article" translated={true}>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>
:root{--bg:#16161a;--bg-2:#1d1d22;--surface:#232329;--surface-2:#2c2c34;--accent:#FF5E1A;--accent-2:#1FA2FF;--hot:#FF5E1A;--text:#eef1f5;--muted:#9ba2ae;--line:rgba(255,94,26,.22);--line-soft:rgba(238,241,245,.10);--glow:0 0 44px rgba(255,94,26,.28);--ink:#16161a;--maxw:1240px;}
.reveal{opacity:1 !important;transform:none !important}
.hero h1{font-size:clamp(2.4rem,9vw,7rem)}
.hero{background:radial-gradient(120% 90% at 78% 12%,rgba(255,94,26,.16),transparent 60%),radial-gradient(90% 80% at 12% 90%,rgba(31,162,255,.12),transparent 55%),var(--bg)}
.hero__in{max-width:var(--maxw)}
.uf-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}
.qbar{display:flex;flex-wrap:wrap;gap:.5rem 1.4rem;margin-top:1.4rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.74rem;color:var(--muted)}
.qbar b{color:var(--accent-2)}
.uf-note{max-width:var(--maxw);margin:0 auto 1.2rem;display:flex;align-items:flex-start;gap:.75rem;border:1px solid var(--accent-2);border-left-width:3px;background:color-mix(in srgb,var(--accent-2) 8%,transparent);padding:.9rem 1.1rem;border-radius:4px;color:var(--text);font-size:.92rem;line-height:1.55}
.uf-note b{color:#fff}
</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/index.html' }, { label: 'Alpha 4.8', href: '/patches/sc-4-8-0.html' }, { label: 'Item Finder' }]} pill={"WERKZEUG · DATENBANK"} hasEn={true} />

<main id="main">
  <section class="hero">
    <canvas id="stars" aria-hidden="true"></canvas>
    <script is:inline>if(location.search.indexOf('nofx')>-1){document.documentElement.style.setProperty('scroll-behavior','auto');var c=document.getElementById('stars');if(c)c.remove();}</script>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-8-0.html">Alpha 4.8</a> &nbsp;·&nbsp; <span class="uf-tag">Item-Datenbank</span></div>
      <h1><span class="thin">Universal</span>Item Finder</h1>
      <p class="lead">Durchsuche <b>{total.toLocaleString('de-DE')} Items</b> aus den Spieldateien — <b>{sourced.toLocaleString('de-DE')}</b> davon mit verifizierten Bezugsquellen: Shop-Preise, Loot-Fundorte mit Guide, Schiffshändler. Einträge ohne bekannte Quelle sind ehrlich als Katalog markiert.</p>
      <div class="qbar"><span>Items <b>{total.toLocaleString('de-DE')}</b></span><span>Mit Quellen <b>{sourced.toLocaleString('de-DE')}</b></span><span>Patch <b>4.8</b></span><span>Stand <b>{snap}</b></span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <div class="uf-note reveal">
    <span>Preise &amp; Kauforte: <b>UEX Corp</b> (Stand {DB.pricesAsOf}) — dieselben Daten, die <a href="https://starcitizen.tools/" rel="noopener">starcitizen.tools</a> auf den Item-Seiten anzeigt. Dazu eigene Loot-Recherche mit Guides, UEX-Fahrzeugpreise und Namen aus den Spieldateien (global.ini). Keine erfundenen Werte — <b>Patch-volatil, ingame prüfen</b>.</span>
  </div>

  <ItemFinderApp lang="de" />
</main>

<Attribution sources={["UEX Corp / starcitizen.tools", "CIG-Spieldaten", "eigene Loot-Recherche"]} updated={snap} />

<script is:inline src="/assets/detail.js"></script>
</Layout>
