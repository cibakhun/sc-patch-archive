---
// Neues Passwort setzen (Recovery-Landing) — EN. noindex.
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import Attribution from '../../components/Attribution.astro';
import AccountShell from '../../components/account/AccountShell.astro';
import AuthUpdatePassword from '../../components/account/AuthUpdatePassword.astro';
---
<Layout
  title={'Set new password | VerseBase'}
  description={'Set a new password for your VerseBase account — the recovery link from your e-mail lands here and signs you back in securely.'}
  themeColor="#05070d"
  ogImage="/assets/og-default.jpg"
  translated={true}
  noindex={true}
>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<link slot="head" rel="stylesheet" href="/assets/account.css" />
<style is:inline>
/* Palette lebt jetzt in /assets/account.css (geteilt, entdoppelt). */


.reveal{opacity:1 !important;transform:none !important}
.hero__in{max-width:var(--maxw)}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Account', href: '/account.html' }, { label: 'New password' }]} hasEn={true} />

<main id="main">
  <AccountShell
    eyebrow="VerseBase · System access"
    titleThin="Almost back in"
    title="New password"
  >
    <AuthUpdatePassword lang="en" />
  </AccountShell>
</main>

<Attribution sources={[]} />

<script is:inline src="/assets/detail.js"></script>
</Layout>
