---
// Registrierung — EN.
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import Attribution from '../../components/Attribution.astro';
import AccountShell from '../../components/account/AccountShell.astro';
import AuthRegister from '../../components/account/AuthRegister.astro';
---
<Layout
  title={'Create account | VerseBase'}
  description={'Create your free VerseBase account: bookmark your favorite Star Citizen ships and manage your profile.'}
  themeColor="#05070d"
  ogImage="/assets/og-default.jpg"
  translated={true}
>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<link slot="head" rel="stylesheet" href="/assets/account.css" />
<style is:inline>
/* Palette lebt jetzt in /assets/account.css (geteilt, entdoppelt). */


.reveal{opacity:1 !important;transform:none !important}
.hero__in{max-width:var(--maxw)}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Account', href: '/account.html' }, { label: 'Create account' }]} hasEn={true} />

<main id="main">
  <AccountShell
    eyebrow="VerseBase · System access"
    titleThin="Join the base"
    title="Create account"
    lead="Free, fast, no strings attached — star your favorite ships and keep your profile in one place."
  >
    <AuthRegister lang="en" />
  </AccountShell>
</main>

<Attribution sources={[]} />

<script is:inline src="/assets/detail.js"></script>
</Layout>
