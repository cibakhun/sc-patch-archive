---
// Passwort vergessen — EN. noindex: reiner Utility-Schritt.
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import Attribution from '../../components/Attribution.astro';
import AccountShell from '../../components/account/AccountShell.astro';
import AuthReset from '../../components/account/AuthReset.astro';
---
<Layout
  title={'Reset password | VerseBase'}
  description={'Forgot your password? Request a reset link for your VerseBase account and get back to your ship favorites and profile in minutes.'}
  themeColor="#05070d"
  ogImage="/assets/og-default.jpg"
  translated={true}
  noindex={true}
>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<link slot="head" rel="stylesheet" href="/assets/account.css" />
<style is:inline>
/* Palette lebt jetzt in /assets/account.css (geteilt, entdoppelt). */


.reveal{opacity:1 !important;transform:none !important}
.hero__in{max-width:var(--maxw)}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Account', href: '/account.html' }, { label: 'Reset password' }]} hasEn={true} />

<main id="main">
  <AccountShell
    eyebrow="VerseBase · System access"
    titleThin="Locked out?"
    title="Reset password"
  >
    <AuthReset lang="en" />
  </AccountShell>
</main>

<Attribution sources={[]} />

<script is:inline src="/assets/detail.js"></script>
</Layout>
