---
// Account-Vorschau — "Citizen Dossier" (noindex, kein Auth, Demo-Daten).
// Ziel-Design fuer das echte Dashboard; wird nach Freigabe portiert.
// Design gewaehlt aus einem 4-Wege-Konzeptwettbewerb (v1 Dossier gewann Craft).
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
---
<Layout title="Citizen Dossier — Account Preview | VerseBase" noindex={true} themeColor="#05070d">
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>
:root{
  --bg:#05070d;--bg-2:#0a0e18;--surface:#0f1524;--surface-2:#141c30;
  --accent:#2dd4ff;--accent-2:#6ea8ff;--gold:#e6b25c;--ok:#5ad19a;--hot:#f4708a;
  --text:#e8eefc;--muted:#8a99b8;
  --line:rgba(110,168,255,.16);--line-soft:rgba(110,168,255,.10);--line-2:rgba(110,168,255,.32);
  --ink:#04121a;
  --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;--font-mono:'Share Tech Mono',monospace;--font-num:'Teko',sans-serif;
  --nav:64px;
  --amber:#e6c34a;--orange:#f0a24b;
  /* CRT-Scanlines aus: schlagen auf dem hellen Hero-Namen als "Glitch" durch (Vignette bleibt) */
  --scanline:rgba(0,0,0,0);
}

.dsr *,.dsr *::before,.dsr *::after{box-sizing:border-box}
html{-webkit-text-size-adjust:100%}
.dsr{
  margin:0;padding-top:var(--nav);
  background:
    radial-gradient(1200px 640px at 78% -8%, rgba(45,212,255,.05), transparent 60%),
    radial-gradient(900px 520px at 8% 4%, rgba(110,168,255,.05), transparent 55%),
    linear-gradient(180deg,var(--bg-2),var(--bg) 42%);
  color:var(--text);
  font-family:var(--font-body);
  font-size:15px;line-height:1.55;
  overflow-x:hidden;
  min-height:100vh;
}
.dsr img{max-width:100%;display:block}
.dsr button{font-family:inherit;color:inherit;background:none;border:0;cursor:pointer}
.dsr a{color:inherit;text-decoration:none}
.dsr input,.dsr select,.dsr textarea{font-family:inherit;font-size:inherit;color:inherit}
.dsr svg{display:block}
.dsr ::selection{background:rgba(45,212,255,.28);color:#fff}
.tnum{font-variant-numeric:tabular-nums}

/* ---------- shared type ---------- */
.eyebrow{font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.24em;font-size:11px;color:var(--muted)}
.mono{font-family:var(--font-mono);letter-spacing:.02em;font-variant-numeric:tabular-nums}
.disp{font-family:var(--font-display);font-weight:900;letter-spacing:.01em}

/* ---------- layout ---------- */
.dwrap{max-width:1360px;margin:0 auto;padding-inline:clamp(16px,4vw,40px)}
.fullbleed{border-block:1px solid var(--line-soft);background:linear-gradient(180deg,rgba(20,28,48,.55),rgba(10,14,24,.2))}

/* classification strip */
.class-strip{position:relative;overflow:hidden}
.class-strip .dwrap{display:flex;align-items:center;gap:18px;height:34px;flex-wrap:nowrap;overflow:hidden}
.class-strip .cs-tag{font-family:var(--font-mono);font-size:11px;letter-spacing:.16em;color:var(--muted);white-space:nowrap}
.class-strip .cs-tag b{color:var(--accent);font-weight:400}
.class-strip .cs-tag.warn b{color:var(--gold)}
.class-strip .cs-spacer{flex:1}
.class-strip .cs-barcode{display:flex;gap:2px;align-items:center;height:14px;opacity:.6}
.class-strip .cs-barcode i{display:block;width:2px;height:14px;background:var(--line-2)}
.hazard{position:absolute;inset:0;bottom:auto;height:2px;background:repeating-linear-gradient(90deg,var(--accent) 0 14px,transparent 14px 28px);opacity:.35}

/* masthead */
.masthead{padding-block:26px 20px}
.masthead .wrap{display:flex;justify-content:space-between;align-items:flex-end;gap:24px;flex-wrap:wrap}
.mh-left{display:flex;flex-direction:column;gap:8px;min-width:0}
.mh-crest{display:flex;align-items:center;gap:14px}
.crest{width:46px;height:46px;flex:none;position:relative;display:grid;place-items:center;color:var(--accent)}
.crest svg{width:46px;height:46px}
.mh-title{font-family:var(--font-display);font-weight:900;font-size:clamp(22px,3.4vw,34px);line-height:.98;letter-spacing:.02em;margin:0}
.mh-title span{color:var(--accent)}
.mh-sub{font-family:var(--font-mono);font-size:12px;color:var(--muted);letter-spacing:.06em}
.mh-right{display:flex;gap:10px;flex-wrap:wrap}
.mh-meta{border:1px solid var(--line);background:var(--surface);padding:8px 14px;min-width:120px}
.mh-meta .k{font-family:var(--font-mono);font-size:10px;letter-spacing:.14em;color:var(--muted);text-transform:uppercase}
.mh-meta .v{font-family:var(--font-mono);font-size:13px;color:var(--text);margin-top:3px}
.mh-meta .v.ok{color:var(--ok)}

/* ---------- tabs (dossier dividers) ---------- */
.tabsbar{position:sticky;top:var(--nav);z-index:20;background:linear-gradient(180deg,rgba(8,11,20,.92),rgba(8,11,20,.72));backdrop-filter:blur(8px);border-block:1px solid var(--line-soft)}
.tabs{display:flex;gap:0;overflow-x:auto;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tab{position:relative;flex:none;display:flex;align-items:center;gap:11px;padding:14px 22px;border-right:1px solid var(--line-soft);color:var(--muted);white-space:nowrap;transition:color .2s ease,background .2s ease}
.tab:first-child{border-left:1px solid var(--line-soft)}
.tab .idx{font-family:var(--font-mono);font-size:11px;color:var(--line-2);letter-spacing:.05em}
.tab .lbl{font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.2em;font-size:13px}
.tab::after{content:"";position:absolute;left:0;right:0;bottom:0;height:2px;background:var(--accent);transform:scaleX(0);transform-origin:left;transition:transform .28s cubic-bezier(.4,0,.2,1)}
.tab:hover{color:var(--text);background:rgba(45,212,255,.04)}
.tab[aria-selected="true"]{color:var(--text);background:linear-gradient(180deg,rgba(45,212,255,.08),transparent)}
.tab[aria-selected="true"] .idx{color:var(--accent)}
.tab[aria-selected="true"]::after{transform:scaleX(1)}

/* ---------- panels / cards ---------- */
.dpanels{padding-block:30px 72px}
.panel{display:none}
.panel.active{display:block;animation:fade .4s ease}
@keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

.card{position:relative;background:var(--surface);border:1px solid var(--line)}
.card.raise{box-shadow:0 18px 44px -30px rgba(0,0,0,.9)}
.framed::before,.framed::after{content:"";position:absolute;width:13px;height:13px;pointer-events:none;z-index:2}
.framed::before{top:-1px;left:-1px;border-top:1.5px solid var(--line-2);border-left:1.5px solid var(--line-2)}
.framed::after{bottom:-1px;right:-1px;border-bottom:1.5px solid var(--line-2);border-right:1.5px solid var(--line-2)}

.dsec{display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin:2px 0 16px;flex-wrap:wrap}
.dsec h2{font-family:var(--font-display);font-weight:700;font-size:16px;letter-spacing:.14em;text-transform:uppercase;margin:0;color:var(--text)}
.dsec .code{font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.1em}

.stack{display:flex;flex-direction:column;gap:22px}

/* ---------- identity record card ---------- */
.record{position:relative;overflow:hidden;background:var(--surface)}
.record .guilloche{position:absolute;inset:0;pointer-events:none;opacity:.9;
  background-image:
    repeating-radial-gradient(circle at 22% 34%, rgba(110,168,255,.045) 0 1px, transparent 1px 7px),
    repeating-radial-gradient(circle at 86% 78%, rgba(45,212,255,.04) 0 1px, transparent 1px 9px),
    repeating-linear-gradient(38deg, rgba(110,168,255,.035) 0 1px, transparent 1px 8px),
    repeating-linear-gradient(-38deg, rgba(110,168,255,.03) 0 1px, transparent 1px 10px);
  mask-image:linear-gradient(180deg,rgba(0,0,0,.85),rgba(0,0,0,.35))}
.record .watermark{position:absolute;right:-30px;bottom:-56px;color:rgba(110,168,255,.05);pointer-events:none}
.record .watermark svg{width:340px;height:340px}
.rec-banner{position:relative;height:132px;overflow:hidden;border-bottom:1px solid var(--line)}
.rec-banner img{width:100%;height:100%;object-fit:cover;filter:saturate(.9) brightness(.62)}
.rec-banner::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(5,7,13,.15),rgba(15,21,36,.9))}
.rec-banner .bmeta{position:absolute;left:18px;bottom:12px;z-index:2;display:flex;gap:10px;align-items:center}
.rec-banner .bchip{font-family:var(--font-mono);font-size:10px;letter-spacing:.14em;color:var(--accent);border:1px solid var(--line-2);background:rgba(5,7,13,.5);padding:3px 8px;text-transform:uppercase}
.rec-banner .barcode{position:absolute;right:18px;top:14px;z-index:2;display:flex;gap:2px}
.rec-banner .barcode i{width:2px;height:20px;background:rgba(232,238,252,.5)}

/* holo strip */
.holostrip{position:absolute;top:0;bottom:0;right:118px;width:20px;z-index:3;overflow:hidden;
  background:linear-gradient(160deg,rgba(45,212,255,.55),rgba(110,168,255,.4) 30%,rgba(168,85,247,.4) 55%,rgba(230,178,92,.5) 80%,rgba(45,212,255,.5));
  border-inline:1px solid rgba(255,255,255,.14);opacity:.85;mix-blend-mode:screen}
.holostrip::before{content:"UEE·UEE·UEE·UEE·UEE·UEE·UEE·UEE·UEE·UEE·UEE·UEE";position:absolute;inset:0;writing-mode:vertical-rl;font-family:var(--font-mono);font-size:9px;letter-spacing:.1em;color:rgba(4,18,26,.55);white-space:nowrap;padding:6px 4px;line-height:20px}
.holostrip::after{content:"";position:absolute;inset:-40% -60%;background:linear-gradient(120deg,transparent 40%,rgba(255,255,255,.5) 50%,transparent 60%);animation:sheen 5.5s linear infinite}
@keyframes sheen{0%{transform:translateY(-30%)}100%{transform:translateY(60%)}}

.rec-body{position:relative;z-index:2;display:grid;grid-template-columns:150px 1fr;gap:22px;padding:22px}
/* photo */
.photo{position:relative;align-self:start}
.photo-frame{position:relative;aspect-ratio:1/1.18;border:1px solid var(--line-2);background:
    radial-gradient(120% 90% at 50% 12%, rgba(45,212,255,.18), transparent 60%),
    linear-gradient(180deg,var(--surface-2),#0b1120);
  display:grid;place-items:center;overflow:hidden}
.photo-frame .glyph{font-size:64px;line-height:1;color:var(--accent);text-shadow:0 0 24px rgba(45,212,255,.4)}
.photo-frame .scan{position:absolute;inset:0;background:repeating-linear-gradient(0deg,rgba(45,212,255,.06) 0 1px,transparent 1px 4px);pointer-events:none}
.photo-frame .ptick{position:absolute;width:10px;height:10px;border:1.5px solid var(--accent)}
.photo-frame .ptick.tl{top:6px;left:6px;border-right:0;border-bottom:0}
.photo-frame .ptick.tr{top:6px;right:6px;border-left:0;border-bottom:0}
.photo-frame .ptick.bl{bottom:6px;left:6px;border-right:0;border-top:0}
.photo-frame .ptick.br{bottom:6px;right:6px;border-left:0;border-top:0}
.photo-cap{font-family:var(--font-mono);font-size:10px;letter-spacing:.16em;color:var(--muted);text-align:center;margin-top:7px;text-transform:uppercase}

/* details */
.rec-id{display:flex;flex-direction:column;gap:12px;min-width:0}
.name-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.pilot-name{font-family:var(--font-display);font-weight:900;font-size:clamp(26px,4.2vw,40px);line-height:.96;letter-spacing:.01em;margin:0}
.chip{display:inline-flex;align-items:center;gap:6px;font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.12em;font-size:11px;padding:5px 10px;border:1px solid var(--line);background:var(--surface-2)}
.chip svg{width:13px;height:13px}
.chip.verified{color:var(--ok);border-color:rgba(90,209,154,.4);background:rgba(90,209,154,.08)}
.handle{font-family:var(--font-mono);font-size:14px;color:var(--accent);letter-spacing:.03em}
.status-line{display:flex;align-items:center;gap:9px;font-family:var(--font-mono);font-size:13px;color:var(--muted)}
.status-line b{color:var(--text);font-weight:400}
.dot{width:9px;height:9px;border-radius:50%;flex:none;background:var(--dot,var(--muted));box-shadow:0 0 0 3px color-mix(in srgb, var(--dot,var(--muted)) 22%, transparent)}
.dot.pulse{animation:pulse 1.9s ease-in-out infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 3px color-mix(in srgb,var(--dot) 26%,transparent)}50%{box-shadow:0 0 0 7px color-mix(in srgb,var(--dot) 4%,transparent)}}

.fieldgrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1px;background:var(--line-soft);border:1px solid var(--line-soft);margin-top:2px}
.frow{background:var(--surface);padding:10px 13px}
.frow .k{font-family:var(--font-mono);font-size:10px;letter-spacing:.14em;color:var(--muted);text-transform:uppercase}
.frow .v{font-family:var(--font-mono);font-size:13.5px;color:var(--text);margin-top:3px;display:flex;align-items:center;gap:7px}
.frow .v svg{width:13px;height:13px;color:var(--accent)}
.frow .v.reg{color:var(--accent);letter-spacing:.08em}

.rec-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:4px}

/* MRZ machine readable zone */
.mrz{position:relative;z-index:2;margin:0 22px 20px;border-top:1px dashed var(--line-2);padding-top:14px}
.mrz .mrz-cap{font-family:var(--font-mono);font-size:10px;letter-spacing:.18em;color:var(--muted);text-transform:uppercase;margin-bottom:8px}
.mrz .mrz-lines{font-family:var(--font-mono);font-size:clamp(11px,1.7vw,15px);letter-spacing:.16em;line-height:1.7;color:var(--text);background:linear-gradient(180deg,rgba(45,212,255,.05),transparent);border:1px solid var(--line-soft);padding:10px 12px;overflow-x:auto;white-space:nowrap}
.mrz .mrz-lines span{color:var(--accent)}

/* verified seal */
.seal{position:absolute;z-index:4;right:20px;bottom:78px;width:118px;height:118px;color:var(--ok);opacity:.9;transform:rotate(-9deg);pointer-events:none;filter:drop-shadow(0 0 10px rgba(90,209,154,.2))}
.seal svg{width:100%;height:100%}

/* ---------- buttons ---------- */
.btn{display:inline-flex;align-items:center;gap:8px;font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:12.5px;padding:10px 16px;border:1px solid var(--line-2);color:var(--text);background:var(--surface-2);transition:.18s ease;
  clip-path:polygon(7px 0,100% 0,100% calc(100% - 7px),calc(100% - 7px) 100%,0 100%,0 7px)}
.btn svg{width:15px;height:15px}
.btn:hover{border-color:var(--accent);color:#fff;background:rgba(45,212,255,.1)}
.btn.primary{background:linear-gradient(180deg,rgba(45,212,255,.9),rgba(45,212,255,.72));color:var(--ink);border-color:transparent;font-weight:700}
.btn.primary:hover{background:var(--accent);box-shadow:0 10px 26px -14px rgba(45,212,255,.8)}
.btn.ghost{background:transparent}
.btn.sm{padding:7px 12px;font-size:11px;letter-spacing:.1em}
.btn.gold{border-color:rgba(230,178,92,.5);color:var(--gold)}
.btn.gold:hover{background:rgba(230,178,92,.1);border-color:var(--gold)}
.btn.danger{border-color:rgba(244,112,138,.5);color:var(--hot)}
.btn.danger:hover{background:rgba(244,112,138,.12);border-color:var(--hot)}
.btn.ok{border-color:rgba(90,209,154,.5);color:var(--ok)}
.btn.ok:hover{background:rgba(90,209,154,.1)}

/* ---------- metrics ---------- */
.metrics{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:14px}
.metric{position:relative;background:var(--surface);border:1px solid var(--line);padding:16px 15px 15px;display:flex;flex-direction:column;gap:8px;min-height:132px}
.metric .mlabel{display:flex;align-items:center;justify-content:space-between;gap:8px}
.metric .mlabel .k{font-family:var(--font-mono);font-size:10px;letter-spacing:.14em;color:var(--muted);text-transform:uppercase}
.metric .mlabel .fid{font-family:var(--font-mono);font-size:9px;color:var(--line-2);letter-spacing:.1em}
.metric .micon{color:var(--accent);opacity:.8}
.metric .micon svg{width:16px;height:16px}
.metric .big{font-family:var(--font-num);font-weight:600;font-size:46px;line-height:.85;letter-spacing:.01em;color:var(--text);font-variant-numeric:tabular-nums}
.metric .big.gold{color:var(--gold)}
.metric .sub{font-family:var(--font-mono);font-size:11px;color:var(--muted);margin-top:auto}
.metric .sub b{color:var(--ok);font-weight:400}
.metric .sub b.dim{color:var(--accent)}
.metric.wide{grid-column:span 1}
.spark{margin-top:4px}
.spark svg{width:100%;height:46px;overflow:visible}
.ringwrap{display:flex;align-items:center;gap:12px;margin-top:2px}
.ringwrap .rmeta{font-family:var(--font-mono);font-size:11px;color:var(--muted);line-height:1.5}
.ringwrap .rmeta b{color:var(--text);font-weight:400}
.metric .verline{display:flex;align-items:center;gap:8px;font-family:var(--font-mono);font-size:13px;color:var(--ok);margin-top:2px}
.metric .verline svg{width:15px;height:15px}
.metric .versub{font-family:var(--font-mono);font-size:11px;color:var(--muted)}

/* ---------- quick access ---------- */
.qgrid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.qcard{position:relative;display:flex;align-items:center;gap:14px;padding:16px;background:var(--surface);border:1px solid var(--line);text-align:left;transition:.18s ease;width:100%}
.qcard:hover{border-color:var(--line-2);background:var(--surface-2);transform:translateY(-2px)}
.qcard .qi{width:42px;height:42px;flex:none;display:grid;place-items:center;border:1px solid var(--line);background:rgba(45,212,255,.06);color:var(--accent)}
.qcard .qi svg{width:20px;height:20px}
.qcard .qt{font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.1em;font-size:13.5px;color:var(--text)}
.qcard .qd{font-family:var(--font-mono);font-size:10.5px;color:var(--muted);letter-spacing:.05em;margin-top:2px}
.qcard .qext{margin-left:auto;color:var(--muted)}
.qcard .qext svg{width:15px;height:15px}
.qcard.ext .qi{color:var(--gold);border-color:rgba(230,178,92,.3);background:rgba(230,178,92,.06)}

/* ---------- activity log ---------- */
.log{position:relative;padding:6px 4px}
.logrow{position:relative;display:grid;grid-template-columns:22px 1fr auto;gap:14px;align-items:center;padding:12px 8px;border-bottom:1px solid var(--line-soft)}
.logrow:last-child{border-bottom:0}
.logrow .lnode{position:relative;display:grid;place-items:center}
.logrow .lnode .ldot{width:9px;height:9px;border:1.5px solid var(--accent);background:var(--bg);transform:rotate(45deg)}
.logrow::before{content:"";position:absolute;left:14px;top:0;bottom:0;width:1px;background:var(--line-soft);z-index:0}
.logrow:first-child::before{top:50%}
.logrow:last-child::before{bottom:50%}
.logrow .ltext{font-family:var(--font-body);font-size:14px;color:var(--text);z-index:1}
.logrow .ltext b{color:var(--accent);font-weight:600}
.logrow .lkind{font-family:var(--font-mono);font-size:10px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;margin-right:6px}
.logrow .ltime{font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.05em;white-space:nowrap}

/* two-col overview */
.ov-cols{display:grid;grid-template-columns:1fr;gap:22px}

/* ---------- forms / identity edit ---------- */
.form2{display:grid;grid-template-columns:1.35fr .95fr;gap:22px;align-items:start}
.field{display:flex;flex-direction:column;gap:7px;margin-bottom:16px}
.field label{font-family:var(--font-mono);font-size:11px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase;display:flex;justify-content:space-between}
.field label .hint{color:var(--line-2);letter-spacing:.05em}
.ctrl,.inp{width:100%;background:var(--bg-2);border:1px solid var(--line);color:var(--text);padding:11px 13px;font-family:var(--font-body);font-size:14.5px;transition:.16s ease}
.ctrl:focus,.inp:focus,textarea.inp:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(45,212,255,.12)}
textarea.inp{resize:vertical;min-height:96px;line-height:1.5}
.inp.mono{font-family:var(--font-mono);letter-spacing:.03em}
.inp-affix{display:flex;align-items:center;border:1px solid var(--line);background:var(--bg-2)}
.inp-affix:focus-within{border-color:var(--accent);box-shadow:0 0 0 3px rgba(45,212,255,.12)}
.inp-affix .pre{padding:0 4px 0 13px;color:var(--accent);font-family:var(--font-mono);font-size:15px}
.inp-affix .inp{border:0;box-shadow:none!important;padding-left:4px}
select.ctrl{appearance:none;background-image:linear-gradient(45deg,transparent 50%,var(--muted) 50%),linear-gradient(135deg,var(--muted) 50%,transparent 50%);background-position:calc(100% - 18px) 50%,calc(100% - 13px) 50%;background-size:5px 5px,5px 5px;background-repeat:no-repeat;padding-right:36px}

.subpanel{border:1px solid var(--line);background:var(--surface);padding:18px}
.subpanel + .subpanel{margin-top:16px}
.subhead{font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.16em;font-size:12px;color:var(--muted);margin:0 0 14px;display:flex;align-items:center;gap:9px}
.subhead .num{font-family:var(--font-mono);color:var(--line-2);font-size:11px}

/* banner picker */
.banners{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.banner-opt{position:relative;cursor:pointer;border:1px solid var(--line);overflow:hidden;aspect-ratio:16/9;background:var(--bg-2)}
.banner-opt img{width:100%;height:100%;object-fit:cover;filter:brightness(.72) saturate(.9);transition:.2s ease}
.banner-opt .bn{position:absolute;left:0;right:0;bottom:0;font-family:var(--font-mono);font-size:9.5px;letter-spacing:.06em;color:var(--text);background:linear-gradient(180deg,transparent,rgba(5,7,13,.9));padding:12px 7px 5px;text-transform:uppercase}
.banner-opt .bcheck{position:absolute;top:6px;right:6px;width:20px;height:20px;display:none;place-items:center;background:var(--accent);color:var(--ink);clip-path:polygon(4px 0,100% 0,100% calc(100% - 4px),calc(100% - 4px) 100%,0 100%,0 4px)}
.banner-opt .bcheck svg{width:13px;height:13px}
.banner-opt:hover img{filter:brightness(.88)}
.banner-opt[aria-pressed="true"]{border-color:var(--accent);box-shadow:0 0 0 1px var(--accent),0 0 22px -8px rgba(45,212,255,.6)}
.banner-opt[aria-pressed="true"] .bcheck{display:grid}
.banner-opt[aria-pressed="true"] img{filter:brightness(.95)}

/* glyph + color pickers */
.glyphs{display:grid;grid-template-columns:repeat(8,1fr);gap:8px}
.glyph-opt{aspect-ratio:1;border:1px solid var(--line);background:var(--bg-2);color:var(--muted);font-size:22px;display:grid;place-items:center;cursor:pointer;transition:.15s ease}
.glyph-opt:hover{color:var(--text);border-color:var(--line-2)}
.glyph-opt[aria-pressed="true"]{color:var(--ink);background:var(--accent);border-color:var(--accent)}
.swatches{display:flex;gap:10px;flex-wrap:wrap}
.swatch{position:relative;width:38px;height:38px;border:1px solid var(--line);cursor:pointer;display:grid;place-items:center;transition:.15s ease;
  clip-path:polygon(6px 0,100% 0,100% calc(100% - 6px),calc(100% - 6px) 100%,0 100%,0 6px)}
.swatch i{width:20px;height:20px;border-radius:50%;background:var(--sc)}
.swatch[aria-pressed="true"]{box-shadow:0 0 0 2px var(--bg),0 0 0 3px var(--sc)}
.swatch:hover{transform:translateY(-2px)}
.swatch-names{display:flex;flex-wrap:wrap;gap:6px 16px;margin-top:10px}
.swatch-names span{font-family:var(--font-mono);font-size:10px;color:var(--muted)}

/* live identity preview */
.livecard{position:sticky;top:calc(var(--nav) + 66px)}
.lp{border:1px solid var(--line);background:linear-gradient(180deg,var(--surface-2),var(--surface));padding:18px;text-align:center}
.lp .lpav{width:78px;height:78px;margin:0 auto 12px;border:1px solid var(--lpc,var(--accent));display:grid;place-items:center;font-size:40px;color:var(--lpc,var(--accent));background:radial-gradient(120% 90% at 50% 15%,color-mix(in srgb,var(--lpc,var(--accent)) 22%,transparent),transparent 65%)}
.lp .lpname{font-family:var(--font-display);font-weight:900;font-size:20px;letter-spacing:.02em}
.lp .lph{font-family:var(--font-mono);font-size:12px;color:var(--lpc,var(--accent));margin-top:3px}
.lp .lprole{font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:11px;color:var(--muted);margin-top:10px}
.lp .lpstatus{display:inline-flex;align-items:center;gap:8px;font-family:var(--font-mono);font-size:11px;color:var(--muted);margin-top:10px;border:1px solid var(--line);padding:5px 10px}
.lp-cap{font-family:var(--font-mono);font-size:10px;letter-spacing:.16em;color:var(--muted);text-transform:uppercase;text-align:center;margin-bottom:12px}

/* ---------- favorites ---------- */
.fav-filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px}
.chipbtn{font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.1em;font-size:11px;padding:7px 13px;border:1px solid var(--line);color:var(--muted);background:var(--surface);transition:.15s ease}
.chipbtn:hover{color:var(--text);border-color:var(--line-2)}
.chipbtn[aria-pressed="true"]{color:var(--ink);background:var(--accent);border-color:var(--accent)}
.chipbtn .n{font-family:var(--font-mono);opacity:.7;margin-left:5px}
.favgrid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
.fav{position:relative;display:flex;gap:13px;align-items:center;padding:14px;background:var(--surface);border:1px solid var(--line);transition:.16s ease}
.fav:hover{border-color:var(--line-2);background:var(--surface-2)}
.fav .fic{width:40px;height:40px;flex:none;display:grid;place-items:center;border:1px solid var(--line);background:var(--bg-2);color:var(--kc,var(--accent))}
.fav .fic svg{width:20px;height:20px}
.fav .fmain{min-width:0;flex:1}
.fav .fkind{font-family:var(--font-mono);font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--kc,var(--accent))}
.fav .fname{font-family:var(--font-ui);font-weight:600;font-size:14.5px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fav .frm{flex:none;width:26px;height:26px;display:grid;place-items:center;border:1px solid var(--line);color:var(--muted);transition:.15s ease}
.fav .frm:hover{border-color:var(--hot);color:var(--hot);background:rgba(244,112,138,.1)}
.fav .frm svg{width:13px;height:13px}
.fav.removing{opacity:0;transform:scale(.96);transition:.28s ease}

/* ---------- friends ---------- */
.pending{border:1px solid rgba(230,195,74,.32);background:linear-gradient(180deg,rgba(230,195,74,.06),transparent);padding:16px 18px;margin-bottom:22px}
.pending .ph{display:flex;align-items:center;gap:9px;font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:12px;color:var(--amber);margin-bottom:14px}
.pending .ph .cnt{font-family:var(--font-mono);color:var(--ink);background:var(--amber);padding:1px 7px;font-size:11px;letter-spacing:.05em}
.preq{display:flex;align-items:center;gap:14px;flex-wrap:wrap}
.friendlist{display:flex;flex-direction:column;gap:0;border:1px solid var(--line);background:var(--surface)}
.friend{display:grid;grid-template-columns:44px 1fr auto;gap:14px;align-items:center;padding:14px 16px;border-bottom:1px solid var(--line-soft);transition:.15s ease}
.friend:last-child{border-bottom:0}
.friend:hover{background:var(--surface-2)}
.av{width:44px;height:44px;flex:none;display:grid;place-items:center;border:1px solid var(--line);background:var(--bg-2);color:var(--avc,var(--accent));font-family:var(--font-display);font-weight:700;font-size:16px;
  clip-path:polygon(6px 0,100% 0,100% calc(100% - 6px),calc(100% - 6px) 100%,0 100%,0 6px)}
.fr-main{min-width:0}
.fr-name{display:flex;align-items:center;gap:9px;flex-wrap:wrap}
.fr-name b{font-family:var(--font-ui);font-weight:700;font-size:15px;letter-spacing:.02em}
.fr-name .fh{font-family:var(--font-mono);font-size:12px;color:var(--accent)}
.fr-role{font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.04em;margin-top:2px;text-transform:uppercase}
.fr-status{display:flex;align-items:center;gap:8px;font-family:var(--font-mono);font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);white-space:nowrap}
.addbar{display:flex;gap:10px;margin-top:18px;flex-wrap:wrap}
.addbar .inp-affix{flex:1;min-width:220px}

/* ---------- security ---------- */
.seccols{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}
.seccard{border:1px solid var(--line);background:var(--surface);padding:20px;display:flex;flex-direction:column}
.seccard .sc-h{display:flex;align-items:center;gap:11px;margin-bottom:6px}
.seccard .sc-h .sci{width:34px;height:34px;flex:none;display:grid;place-items:center;border:1px solid var(--line);color:var(--accent);background:rgba(45,212,255,.06)}
.seccard .sc-h .sci svg{width:17px;height:17px}
.seccard .sc-h h3{font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.13em;font-size:14px;margin:0}
.seccard .sc-desc{font-family:var(--font-mono);font-size:11.5px;color:var(--muted);margin:0 0 16px;line-height:1.55}
.seccard .field:last-of-type{margin-bottom:16px}
.seccard .sc-foot{margin-top:auto}
.verify-card{grid-column:1/-1;display:grid;grid-template-columns:auto 1fr auto;gap:22px;align-items:center;border:1px solid rgba(90,209,154,.3);background:linear-gradient(120deg,rgba(90,209,154,.07),transparent 60%);padding:20px 22px}
.verify-card .vseal{width:84px;height:84px;color:var(--ok);flex:none}
.verify-card .vmain h3{font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:15px;margin:0 0 5px;display:flex;align-items:center;gap:9px}
.verify-card .vmain h3 .vok{color:var(--ok);font-size:12px;border:1px solid rgba(90,209,154,.4);padding:2px 8px;letter-spacing:.1em}
.verify-card .vmain .vd{font-family:var(--font-mono);font-size:12px;color:var(--muted);line-height:1.6}
.verify-card .vmain .vd b{color:var(--text);font-weight:400}
.danger-card{grid-column:1/-1;border:1px solid rgba(244,112,138,.4);background:linear-gradient(180deg,rgba(244,112,138,.05),transparent);position:relative;overflow:hidden}
.danger-card .dz-hazard{height:6px;background:repeating-linear-gradient(-45deg,rgba(244,112,138,.7) 0 10px,transparent 10px 20px)}
.danger-card .dz-body{padding:20px 22px;display:grid;grid-template-columns:1fr auto;gap:20px;align-items:center}
.danger-card h3{font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.14em;font-size:15px;margin:0 0 6px;color:var(--hot);display:flex;align-items:center;gap:9px}
.danger-card .stamp{position:absolute;right:18px;top:22px;font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;color:rgba(244,112,138,.5);border:1.5px solid rgba(244,112,138,.4);padding:4px 10px;transform:rotate(-8deg);text-transform:uppercase;pointer-events:none}
.danger-card p{font-family:var(--font-mono);font-size:11.5px;color:var(--muted);margin:0;max-width:56ch;line-height:1.6}
.danger-card .dz-input{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-top:14px}
.danger-card .dz-input .inp{max-width:230px}

/* toast */
.toast{position:fixed;left:50%;bottom:28px;transform:translateX(-50%) translateY(20px);background:var(--surface-2);border:1px solid var(--line-2);color:var(--text);font-family:var(--font-mono);font-size:12.5px;letter-spacing:.04em;padding:11px 18px;z-index:80;opacity:0;pointer-events:none;transition:.3s cubic-bezier(.4,0,.2,1);display:flex;align-items:center;gap:9px;
  clip-path:polygon(8px 0,100% 0,100% calc(100% - 8px),calc(100% - 8px) 100%,0 100%,0 8px)}
.toast svg{width:15px;height:15px;color:var(--ok)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

.divider{height:1px;background:repeating-linear-gradient(90deg,var(--line-2) 0 6px,transparent 6px 12px);margin:2px 0;opacity:.5}

/* ---------- responsive ---------- */
@media(max-width:1080px){
  .metrics{grid-template-columns:repeat(3,1fr)}
  .qgrid{grid-template-columns:repeat(2,1fr)}
  .favgrid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:900px){
  .form2{grid-template-columns:1fr}
  .livecard{position:static;order:-1}
  .seccols{grid-template-columns:1fr}
  .verify-card{grid-template-columns:auto 1fr;gap:16px}
  .verify-card .btn{grid-column:1/-1}
}
@media(max-width:820px){
  .dsr{font-size:14.5px}
  .rec-body{grid-template-columns:110px 1fr;gap:16px;padding:16px}
  .holostrip{right:88px;width:16px}
  .fieldgrid{grid-template-columns:1fr}
  .seal{width:92px;height:92px;right:12px;bottom:auto;top:12px}
  .metrics{grid-template-columns:repeat(2,1fr)}
  .qgrid{grid-template-columns:1fr}
  .favgrid{grid-template-columns:1fr}
  .danger-card .dz-body{grid-template-columns:1fr}
  .mh-right{width:100%}
}
@media(max-width:560px){
  .metrics{grid-template-columns:1fr}
  .glyphs{grid-template-columns:repeat(4,1fr)}
  .banners{grid-template-columns:repeat(2,1fr)}
  .rec-body{grid-template-columns:1fr}
  .photo{max-width:150px}
  .holostrip{display:none}
  .friend{grid-template-columns:40px 1fr;gap:12px}
  .fr-status{grid-column:2;justify-content:flex-start}
  .name-row{gap:8px}
}

@media(prefers-reduced-motion:reduce){
  *,*::before,*::after{animation:none!important;transition:none!important}
  .panel.active{animation:none}
}

/* --- site-integration + a11y grafts (from judge panel) --- */
/* neutralise the site-global `section{padding:...}` rule (detail.css) — our
   tab panels are <section> and were inheriting ~99px of dead vertical padding */
.dsr .panel{padding:0;margin:0}
.dsr :is(a,button,input,select,textarea,[role=tab]):focus-visible{outline:2px solid var(--accent);outline-offset:2px}
.rec-remarks{margin-top:4px;border-left:2px solid var(--line-2);padding:1px 0 1px 12px}
.rec-remarks .rk{display:block;font-family:var(--font-mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
.rec-remarks p{margin:0;font-family:var(--font-body);font-size:13px;line-height:1.55;color:#c9d6ee;max-width:66ch}

/* ================= LEGIBILITY + RUHE (Polish-Pass) ================= */
/* mehr Kontrast beim Kleintext, ruhigere Grundtypo */
.dsr{--muted:#a6b4d2;font-size:15.5px;line-height:1.64}

/* Inhalt/Werte in Barlow statt Mono, ohne Sperrung — Mono nur noch fuer echte Codes/Zeiten */
.dsr :is(.status-line,.status-line b,.mh-meta .v,.frow .v,.metric .sub,.metric .versub,
  .qcard .qd,.fr-role,.fr-status,.seccard .sc-desc,.verify-card .vmain .vd,
  .danger-card p,.lp .lpstatus,.ringwrap .rmeta,.preq .fr-role){font-family:var(--font-body);letter-spacing:normal}
.status-line b,.frow .v,.mh-meta .v{color:var(--text)}
.frow .v.reg{font-family:var(--font-mono);color:var(--accent)}

/* groessere, ruhigere Labels */
.dsr :is(.frow .k,.mh-meta .k,.metric .mlabel .k,.subhead){font-size:10.5px;letter-spacing:.1em}

/* mehr Luft zwischen allem */
.stack{gap:26px}
.dsec{margin:8px 0 22px}
.dsec h2{font-size:18px;letter-spacing:.08em}
.rec-body{gap:26px;padding:26px}
.fieldgrid{margin-top:6px}
.frow{padding:14px 18px}
.frow .v{font-size:14.5px;margin-top:5px}
.rec-remarks{margin-top:8px}
.rec-remarks p{font-size:14px;line-height:1.6}
.metrics{gap:16px}
.metric{padding:20px 18px 18px}
.metric .sub{font-size:12px}
.qgrid{gap:16px}
.qcard{padding:18px}
.qcard .qt{letter-spacing:.05em;font-size:14px;text-transform:none}
.qcard .qd{font-size:12px}
.friend{padding:16px 18px}
.log .logrow{padding:14px 10px}
.logrow .ltext{font-size:14.5px}
.seccard{padding:24px}
.seccard .sc-desc{font-size:13px;line-height:1.6}

/* dekorative Mikrotexte zuruecknehmen, damit der echte Inhalt fuehrt */
.class-strip .dwrap{opacity:.6}
.rec-banner .barcode{opacity:.38}
.record .watermark{opacity:.5}
.mrz{opacity:.62}
.mrz .mrz-lines{font-size:12px;letter-spacing:.1em}

/* ================= CINEMATIC PILOT HERO (Landingpage-Qualitaet) ================= */
.dsr{padding-top:0}
.phero{position:relative;overflow:hidden;isolation:isolate;display:flex;align-items:flex-end;min-height:clamp(440px,60svh,600px)}
.ph__img{position:absolute;inset:0;z-index:-2;background:var(--media-void) center/cover no-repeat;background-image:var(--hero);transform:scale(1.06);animation:kenburns 34s ease-in-out infinite alternate}
@keyframes kenburns{from{transform:scale(1.06)}to{transform:scale(1.14) translate3d(-1.5%,-1%,0)}}
.ph__scrim{position:absolute;inset:0;z-index:-1;background:
  linear-gradient(90deg,rgba(4,6,12,.9) 0%,rgba(4,6,12,.56) 44%,rgba(4,6,12,.12) 78%,transparent 100%),
  linear-gradient(0deg,var(--bg) 1%,rgba(4,6,12,.58) 26%,transparent 64%)}
.ph__in{position:relative;z-index:1;width:100%;padding-top:calc(var(--nav) + clamp(2rem,4vw,3rem));padding-bottom:clamp(2rem,4vw,3.4rem)}
.ph__kicker{display:inline-flex;align-items:center;gap:.7rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;font-size:.74rem;color:var(--accent)}
.ph__kicker::before{content:"";width:28px;height:1px;background:var(--accent)}
.ph__row{display:flex;align-items:center;gap:clamp(16px,2vw,24px);margin:1.15rem 0 0}
.ph__av{width:clamp(60px,6vw,84px);aspect-ratio:1;flex:none;display:grid;place-items:center;border:1px solid var(--line-2);background:radial-gradient(120% 90% at 50% 12%,rgba(45,212,255,.22),transparent 60%),linear-gradient(180deg,var(--surface-2),#0b1120);clip-path:polygon(10px 0,100% 0,100% calc(100% - 10px),calc(100% - 10px) 100%,0 100%,0 10px)}
.ph__av span{font-size:clamp(28px,3vw,38px);color:var(--accent);text-shadow:0 0 22px rgba(45,212,255,.45)}
.ph__name{font-family:var(--font-display);font-weight:900;line-height:.9;letter-spacing:-.02em;margin:0;font-size:clamp(2.7rem,7.5vw,5.6rem);background:linear-gradient(180deg,#fff 52%,color-mix(in srgb,#fff 58%,var(--accent)));-webkit-background-clip:text;background-clip:text;color:transparent;text-shadow:0 10px 60px rgba(0,0,0,.5)}
.ph__chips{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:16px}
.ph__handle{font-family:var(--font-mono);font-size:1rem;color:var(--accent-2)}
.ph__chip{display:inline-flex;align-items:center;gap:6px;font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.1em;font-size:11px;padding:6px 11px;border:1px solid var(--on-media-line);background:rgba(4,6,12,.5);backdrop-filter:blur(4px);color:var(--on-media-dim)}
.ph__chip svg{width:13px;height:13px}
.ph__chip.ok{color:var(--ok);border-color:rgba(90,209,154,.5)}
.ph__lede{max-width:60ch;margin:1.05rem 0 0;font-size:clamp(1rem,1.5vw,1.2rem);font-weight:500;line-height:1.55;color:var(--on-media-dim);text-shadow:0 2px 18px rgba(0,0,0,.6)}
.ph__meta{display:flex;flex-wrap:wrap;gap:7px 28px;margin-top:1.2rem;font-family:var(--font-mono);font-size:13px;color:var(--on-media-dim)}
.ph__meta span{white-space:nowrap}
.ph__meta b{color:var(--muted);font-weight:400;text-transform:uppercase;letter-spacing:.12em;font-size:10px;margin-right:8px}
.ph__acts{display:flex;gap:12px;flex-wrap:wrap;margin-top:1.5rem}
@media(prefers-reduced-motion:reduce){.ph__img{animation:none}}
@media(max-width:640px){.ph__row{gap:14px}.ph__meta{gap:7px 18px}.ph__name{font-size:clamp(2.4rem,13vw,3.4rem)}}

/* cleaner tabs (weniger Verwaltungs-Mikrotext) */
.tab .idx{display:none}
.tab{padding:15px 24px}
.tab .lbl{letter-spacing:.16em}

/* Sektions-Ueberschriften auf Landing-Niveau */
.dsec{align-items:baseline;gap:14px;margin:8px 0 24px}
.dsec h2{font-family:var(--font-display);font-weight:800;font-size:clamp(1.35rem,2.4vw,2rem);letter-spacing:0;text-transform:none;color:var(--text)}
.dsec .code{margin-left:auto}
.dpanels{padding-block:clamp(2.2rem,4vw,3.2rem) 96px}
.stack{gap:clamp(2.2rem,4vw,3rem)}

/* Quick-Access: Titel/Untertitel sauber stapeln (war inline verklebt) */
.qcard .qt{display:block}
.qcard .qd{display:block;margin-top:3px}

/* ================= COMFORT / LESBARKEIT (weniger HUD-Haerte) ================= */
.dsr{--muted:#b6c3db;font-size:16px;line-height:1.66}

/* Labels: Satzschrift statt Caps-Sperrung, groesser, mehr Kontrast */
.dsr :is(.metric .mlabel .k,.frow .k,.mh-meta .k,.subhead,.fav .fkind,.fr-role,
  .fr-status,.seccard .sc-h h3,.logrow .lkind,.chipbtn,.ph__chip,.ph__meta b,
  .metric .versub,.dsec h2,.qcard .qt,.qcard .qd,.tab .lbl,.rd__k,.photo-cap){
  text-transform:none;letter-spacing:.005em}

