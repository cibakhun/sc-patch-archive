---
// TEMP Design-Vorschau (noindex, kein Auth) — echte Site-Umgebung + Demo-Daten,
// damit der Design-Durchgang live sichtbar ist, ohne Login. Wird nach Freigabe
// aufs echte Dashboard portiert und wieder geloescht.
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
---
<Layout title="Citizen Terminal — Preview | VerseBase" noindex={true} themeColor="#04060c">
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>
  :root{
    --bg:#05070d;--bg-2:#0a0e18;--surface:#0f1524;--surface-2:#141c30;
    --accent:#2dd4ff;--accent-2:#6ea8ff;--gold:#e6b25c;--ok:#5ad19a;
    --text:#e8eefc;--muted:#8a99b8;--line:rgba(110,168,255,.16);--line-2:rgba(110,168,255,.32);
  }
  *{box-sizing:border-box}
  .ct{position:relative;min-height:100vh;overflow:hidden;font-family:var(--font-body)}
  /* Vollflaechiges Cinematic — das ganze Panel liegt auf einem Schiff-Render */
  .ct__sky{position:absolute;inset:0;z-index:0;background:url('/assets/img-polaris.jpg') center 20%/cover no-repeat;
    animation:ctkb 40s ease-in-out infinite alternate}
  @keyframes ctkb{from{transform:scale(1.04)}to{transform:scale(1.14)}}
  .ct__veil{position:absolute;inset:0;z-index:1;background:
    linear-gradient(180deg,rgba(4,6,12,.55),rgba(4,6,12,.72) 42%,rgba(4,6,12,.94) 78%,var(--bg) 100%),
    radial-gradient(120% 80% at 78% 6%,transparent,rgba(4,6,12,.6) 80%)}
  .ct__grid{position:absolute;inset:0;z-index:2;pointer-events:none;opacity:.5;
    background-image:linear-gradient(rgba(110,168,255,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(110,168,255,.06) 1px,transparent 1px);
    background-size:54px 54px;-webkit-mask-image:linear-gradient(180deg,#000,transparent 60%);mask-image:linear-gradient(180deg,#000,transparent 60%)}
  .ct__scan{position:absolute;left:0;right:0;top:0;height:120px;z-index:2;pointer-events:none;
    background:linear-gradient(180deg,transparent,rgba(45,212,255,.06),transparent);animation:ctscan 8s linear infinite}
  @keyframes ctscan{0%{top:-120px}60%,100%{top:100%}}
  @media(prefers-reduced-motion:reduce){.ct__sky,.ct__scan{animation:none}}

  .ct__in{position:relative;z-index:3;max-width:1360px;margin:0 auto;padding:clamp(6.5rem,11vh,9rem) clamp(1.2rem,4vw,3.2rem) 5rem;
    animation:ctrise .7s cubic-bezier(.2,.7,.2,1) both}
  @keyframes ctrise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}

  .ct__kick{display:flex;align-items:center;gap:.7rem;font-family:var(--font-ui);font-weight:700;font-size:.82rem;
    letter-spacing:.3em;text-transform:uppercase;color:var(--accent);margin-bottom:1rem;text-shadow:0 2px 14px rgba(0,0,0,.8)}
  .ct__kick::before{content:"";width:34px;height:1px;background:linear-gradient(90deg,var(--accent),transparent)}

  /* Kopf: Riesen-Metallic-Name + Holo-Avatar + Aktionen */
  .ct__head{display:flex;align-items:flex-end;gap:clamp(1.5rem,4vw,3.5rem);flex-wrap:wrap}
  .ct__portrait{position:relative;width:clamp(96px,11vw,140px);aspect-ratio:1;flex:none}
  .ct__portrait .ring{position:absolute;inset:-9px;color:var(--accent);opacity:.7;animation:ctspin 34s linear infinite}
  @media(prefers-reduced-motion:reduce){.ct__portrait .ring{animation:none}}
  .ct__portrait .core{position:absolute;inset:0;overflow:hidden;border:1px solid var(--line-2);
    clip-path:polygon(0 0,100% 0,100% calc(100% - 20px),calc(100% - 20px) 100%,0 100%);
    background:linear-gradient(150deg,#183a55,#0a1626 72%);display:grid;place-items:center}
  .ct__portrait .core span{font-family:var(--font-display);font-weight:900;font-size:clamp(1.9rem,3vw,2.8rem);
    background:linear-gradient(180deg,#fff,var(--accent) 80%);-webkit-background-clip:text;background-clip:text;color:transparent}
  .ct__portrait .live{position:absolute;right:-3px;bottom:-3px;width:16px;height:16px;border-radius:50%;background:var(--ok);
    border:3px solid #04060c;box-shadow:0 0 10px var(--ok);animation:ctpulse 2.4s ease infinite}
  .ct__namewrap{min-width:0;flex:1 1 320px}
  .ct__name{font-family:var(--font-display);font-weight:900;line-height:.86;font-size:clamp(3rem,10vw,7.4rem);letter-spacing:.005em;margin:0;
    background:linear-gradient(180deg,#f2f7ff,var(--accent-2) 58%,var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent;
    filter:drop-shadow(0 4px 40px rgba(45,212,255,.3))}
  .ct__row{display:flex;align-items:center;gap:.7rem;flex-wrap:wrap;margin-top:1.1rem}
  .ct__handle{font-family:var(--font-ui);font-weight:700;font-size:clamp(1rem,1.6vw,1.35rem);color:var(--accent-2);letter-spacing:.04em}
  .chip{display:inline-flex;align-items:center;gap:.4rem;font-family:var(--font-ui);font-weight:700;font-size:.72rem;letter-spacing:.12em;
    text-transform:uppercase;padding:.32rem .6rem;border:1px solid var(--line-2);background:rgba(10,20,34,.6);backdrop-filter:blur(4px);color:var(--muted)}
  .chip svg{width:13px;height:13px}
  .chip--ok{color:var(--ok);border-color:rgba(90,209,154,.45)}
  .chip--ok svg{color:var(--ok)}
  .chip .dot{width:6px;height:6px;border-radius:50%;background:var(--ok);box-shadow:0 0 7px var(--ok)}
  .ct__acts{display:flex;gap:.6rem;flex-wrap:wrap;margin-top:1.4rem}
  .btn{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--font-ui);font-weight:700;font-size:.82rem;letter-spacing:.06em;
    text-transform:uppercase;padding:.7rem 1.15rem;cursor:pointer;border:1px solid var(--line-2);color:var(--text);background:rgba(10,20,34,.5);
    backdrop-filter:blur(4px);clip-path:polygon(9px 0,100% 0,100% calc(100% - 9px),calc(100% - 9px) 100%,0 100%,0 9px);transition:.18s}
  .btn svg{width:15px;height:15px;color:var(--accent)}
  .btn:hover{border-color:var(--accent);background:rgba(45,212,255,.1)}
  .btn--primary{background:var(--accent);color:#04121a;border-color:var(--accent)}
  .btn--primary svg{color:#04121a}
  .btn--primary:hover{filter:brightness(1.1)}

  /* Metrics-HUD-Band */
  .ct__metrics{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;margin:clamp(2.4rem,5vw,3.8rem) 0 0;
    border:1px solid var(--line);background:var(--line)}
  .met{position:relative;background:rgba(9,14,24,.72);backdrop-filter:blur(6px);padding:1.15rem 1.2rem 1.25rem}
  .met::before{content:"";position:absolute;top:0;left:0;width:16px;height:2px;background:var(--accent)}
  .met dt{font-family:var(--font-ui);font-weight:700;font-size:.68rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:.4rem}
  .met dt svg{width:14px;height:14px;color:var(--accent)}
  .met dd{margin:.85rem 0 0;font-family:var(--font-ui);font-weight:700;font-size:clamp(1.9rem,2.6vw,2.4rem);color:var(--accent);
    font-variant-numeric:tabular-nums;line-height:1}
  .met dd u{font-family:var(--font-ui);font-size:.8rem;color:var(--muted);text-decoration:none;font-weight:600;margin-left:.2rem}
  .met .s{font-family:var(--font-ui);font-size:.72rem;color:var(--muted);margin-top:.7rem;letter-spacing:.03em}
  .met--gold::before{background:var(--gold)}.met--gold dt svg{color:var(--gold)}.met--gold dd{color:var(--gold)}

  /* Untere Panels */
  .ct__cols{display:grid;grid-template-columns:1.5fr 1fr;gap:1.4rem;margin-top:1.4rem}
  .panel{position:relative;border:1px solid var(--line);background:rgba(9,14,24,.62);backdrop-filter:blur(6px);padding:1.3rem 1.4rem 1.5rem;
    clip-path:polygon(0 0,100% 0,100% calc(100% - 16px),calc(100% - 16px) 100%,0 100%)}
  .panel::after{content:"";position:absolute;left:0;top:0;width:14px;height:14px;border-top:2px solid var(--accent);border-left:2px solid var(--accent)}
  .panel h2{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.24em;text-transform:uppercase;color:var(--muted);margin:0 0 1.1rem;display:flex;align-items:center;gap:.7rem}
  .panel h2 b{color:var(--accent);font-weight:700}
  .panel h2 .r{flex:1;height:1px;background:linear-gradient(90deg,var(--line-2),transparent)}

  .acc a{display:flex;align-items:center;gap:.9rem;padding:.9rem 0;border-top:1px solid var(--line);transition:.2s}
  .acc a:first-of-type{border-top:0}
  .acc .i{width:34px;height:34px;flex:none;display:grid;place-items:center;border:1px solid var(--line);color:var(--accent);background:rgba(45,212,255,.08)}
  .acc .i svg{width:18px;height:18px}
  .acc .t{flex:1;min-width:0}
  .acc .t b{display:block;font-family:var(--font-ui);font-weight:700;font-size:1.05rem;color:var(--text)}
  .acc .t span{display:block;font-family:var(--font-ui);font-size:.76rem;color:var(--accent-2);letter-spacing:.03em}
  .acc .go{font-family:var(--font-ui);color:var(--muted);transition:.2s}
  .acc a:hover{padding-left:.7rem}.acc a:hover .go{color:var(--accent);transform:translateX(3px)}

  .log__row{display:grid;grid-template-columns:auto 1fr auto;gap:.8rem;align-items:baseline;padding:.75rem 0;border-top:1px solid var(--line);font-size:.9rem;color:var(--muted)}
  .log__row:first-of-type{border-top:0}
  .log__row .d{width:6px;height:6px;border-radius:50%;background:var(--accent);align-self:center}
  .log__row em{font-style:normal;color:var(--text);font-weight:600}
  .log__row time{font-family:var(--font-ui);font-size:.72rem;color:var(--muted);letter-spacing:.06em;white-space:nowrap}

  @keyframes ctspin{to{transform:rotate(360deg)}}
  @keyframes ctpulse{0%,100%{opacity:1}50%{opacity:.4}}
  @media(max-width:820px){.ct__metrics{grid-template-columns:repeat(2,1fr)}.ct__cols{grid-template-columns:1fr}.ct__name{font-size:clamp(2.6rem,15vw,4rem)}}

  svg.ic0{display:none}
</style>

<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>
<SiteNav crumbs={[{ label: 'Account' }]} hasEn={true} />

<svg class="ic0" xmlns="http://www.w3.org/2000/svg"><defs>
  <symbol id="p-star" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.6l2.5 5.2 5.7.8-4.1 4 1 5.6L12 16.9l-5.1 2.3 1-5.6-4.1-4 5.7-.8z"/></symbol>
  <symbol id="p-users" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3.6 18.6c.6-2.9 2.8-4.3 5.4-4.3s4.8 1.4 5.4 4.3"/><path d="M16.2 5.3a3 3 0 0 1 0 5.4"/><path d="M17.6 14.5c1.9.6 3.2 1.9 3.8 4.1"/></symbol>
  <symbol id="p-hex" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7.4 4.2v8.4L12 21l-7.4-4.2V7.2z"/><path d="M12 8l3.5 2v4L12 16l-3.5-2v-4z"/></symbol>
  <symbol id="p-id" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="1"/><circle cx="8.5" cy="11" r="2"/><path d="M5.4 16.4c.5-1.4 1.7-2.1 3.1-2.1s2.6.7 3.1 2.1"/><path d="M14.5 10h4M14.5 13h3"/></symbol>
  <symbol id="p-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 2.4v5.4c0 4.4-3 7.5-7 8.9-4-1.4-7-4.5-7-8.9V5.4z"/></symbol>
  <symbol id="p-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 2.4v5.4c0 4.4-3 7.5-7 8.9-4-1.4-7-4.5-7-8.9V5.4z"/><path d="M8.6 12l2.2 2.2 4.4-4.7"/></symbol>
  <symbol id="p-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 16L16 8"/><path d="M9.5 8H16v6.5"/></symbol>
  <symbol id="p-edit" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20.5h16"/><path d="M14.5 5.5l4 4L9 19l-4.5 1 1-4.5z"/></symbol>
  <symbol id="p-org" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20V6l6-2.5V20"/><path d="M10 8h6a2 2 0 0 1 2 2v10"/><path d="M13 12h2M13 15h2"/></symbol>
</defs></svg>

<main id="main">
  <div class="ct">
    <div class="ct__sky" aria-hidden="true"></div>
    <div class="ct__veil" aria-hidden="true"></div>
    <div class="ct__grid" aria-hidden="true"></div>
    <div class="ct__scan" aria-hidden="true"></div>

    <div class="ct__in">
      <div class="ct__kick">UEE Citizen Registry // Pilot Dossier</div>

      <div class="ct__head">
        <div class="ct__portrait">
          <svg class="ring" viewBox="0 0 132 132" fill="none" stroke="currentColor"><circle cx="66" cy="66" r="62" stroke-width="1.5" stroke-dasharray="24 12"/><circle cx="66" cy="66" r="62" stroke-width="3" stroke-dasharray="4 92"/></svg>
          <div class="core"><span>KX</span></div>
          <span class="live"></span>
        </div>
        <div class="ct__namewrap">
          <h1 class="ct__name">KrysX141</h1>
          <div class="ct__row">
            <span class="ct__handle">@krysx141</span>
            <span class="chip chip--ok"><svg><use href="#p-check"/></svg> RSI Verified</span>
            <span class="chip"><svg><use href="#p-hex"/></svg> Mining Specialist</span>
            <span class="chip"><span class="dot"></span> In-Verse · Lyria</span>
            <span class="chip"><svg><use href="#p-org"/></svg> VerseBase Fleet — QA Tester</span>
          </div>
          <div class="ct__acts">
            <a class="btn btn--primary"><svg><use href="#p-out"/></svg> Public Profile</a>
            <a class="btn"><svg><use href="#p-edit"/></svg> Edit Profile</a>
          </div>
        </div>
      </div>

      <dl class="ct__metrics">
        <div class="met"><dt><svg><use href="#p-star"/></svg> Favorites</dt><dd>12</dd><div class="s">+3 this week</div></div>
        <div class="met"><dt><svg><use href="#p-users"/></svg> Network</dt><dd>08</dd><div class="s">1 request pending</div></div>
        <div class="met met--gold"><dt><svg><use href="#p-hex"/></svg> Refinery yield</dt><dd>428<u>K aUEC</u></dd><div class="s">2 jobs active</div></div>
        <div class="met"><dt><svg><use href="#p-id"/></svg> Completeness</dt><dd>80<u>%</u></dd><div class="s">avatar missing</div></div>
        <div class="met"><dt><svg><use href="#p-shield"/></svg> RSI status</dt><dd style="font-size:1.4rem;color:var(--ok);margin-top:1.1rem">Verified</dd><div class="s">@Roberts</div></div>
      </dl>

      <div class="ct__cols">
        <div class="panel acc">
          <h2><b>02</b> Access <span class="r"></span></h2>
          <a><span class="i"><svg><use href="#p-id"/></svg></span><span class="t"><b>Profile &amp; Identity</b><span>Name, avatar, banner, role</span></span><span class="go">→</span></a>
          <a><span class="i"><svg><use href="#p-star"/></svg></span><span class="t"><b>Favorites</b><span>12 ships, items &amp; missions</span></span><span class="go">→</span></a>
          <a><span class="i"><svg><use href="#p-users"/></svg></span><span class="t"><b>Network</b><span>Friends, requests &amp; pilots</span></span><span class="go">→</span></a>
          <a><span class="i"><svg><use href="#p-hex"/></svg></span><span class="t"><b>Refinery Tracker</b><span>Ore jobs &amp; yield</span></span><span class="go">↗</span></a>
          <a><span class="i"><svg><use href="#p-shield"/></svg></span><span class="t"><b>Security</b><span>E-mail, password, RSI, account</span></span><span class="go">→</span></a>
        </div>
        <div class="panel">
          <h2><b>03</b> Log <span class="r"></span></h2>
          <div class="log__row"><span class="d"></span><span>Favorited <em>Drake Cutlass Black</em></span><time>14:20</time></div>
          <div class="log__row"><span class="d"></span><span>Request from <em>@nova_pilot</em></span><time>Yesterday</time></div>
          <div class="log__row"><span class="d"></span><span>Refinery job <em>ARC-L1 · Ferrous</em></span><time>21.07.</time></div>
          <div class="log__row"><span class="d"></span><span>RSI account <em>verified</em></span><time>20.07.</time></div>
        </div>
      </div>
    </div>
  </div>
</main>

<script is:inline src="/assets/detail.js"></script>
</Layout>
