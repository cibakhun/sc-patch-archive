/* konsistenter, groszuegiger Sektions-Rhythmus */
.stack{gap:clamp(2.4rem,4.5vw,3.6rem)}
.dpanels{padding-block:clamp(2.4rem,4vw,3.4rem) 110px}

/* Favoriten fuellen die Breite (auto 4 Spalten auf grossen Screens) */
.favgrid{grid-template-columns:repeat(auto-fill,minmax(320px,1fr))}

/* Sicherheit: zwei ausgewogene Spalten */
.seccols{gap:20px}

@media(max-width:960px){.ov-cols{grid-template-columns:1fr}.qgrid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.qgrid{grid-template-columns:1fr}}

/* ================= UI / UX PASS ================= */
/* konsistente Uebergaenge + Press-Feedback auf allen Bedienelementen */
.btn,.qcard,.fav,.friend,.chipbtn,.banner-opt,.glyph-opt,.swatch,.tab,.metric--act,.frm,.acbtn{
  transition:transform .16s ease,border-color .18s ease,background .18s ease,box-shadow .18s ease,color .18s ease}
.btn:active,.qcard:active,.metric--act:active,.chipbtn:active,.fav:active{transform:translateY(1px)}

/* klickbare Metrik-Karten: klare Affordance */
.metric--act{cursor:pointer}
.metric--act:hover{transform:translateY(-3px);border-color:color-mix(in srgb,var(--accent) 55%,transparent);box-shadow:0 14px 34px color-mix(in srgb,var(--accent) 13%,transparent)}

/* Activity-Zeilen: Hover-Feedback (scannbarer) */
.logrow{transition:background .15s ease}
.logrow:hover{background:color-mix(in srgb,var(--accent) 7%,transparent)}

/* Cursor + einheitlicher, gut sichtbarer Fokusring */
.tab,.qcard,.fav,.chipbtn,.banner-opt,.glyph-opt,.swatch,.frm,.btn,.acbtn{cursor:pointer}
.dsr :is(a,button,[role=button],[role=link],[role=tab],input,select,textarea):focus-visible{outline:2px solid var(--accent);outline-offset:3px}

@media(prefers-reduced-motion:reduce){
  .btn:active,.qcard:active,.metric--act:hover,.metric--act:active,.chipbtn:active,.fav:active{transform:none}
}




