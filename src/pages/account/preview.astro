/* HUD-Deko dezenter */
.framed::before,.framed::after{opacity:.32}

/* ================= OVERLAY PASS: Seiten-Atmosphaere + Frosted-Glass ================= */
/* eine zusammenhaengende Ebene: gefadetes Nebel-Bild + Akzent-Glows hinter allem */
.dsr{position:relative;z-index:0;background:#05070d}
.dsr::before{content:"";position:fixed;inset:0;z-index:-2;pointer-events:none;
  background:url('/assets/t-nyx-1.jpg') center/cover no-repeat;
  opacity:.18;filter:blur(3px) saturate(.85) brightness(.72)}
.dsr::after{content:"";position:fixed;inset:0;z-index:-1;pointer-events:none;background:
  radial-gradient(1200px 780px at 82% -8%, color-mix(in srgb,var(--accent) 14%,transparent), transparent 58%),
  radial-gradient(1000px 700px at 0% 14%, color-mix(in srgb,var(--accent-2) 11%,transparent), transparent 55%),
  radial-gradient(1000px 1000px at 60% 112%, color-mix(in srgb,var(--accent) 8%,transparent), transparent 60%),
  linear-gradient(180deg, rgba(5,7,13,.35) 0%, transparent 30%, transparent 72%, rgba(5,7,13,.55))}

/* Panels schweben als Frosted-Glass auf der Atmosphaere */
.metric,.qcard,.card,.friendlist,.seccard,.subpanel,.log,.fav{
  background:color-mix(in srgb,var(--surface) 55%,transparent);
  -webkit-backdrop-filter:blur(14px) saturate(1.18);backdrop-filter:blur(14px) saturate(1.18)}
.lp{background:color-mix(in srgb,var(--surface-2) 58%,transparent);-webkit-backdrop-filter:blur(14px);backdrop-filter:blur(14px)}
.pending{background:linear-gradient(180deg,color-mix(in srgb,var(--amber) 11%,transparent),color-mix(in srgb,var(--surface) 42%,transparent));-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px)}
.verify-card{background:linear-gradient(120deg,color-mix(in srgb,var(--ok) 9%,transparent),color-mix(in srgb,var(--surface) 50%,transparent) 62%);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px)}
.danger-card{background:linear-gradient(180deg,color-mix(in srgb,var(--hot) 7%,transparent),color-mix(in srgb,var(--surface) 50%,transparent));-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px)}
.friend{background:transparent}
.friend:hover{background:color-mix(in srgb,var(--surface-2) 55%,transparent)}
.tabsbar{background:color-mix(in srgb,var(--bg-2) 60%,transparent);-webkit-backdrop-filter:blur(14px);backdrop-filter:blur(14px)}
/* Glaskanten etwas heller, damit die Panels sauber abheben */
.metric,.qcard,.card,.friendlist,.seccard,.fav,.log{border-color:color-mix(in srgb,var(--line-2) 55%,transparent)}
@media (prefers-reduced-motion:reduce){.dsr::before{filter:blur(3px) saturate(.85) brightness(.72)}}

/* ================= LAYOUT PASS ================= */
/* mehr Breite -> vollwertiges Dashboard auf grossen Screens */
.dwrap{max-width:1500px}

/* Overview: breitere Quick-access-Flaeche + Activity-Sidebar, gleiche Oberkante */
.ov-cols{grid-template-columns:1.55fr 1fr;gap:clamp(1.6rem,3vw,2.6rem);align-items:start}
.qgrid{grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
