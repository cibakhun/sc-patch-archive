<script is:inline>
(function(){
  "use strict";
  var $  = function(s,c){return (c||document).querySelector(s);};
  var $$ = function(s,c){return Array.prototype.slice.call((c||document).querySelectorAll(s));};

  /* ---------- toast ---------- */
  var toastEl=$("#toast"), toastMsg=$("#toastMsg"), toastT;
  function toast(msg){ toastMsg.textContent=msg; toastEl.classList.add("show"); clearTimeout(toastT); toastT=setTimeout(function(){toastEl.classList.remove("show");},2600); }

  /* ---------- tab switching ---------- */
  var tabs=$$(".tab");
  function activate(id){
    tabs.forEach(function(t){ t.setAttribute("aria-selected", t.dataset.tab===id ? "true":"false"); });
    $$(".panel").forEach(function(p){ p.classList.toggle("active", p.id==="panel-"+id); });
    (function(){var tb=document.querySelector(".tabsbar");var nv=parseInt(getComputedStyle(document.documentElement).getPropertyValue("--nav"))||64;var y=tb?Math.max(0,tb.getBoundingClientRect().top+window.pageYOffset-nv):0;try{window.scrollTo({top:y,behavior:"smooth"});}catch(e){window.scrollTo(0,y);}})();
  }
  tabs.forEach(function(t){ t.addEventListener("click", function(){ activate(t.dataset.tab); }); });
  $$("[data-goto]").forEach(function(b){ b.addEventListener("click", function(){ activate(b.dataset.goto); }); });

  /* ---------- quick actions ---------- */
  $$("[data-share]").forEach(function(b){ b.addEventListener("click", function(){ toast("Public profile link copied — /pilot/krysx141"); }); });
  $$("[data-toast]").forEach(function(b){ b.addEventListener("click", function(){ toast(b.getAttribute("data-toast")); }); });

  /* ---------- profile: pickers + live preview ---------- */
  var lp=$("#livePreview"), lpAv=$("#lpAvatar"), lpName=$("#lpName"), lpHandle=$("#lpHandle"), lpRole=$("#lpRole"), lpStatus=$("#lpStatus"), lpDot=$("#lpDot");
  var presenceMap={ "Online":"var(--accent-2)", "In-Verse":"var(--ok)", "On Mission":"var(--amber)", "Away":"var(--orange)", "Offline":"var(--muted)" };
  var pulseSet={ "In-Verse":1, "On Mission":1 };

  function pickGroup(container, onPick){
    $$("button", container).forEach(function(btn){
      btn.addEventListener("click", function(){
        $$("button", container).forEach(function(b){ b.setAttribute("aria-pressed","false"); });
        btn.setAttribute("aria-pressed","true");
        onPick(btn);
      });
    });
  }

  pickGroup($("#glyphPicker"), function(btn){ lpAv.innerHTML = btn.dataset.g; });
  pickGroup($("#bannerPicker"), function(btn){ toast("Banner set — " + btn.dataset.name); });
  pickGroup($("#colorPicker"), function(btn){
    var c=btn.dataset.c;
    lp.style.setProperty("--lpc", c);
    $("#colorName").textContent = btn.dataset.name + " · " + c;
  });

  $("#f-name").addEventListener("input", function(e){ lpName.textContent = e.target.value || "—"; });
  $("#f-handle").addEventListener("input", function(e){ lpHandle.textContent = "@" + (e.target.value||"").toLowerCase().replace(/\s+/g,""); });
  $("#f-role").addEventListener("change", function(e){ lpRole.textContent = e.target.value; });
  function updateStatus(){
    var p=$("#f-presence").value, custom=$("#f-custom").value.trim();
    lpStatus.textContent = p + (custom ? " · " + custom : "");
    lpDot.style.setProperty("--dot", presenceMap[p]||"var(--muted)");
    lpDot.classList.toggle("pulse", !!pulseSet[p]);
  }
  $("#f-presence").addEventListener("change", updateStatus);
  $("#f-custom").addEventListener("input", updateStatus);

  $("#saveBtn").addEventListener("click", function(){ toast("Record sealed — amendments committed."); });
  $("#resetBtn").addEventListener("click", function(){ toast("Changes discarded."); });

  /* ---------- favorites ---------- */
  var favData=[
    {k:"ship",   ic:"ic-ship",   c:"var(--accent)", n:"Drake Cutlass Black"},
    {k:"ship",   ic:"ic-ship",   c:"var(--accent)", n:"Aegis Avenger Titan"},
    {k:"ship",   ic:"ic-ship",   c:"var(--accent)", n:"Origin 400i"},
    {k:"ship",   ic:"ic-ship",   c:"var(--accent)", n:"RSI Polaris"},
    {k:"ship",   ic:"ic-ship",   c:"var(--accent)", n:"Anvil Carrack"},
    {k:"mineral",ic:"ic-gem",    c:"var(--gold)",   n:"Quantainium"},
    {k:"mineral",ic:"ic-gem",    c:"var(--gold)",   n:"Laranite"},
    {k:"mission",ic:"ic-target", c:"var(--accent-2)",n:"Save Stanton"},
    {k:"mission",ic:"ic-target", c:"var(--accent-2)",n:"XenoThreat"},
    {k:"item",   ic:"ic-item",   c:"#a855f7",       n:"Ballistic Gatling"},
    {k:"patch",  ic:"ic-tag",    c:"var(--ok)",     n:"Star Citizen 4.9.0"},
    {k:"topic",  ic:"ic-hash",   c:"var(--muted)",  n:"Mining"}
  ];
  var kindLabel={ship:"Ship",mineral:"Mineral",mission:"Mission",item:"Item",patch:"Patch",topic:"Topic"};
  var favGrid=$("#favGrid"), favEmpty=$("#favEmpty"), curFilter="all";

  function renderFavs(){
    favGrid.innerHTML="";
    var shown=0;
    favData.forEach(function(f,i){
      if(curFilter!=="all" && f.k!==curFilter) return;
      shown++;
      var el=document.createElement("div");
      el.className="fav framed";
      el.innerHTML=
        '<span class="fic" style="--kc:'+f.c+'"><svg viewBox="0 0 24 24"><use href="#'+f.ic+'"/></svg></span>'+
        '<span class="fmain"><span class="fkind" style="--kc:'+f.c+'">'+kindLabel[f.k]+'</span><span class="fname">'+f.n+'</span></span>'+
        '<button class="frm" title="Remove from favorites" aria-label="Remove '+f.n+'"><svg viewBox="0 0 24 24"><use href="#ic-x"/></svg></button>';
      el.querySelector(".frm").addEventListener("click", function(){
        el.classList.add("removing");
        setTimeout(function(){
          var idx=favData.indexOf(f);
          if(idx>-1) favData.splice(idx,1);
          $("#favCount").textContent=favData.length;
          renderFavs();
          toast("Removed — " + f.n);
        },260);
      });
      favGrid.appendChild(el);
    });
    favEmpty.style.display = shown ? "none" : "block";
  }
  $$("#favFilters .chipbtn").forEach(function(b){
    b.addEventListener("click", function(){
      $$("#favFilters .chipbtn").forEach(function(x){ x.setAttribute("aria-pressed","false"); });
      b.setAttribute("aria-pressed","true");
      curFilter=b.dataset.f; renderFavs();
    });
  });
  renderFavs();

  /* ---------- friends ---------- */
  var friends=[
    {h:"stardancer",  n:"StarDancer",  r:"Hauler",           s:"In-Verse",  c:"#38bdf8"},
    {h:"ore_baron",   n:"Ore Baron",   r:"Mining",           s:"Online",    c:"#f59e0b"},
    {h:"vexis",       n:"Vexis",       r:"Bounty Hunter",    s:"On Mission",c:"#f43f5e"},
    {h:"cmdr_hale",   n:"Cmdr Hale",   r:"Fleet Commander",  s:"Away",      c:"#6ea8ff"},
    {h:"lyria_lily",  n:"Lily",        r:"Medic",            s:"Offline",   c:"#10b981"},
    {h:"quantum_jane",n:"Quantum Jane",r:"Salvage",          s:"Online",    c:"#a855f7"},
    {h:"deadeye",     n:"Deadeye",     r:"Outlaw",           s:"Offline",   c:"#8a99b8"},
    {h:"kestrel_vale",n:"Kestrel Vale",r:"Explorer",         s:"In-Verse",  c:"#2dd4ff"}
  ];
  var statusStyle={
    "Online":     {dot:"var(--accent-2)", pulse:false},
    "In-Verse":   {dot:"var(--ok)",       pulse:true},
    "On Mission": {dot:"var(--amber)",    pulse:true},
    "Away":       {dot:"var(--orange)",   pulse:false},
    "Offline":    {dot:"var(--muted)",    pulse:false}
  };
  var friendList=$("#friendList");
  function initials(n){ var p=n.trim().split(/\s+/); return (p[0][0]+(p[1]?p[1][0]:"")).toUpperCase(); }
  function renderFriends(){
    friendList.innerHTML="";
    friends.forEach(function(f){
      var st=statusStyle[f.s]||statusStyle.Offline;
      var row=document.createElement("div");
      row.className="friend";
      row.innerHTML=
        '<span class="av" style="--avc:'+f.c+'">'+initials(f.n)+'</span>'+
        '<div class="fr-main"><div class="fr-name"><b>'+f.n+'</b><span class="fh">@'+f.h+'</span></div><div class="fr-role">'+f.r+'</div></div>'+
        '<div class="fr-status"><span class="dot'+(st.pulse?" pulse":"")+'" style="--dot:'+st.dot+'"></span>'+f.s+'</div>';
      friendList.appendChild(row);
    });
  }
  renderFriends();

  /* pending accept/decline */
  var pendWrap=$("#pendingWrap");
  $("[data-accept]").addEventListener("click", function(){
    friends.unshift({h:"nova_pilot",n:"Nova",r:"Explorer",s:"Online",c:"#6ea8ff"});
    renderFriends();
    pendWrap.style.display="none";
    toast("Request accepted — Nova added to network.");
  });
  $("[data-decline]").addEventListener("click", function(){
    pendWrap.style.display="none";
    toast("Request from @nova_pilot declined.");
  });

  /* add by handle */
  $("#addBtn").addEventListener("click", function(){
    var v=$("#addHandle").value.trim().replace(/^@/,"");
    if(!v){ toast("Enter a handle to send a request."); return; }
    toast("Friend request sent to @" + v.toLowerCase());
    $("#addHandle").value="";
  });
  $("#addHandle").addEventListener("keydown", function(e){ if(e.key==="Enter") $("#addBtn").click(); });

})();
</script>

<script is:inline>
(function(){
  var tabEls = [].slice.call(document.querySelectorAll('.tab'));
  var tablist = document.querySelector('[role="tablist"]');

  // Roving-Tabindex fuer die ARIA-Tablist
  function roving(active){ tabEls.forEach(function(t){ t.setAttribute('tabindex', t===active?'0':'-1'); }); }
  roving(document.querySelector('.tab[aria-selected="true"]') || tabEls[0]);
  tabEls.forEach(function(t){ t.addEventListener('click', function(){ roving(t); }); });

  // Pfeiltasten-/Home-/End-Navigation der Tabs
  if(tablist){ tablist.addEventListener('keydown', function(e){
    var i = tabEls.indexOf(document.activeElement); if(i<0) return; var n;
    if(e.key==='ArrowRight'||e.key==='ArrowDown') n=(i+1)%tabEls.length;
    else if(e.key==='ArrowLeft'||e.key==='ArrowUp') n=(i-1+tabEls.length)%tabEls.length;
    else if(e.key==='Home') n=0; else if(e.key==='End') n=tabEls.length-1; else return;
    e.preventDefault(); tabEls[n].click(); tabEls[n].focus();
  }); }

  // Metrik-Karten klickbar -> passender Tab bzw. Tool
  var map  = {'Favorites':'as','Network':'nw','Completeness':'id','RSI Status':'cl'};
  var aria = {'Favorites':'Open favorites','Network':'Open friends & network','Completeness':'Complete your profile','RSI Status':'Open security','Refinery Value':'Open refinery tracker'};
  [].slice.call(document.querySelectorAll('.metric')).forEach(function(m){
    var k=m.querySelector('.mlabel .k'); if(!k) return; var label=k.textContent.trim();
    var go=map[label]; var isRef=label==='Refinery Value';
    if(!go && !isRef) return;
    function act(){ if(go){ var t=document.querySelector('.tab[data-tab="'+go+'"]'); if(t) t.click(); } else { window.location.href='/refinery.html'; } }
    m.classList.add('metric--act');
    m.setAttribute('role', go?'button':'link');
    m.setAttribute('tabindex','0');
    m.setAttribute('aria-label', aria[label]||'Open');
    m.addEventListener('click', act);
    m.addEventListener('keydown', function(e){ if(e.key==='Enter' || (go && e.key===' ')){ e.preventDefault(); act(); } });
  });
})();
</script>

