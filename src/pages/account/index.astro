---
// Account-Dashboard — EN (/account.html). noindex: private Inhalte.
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import Attribution from '../../components/Attribution.astro';
import AccountShell from '../../components/account/AccountShell.astro';
import AccountDashboard from '../../components/account/AccountDashboard.astro';
---
<Layout
  title={'Your account | VerseBase'}
  description={'Your VerseBase account: profile, favorite ships, security settings.'}
  themeColor="#05070d"
  ogImage="/assets/og-default.jpg"
  translated={true}
  noindex={true}
>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<link slot="head" rel="stylesheet" href="/assets/account.css" />
<style is:inline>
/* Palette + Shell-Stile leben jetzt in /assets/account.css (geteilt, entdoppelt). */
.reveal{opacity:1 !important;transform:none !important}
.hero__in{max-width:var(--maxw)}
.hero--acct{min-height:34svh}
.acwrap--wide .sec-head{margin-top:2.6rem}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Account' }]} hasEn={true} />

<main id="main">
  <AccountShell
    eyebrow="VerseBase · System access"
    titleThin="Your base"
    title="Account"
    wide={true}
  >
    <AccountDashboard lang="en" />
  </AccountShell>
</main>

<Attribution sources={[]} />

<script is:inline src="/assets/detail.js"></script>
</Layout>
