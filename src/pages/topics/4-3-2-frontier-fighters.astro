---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
---
<Layout title={"Frontier Fighters — Star Citizen 4.3.2 | SC Patch-Archiv"} description={"Frontier Fighters: das grosse Finale von Alpha 4.3.2 'Fractured Frontiers'. Headhunters und Citizens for Prosperity jagen ueber drei Phasen Amelia Boyds Frontier Fighters durch Stanton und Pyro — bis zum servuerweiten Polaris-Takedown."} themeColor="#16181b" ogType="article" ogImage="/assets/t-front-1.jpg">
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Fractured-Frontiers-Theme (4.3.2) */
:root{--bg:#16181b;--bg-2:#1d2024;--surface:#23272b;--surface-2:#2c3137;--accent:#B5642A;--accent-2:#E4B400;--hot:#8E1F1F;--text:#ede6db;--muted:#a89d8e;--line:rgba(181,100,42,.22);--line-soft:rgba(237,230,219,.10);--glow:0 0 44px rgba(181,100,42,.30);--ink:#16181b;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.phasetag{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.78rem}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/index.html' }, { label: 'Alpha 4.3.2', href: '/patches/sc-4-3-2.html' }, { label: "Frontier Fighters" }]} pill={"EVENT · ALPHA 4.3.2"} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-front-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-3-2.html">Alpha 4.3.2 · Fractured Frontiers</a> &nbsp;·&nbsp; Finale-Event</div>
      <h1><span class="thin">Das Finale · Pyro Must Burn</span>Frontier Fighters</h1>
      <p class="lead">Das grosse Finale von 4.3.2: Headhunters und Citizens for Prosperity verbuenden sich, um Amelia Boyds Frontier Fighters ueber drei Phasen quer durch Stanton und Pyro zur Strecke zu bringen.</p>
      <div class="tags"><span class="tag hot">Finale-Event</span><span class="tag">3 Phasen</span><span class="tag">Headhunters + CFP</span><span class="tag">Amelia Boyd</span><span class="tag">Polaris-Takedown</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>FRONTIER FIGHTERS</span><span class="dot">◆</span><span>PYRO MUST BURN</span><span class="dot">◆</span><span>HEADHUNTERS</span><span class="dot">◆</span><span>CITIZENS FOR PROSPERITY</span><span class="dot">◆</span><span>AMELIA BOYD</span><span class="dot">◆</span><span>3 PHASEN</span><span class="dot">◆</span>
      <span>FRONTIER FIGHTERS</span><span class="dot">◆</span><span>PYRO MUST BURN</span><span class="dot">◆</span><span>HEADHUNTERS</span><span class="dot">◆</span><span>CITIZENS FOR PROSPERITY</span><span class="dot">◆</span><span>AMELIA BOYD</span><span class="dot">◆</span><span>3 PHASEN</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-3-2-frontier-fighters" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Phasen bis zum Takedown</div></div>
    <div class="s"><div class="n count" data-to="2">0</div><div class="c">Verbuendete Fraktionen</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Gejagte Polaris</div></div>
    <div class="s"><div class="n">FINALE</div><div class="c">Endkapitel der Pyro-Story</div></div>
  </div>

  <!-- FULL-BLEED BAND — Auftakt / Überblick als Riesentext über Standbild -->
  <section class="band band--center" style="padding-top:0">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/cz-ruin.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">Das Endkapitel von 4.3.2</div>
      <div class="big outline">PYRO MUST BURN.</div>
      <p>Das Frontier-Fighters-Finale ist das narrative Schlusskapitel von Alpha 4.3.2 — der Hoehepunkt der <b style="color:var(--accent-2)">Pyro-Must-Burn</b>-Story, der sich quer durch Stanton und Pyro entfaltet und das gesamte Verse in eine einzige Jagd zieht.</p>
    </div>
  </section>

  <!-- MANIFESTO — early pull-quote -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Diesmal jagt <span class="hl">der ganze Server</span> dasselbe Ziel.</blockquote>
    <cite>Frontier Fighters · Finale 4.3.2</cite>
  </section>

  <!-- VERSUS: Die Allianz vs. die Frontier Fighters (full-bleed) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚔ Die Frontier Fighters</h3>
        <ul>
          <li>Outlaw-Fraktion im Zentrum des 4.3.2-Finales.</li>
          <li>Gefuehrt von <b>Amelia Boyd</b>.</li>
          <li>Operieren von Stanton bis tief nach Pyro.</li>
          <li>Stehlen in der Eskalation eine ganze Polaris.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ Die Allianz</h3>
        <ul>
          <li>Headhunters und Citizens for Prosperity — hier Verbuendete.</li>
          <li>Gemeinsame Jagd auf Boyds Fighters.</li>
          <li>Koordinieren ueber alle drei Phasen hinweg.</li>
          <li>Treiben das Verse zum finalen Takedown.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SCROLLYTELLING: Die drei Phasen als Eskalations-Prozess -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">01</span><h2>Drei Phasen bis zum Takedown</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-ffp-2.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-facility.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-combat.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-polaris-1.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">00</div><h3>Eine Allianz formiert sich</h3><p>Headhunters und Citizens for Prosperity legen ihre Differenzen beiseite und schliessen sich zusammen, um die Frontier Fighters um Amelia Boyd ins Visier zu nehmen.</p></div>
      <div class="sstep"><div class="sn">01</div><h3>Phase Eins · Aufklaerung</h3><p>Der Auftakt der Eskalation: Die Allianz spuert die Bewegungen der Frontier Fighters quer durch Stanton und Pyro auf und steckt das Schlachtfeld ab.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Phase Zwei · Belagerung</h3><p>Die Jagd verdichtet sich. Aus Aufklaerung wird Druck — die Verbuendeten setzen Boyds Fighters an ihren Stuetzpunkten zu und treiben sie in die Enge.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Phase Drei · Der Takedown</h3><p>In der finalen Phase jagt der ganze Server gemeinsam die eine Polaris, die die Frontier Fighters gestohlen haben — der Hoehepunkt des gesamten Finales.</p></div>
    </div>
  </div>

  <!-- FULL-BLEED BAND — Der Polaris-Takedown -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/img-polaris.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="phasetag">Phase Drei · Server-Event</div>
      <div class="big" style="font-size:clamp(2.4rem,8vw,6rem)">EINE POLARIS.<br>EIN SERVER.</div>
      <p>Die Frontier Fighters haben eine ganze Polaris gestohlen — und im Finale zaehlt nur noch eines: das gesamte Verse jagt dieses eine Schiff gemeinsam. Der servuerweite Takedown setzt den Schlusspunkt unter die Pyro-Must-Burn-Story.</p>
    </div>
  </section>

  <!-- SPLIT — der EINE gerahmte Abschnitt: weitere 4.3.2-Inhalte (Paladin, Yormandi, Salvage) -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/img-paladin.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">02 · Was 4.3.2 sonst noch brachte</div>
        <h3>Mehr als nur das Finale</h3>
        <p>Rund um das Frontier-Fighters-Event lieferte Alpha <b>4.3.2 "Fractured Frontiers"</b> spuerbar mehr: Headliner-Schiff des Patches ist die <b>Anvil Paladin</b>.</p>
        <p>Dazu kam der <b>Yormandi-Boss</b> in den Onyx-Hoehlen auf <b>ASD Site B</b> sowie ein umfassendes <b>Salvage- und Refining-Rework</b> — Inhalte, die ueber das Finale hinaus Bestand haben.</p>
      </div>
    </div>
  </section>

  <!-- CLOSING — full-bleed mixed gallery (kein offizielles Video) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">03</span><h2>Bildergalerie</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-front-1.jpg"><img src="/assets/t-front-1.jpg" alt="Frontier Fighters — Finale-Event" loading="lazy"><span class="zoomic">⤢</span><figcaption>Frontier Fighters · Finale</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/img-pyro.jpg"><img src="/assets/img-pyro.jpg" alt="Das Pyro-System — Schauplatz der Jagd" loading="lazy"><span class="zoomic">⤢</span><figcaption>Pyro · Schauplatz</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/cz-combat.jpg"><img src="/assets/cz-combat.jpg" alt="Gefecht waehrend der Jagd" loading="lazy"><span class="zoomic">⤢</span><figcaption>Belagerung</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/cz-facility.jpg"><img src="/assets/cz-facility.jpg" alt="Anlage in Pyro" loading="lazy"><span class="zoomic">⤢</span><figcaption>Aufklaerung</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/img-polaris.jpg"><img src="/assets/img-polaris.jpg" alt="Die gestohlene Polaris" loading="lazy"><span class="zoomic">⤢</span><figcaption>Die gestohlene Polaris</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/img-paladin.jpg"><img src="/assets/img-paladin.jpg" alt="Anvil Paladin — Headliner-Schiff" loading="lazy"><span class="zoomic">⤢</span><figcaption>Anvil Paladin · Headliner</figcaption></figure>
      </div>
      <p class="src reveal">Quelle: Star Citizen Wiki &amp; offizielle Community-Quellen (© Cloud Imperium Games). Bilder zu Illustrationszwecken.</p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-3-2-frontier-fighters" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Schließen">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
