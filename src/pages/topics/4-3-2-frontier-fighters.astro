---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TopicSeo from '../../components/dossier/TopicSeo.astro';
---
<Layout title={"Frontier Fighters — Star Citizen 4.3.2 | VerseBase"} description={"Frontier Fighters: the grand finale of Alpha 4.3.2 'Fractured Frontiers'. Headhunters and Citizens for Prosperity hunt Amelia Boyd's Frontier Fighters across three phases through Stanton and Pyro — up to the server-wide Polaris takedown."} translated={true} themeColor="#16181b" ogType="article" ogImage="/assets/t-front-1.jpg">
<TopicSeo slug="4-3-2-frontier-fighters" image="/assets/t-front-1.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Fractured-Frontiers-Theme (4.3.2) */
:root{--bg:#16181b;--bg-2:#1d2024;--surface:#23272b;--surface-2:#2c3137;--accent:#B5642A;--accent-2:#E4B400;--hot:#8E1F1F;--text:#ede6db;--muted:#a89d8e;--line:rgba(181,100,42,.22);--line-soft:rgba(237,230,219,.10);--glow:0 0 44px rgba(181,100,42,.30);--ink:#16181b;--maxw:1180px;}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f5f8fc;--bg-2:#eaeef4;--surface:#fcfeff;--surface-2:#edf3fb;--text:#231e16;--muted:#605649;--accent:#8d4402;--accent-2:#6a5200;--hot:#9a1118;--ink:#ffffff;--accent-media:#B5642A;--accent-2-media:#E4B400;--line:rgba(159,96,54,.3);--line-soft:rgba(50,45,37,.12);--glow:0 6px 22px rgba(166,91,37,.18)}

/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.phasetag{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.78rem}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.3.2', href: '/patches/sc-4-3-2.html' }, { label: "Frontier Fighters" }]} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-front-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-3-2.html">Alpha 4.3.2 · Fractured Frontiers</a> &nbsp;·&nbsp; Finale event</div>
      <h1><span class="thin">The Finale · Pyro Must Burn</span>Frontier Fighters</h1>
      <p class="lead">The grand finale of 4.3.2: Headhunters and Citizens for Prosperity join forces to bring down Amelia Boyd's Frontier Fighters across three phases, all the way through Stanton and Pyro.</p>
      <div class="tags"><span class="tag hot">Finale event</span><span class="tag">3 phases</span><span class="tag">Headhunters + CFP</span><span class="tag">Amelia Boyd</span><span class="tag">Polaris takedown</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>FRONTIER FIGHTERS</span><span class="dot">◆</span><span>PYRO MUST BURN</span><span class="dot">◆</span><span>HEADHUNTERS</span><span class="dot">◆</span><span>CITIZENS FOR PROSPERITY</span><span class="dot">◆</span><span>AMELIA BOYD</span><span class="dot">◆</span><span>3 PHASES</span><span class="dot">◆</span>
      <span>FRONTIER FIGHTERS</span><span class="dot">◆</span><span>PYRO MUST BURN</span><span class="dot">◆</span><span>HEADHUNTERS</span><span class="dot">◆</span><span>CITIZENS FOR PROSPERITY</span><span class="dot">◆</span><span>AMELIA BOYD</span><span class="dot">◆</span><span>3 PHASES</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-3-2-frontier-fighters" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Phases to the takedown</div></div>
    <div class="s"><div class="n count" data-to="2">0</div><div class="c">Allied factions</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Polaris hunted</div></div>
    <div class="s"><div class="n">FINALE</div><div class="c">Final chapter of the Pyro story</div></div>
  </div>

  <!-- FULL-BLEED BAND — Auftakt / Überblick als Riesentext über Standbild -->
  <section class="band band--center" style="padding-top:0">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/cz-ruin.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">The final chapter of 4.3.2</div>
      <div class="big outline">PYRO MUST BURN.</div>
      <p>The Frontier Fighters finale is the narrative closing chapter of Alpha 4.3.2 — the climax of the <b style="color:var(--accent-2)">Pyro Must Burn</b> story, unfolding across Stanton and Pyro and pulling the entire 'verse into a single hunt.</p>
    </div>
  </section>

  <!-- MANIFESTO — early pull-quote -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>This time <span class="hl">the whole server</span> hunts the same target.</blockquote>
    <cite>Frontier Fighters · Finale 4.3.2</cite>
  </section>

  <!-- VERSUS: Die Allianz vs. die Frontier Fighters (full-bleed) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚔ The Frontier Fighters</h3>
        <ul>
          <li>Outlaw faction at the heart of the 4.3.2 finale.</li>
          <li>Led by <b>Amelia Boyd</b>.</li>
          <li>Operate from Stanton deep into Pyro.</li>
          <li>Steal an entire Polaris as the escalation peaks.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ The Alliance</h3>
        <ul>
          <li>Headhunters and Citizens for Prosperity — allies here.</li>
          <li>Joint hunt for Boyd's Fighters.</li>
          <li>Coordinate across all three phases.</li>
          <li>Drive the 'verse toward the final takedown.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SCROLLYTELLING: Die drei Phasen als Eskalations-Prozess -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">01</span><h2>Three phases to the takedown</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-ffp-2.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-facility.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-combat.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-polaris-1.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">00</div><h3>An alliance forms</h3><p>Headhunters and Citizens for Prosperity set aside their differences and band together to target the Frontier Fighters under Amelia Boyd.</p></div>
      <div class="sstep"><div class="sn">01</div><h3>Phase One · Reconnaissance</h3><p>The opening of the escalation: the Alliance tracks the Frontier Fighters' movements across Stanton and Pyro and stakes out the battlefield.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Phase Two · Siege</h3><p>The hunt tightens. Reconnaissance turns into pressure — the allies close in on Boyd's Fighters at their strongholds and corner them.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Phase Three · The Takedown</h3><p>In the final phase, the whole server hunts together for the one Polaris the Frontier Fighters have stolen — the climax of the entire finale.</p></div>
    </div>
  </div>

  <!-- FULL-BLEED BAND — Der Polaris-Takedown -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/img-polaris.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="phasetag">Phase Three · Server event</div>
      <div class="big" style="font-size:clamp(2.4rem,8vw,6rem)">ONE POLARIS.<br>ONE SERVER.</div>
      <p>The Frontier Fighters have stolen an entire Polaris — and in the finale only one thing matters: the whole 'verse hunts this one ship together. The server-wide takedown puts the closing punctuation on the Pyro Must Burn story.</p>
    </div>
  </section>

  <!-- SPLIT — der EINE gerahmte Abschnitt: weitere 4.3.2-Inhalte (Paladin, Yormandi, Salvage) -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/img-paladin.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">02 · What else 4.3.2 brought</div>
        <h3>More than just the finale</h3>
        <p>Around the Frontier Fighters event, Alpha <b>4.3.2 "Fractured Frontiers"</b> delivered noticeably more: the patch's headliner ship is the <b>Anvil Paladin</b>.</p>
        <p>It also added the <b>Yormandi boss</b> in the Onyx caves on <b>ASD Site B</b>, as well as a comprehensive <b>salvage and refining rework</b> — content that endures beyond the finale.</p>
      </div>
    </div>
  </section>

  <!-- CLOSING — full-bleed mixed gallery (kein offizielles Video) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">03</span><h2>Image gallery</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-front-1.jpg"><img src="/assets/t-front-1.jpg" alt="Frontier Fighters — finale event" loading="lazy"><span class="zoomic">⤢</span><figcaption>Frontier Fighters · Finale</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/img-pyro.jpg"><img src="/assets/img-pyro.jpg" alt="The Pyro system — setting of the hunt" loading="lazy"><span class="zoomic">⤢</span><figcaption>Pyro · Setting</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/cz-combat.jpg"><img src="/assets/cz-combat.jpg" alt="Firefight during the hunt" loading="lazy"><span class="zoomic">⤢</span><figcaption>Siege</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/cz-facility.jpg"><img src="/assets/cz-facility.jpg" alt="Facility in Pyro" loading="lazy"><span class="zoomic">⤢</span><figcaption>Reconnaissance</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/img-polaris.jpg"><img src="/assets/img-polaris.jpg" alt="The stolen Polaris" loading="lazy"><span class="zoomic">⤢</span><figcaption>The stolen Polaris</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/img-paladin.jpg"><img src="/assets/img-paladin.jpg" alt="Anvil Paladin — headliner ship" loading="lazy"><span class="zoomic">⤢</span><figcaption>Anvil Paladin · Headliner</figcaption></figure>
      </div>
      <p class="src reveal">Source: Star Citizen Wiki &amp; official community sources (© Cloud Imperium Games). Images for illustration purposes.</p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-3-2-frontier-fighters" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
