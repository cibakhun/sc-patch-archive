---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TopicSeo from '../../components/dossier/TopicSeo.astro';
---
<Layout title={"XenoThreat — Star Citizen 4.8.3 | VerseBase"} description={"XenoThreat: a human-supremacist, anti-alien outlaw faction — with Alpha 4.8.3 the Assault on Stanton returns as a points-based combat event (July 1–15, 2026, 120,000 event points, blueprint rewards)."} themeColor="#0d0a16" ogType="article" ogImage="/assets/t-xeno-1.jpg" translated={true}>
<TopicSeo slug="4-8-3-xenothreat" image="/assets/t-xeno-1.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Tactical-Strike-Theme (4.8.x) */
:root{--bg:#0d0a16;--bg-2:#140f24;--surface:#1a1330;--surface-2:#231a3e;--accent:#E8651E;--accent-2:#1FB8A6;--hot:#E8651E;--text:#ede9f5;--muted:#a39db5;--line:rgba(232,101,30,.22);--line-soft:rgba(237,233,245,.10);--glow:0 0 44px rgba(232,101,30,.30);--ink:#0d0a16;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.kx-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.8.3', href: '/patches/sc-4-8-3.html' }, { label: "XenoThreat" }]} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-xeno-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-8-3.html">Alpha 4.8.3 · XenoThreat</a> &nbsp;·&nbsp; Faction</div>
      <h1><span class="thin">The Assault on Stanton</span>XenoThreat</h1>
      <p class="lead">A human-supremacist, anti-alien outlaw faction: with 4.8.3 their Assault-on-Stanton event returns — this time not as a cinematic server-wide war, but as a points-based PvE combat event running July 1–15, 2026.</p>
      <div class="tags"><span class="tag hot">Outlaw faction</span><span class="tag">Assault on Stanton</span><span class="tag">Points event</span><span class="tag">Foxwell Enforcement</span><span class="tag">Idris objective</span></div>
      <div class="hero__play" data-lb="yt:SsOtI2dtvBc"><span class="pbtn">▶</span>Watch trailer</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>XENOTHREAT</span><span class="dot">◆</span><span>ASSAULT ON STANTON</span><span class="dot">◆</span><span>FOXWELL ENFORCEMENT</span><span class="dot">◆</span><span>120,000 POINTS</span><span class="dot">◆</span><span>5 MISSION TYPES</span><span class="dot">◆</span><span>IDRIS FRIGATE</span><span class="dot">◆</span>
      <span>XENOTHREAT</span><span class="dot">◆</span><span>ASSAULT ON STANTON</span><span class="dot">◆</span><span>FOXWELL ENFORCEMENT</span><span class="dot">◆</span><span>120,000 POINTS</span><span class="dot">◆</span><span>5 MISSION TYPES</span><span class="dot">◆</span><span>IDRIS FRIGATE</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AT A GLANCE (data register, uniform) -->
  <TopicFacts topicSlug="4-8-3-xenothreat" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="120000">0</div><div class="c">Event points for the full reward track</div></div>
    <div class="s"><div class="n count" data-to="5">0</div><div class="c">Mission types earn points</div></div>
    <div class="s"><div class="n">JULY 1–15</div><div class="c">Event window 2026</div></div>
  </div>

  <!-- FULL-BLEED BAND (parallax) — who is XenoThreat -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-xeno-3.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">From the ruins of Pyro</div>
      <div class="big outline">BETRAYAL.</div>
      <p>XenoThreat is a human-supremacist, alien-hostile outlaw group out of Pyro — mostly former <b style="color:var(--accent-2)">UEE Navy members</b> who see the UEE's coexistence with alien species as a betrayal of humanity. Because Stanton upholds that coexistence, XenoThreat attacks the system.</p>
    </div>
  </section>

  <!-- OVERVIEW as SPLIT (the one framed/split section) -->
  <section style="padding-bottom:0">
    <div class="split reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-hh-2.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">01 · Who they are</div>
        <h3>Deserters with a doctrine</h3>
        <p>What sets XenoThreat apart from ordinary outlaws is conviction. These are trained soldiers who have renounced their loyalty to the UEE — convinced that the alliance with alien species betrays humanity.</p>
        <p>Out of the lawless depths of Pyro they form not a mere gang, but a <b>paramilitary faction</b> with ships, discipline and a single goal: to hit Stanton where it most openly lives alien coexistence.</p>
      </div>
    </div>
  </section>

  <!-- HISTORY — full-bleed band (image as background, design on top) -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/cz-ruin.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">02 · The historical opening (2951)</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">STANTON 2951</div>
      <p>Back in 2951 XenoThreat ambushed a civilian convoy in Stanton bound for Terra — all ships destroyed, the crews executed. The UEE Navy mobilized the <b style="color:var(--accent-2)">Civilian Defense Force</b>; after eleven days of fighting XenoThreat withdrew to Pyro. 4.8.3 brings them back.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: The five mission types -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">03</span><h2>Five ways to earn points</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-xeno-2.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/img-hammerhead.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-hh-3.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-def-2.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/img-idris.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Defend alien-built ships</h3><p>Alien-made ships come under fire from isolationist forces — players keep them clear.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Clear anti-alien fighters</h3><p>Waves of xenophobic fighters arrive and have to be intercepted.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Intercept squadrons</h3><p>Incoming exclusionary elitists are hunted down and destroyed.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Draw out lieutenants</h3><p>Xenophobic leaders are lured out and defeated to weaken the command structure.</p></div>
      <div class="sstep"><div class="sn">05</div><h3>Idris frigate</h3><p>The capital-ship objective: destroy the Idris or kill its pilot — the toughest contract on the track.</p></div>
    </div>
  </div>

  <!-- REWARD BAND -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/cz-loot.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · The reward track</div>
      <div class="big">120,000 POINTS</div>
      <p>4.8.3 is a combat point farm: progress is tracked in your journal, and standard missions grant roughly 4,000 points. Work up to the full track of <b style="color:var(--accent-2)">120,000 event points</b> and you unlock <b style="color:var(--accent-2)">unique blueprints</b> that persist across future updates.</p>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Five fronts, one goal: the <span class="hl">Idris</span> falls — or Stanton bends to xenophobia.</blockquote>
    <cite>XenoThreat · Assault on Stanton (4.8.3)</cite>
  </section>

  <!-- MEDIA (mixed gallery + trailer) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">05</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-xeno-1.jpg"><img src="/assets/t-xeno-1.jpg" alt="XenoThreat forces over Stanton" loading="lazy"><span class="zoomic">⤢</span><figcaption>XenoThreat · Forces</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-xeno-2.jpg"><img src="/assets/t-xeno-2.jpg" alt="XenoThreat in combat" loading="lazy"><span class="zoomic">⤢</span><figcaption>In combat</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-idris.jpg"><img src="/assets/img-idris.jpg" alt="Idris frigate as the capital-ship objective" loading="lazy"><span class="zoomic">⤢</span><figcaption>Idris · Capital-ship objective</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-hammerhead.jpg"><img src="/assets/img-hammerhead.jpg" alt="Hammerhead gunship" loading="lazy"><span class="zoomic">⤢</span><figcaption>Hammerhead gunship</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-xeno-3.jpg"><img src="/assets/t-xeno-3.jpg" alt="XenoThreat propaganda broadcast in front of a gathered crowd" loading="lazy"><span class="zoomic">⤢</span><figcaption>Propaganda broadcast</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="SsOtI2dtvBc" style="background-image:url('/assets/t-hh-1.jpg')"><span class="vlbl">XenoThreat — Assault on Stanton</span><button class="play" aria-label="Play trailer">▶</button></div>
      <p class="src reveal">Source: official Star Citizen YouTube channel &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=SsOtI2dtvBc" target="_blank" rel="noopener">Watch on YouTube ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-8-3-xenothreat" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
