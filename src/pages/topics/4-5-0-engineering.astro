---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TopicSeo from '../../components/dossier/TopicSeo.astro';
---
<Layout title={"Engineering — Star Citizen 4.5.0 | VerseBase"} description={"Dawn of Engineering: With Alpha 4.5.0, operating your ship becomes gameplay in itself — distribute power, manage Ship Armor, put out fires. Plus Vulkan as the default renderer and experimental VR support."} themeColor="#0f1316" ogType="article" ogImage="/assets/t-eng-3.jpg" translated={true}>
<TopicSeo slug="4-5-0-engineering" image="/assets/t-eng-3.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Engineering-Theme (geerbt von 4.5.0 "Dawn of Engineering") */
:root{--bg:#0f1316;--bg-2:#151a1e;--surface:#1c2024;--surface-2:#262c31;--accent:#FFB000;--accent-2:#2BC4C4;--hot:#D7263D;--text:#e9eef0;--muted:#9aa7ac;--line:rgba(255,176,0,.22);--line-soft:rgba(233,238,240,.10);--glow:0 0 44px rgba(255,176,0,.30);--ink:#0f1316;--maxw:1180px;}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f2f8fd;--bg-2:#e8eff5;--surface:#fcfeff;--surface-2:#ecf4fa;--text:#1c2021;--muted:#4f5a5f;--accent:#7a5201;--accent-2:#056262;--hot:#9d0223;--ink:#ffffff;--accent-media:#FFB000;--accent-2-media:#2BC4C4;--line:rgba(146,105,37,.3);--line-soft:rgba(42,47,48,.12);--glow:0 6px 22px rgba(146,105,37,.18)}

/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.kx-hot{color:var(--hot)!important}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.5.0', href: '/patches/sc-4-5-0.html' }, { label: "Engineering" }]} hasEn={true} />


<main id="main">

  <!-- HERO (full-bleed media) -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-eng-3.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-5-0.html">Alpha 4.5.0 · Dawn of Engineering</a> &nbsp;·&nbsp; Feature</div>
      <h1><span class="thin">The ship becomes the battlefield</span>Engineering</h1>
      <p class="lead">With 4.5.0, operating your ship becomes gameplay in itself: distribute power, manage armor, put out fires — whoever survives the fight is the one who keeps their ship running.</p>
      <div class="tags"><span class="tag">Engineering</span><span class="tag">Ship Armor</span><span class="tag hot">Fire Hazard</span><span class="tag">Power Management</span><span class="tag">VR</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>ENGINEERING</span><span class="dot">◆</span><span>SHIP ARMOR</span><span class="dot">◆</span><span>FIRE HAZARD</span><span class="dot">◆</span><span>POWER MANAGEMENT</span><span class="dot">◆</span><span>VULKAN</span><span class="dot">◆</span><span>VR</span><span class="dot">◆</span>
      <span>ENGINEERING</span><span class="dot">◆</span><span>SHIP ARMOR</span><span class="dot">◆</span><span>FIRE HAZARD</span><span class="dot">◆</span><span>POWER MANAGEMENT</span><span class="dot">◆</span><span>VULKAN</span><span class="dot">◆</span><span>VR</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-5-0-engineering" />

  <!-- INTRO as FULL-BLEED BAND (parallax, big overlaid text) -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-eng-2.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">Dawn of Engineering</div>
      <div class="big outline">KEEP IT RUNNING.</div>
      <p>Shields drop, components burn out, power runs low. In 4.5.0 it's no longer just about how well you fly — but how well you keep your ship <b style="color:var(--accent-2)">alive</b> in the fight.</p>
    </div>
  </section>

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="4">0</div><div class="c">New systems · Engineering, Armor, Fire, Power</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Physical armor layer over the hull</div></div>
    <div class="s"><div class="n">VULKAN</div><div class="c">Default renderer from 4.5.0</div></div>
    <div class="s"><div class="n">VR</div><div class="c">Experimental · via Vulkan</div></div>
  </div>

  <!-- OVERVIEW — single split section (the ONE framed/split allowed) -->
  <section style="padding-bottom:0">
    <div class="split reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-eng-4.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">01 · Engineering Gameplay</div>
        <h3>The engine room becomes the cockpit</h3>
        <p>At an <b>Engineering terminal</b>, players monitor the state of their ship in real time — and repair damaged components right in the middle of operation. What used to run invisibly in the background becomes an active task on board.</p>
        <p>In a multi-crew ship, this creates a role of its own: while some fly and fire, the engineer keeps the reactor, shields, and drive running. Ships turn from a tool into a <b>crew experience</b>.</p>
      </div>
    </div>
  </section>

  <!-- VERSUS: Ship Armor vs Feuer-Hazard (full-bleed dual pane) -->
  <section style="padding:0">
    <div class="wrap" style="padding:clamp(2.5rem,6vw,4.5rem) 0 1.4rem"><div class="sec-head reveal"><span class="num">02</span><h2>Protection &amp; Hazard</h2><span class="rule"></span></div></div>
    <div class="versus reveal">
      <div class="side b">
        <h3>★ Ship Armor</h3>
        <ul>
          <li>Its own physical layer over the hull and components.</li>
          <li>Absorbs incoming damage before it reaches the structure.</li>
          <li>Wears down over time — armor is finite.</li>
          <li>Makes damage management a strategic decision.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side a">
        <h3>⚠ Fire Hazard</h3>
        <ul>
          <li>Fire spreads dynamically through the ship.</li>
          <li>Consumes oxygen — the atmosphere on board becomes a hazard.</li>
          <li>Spreads to adjacent rooms if you do nothing.</li>
          <li>Must be actively put out — it won't die down on its own.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SCROLLYTELLING: So ueberlebst du ein Gefecht (process) -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">03</span><h2>Crisis management on board</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-eng-5.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-eng-6.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-eng-7.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-eng-8.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Take the hit</h3><p>Incoming fire strikes the Ship Armor first. The armor layer absorbs the damage — but with every hit it wears down further.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Read the situation</h3><p>At the Engineering terminal you can see which components are damaged, where power is lacking, and where it's already getting dangerously hot.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Fight the fire</h3><p>If a fire breaks out, it consumes oxygen and spreads to neighboring rooms. It has to be actively put out before the blaze eats its way through the ship.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Repair &amp; carry on</h3><p>Damaged components are repaired in real time, power is redistributed — and the ship stays in the fight. Master this, and you survive.</p></div>
    </div>
  </div>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Anyone can fly. <span class="hl">Keeping it alive</span> is the art.</blockquote>
    <cite>Dawn of Engineering · Alpha 4.5.0</cite>
  </section>

  <!-- POWER MANAGEMENT — full-bleed band (image as background, design on top) -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/trailer-4-5-0.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · Power Management</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">EVERY WATT COUNTS</div>
      <p>Power is distributed to components in real time — more output for shields, thrusters, or weapons, depending on the situation. But <b style="color:var(--hot)">overload</b> leads to heat, failures, and damage. Try to have it all at once, and you risk nothing working at all.</p>
    </div>
  </section>

  <!-- TECH BAND: Vulkan & VR (full-bleed, big overlaid text) -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-eng-1.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">05 · Under the Hood</div>
      <div class="big">VULKAN &amp; VR</div>
      <p>From 4.5.0, <b style="color:var(--accent-2)">Vulkan</b> is the default renderer, replacing DirectX 11 — the API has already been in the game since 3.23. This pipeline is the foundation for the new, <b>experimental VR support</b>: a first step toward experiencing the Verse through the goggles.</p>
    </div>
  </section>

  <!-- MEDIA — closing mixed gallery (no video embed) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">06</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-eng-1.jpg"><img src="/assets/t-eng-1.jpg" alt="Engineering — ship operations in combat" loading="lazy"><span class="zoomic">⤢</span><figcaption>Engineering · Ship operations</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-eng-2.jpg"><img src="/assets/t-eng-2.jpg" alt="Damage and component management" loading="lazy"><span class="zoomic">⤢</span><figcaption>Components under fire</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/trailer-4-5-0.jpg"><img src="/assets/trailer-4-5-0.jpg" alt="Dawn of Engineering — key art" loading="lazy"><span class="zoomic">⤢</span><figcaption>Dawn of Engineering</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-eng-4.jpg"><img src="/assets/t-eng-4.jpg" alt="The Engineering terminal on board" loading="lazy"><span class="zoomic">⤢</span><figcaption>Engineering terminal</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-eng-3.jpg"><img src="/assets/t-eng-3.jpg" alt="Crew inside the ship during combat" loading="lazy"><span class="zoomic">⤢</span><figcaption>Crew in the engine room</figcaption></figure>
      </div>
      <p class="src reveal">Source: official Star Citizen YouTube channel &amp; Star Citizen Wiki (© Cloud Imperium Games). Unofficial fan compilation.</p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-5-0-engineering" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
