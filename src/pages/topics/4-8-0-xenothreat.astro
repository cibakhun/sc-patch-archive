---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
---
<Layout title={"XenoThreat — Star Citizen 4.8.0 | SC Patch-Archiv"} description={"XenoThreat: eine menschen-suprematistische Outlaw-Fraktion aus desertierten UEE-Navy-Soldaten — mit Alpha 4.8.0 kehrt der Assault on Stanton ins Zentrum des Patches zurück."} themeColor="#0d0a16" ogType="article" ogImage="/assets/t-xeno-1.jpg">
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Tactical-Strike-Theme (4.8.x) */
:root{--bg:#0d0a16;--bg-2:#140f24;--surface:#1a1330;--surface-2:#231a3e;--accent:#E8651E;--accent-2:#1FB8A6;--hot:#E8651E;--text:#ede9f5;--muted:#a39db5;--line:rgba(232,101,30,.22);--line-soft:rgba(237,233,245,.10);--glow:0 0 44px rgba(232,101,30,.30);--ink:#0d0a16;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.kx-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/index.html' }, { label: 'Alpha 4.8.0', href: '/patches/sc-4-8-0.html' }, { label: "XenoThreat" }]} pill={"FRAKTION · ALPHA 4.8.0"} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-xeno-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-8-0.html">Alpha 4.8.0 · Tactical Strike</a> &nbsp;·&nbsp; Fraktion</div>
      <h1><span class="thin">Der Angriff auf Stanton</span>XenoThreat</h1>
      <p class="lead">Eine menschen-suprematistische Outlaw-Fraktion aus desertierten UEE-Navy-Soldaten: mit 4.8.0 kehrt ihr Assault-on-Stanton-Event ins Zentrum des Patches zurück — Wellen aus Jägern, Gunships und Fregatten.</p>
      <div class="tags"><span class="tag hot">Outlaw-Fraktion</span><span class="tag">Assault on Stanton</span><span class="tag">Dynamisches Event</span><span class="tag">INS Jericho</span><span class="tag">Wellen-Kampf</span></div>
      <div class="hero__play" data-lb="yt:SsOtI2dtvBc"><span class="pbtn">▶</span>Trailer ansehen</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>XENOTHREAT</span><span class="dot">◆</span><span>ASSAULT ON STANTON</span><span class="dot">◆</span><span>UEES WAR HAMMER</span><span class="dot">◆</span><span>INS JERICHO</span><span class="dot">◆</span><span>IDRIS-M</span><span class="dot">◆</span><span>HAMMERHEAD</span><span class="dot">◆</span>
      <span>XENOTHREAT</span><span class="dot">◆</span><span>ASSAULT ON STANTON</span><span class="dot">◆</span><span>UEES WAR HAMMER</span><span class="dot">◆</span><span>INS JERICHO</span><span class="dot">◆</span><span>IDRIS-M</span><span class="dot">◆</span><span>HAMMERHEAD</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-8-0-xenothreat" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Flaggschiff zu verteidigen · UEES War Hammer</div></div>
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Eskalierende Event-Phasen</div></div>
    <div class="s"><div class="n">WELLEN</div><div class="c">Kein Ende, bis die Front hält</div></div>
  </div>

  <!-- FULL-BLEED BAND (parallax) — wer ist XenoThreat -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-xeno-3.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">Aus den Ruinen von Pyro</div>
      <div class="big outline">VERRAT.</div>
      <p>XenoThreat ist eine menschen-suprematistische, alien-feindliche Outlaw-Gruppe aus Pyro — grösstenteils ehemalige <b style="color:var(--accent-2)">UEE-Navy-Mitglieder</b>, die die Zusammenarbeit der UEE mit Aliens als Verrat an der Menschheit sehen.</p>
    </div>
  </section>

  <!-- OVERVIEW as SPLIT (the one framed/split section) -->
  <section style="padding-bottom:0">
    <div class="split reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-hh-2.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">01 · Wer sie sind</div>
        <h3>Deserteure mit einer Doktrin</h3>
        <p>Was XenoThreat von gewöhnlichen Outlaws unterscheidet, ist die Überzeugung. Es sind ausgebildete Soldaten, die ihre Loyalität zur UEE aufgekündigt haben — überzeugt davon, dass die Allianz mit fremden Spezies die Menschheit verrät.</p>
        <p>Aus den gesetzlosen Tiefen Pyros heraus formen sie keine bloße Bande, sondern eine <b>paramilitärische Fraktion</b> mit Schiffen, Disziplin und einem Ziel: Stanton zu treffen, wo es am meisten wehtut.</p>
      </div>
    </div>
  </section>

  <!-- THE ASSAULT BEGINS — full-bleed band (image as background, design on top) -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/img-idris.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">02 · Der Auftakt</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">HINRICHTUNG</div>
      <p>Der Assault on Stanton beginnt mit einem Schlag: XenoThreat überfällt einen <b style="color:var(--accent-2)">Konzern-Konvoi</b> — und richtet dessen Crew öffentlich als Kollaborateure hin. Eine Botschaft, kein Überfall.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: So läuft der Assault on Stanton -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">03</span><h2>Der Assault on Stanton</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-xeno-2.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/img-hammerhead.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-hh-3.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-hh-1.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Der Überfall</h3><p>XenoThreat greift einen Konzern-Konvoi an und richtet dessen Crew öffentlich als Kollaborateure hin — der Funke, der das Event entzündet.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Mobilmachung</h3><p>Die Civilian Defense Force wird mobilisiert: verlorenen Starfarer-Nachschub bergen und das UEE-Navy-Flaggschiff UEES War Hammer bei INS Jericho verteidigen.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Bergung nach Jericho</h3><p>Spieler holen Fracht aus zurückgelassenen Starfarer-Wracks und bringen sie nach INS Jericho — der Nachschub, der die Verteidigung am Leben hält.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Wellen halten</h3><p>Die War Hammer wird durch eskalierende Wellen verteidigt. In der finalen Phase fliegt XenoThreat Jäger plus Hammerhead-Gunships und Idris-M-Fregatten, die in Wellen eintreffen.</p></div>
    </div>
  </div>

  <!-- VERSUS: XenoThreat vs Civilian Defense Force (full-bleed) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚠ XenoThreat</h3>
        <ul>
          <li>Menschen-suprematistische Outlaw-Fraktion aus Pyro.</li>
          <li>Grösstenteils desertierte UEE-Navy-Soldaten.</li>
          <li>Greift einen Konzern-Konvoi an und richtet die Crew hin.</li>
          <li>In der Endphase: Jäger, Hammerhead-Gunships, Idris-M-Fregatten.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ Civilian Defense Force</h3>
        <ul>
          <li>Wird gegen XenoThreat mobilisiert.</li>
          <li>Birgt verlorenen Starfarer-Nachschub.</li>
          <li>Verteidigt das Flaggschiff UEES War Hammer bei INS Jericho.</li>
          <li>Hält gegen eskalierende, in Wellen eintreffende Angriffe.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FINAL WAVE — full-bleed band -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-polaris-3.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · Die finale Phase</div>
      <div class="big">WELLE UM WELLE</div>
      <p>In der letzten Phase fliegt XenoThreat <b style="color:var(--accent-2)">Jäger</b>, dazu <b style="color:var(--accent-2)">Hammerhead-Gunships</b> und <b style="color:var(--accent-2)">Idris-M-Fregatten</b> — sie treffen in Wellen ein, bis die Verteidiger die Front entweder halten oder brechen.</p>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Hältst du die <span class="hl">War Hammer</span> — oder fällt Stanton Welle um Welle?</blockquote>
    <cite>XenoThreat · Assault on Stanton</cite>
  </section>

  <!-- MEDIA (mixed gallery + trailer) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">05</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-xeno-1.jpg"><img src="/assets/t-xeno-1.jpg" alt="XenoThreat-Streitkräfte" loading="lazy"><span class="zoomic">⤢</span><figcaption>XenoThreat · Streitkräfte</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-xeno-2.jpg"><img src="/assets/t-xeno-2.jpg" alt="XenoThreat im Gefecht" loading="lazy"><span class="zoomic">⤢</span><figcaption>Im Gefecht</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-idris.jpg"><img src="/assets/img-idris.jpg" alt="Idris-M-Fregatte" loading="lazy"><span class="zoomic">⤢</span><figcaption>Idris-M-Fregatte</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-hammerhead.jpg"><img src="/assets/img-hammerhead.jpg" alt="Hammerhead-Gunship" loading="lazy"><span class="zoomic">⤢</span><figcaption>Hammerhead-Gunship</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/img-vanduul.jpg"><img src="/assets/img-vanduul.jpg" alt="Bedrohung von aussen" loading="lazy"><span class="zoomic">⤢</span><figcaption>Bedrohung von außen</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="SsOtI2dtvBc" style="background-image:url('/assets/trailer-4-8-0.jpg')"><span class="vlbl">Alpha 4.8.0 — Trailer</span><button class="play" aria-label="Trailer abspielen">▶</button></div>
      <p class="src reveal">Quelle: offizieller Star-Citizen-YouTube-Kanal &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=SsOtI2dtvBc" target="_blank" rel="noopener">Auf YouTube ansehen ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-8-0-xenothreat" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Schließen">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
