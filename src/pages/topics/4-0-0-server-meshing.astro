---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TopicSeo from '../../components/dossier/TopicSeo.astro';
---
<Layout title={"Server Meshing — Star Citizen 4.0.0 | VerseBase"} description={"Server Meshing: the key technology of Alpha 4.0.0. Multiple game servers invisibly and seamlessly serve a single shard — Stanton and Pyro in one shared universe."} translated={true} themeColor="#120f0c" ogType="article" ogImage="/assets/t-mesh-1.jpg">
<TopicSeo slug="4-0-0-server-meshing" image="/assets/t-mesh-1.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Pyro-Theme (geerbt von 4.0.0) */
:root{--bg:#120f0c;--bg-2:#1a1714;--surface:#211b16;--surface-2:#2b231b;--accent:#ff5a1f;--accent-2:#d9d12a;--hot:#c0271f;--text:#f3e9df;--muted:#b6a596;--line:rgba(255,90,31,.22);--line-soft:rgba(243,233,223,.10);--glow:0 0 44px rgba(255,90,31,.32);--ink:#120f0c;--maxw:1180px;}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#fbf7f2;--bg-2:#f1ede9;--surface:#fefdfc;--surface-2:#f9f1e9;--text:#251e17;--muted:#645547;--accent:#9e2f01;--accent-2:#5c5801;--hot:#9e0004;--ink:#ffffff;--accent-media:#ff5a1f;--accent-2-media:#d9d12a;--line:rgba(163,91,69,.3);--line-soft:rgba(52,44,37,.12);--glow:0 6px 22px rgba(171,85,59,.18)}


/* page-local accents */
.hero h1{font-size:clamp(3rem,12vw,9.5rem)}
.tech-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}
.band .big.layer{-webkit-text-stroke:2px var(--accent-2);color:transparent}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.0.0', href: '/patches/sc-4-0-0.html' }, { label: "Server Meshing" }]} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-mesh-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-0-0.html">Alpha 4.0.0 · Destination Pyro</a> &nbsp;·&nbsp; Technology</div>
      <h1><span class="thin">The technology behind 4.0.0</span>Server Meshing</h1>
      <p class="lead">The key technology of Alpha 4.0.0: multiple game servers invisibly and seamlessly serve a single shard — for the first time, hundreds of players share one contiguous universe.</p>
      <div class="tags"><span class="tag">Static Server Meshing</span><span class="tag">Replication Layer</span><span class="tag">1 Shard</span><span class="tag hot">500 players</span><span class="tag">Stanton + Pyro</span></div>
      <div class="hero__play" data-lb="yt:DE3ePRgpUQo"><span class="pbtn">▶</span>Watch trailer</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>SERVER MESHING</span><span class="dot">◆</span><span>REPLICATION LAYER</span><span class="dot">◆</span><span>1 SHARD</span><span class="dot">◆</span><span>500 PLAYERS</span><span class="dot">◆</span><span>STATIC MESH</span><span class="dot">◆</span><span>STANTON + PYRO</span><span class="dot">◆</span>
      <span>SERVER MESHING</span><span class="dot">◆</span><span>REPLICATION LAYER</span><span class="dot">◆</span><span>1 SHARD</span><span class="dot">◆</span><span>500 PLAYERS</span><span class="dot">◆</span><span>STATIC MESH</span><span class="dot">◆</span><span>STANTON + PYRO</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-0-0-server-meshing" />

  <!-- FULL-BLEED BAND (parallax) — the thesis -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/img-pyro.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">After years of development</div>
      <div class="big outline">ONE SHARD.</div>
      <p>Alpha 4.0.0 delivered the first implementation of <b style="color:var(--accent-2)">Static Server Meshing</b> — the key technology of the patch. Instead of one server per game world, multiple servers now jointly simulate a single, seamless universe.</p>
    </div>
  </section>

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="500">0</div><div class="c">Players per shard</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Shared shard</div></div>
    <div class="s"><div class="n count" data-to="2">0</div><div class="c">Systems · Stanton + Pyro</div></div>
    <div class="s"><div class="n">STATIC</div><div class="c">Server Meshing premiere</div></div>
  </div>

  <!-- SCROLLYTELLING: Wie Meshing funktioniert (process) -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">01</span><h2>How the meshing works</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/img-pyro.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-pyro-3.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-pyro-7.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-pyro-5.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Split the world</h3><p>Static Server Meshing uses a fixed, predefined division of the world across multiple servers — each takes over a clearly assigned part of the universe.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Servers simulate</h3><p>Each game server simulates its section — such as Stanton or Pyro — independently, while all together carry the same play space.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Replication Layer</h3><p>Beneath it lies the Replication Layer, which separates game state persistence from the individual servers — the state of the world lives independently of any single server.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Switch seamlessly</h3><p>This lets players move between meshed servers without a disconnect and experience the whole as a single, contiguous shard.</p></div>
    </div>
  </div>

  <!-- VERSUS: Vorher vs Nachher (full-bleed) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚙ Single server</h3>
        <ul>
          <li>One server carries a game world on its own.</li>
          <li>Around 100 players in the same space.</li>
          <li>Persistence tied to the individual server.</li>
          <li>Multiple systems together not possible.</li>
        </ul>
      </div>
      <div class="vs">→</div>
      <div class="side b">
        <h3>★ Server Meshing</h3>
        <ul>
          <li>Multiple servers serve one shard.</li>
          <li>Up to around 500 players in the same space.</li>
          <li>Replication Layer holds the persistence.</li>
          <li>Stanton and Pyro in the shared shard.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Many servers. <span class="hl">One seamless universe.</span> No seam to be seen.</blockquote>
    <cite>Static Server Meshing · Alpha 4.0.0</cite>
  </section>

  <!-- DER REPLICATION LAYER — single framed/split section (the only one) -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-mesh-2.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">02 · The foundation</div>
        <h3>The Replication Layer</h3>
        <p>Beneath the meshing lies the <b>Replication Layer</b> — the layer that decouples game state persistence from the individual game servers. The state of the world is no longer held by a single server, but replicated centrally.</p>
        <p>This is exactly what makes the seamless transition possible: players switch <b>without a disconnect</b> between meshed servers. It is the first step toward the later <b>Dynamic Server Meshing</b>, in which the division of the world adapts flexibly to the load.</p>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND — warum es nötig war -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-pyro-4.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">03 · Why at all?</div>
      <div class="big layer" style="font-size:clamp(2.4rem,8vw,6rem)">STANTON + PYRO</div>
      <p>The technology was needed to run <b style="color:var(--accent-2)">Stanton and Pyro</b> together in a shared shard. Two full star systems in one contiguous space — that exceeded the limits of a single server and made meshing a prerequisite for Destination Pyro.</p>
    </div>
  </section>

  <!-- MEDIA (mixed gallery + trailer) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">04</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-mesh-1.jpg"><img src="/assets/t-mesh-1.jpg" alt="Server Meshing — server cluster" loading="lazy"><span class="zoomic">⤢</span><figcaption>Server cluster · one shard</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-mesh-2.jpg"><img src="/assets/t-mesh-2.jpg" alt="Replication Layer" loading="lazy"><span class="zoomic">⤢</span><figcaption>Replication Layer</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-pyro-3.jpg"><img src="/assets/t-pyro-3.jpg" alt="Shattered, glowing moon with a debris field in Pyro" loading="lazy"><span class="zoomic">⤢</span><figcaption>Pyro · new system</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/cz-facility.jpg"><img src="/assets/cz-facility.jpg" alt="Pyro facility" loading="lazy"><span class="zoomic">⤢</span><figcaption>Shared space</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="DE3ePRgpUQo" style="background-image:url('/assets/trailer-4-0-0.jpg')"><span class="vlbl">Destination Pyro — Trailer</span><button class="play" aria-label="Play trailer">▶</button></div>
      <p class="src reveal">Source: official Star Citizen YouTube channel &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=DE3ePRgpUQo" target="_blank" rel="noopener">Watch on YouTube ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-0-0-server-meshing" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
