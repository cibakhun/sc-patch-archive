---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TopicSeo from '../../components/dossier/TopicSeo.astro';
---
<Layout title={"Onyx Facilities — Star Citizen 4.3.0 | VerseBase"} description={"Onyx Facilities: around 100 abandoned ASD research stations across Stanton — data salvage, audio logs and the dark truth behind the regen crisis. Introduced with Alpha 4.3.0 Dark Territory."} translated={true} themeColor="#0B0B0F" ogType="article" ogImage="/assets/t-onyx-1.jpg">
<TopicSeo slug="4-3-0-onyx-facilities" image="/assets/t-onyx-1.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Onyx-Theme (4.3.0 · Dark Territory) */
:root{--bg:#0B0B0F;--bg-2:#101218;--surface:#15181f;--surface-2:#1c212b;--accent:#E8A317;--accent-2:#3E5C76;--hot:#C0392B;--text:#e9edf2;--muted:#97a3b2;--line:rgba(232,163,23,.22);--line-soft:rgba(233,237,242,.10);--glow:0 0 44px rgba(232,163,23,.30);--ink:#0B0B0F;--maxw:1180px;}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f7f7fd;--bg-2:#eaeef7;--surface:#fdfdff;--surface-2:#eef3fc;--text:#1d2023;--muted:#4e5967;--accent:#785305;--accent-2:#365977;--hot:#9e0500;--ink:#ffffff;--accent-media:#E8A317;--accent-2-media:#3E5C76;--line:rgba(144,106,39,.3);--line-soft:rgba(43,46,49,.12);--glow:0 6px 22px rgba(144,106,39,.18)}

/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.dossier{font-family:var(--font-ui);font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--hot);font-size:.78rem}
.tag.case{border-color:color-mix(in srgb,var(--accent-2) 60%,transparent);color:color-mix(in srgb,var(--accent-2) 80%,var(--text))}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.3.0', href: '/patches/sc-4-3-0.html' }, { label: "Onyx Facilities" }]} hasEn={true} />


<main id="main">

  <!-- HERO (full-bleed, kinetic) -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-onyx-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-3-0.html">Alpha 4.3.0 · Dark Territory</a> &nbsp;·&nbsp; Feature</div>
      <h1><span class="thin">Abandoned ASD research stations</span>Onyx Facilities</h1>
      <p class="lead">Around 100 abandoned research facilities of Associated Sciences and Development, scattered across Stanton — dangerous ruins full of data traces, audio logs and the dark truth behind the regen crisis.</p>
      <div class="tags"><span class="tag hot">Investigation</span><span class="tag case">ASD</span><span class="tag">Personal Hangars</span><span class="tag hot">Regen Crisis</span><span class="tag">Loot</span></div>
      <div class="hero__play" data-lb="yt:MCJlD2Meuek"><span class="pbtn">▶</span>Watch trailer</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>ONYX</span><span class="dot">◆</span><span>ASD</span><span class="dot">◆</span><span>REGEN CRISIS</span><span class="dot">◆</span><span>ARKEN MALLOR</span><span class="dot">◆</span><span>DR. JORRIT</span><span class="dot">◆</span><span>DATA SALVAGE</span><span class="dot">◆</span><span>PERSONAL HANGARS</span><span class="dot">◆</span>
      <span>ONYX</span><span class="dot">◆</span><span>ASD</span><span class="dot">◆</span><span>REGEN CRISIS</span><span class="dot">◆</span><span>ARKEN MALLOR</span><span class="dot">◆</span><span>DR. JORRIT</span><span class="dot">◆</span><span>DATA SALVAGE</span><span class="dot">◆</span><span>PERSONAL HANGARS</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-3-0-onyx-facilities" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="100">0</div><div class="c">Abandoned ASD facilities</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">System · Stanton, system-wide</div></div>
    <div class="s"><div class="n count" data-to="0">0</div><div class="c">Secured interiors</div></div>
    <div class="s"><div class="n">ASD</div><div class="c">Associated Sciences & Development</div></div>
  </div>

  <!-- FULL-BLEED BAND (parallax, big overlaid text) -->
  <section class="band" style="padding-top:0">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-onyx-3.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">01 · Dark Territory</div>
      <div class="big outline">ABANDONED.</div>
      <p>Alpha 4.3.0 brought around <b style="color:var(--accent-2)">100 abandoned research facilities</b> of Associated Sciences and Development — scattered across the entire Stanton system. No one has secured them. What remains are ruins and the traces of what was researched here.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: Die Ermittlung (full-bleed process) -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>The Investigation</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-onyx-4.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-onyx-5.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-onyx-6.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-onyx-7.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Take the contract</h3><p>Arken Mallor of the Hockrow Agency approaches you. Through a new investigation and data salvage system in the mobiGlas, he drives the inquiry against ASD and Dr. Logan Jorrit forward.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Enter the facility</h3><p>Land at one of the roughly 100 abandoned ASD stations and go in on foot. The interiors are unsecured and dangerous — no safety, only ruins and traces.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Salvage the data</h3><p>Recover data, solve the facility's puzzles and find hidden audio logs. Every find adds a piece to the picture — the backstory of the regen crisis.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Piece together the truth</h3><p>The recovered traces tell of Dr. Jorrit's experiments in regeneration. What ASD wanted to hide lies among the rubble and broken logs.</p></div>
    </div>
  </div>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Behind every ruin <span class="hl">the truth about the regen crisis</span>.</blockquote>
    <cite>Onyx Facilities · ASD investigation</cite>
  </section>

  <!-- VERSUS: Datenbergung vs Gefahr (full-bleed dual pane) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚠ The Danger</h3>
        <ul>
          <li>Interiors are unsecured — no safe zone.</li>
          <li>Ruins and unstable structures instead of safe paths.</li>
          <li>What ASD left behind protects itself.</li>
          <li>Deep in the complex — no med bay, no quick respawn.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ The Salvage</h3>
        <ul>
          <li>Recovered data drives the investigation forward.</li>
          <li>The facilities' puzzles unlock sealed traces.</li>
          <li>Hidden audio logs reveal Jorrit's experiments.</li>
          <li>Loot from the depths of the abandoned stations.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- AKTEURE — single framed/split section (the one allowed card-like layout) -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-onyx-8.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">03 · The Players</div>
        <h3>Mallor, ASD and Dr. Jorrit</h3>
        <p>The employer is <b>Arken Mallor</b> of the <b>Hockrow Agency</b>. He drives the investigation against Associated Sciences and Development and against <b>Dr. Logan Jorrit</b> forward.</p>
        <p>The abandoned facilities tell the backstory of the regen crisis: <b>Dr. Jorrit's experiments in regeneration</b>. Whoever searches the Onyx Facilities follows the trail back to its origin.</p>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND — Personal Hangars (image as background, design on top) -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-hangar-1.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · Also in 4.3.0</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">PERSONAL HANGARS</div>
      <p>4.3.0 also brought the <b style="color:var(--accent-2)">Personal Hangars</b>: players now load directly into their own, instanced hangar at their home location — a fixed starting point for every push into the Dark Territory.</p>
    </div>
  </section>

  <!-- MEDIA (mixed gallery + trailer) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">05</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-onyx-1.jpg"><img src="/assets/t-onyx-1.jpg" alt="Onyx Facility — abandoned ASD facility" loading="lazy"><span class="zoomic">⤢</span><figcaption>Abandoned ASD facility</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-onyx-2.jpg"><img src="/assets/t-onyx-2.jpg" alt="Ruins inside an Onyx Facility" loading="lazy"><span class="zoomic">⤢</span><figcaption>Ruins inside</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-onyx-3.jpg"><img src="/assets/t-onyx-3.jpg" alt="ASD facility exterior — ship on approach" loading="lazy"><span class="zoomic">⤢</span><figcaption>ASD facility · approach</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/trailer-4-3-0.jpg"><img src="/assets/trailer-4-3-0.jpg" alt="Dark Territory — 4.3.0" loading="lazy"><span class="zoomic">⤢</span><figcaption>Dark Territory</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-onyx-9.jpg"><img src="/assets/t-onyx-9.jpg" alt="Interior of an Onyx Facility with terminal and installations" loading="lazy"><span class="zoomic">⤢</span><figcaption>Inside · Terminals &amp; installations</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="MCJlD2Meuek" style="background-image:url('/assets/trailer-4-3-0.jpg')"><span class="vlbl">Alpha 4.3.0 Dark Territory — Trailer</span><button class="play" aria-label="Play trailer">▶</button></div>
      <p class="src reveal">Source: official Star Citizen YouTube channel &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=MCJlD2Meuek" target="_blank" rel="noopener">Watch on YouTube ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-3-0-onyx-facilities" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
