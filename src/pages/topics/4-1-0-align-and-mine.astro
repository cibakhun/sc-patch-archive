---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TopicSeo from '../../components/dossier/TopicSeo.astro';
---
<Layout title={"Align &amp; Mine — Star Citizen 4.1.0 | VerseBase"} description={"Align & Mine: a cooperative sandbox activity from Alpha 4.1.0 Orbital Assault — align the Hathor facilities on Aberdeen and Daymar and the orbital laser blasts open a fresh, mineral-rich cave."} themeColor="#10141a" ogType="article" ogImage="/assets/t-align-3.jpg" translated={true}>
<TopicSeo slug="4-1-0-align-and-mine" image="/assets/t-align-3.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Orbital-Assault-Theme (4.1.0) */
:root{--bg:#10141a;--bg-2:#171c24;--surface:#1d242e;--surface-2:#26303c;--accent:#3DA5D9;--accent-2:#E8A33D;--hot:#C0392B;--text:#eef1f4;--muted:#9aa4af;--line:rgba(61,165,217,.22);--line-soft:rgba(238,241,244,.10);--glow:0 0 44px rgba(61,165,217,.30);--ink:#10141a;--maxw:1180px;}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f3f8fe;--bg-2:#e8eef9;--surface:#fdfdff;--surface-2:#ecf3fc;--text:#1d1f22;--muted:#505963;--accent:#00638a;--accent-2:#754b02;--hot:#9e0500;--ink:#ffffff;--accent-media:#3DA5D9;--accent-2-media:#E8A33D;--line:rgba(40,122,163,.3);--line-soft:rgba(44,46,49,.12);--glow:0 6px 22px rgba(40,122,163,.18)}


/* page-local accents */
.hero h1{font-size:clamp(3.1rem,13vw,10rem)}
.lede-kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}
.moon-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.1.0', href: '/patches/sc-4-1-0.html' }, { label: "Align & Mine" }]} hasEn={true} />


<main id="main">

  <!-- HERO (full-bleed bg, kinetic) -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-align-3.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-1-0.html">Alpha 4.1.0 · Orbital Assault</a> &nbsp;·&nbsp; Feature</div>
      <h1><span class="thin">Orbital Laser Mining</span>Align &amp; Mine</h1>
      <p class="lead">A cooperative sandbox activity: align the Hathor facilities on two moons, fire the orbital mining laser — and it blasts a brand-new, mineral-rich cave into the surface.</p>
      <div class="tags"><span class="tag">Co-op</span><span class="tag">Mining</span><span class="tag">Hathor</span><span class="tag">Orbital Laser</span><span class="tag">Persistent</span></div>
      <div class="hero__play" data-lb="yt:NArGjlRFsQQ"><span class="pbtn">▶</span>Watch trailer</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>ALIGN &amp; MINE</span><span class="dot">◆</span><span>HATHOR</span><span class="dot">◆</span><span>ORBITAL-LASER</span><span class="dot">◆</span><span>ABERDEEN</span><span class="dot">◆</span><span>DAYMAR</span><span class="dot">◆</span><span>MINING</span><span class="dot">◆</span>
      <span>ALIGN &amp; MINE</span><span class="dot">◆</span><span>HATHOR</span><span class="dot">◆</span><span>ORBITAL-LASER</span><span class="dot">◆</span><span>ABERDEEN</span><span class="dot">◆</span><span>DAYMAR</span><span class="dot">◆</span><span>MINING</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-1-0-align-and-mine" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="2">0</div><div class="c">Moons · Aberdeen &amp; Daymar</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Orbital Mining Station per moon</div></div>
    <div class="s"><div class="n">1<span class="u">cave</span></div><div class="c">Blasted open per alignment</div></div>
    <div class="s"><div class="n">Co-op</div><div class="c">Persistent multiplayer loop</div></div>
  </div>

  <!-- FULL-BLEED BAND (parallax) — big overlaid statement -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-align-4.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">01 · What is Align &amp; Mine?</div>
      <div class="big outline">ALIGN. FIRE. MINE.</div>
      <p>Alpha 4.1.0 <b style="color:var(--accent-2)">Orbital Assault</b> brings a new cooperative, persistent sandbox activity to the Stanton system. Players align the <b style="color:var(--accent-2)">Hathor facilities</b> spread across the moons — triggering a strike from orbit.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: der mehrstufige Loop (PROCESS / steps) -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>The loop, step by step</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-align-5.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-align-9.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-align-7.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-align-2.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Find the Hathor facilities</h3><p>The Hathor facilities are spread across the Stanton moons Aberdeen and Daymar. Each moon has ground-based Alignment Facilities — the starting point of every run.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Align on the ground</h3><p>The crew works through the ground-based Alignment Facilities and aligns the facility correctly. This ground phase is the setup — cooperative and multi-stage.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>The laser fires from orbit</h3><p>Once correctly aligned, the Hathor laser fires from the Orbital Mining Station in orbit onto the moon's surface — the decisive moment of the loop.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Cave &amp; reward</h3><p>The beam blasts open a brand-new cave full of valuable minerals. The setup on the ground turns into the reward: fresh, mineral-rich mining grounds.</p></div>
    </div>
  </div>

  <!-- VERSUS: zwei Seiten des Loops (full-bleed) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⛏ Ground · Alignment</h3>
        <ul>
          <li>Work through the ground-based Alignment Facilities.</li>
          <li>Align the Hathor facility correctly.</li>
          <li>Cooperative, multi-stage setup.</li>
          <li>Spread across Aberdeen and Daymar.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ Orbit · Reward</h3>
        <ul>
          <li>The Hathor laser fires from orbit.</li>
          <li>The beam blasts open a brand-new cave.</li>
          <li>A cave full of valuable minerals.</li>
          <li>Mining as the payoff of the shared run.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>First <span class="hl">align on the ground</span> — then orbit blasts a cave into the moon.</blockquote>
    <cite>Align &amp; Mine · Orbital Assault</cite>
  </section>

  <!-- FRAMED SPLIT (the one framed section) — die Hathor-Anlagen -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-align-1.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">03 · The Hathor facilities</div>
        <h3>Ground and orbit, two moons</h3>
        <p>Each of the two moons — <b>Aberdeen</b> and <b>Daymar</b> — has ground-based <b>Alignment Facilities</b> plus an <b>Orbital Mining Station</b>. Only the interplay between ground facilities and orbital platform makes the strike possible.</p>
        <p>The facilities are spread across the moon's surface; the crew has to seek them out and align them before the station in orbit can fire. <b>Correctly aligned</b>, the Hathor laser focuses its energy on a single point of the surface.</p>
        <div style="margin-top:.4rem"><span class="moon-tag">Aberdeen</span> &nbsp;·&nbsp; <span class="moon-tag">Daymar</span></div>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND (parallax) — der Einschlag -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-align-8.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · The impact</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">NEW CAVE</div>
      <p>Where the beam hits the surface, a brand-new cave full of valuable minerals opens up — fresh mining grounds that didn't exist before. Persistent in the universe, created by the shared run.</p>
    </div>
  </section>

  <!-- MEDIA (mixed gallery + trailer) — close with full-bleed media -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">05</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-align-3.jpg"><img src="/assets/t-align-3.jpg" alt="Hathor facility backlit by the rising sun" loading="lazy"><span class="zoomic">⤢</span><figcaption>Hathor facility · Sunrise</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-align-7.jpg"><img src="/assets/t-align-7.jpg" alt="The orbital mining laser fires at the surface" loading="lazy"><span class="zoomic">⤢</span><figcaption>Laser from orbit</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-align-2.jpg"><img src="/assets/t-align-2.jpg" alt="Drill head in the blasted-open cave" loading="lazy"><span class="zoomic">⤢</span><figcaption>Cave · Drill head</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="NArGjlRFsQQ" style="background-image:url('/assets/trailer-4-1-0.jpg')"><span class="vlbl">Orbital Assault — Trailer</span><button class="play" aria-label="Play trailer">▶</button></div>
      <p class="src reveal">Source: official Star Citizen YouTube channel &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=NArGjlRFsQQ" target="_blank" rel="noopener">Watch on YouTube ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-1-0-align-and-mine" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
