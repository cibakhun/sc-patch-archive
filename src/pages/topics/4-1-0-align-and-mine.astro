---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
---
<Layout title={"Align &amp; Mine — Star Citizen 4.1.0 | SC Patch-Archiv"} description={"Align & Mine: kooperative Sandbox-Aktivität aus Alpha 4.1.0 Orbital Assault — richte die Hathor-Anlagen auf Aberdeen und Daymar aus und der Orbital-Laser sprengt eine neue, mineralienreiche Höhle frei."} themeColor="#10141a" ogType="article" ogImage="/assets/t-align-3.jpg" translated={true}>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Orbital-Assault-Theme (4.1.0) */
:root{--bg:#10141a;--bg-2:#171c24;--surface:#1d242e;--surface-2:#26303c;--accent:#3DA5D9;--accent-2:#E8A33D;--hot:#C0392B;--text:#eef1f4;--muted:#9aa4af;--line:rgba(61,165,217,.22);--line-soft:rgba(238,241,244,.10);--glow:0 0 44px rgba(61,165,217,.30);--ink:#10141a;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(3.1rem,13vw,10rem)}
.lede-kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}
.moon-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/index.html' }, { label: 'Alpha 4.1.0', href: '/patches/sc-4-1-0.html' }, { label: "Align & Mine" }]} pill={"FEATURE · ALPHA 4.1.0"} hasEn={true} />


<main id="main">

  <!-- HERO (full-bleed bg, kinetic) -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-align-3.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-1-0.html">Alpha 4.1.0 · Orbital Assault</a> &nbsp;·&nbsp; Feature</div>
      <h1><span class="thin">Orbital-Laser-Bergbau</span>Align &amp; Mine</h1>
      <p class="lead">Eine kooperative Sandbox-Aktivität: richte die Hathor-Anlagen auf zwei Monden aus, zünde den Orbital-Mining-Laser — und er sprengt eine brandneue, mineralienreiche Höhle in die Oberfläche.</p>
      <div class="tags"><span class="tag">Co-op</span><span class="tag">Mining</span><span class="tag">Hathor</span><span class="tag">Orbital-Laser</span><span class="tag">Persistent</span></div>
      <div class="hero__play" data-lb="yt:NArGjlRFsQQ"><span class="pbtn">▶</span>Trailer ansehen</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>ALIGN &amp; MINE</span><span class="dot">◆</span><span>HATHOR</span><span class="dot">◆</span><span>ORBITAL-LASER</span><span class="dot">◆</span><span>ABERDEEN</span><span class="dot">◆</span><span>DAYMAR</span><span class="dot">◆</span><span>MINING</span><span class="dot">◆</span>
      <span>ALIGN &amp; MINE</span><span class="dot">◆</span><span>HATHOR</span><span class="dot">◆</span><span>ORBITAL-LASER</span><span class="dot">◆</span><span>ABERDEEN</span><span class="dot">◆</span><span>DAYMAR</span><span class="dot">◆</span><span>MINING</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-1-0-align-and-mine" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="2">0</div><div class="c">Monde · Aberdeen &amp; Daymar</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Orbital Mining Station je Mond</div></div>
    <div class="s"><div class="n">1<span class="u">Höhle</span></div><div class="c">Freigesprengt pro Ausrichtung</div></div>
    <div class="s"><div class="n">Co-op</div><div class="c">Persistenter Multiplayer-Loop</div></div>
  </div>

  <!-- FULL-BLEED BAND (parallax) — big overlaid statement -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-align-4.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">01 · Was ist Align &amp; Mine?</div>
      <div class="big outline">AUSRICHTEN. ZÜNDEN. SCHÜRFEN.</div>
      <p>Mit Alpha 4.1.0 <b style="color:var(--accent-2)">Orbital Assault</b> kommt eine neue kooperative, persistente Sandbox-Aktivität ins Stanton-System. Spieler richten die über die Monde verteilten <b style="color:var(--accent-2)">Hathor-Anlagen</b> aus — und lösen damit einen Schlag aus dem Orbit aus.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: der mehrstufige Loop (PROCESS / steps) -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>Der Loop, Schritt für Schritt</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-align-5.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-align-9.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-align-7.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-align-2.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Hathor-Anlagen finden</h3><p>Auf den Stanton-Monden Aberdeen und Daymar sind die Hathor-Anlagen verteilt. Zu jedem Mond gehören bodenbasierte Alignment Facilities — der Ausgangspunkt jedes Runs.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Am Boden ausrichten</h3><p>Die Crew arbeitet die bodenbasierten Alignment Facilities ab und richtet die Anlage korrekt aus. Diese Boden-Phase ist die Vorbereitung — kooperativ und mehrstufig.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Laser feuert aus dem Orbit</h3><p>Korrekt ausgerichtet feuert der Hathor-Laser von der Orbital Mining Station aus dem Orbit auf die Mondoberfläche — der entscheidende Moment des Loops.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Höhle &amp; Belohnung</h3><p>Der Strahl sprengt eine brandneue Höhle voller wertvoller Mineralien frei. Aus der Vorbereitung am Boden wird die Belohnung: frisches, mineralienreiches Schürfgebiet.</p></div>
    </div>
  </div>

  <!-- VERSUS: zwei Seiten des Loops (full-bleed) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⛏ Boden · Ausrichtung</h3>
        <ul>
          <li>Bodenbasierte Alignment Facilities abarbeiten.</li>
          <li>Hathor-Anlage korrekt ausrichten.</li>
          <li>Kooperative, mehrstufige Vorbereitung.</li>
          <li>Verteilt auf Aberdeen und Daymar.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ Orbit · Belohnung</h3>
        <ul>
          <li>Hathor-Laser feuert aus dem Orbit.</li>
          <li>Strahl sprengt eine brandneue Höhle frei.</li>
          <li>Höhle voller wertvoller Mineralien.</li>
          <li>Mining als Ertrag des gemeinsamen Runs.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Erst <span class="hl">ausrichten am Boden</span> — dann schlägt der Orbit eine Höhle in den Mond.</blockquote>
    <cite>Align &amp; Mine · Orbital Assault</cite>
  </section>

  <!-- FRAMED SPLIT (the one framed section) — die Hathor-Anlagen -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-align-1.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">03 · Die Hathor-Anlagen</div>
        <h3>Boden und Orbit, zwei Monde</h3>
        <p>Zu jedem der beiden Monde — <b>Aberdeen</b> und <b>Daymar</b> — gehören bodenbasierte <b>Alignment Facilities</b> plus eine <b>Orbital Mining Station</b>. Erst das Zusammenspiel aus Boden-Anlagen und Orbital-Plattform macht den Schlag möglich.</p>
        <p>Die Anlagen sind über die Mondoberfläche verteilt; die Crew muss sie aufsuchen und ausrichten, bevor die Station im Orbit feuern kann. <b>Korrekt ausgerichtet</b> bündelt der Hathor-Laser seine Energie auf einen einzigen Punkt der Oberfläche.</p>
        <div style="margin-top:.4rem"><span class="moon-tag">Aberdeen</span> &nbsp;·&nbsp; <span class="moon-tag">Daymar</span></div>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND (parallax) — der Einschlag -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-align-8.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · Der Einschlag</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">NEUE HÖHLE</div>
      <p>Wo der Strahl die Oberfläche trifft, öffnet sich eine brandneue Höhle voller wertvoller Mineralien — frisches Schürfgebiet, das es vorher nicht gab. Persistent im Universum, geschaffen durch den gemeinsamen Run.</p>
    </div>
  </section>

  <!-- MEDIA (mixed gallery + trailer) — close with full-bleed media -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">05</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-align-3.jpg"><img src="/assets/t-align-3.jpg" alt="Hathor-Anlage im Gegenlicht der aufgehenden Sonne" loading="lazy"><span class="zoomic">⤢</span><figcaption>Hathor-Anlage · Sonnenaufgang</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-align-7.jpg"><img src="/assets/t-align-7.jpg" alt="Der Orbital-Mining-Laser feuert auf die Oberfläche" loading="lazy"><span class="zoomic">⤢</span><figcaption>Laser aus dem Orbit</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-align-2.jpg"><img src="/assets/t-align-2.jpg" alt="Bohrkopf in der freigesprengten Höhle" loading="lazy"><span class="zoomic">⤢</span><figcaption>Höhle · Bohrkopf</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="NArGjlRFsQQ" style="background-image:url('/assets/trailer-4-1-0.jpg')"><span class="vlbl">Orbital Assault — Trailer</span><button class="play" aria-label="Trailer abspielen">▶</button></div>
      <p class="src reveal">Quelle: offizieller Star-Citizen-YouTube-Kanal &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=NArGjlRFsQQ" target="_blank" rel="noopener">Auf YouTube ansehen ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-1-0-align-and-mine" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Schließen">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
