---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TopicSeo from '../../components/dossier/TopicSeo.astro';
---
<Layout title={"Contested Zones — Star Citizen 4.0.0 | VerseBase"} description={"Contested Zones: the Verse's first high-risk PvPvE loot zones, deep inside Pyro's facilities — introduced with Alpha 4.0.0."} translated={true} themeColor="#120f0c" ogType="article" ogImage="/assets/cz-facility.jpg">
<TopicSeo slug="4-0-0-contested-zones" image="/assets/cz-facility.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Pyro-Theme (geerbt von 4.0.0) */
:root{
  --bg:#120f0c;--bg-2:#1a1714;--surface:#211b16;--surface-2:#2b231b;
  --accent:#ff5a1f;--accent-2:#d9d12a;--hot:#c0271f;
  --text:#f3e9df;--muted:#b6a596;
  --line:rgba(255,90,31,.22);--line-soft:rgba(243,233,223,.10);
  --glow:0 0 44px rgba(255,90,31,.32);--ink:#120f0c;
  --maxw:1180px;
}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#fbf7f2;--bg-2:#f1ede9;--surface:#fefdfc;--surface-2:#f9f1e9;--text:#251e17;--muted:#645547;--accent:#9e2f01;--accent-2:#5c5801;--hot:#9e0004;--ink:#ffffff;--accent-media:#ff5a1f;--accent-2-media:#d9d12a;--line:rgba(163,91,69,.3);--line-soft:rgba(52,44,37,.12);--glow:0 6px 22px rgba(171,85,59,.18)}


/* page-local accents */
.hero h1{font-size:clamp(3.4rem,14vw,11rem)}
.lede-kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.0.0', href: '/patches/sc-4-0-0.html' }, { label: "Contested Zones" }]} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/cz-facility.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-0-0.html">Alpha 4.0.0 · Destination Pyro</a> &nbsp;·&nbsp; Feature</div>
      <h1><span class="thin">Pyro's High-Risk Loot Zones</span>Contested Zones</h1>
      <p class="lead">Sealed-off areas deep inside Pyro's facilities, where AI factions, rival players and the best loot in the Verse collide — and only those who make it back out survive.</p>
      <div class="tags"><span class="tag hot">PvPvE</span><span class="tag">On-Foot / FPS</span><span class="tag">High-Tier Loot</span><span class="tag">Extraction</span><span class="tag">No Safe Zone</span></div>
      <div class="hero__play" data-lb="yt:DE3ePRgpUQo"><span class="pbtn">▶</span>Watch trailer</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>PVPVE</span><span class="dot">◆</span><span>EXTRACTION</span><span class="dot">◆</span><span>NO LAW</span><span class="dot">◆</span><span>HIGH-TIER LOOT</span><span class="dot">◆</span><span>AI GUARDS</span><span class="dot">◆</span><span>DEATH = LOOT GONE</span><span class="dot">◆</span><span>RUIN STATION</span><span class="dot">◆</span>
      <span>PVPVE</span><span class="dot">◆</span><span>EXTRACTION</span><span class="dot">◆</span><span>NO LAW</span><span class="dot">◆</span><span>HIGH-TIER LOOT</span><span class="dot">◆</span><span>AI GUARDS</span><span class="dot">◆</span><span>DEATH = LOOT GONE</span><span class="dot">◆</span><span>RUIN STATION</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-0-0-contested-zones" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="6">0</div><div class="c">Ruined Worlds · Pyro</div></div>
    <div class="s"><div class="n count" data-to="500">0</div><div class="c">Players per Shard</div></div>
    <div class="s"><div class="n count" data-to="0">0</div><div class="c">Safe Zones</div></div>
    <div class="s"><div class="n">PvPvE</div><div class="c">Endgame Debut in the PU</div></div>
  </div>

  <!-- OVERVIEW as SPLIT -->
  <section style="padding-bottom:0">
    <div class="split reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/cz-combat.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">01 · Overview</div>
        <h3>The first true PvPvE loot zone</h3>
        <p>With the jump to Pyro, Alpha 4.0.0 brought the <b>Contested Zones</b> — sealed areas inside certain Pyro locations, home to the most valuable loot in the game. No safe zone, no guarantees.</p>
        <p>Whoever enters fights their way through AI factions on foot and shares the space with every other player after the same thing. It's the first real <b>PvPvE endgame activity</b> in the persistent universe — built for exactly the lawless mood that defines Pyro.</p>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND (parallax) -->
  <section class="band" style="padding-top:0">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-pyro-4.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">Pyro Knows No Law</div>
      <div class="big outline">NO NET.</div>
      <p>Even the crew you broke in with can turn on you for the loot. The fragile ceasefire only holds while pockets are empty — just before the exit, when everyone is fully loaded, it shatters first.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: So läuft ein Run -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>How a run plays out</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-pyro-7.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-combat.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-loot.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-ruin.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Break in</h3><p>Land at a Pyro location with a Contested Zone and enter the secured area on foot — from here on, you're on your own.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Fight through</h3><p>Take out hostile AI guards and push deeper toward the locked loot rooms — while other players attempt the same.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Secure the loot</h3><p>Plunder high-value weapons, armor, ship components and valuables from the depots — the deeper you go, the better.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Get out alive</h3><p>Bring the haul back to your ship and escape. Die in the zone and everything you carry is lost.</p></div>
    </div>
  </div>

  <!-- VERSUS: Risiko vs Belohnung (full-bleed) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚠ Risk</h3>
        <ul>
          <li>Heavily armed Outlaw gang guards defend every depot to the last man.</li>
          <li>No bed, no med-bay in the zone — whoever falls has no quick respawn on site.</li>
          <li>Death means losing all carried loot to your killers.</li>
          <li>PvPvE social dynamics: shaky ceasefires shatter, a seeming ally turns traitor.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ Reward</h3>
        <ul>
          <li>High-tier ship components for your own fleet.</li>
          <li>High-value FPS weapons and armor from the locked rooms.</li>
          <li>Valuable trade and contraband goods to resell.</li>
          <li>The deeper you push into the zone, the more valuable the loot.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- WO IN PYRO — full-bleed band (image as background, design on top) -->
  <section class="band">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-ruin-1.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">03 · Where in Pyro?</div>
      <div class="big outline" style="font-size:clamp(2.4rem,7vw,5.5rem)">RUIN STATION</div>
      <p>Contested Zones sit in select Pyro locations — industrial and supply facilities held by Outlaw gangs, sealed off as loot zones. Typical settings are derelict mining and refinery platforms as well as abandoned supply and storage depots, where the most valuable loot lies locked away. Pyro's six planets, its asteroid field and stations like <b style="color:var(--accent-2)">Ruin Station</b>, a former Gold Horizon mining platform, form the lawless backdrop.</p>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Will you plunder <span class="hl">the best loot in the Verse</span> — or become the prey yourself?</blockquote>
    <cite>Contested Zones · Pyro</cite>
  </section>

  <!-- MEDIA (mixed gallery + trailer) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">04</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-pyro-3.jpg"><img src="/assets/t-pyro-3.jpg" alt="Shattered, glowing moon with a debris field in Pyro" loading="lazy"><span class="zoomic">⤢</span><figcaption>Shattered Moon · Pyro</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/cz-facility.jpg"><img src="/assets/cz-facility.jpg" alt="Contested Zone — facility interior" loading="lazy"><span class="zoomic">⤢</span><figcaption>Facility Interior</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/cz-loot.jpg"><img src="/assets/cz-loot.jpg" alt="High-Tier Loot" loading="lazy"><span class="zoomic">⤢</span><figcaption>High-Tier Loot</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-pyro-7.jpg"><img src="/assets/t-pyro-7.jpg" alt="Patch City — Outlaw station in Pyro's asteroid field" loading="lazy"><span class="zoomic">⤢</span><figcaption>Patch City · Outlaw Port</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-ruin-1.jpg"><img src="/assets/t-ruin-1.jpg" alt="Ruin Station in front of the planet Terminus" loading="lazy"><span class="zoomic">⤢</span><figcaption>Ruin Station · Terminus</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="DE3ePRgpUQo" style="background-image:url('/assets/trailer-4-0-0.jpg')"><span class="vlbl">Destination Pyro — Trailer</span><button class="play" aria-label="Play trailer">▶</button></div>
      <p class="src reveal">Source: official Star Citizen YouTube channel &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=DE3ePRgpUQo" target="_blank" rel="noopener">Watch on YouTube ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-0-0-contested-zones" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
