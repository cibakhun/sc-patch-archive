---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
---
<Layout title={"Contested Zones — Star Citizen 4.0.0 | SC Patch-Archiv"} description={"Contested Zones: die ersten PvPvE-Hochrisiko-Beutezonen des Verse, tief in Pyros Anlagen — eingeführt mit Alpha 4.0.0."} themeColor="#120f0c" ogType="article" ogImage="/assets/cz-facility.jpg">
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Pyro-Theme (geerbt von 4.0.0) */
:root{
  --bg:#120f0c;--bg-2:#1a1714;--surface:#211b16;--surface-2:#2b231b;
  --accent:#ff5a1f;--accent-2:#d9d12a;--hot:#c0271f;
  --text:#f3e9df;--muted:#b6a596;
  --line:rgba(255,90,31,.22);--line-soft:rgba(243,233,223,.10);
  --glow:0 0 44px rgba(255,90,31,.32);--ink:#120f0c;
  --maxw:1180px;
}
/* page-local accents */
.hero h1{font-size:clamp(3.4rem,14vw,11rem)}
.lede-kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/index.html' }, { label: 'Alpha 4.0.0', href: '/patches/sc-4-0-0.html' }, { label: "Contested Zones" }]} pill={"FEATURE · ALPHA 4.0.0"} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/cz-facility.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-0-0.html">Alpha 4.0.0 · Destination Pyro</a> &nbsp;·&nbsp; Feature</div>
      <h1><span class="thin">Pyros Hochrisiko-Beutezonen</span>Contested Zones</h1>
      <p class="lead">Abgeriegelte Areale tief in Pyros Anlagen, in denen KI-Fraktionen, rivalisierende Spieler und das beste Loot des Verse aufeinandertreffen — und nur überlebt, wer wieder rauskommt.</p>
      <div class="tags"><span class="tag hot">PvPvE</span><span class="tag">On-Foot / FPS</span><span class="tag">High-Tier Loot</span><span class="tag">Extraktion</span><span class="tag">Keine Sicherheitszone</span></div>
      <div class="hero__play" data-lb="yt:DE3ePRgpUQo"><span class="pbtn">▶</span>Trailer ansehen</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>PVPVE</span><span class="dot">◆</span><span>EXTRAKTION</span><span class="dot">◆</span><span>KEIN GESETZ</span><span class="dot">◆</span><span>HIGH-TIER LOOT</span><span class="dot">◆</span><span>KI-WACHEN</span><span class="dot">◆</span><span>TOD = LOOT WEG</span><span class="dot">◆</span><span>RUIN STATION</span><span class="dot">◆</span>
      <span>PVPVE</span><span class="dot">◆</span><span>EXTRAKTION</span><span class="dot">◆</span><span>KEIN GESETZ</span><span class="dot">◆</span><span>HIGH-TIER LOOT</span><span class="dot">◆</span><span>KI-WACHEN</span><span class="dot">◆</span><span>TOD = LOOT WEG</span><span class="dot">◆</span><span>RUIN STATION</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-0-0-contested-zones" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="6">0</div><div class="c">Ruinierte Welten · Pyro</div></div>
    <div class="s"><div class="n count" data-to="500">0</div><div class="c">Spieler pro Shard</div></div>
    <div class="s"><div class="n count" data-to="0">0</div><div class="c">Sicherheitszonen</div></div>
    <div class="s"><div class="n">PvPvE</div><div class="c">Endgame-Premiere im PU</div></div>
  </div>

  <!-- OVERVIEW as SPLIT -->
  <section style="padding-bottom:0">
    <div class="split reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/cz-combat.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">01 · Überblick</div>
        <h3>Die erste echte PvPvE-Beutezone</h3>
        <p>Mit dem Sprung nach Pyro brachte Alpha 4.0.0 die <b>Contested Zones</b> — versiegelte Areale innerhalb bestimmter Pyro-Standorte, in denen sich die wertvollste Beute des Spiels findet. Keine Sicherheitszone, keine Garantien.</p>
        <p>Wer eintritt, kämpft sich zu Fuß gegen KI-Fraktionen vor und teilt sich den Raum mit jedem anderen Spieler, der dasselbe will. Es ist die erste richtige <b>PvPvE-Endgame-Aktivität</b> im persistenten Universum — gebaut für genau die gesetzlose Stimmung, die Pyro definiert.</p>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND (parallax) -->
  <section class="band" style="padding-top:0">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-pyro-4.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">Pyro kennt kein Gesetz</div>
      <div class="big outline">KEIN NETZ.</div>
      <p>Selbst der Trupp, mit dem du eingedrungen bist, kann sich für das Loot gegen dich wenden. Die brüchige Waffenruhe hält nur, solange die Taschen leer sind — kurz vor dem Ausgang, wenn alle voll beladen sind, zerbricht sie zuerst.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: So läuft ein Run -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>So läuft ein Run</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-pyro-7.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-combat.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-loot.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-ruin.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Eindringen</h3><p>Lande an einem Pyro-Standort mit Contested Zone und betritt das gesicherte Areal zu Fuß — ab hier bist du auf dich gestellt.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Durchkämpfen</h3><p>Schalte feindliche KI-Wachen aus und arbeite dich tiefer zu den verschlossenen Loot-Räumen vor — während andere Spieler dasselbe versuchen.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Loot sichern</h3><p>Plündere hochwertige Waffen, Rüstung, Schiffskomponenten und Wertgüter aus den Depots — je tiefer, desto besser.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Lebend raus</h3><p>Bring die Beute zurück zum Schiff und fliehe. Stirbst du in der Zone, ist alles, was du trägst, verloren.</p></div>
    </div>
  </div>

  <!-- VERSUS: Risiko vs Belohnung (full-bleed) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚠ Risiko</h3>
        <ul>
          <li>Schwer bewaffnete Outlaw-Gang-Wachen verteidigen jedes Depot bis zum letzten Mann.</li>
          <li>Kein Bett, kein Med-Bay in der Zone — wer fällt, hat keinen schnellen Respawn vor Ort.</li>
          <li>Tod bedeutet Verlust der gesamten getragenen Beute an deine Mörder.</li>
          <li>PvPvE-Sozialgefüge: Wackelige Waffenruhen zerbrechen, ein scheinbarer Verbündeter wird zum Verräter.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ Belohnung</h3>
        <ul>
          <li>High-Tier-Schiffskomponenten für deine eigene Flotte.</li>
          <li>Hochwertige FPS-Waffen und Rüstung aus den verschlossenen Räumen.</li>
          <li>Wertvolle Handels- und Schmuggelgüter zum Weiterverkauf.</li>
          <li>Je tiefer du in die Zone vordringst, desto wertvoller das Loot.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- WO IN PYRO — full-bleed band (image as background, design on top) -->
  <section class="band">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-ruin-1.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">03 · Wo in Pyro?</div>
      <div class="big outline" style="font-size:clamp(2.4rem,7vw,5.5rem)">RUIN STATION</div>
      <p>Contested Zones sitzen in ausgewählten Pyro-Standorten — von Outlaw-Gangs gehaltene Industrie- und Versorgungsanlagen, die als Beutezone versiegelt sind. Typische Schauplätze sind verfallene Bergbau- und Raffinerie-Plattformen sowie aufgegebene Versorgungs- und Lagerdepots, in denen die wertvollste Beute eingeschlossen liegt. Pyros sechs Planeten, sein Asteroidenfeld und Stationen wie <b style="color:var(--accent-2)">Ruin Station</b>, eine ehemalige Gold-Horizon-Bergbauplattform, bilden die gesetzlose Kulisse.</p>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Plünderst du <span class="hl">das beste Loot des Verse</span> — oder wirst du selbst zur Beute?</blockquote>
    <cite>Contested Zones · Pyro</cite>
  </section>

  <!-- MEDIA (mixed gallery + trailer) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">04</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-pyro-3.jpg"><img src="/assets/t-pyro-3.jpg" alt="Zerborstener, glühender Mond mit Trümmerfeld in Pyro" loading="lazy"><span class="zoomic">⤢</span><figcaption>Zerborstener Mond · Pyro</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/cz-facility.jpg"><img src="/assets/cz-facility.jpg" alt="Contested Zone — Anlageninneres" loading="lazy"><span class="zoomic">⤢</span><figcaption>Anlageninneres</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/cz-loot.jpg"><img src="/assets/cz-loot.jpg" alt="High-Tier Loot" loading="lazy"><span class="zoomic">⤢</span><figcaption>High-Tier Loot</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-pyro-7.jpg"><img src="/assets/t-pyro-7.jpg" alt="Patch City — Outlaw-Station in Pyros Asteroidenfeld" loading="lazy"><span class="zoomic">⤢</span><figcaption>Patch City · Outlaw-Hafen</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-ruin-1.jpg"><img src="/assets/t-ruin-1.jpg" alt="Ruin Station vor dem Planeten Terminus" loading="lazy"><span class="zoomic">⤢</span><figcaption>Ruin Station · Terminus</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="DE3ePRgpUQo" style="background-image:url('/assets/trailer-4-0-0.jpg')"><span class="vlbl">Destination Pyro — Trailer</span><button class="play" aria-label="Trailer abspielen">▶</button></div>
      <p class="src reveal">Quelle: offizieller Star-Citizen-YouTube-Kanal &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=DE3ePRgpUQo" target="_blank" rel="noopener">Auf YouTube ansehen ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-0-0-contested-zones" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Schließen">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
