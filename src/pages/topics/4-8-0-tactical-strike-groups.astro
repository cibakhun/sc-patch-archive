---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TopicSeo from '../../components/dossier/TopicSeo.astro';
---
<Layout title={"Tactical Strike Groups — Star Citizen 4.8.0 | VerseBase"} description={"Tactical Strike Groups: Star Citizen's first dedicated cooperative ship-combat operation — a multi-phase Vanduul battle in Nyx, introduced with Alpha 4.8.0 Tactical Strike."} themeColor="#0d0a16" ogType="article" ogImage="/assets/t-tsg-1.jpg" translated={true}>
<TopicSeo slug="4-8-0-tactical-strike-groups" image="/assets/t-tsg-1.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Strike-Theme (4.8.0 Tactical Strike) */
:root{--bg:#0d0a16;--bg-2:#140f24;--surface:#1a1330;--surface-2:#231a3e;--accent:#E8651E;--accent-2:#1FB8A6;--hot:#E8651E;--text:#ede9f5;--muted:#a39db5;--line:rgba(232,101,30,.22);--line-soft:rgba(237,233,245,.10);--glow:0 0 44px rgba(232,101,30,.30);--ink:#0d0a16;--maxw:1180px;}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f8f6ff;--bg-2:#eeecf8;--surface:#fdfdff;--surface-2:#f2f1fb;--text:#201e26;--muted:#5a546a;--accent:#963a01;--accent-2:#056359;--hot:#893400;--ink:#ffffff;--accent-media:#E8651E;--accent-2-media:#1FB8A6;--line:rgba(162,93,63,.3);--line-soft:rgba(46,44,53,.12);--glow:0 6px 22px rgba(170,87,49,.18)}


/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.kx-teal{color:var(--accent-2)}
.roleline{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1.1rem}
.rolechip{font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.72rem;padding:.4rem .85rem;border:1px solid var(--line);border-radius:3px;background:var(--veil);color:var(--accent-2)}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.8.0', href: '/patches/sc-4-8-0.html' }, { label: "Tactical Strike Groups" }]} hasEn={true} />


<main id="main">

  <!-- HERO (full-bleed lead) -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-tsg-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-8-0.html">Alpha 4.8.0 · Tactical Strike</a> &nbsp;·&nbsp; Endgame</div>
      <h1><span class="thin">The first true co-op raid</span>Tactical Strike Groups</h1>
      <p class="lead">4.8.0's endgame: a multi-phase, cooperative battle against a Vanduul threat — in space and on the ground. Only a coordinated ship force with clear roles makes it through.</p>
      <div class="tags"><span class="tag hot">Co-op Raid</span><span class="tag">PvE Endgame</span><span class="tag">Vanduul Mauler</span><span class="tag">Nyx</span><span class="tag">7+ Players</span></div>
      <div class="hero__play" data-lb="yt:SsOtI2dtvBc"><span class="pbtn">▶</span>Watch trailer</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>TACTICAL STRIKE GROUPS</span><span class="dot">◆</span><span>VANDUUL MAULER</span><span class="dot">◆</span><span>QV EXTRACTION</span><span class="dot">◆</span><span>NYX</span><span class="dot">◆</span><span>FIGHTER · BOMBER · CAPITAL</span><span class="dot">◆</span><span>PVE-ENDGAME</span><span class="dot">◆</span>
      <span>TACTICAL STRIKE GROUPS</span><span class="dot">◆</span><span>VANDUUL MAULER</span><span class="dot">◆</span><span>QV EXTRACTION</span><span class="dot">◆</span><span>NYX</span><span class="dot">◆</span><span>FIGHTER · BOMBER · CAPITAL</span><span class="dot">◆</span><span>PVE-ENDGAME</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-8-0-tactical-strike-groups" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="7" data-suffix="+">0</div><div class="c">Players · recommended squad size</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Vanduul Mauler · the late boss</div></div>
    <div class="s"><div class="n">∞</div><div class="c">Phases · space to FPS infiltration</div></div>
    <div class="s"><div class="n">Co-op</div><div class="c">PvE endgame for orgs</div></div>
  </div>

  <!-- MANIFESTO (moved up — varies from template) -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>No solo heroes. Only a <span class="hl">coordinated force</span> makes it through.</blockquote>
    <cite>Tactical Strike Groups · Nyx</cite>
  </section>

  <!-- OVERVIEW — full-bleed band (image as background, design on top) -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-tsg-2.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">01 · Overview</div>
      <div class="big outline">ONE FLEET.</div>
      <p>With Alpha 4.8 <b style="color:var(--accent-2)">Tactical Strike</b> comes Star Citizen's first dedicated cooperative ship-combat operation — a multi-phase mission chain with real role specialization. Not luck, but coordination decides who reaches the core.</p>
    </div>
  </section>

  <!-- VERSUS: Zwei Schauplätze (full-bleed, two sides) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>✦ In space</h3>
        <ul>
          <li>Open ship combat against Vanduul around the station.</li>
          <li>Damage the power relays to open the facility.</li>
          <li>Tunnel flight into the interior — tight, precise, merciless.</li>
          <li>Destroy the coolers and expose the core.</li>
        </ul>
      </div>
      <div class="vs">&amp;</div>
      <div class="side b">
        <h3>★ On the ground</h3>
        <ul>
          <li>FPS infiltration of the QV Extraction Station.</li>
          <li>Recover the missing reconnaissance team.</li>
          <li>Pilot extraction under enemy fire.</li>
          <li>Hold the line against a late Vanduul Mauler.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SCROLLYTELLING: Die Phasen (process, full-bleed) -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>The phases of the operation</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-tsg-3.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-tsg-4.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-tsg-5.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-tsg-6.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-tsg-7.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Outer ship combat</h3><p>The Strike Group reaches the QV Extraction Station in the Nyx system and faces the Vanduul threat in open space — fighters secure the sky, bombers and support move in behind.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Power relays &amp; tunnel flight</h3><p>Targeted damage to the power relays opens the facility. Then comes the tunnel flight into the interior of the asteroid — tight corridors where every role counts.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Coolers &amp; core</h3><p>The station's coolers must be destroyed to expose the core — the transition from ship combat to infiltration on foot.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>FPS infiltration &amp; extraction</h3><p>On foot, the station is swept, the missing reconnaissance team is searched for, and the pilot extraction is initiated — under growing pressure.</p></div>
      <div class="sstep"><div class="sn">05</div><h3>The Vanduul Mauler</h3><p>Late in the operation a Vanduul Mauler appears. Only a team with clear roles — Fighter, Bomber, Support, Capital — can hold and complete the raid.</p></div>
    </div>
  </div>

  <!-- ROLLEN — full-bleed band (image as background) -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/img-vanduul.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">03 · Composition</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">ROLES MATTER</div>
      <p>Designed for groups of <b style="color:var(--accent-2)">seven players</b> or more, mixing fighters, bombers, support ships and even Capital Ships. Neglect the roles and you won't make it through all the phases.</p>
      <div class="roleline" style="justify-content:flex-end">
        <span class="rolechip">Fighter</span><span class="rolechip">Bomber</span><span class="rolechip">Support</span><span class="rolechip">Capital</span>
      </div>
    </div>
  </section>

  <!-- BELOHNUNGEN — the single framed/split section -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-tsg-9.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">04 · Loot</div>
        <h3>The new PvE endgame for orgs</h3>
        <p>Tactical Strike Groups is the new <b>PvE endgame for organized orgs</b> — an operation that can only be mastered with discipline and role distribution.</p>
        <p>Those who make it through are paid off with unique rewards: an exclusive <b>Arbalest blueprint</b> and high-value loot that sets this operation apart from anything before it.</p>
      </div>
    </div>
  </section>

  <!-- SCHAUPLATZ — full-bleed band (Nyx) -->
  <section class="band">
    <div class="bbg" data-par="0.13" style="background-image:url('/assets/t-tsg-8.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">05 · Setting</div>
      <div class="big">QV EXTRACTION</div>
      <p>The setting is the <b style="color:var(--accent-2)">QV Extraction Stations</b> — large asteroid facilities deep in the <b style="color:var(--accent-2)">Nyx system</b>, where a missing reconnaissance team is searched for. With Alpha 4.8 Tactical Strike, the operation launched alongside a full wipe.</p>
    </div>
  </section>

  <!-- MEDIA (mixed gallery + trailer — full-bleed close) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">06</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-tsg-1.jpg"><img src="/assets/t-tsg-1.jpg" alt="Tactical Strike Groups — ship combat at the QV Extraction Station" loading="lazy"><span class="zoomic">⤢</span><figcaption>QV Extraction Station · Nyx</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-tsg-2.jpg"><img src="/assets/t-tsg-2.jpg" alt="Strike Group on approach" loading="lazy"><span class="zoomic">⤢</span><figcaption>Strike Group · approach</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-vanduul.jpg"><img src="/assets/img-vanduul.jpg" alt="Vanduul threat" loading="lazy"><span class="zoomic">⤢</span><figcaption>Vanduul threat</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/vid-isc48.jpg"><img src="/assets/vid-isc48.jpg" alt="Inside Star Citizen 4.8" loading="lazy"><span class="zoomic">⤢</span><figcaption>Inside Star Citizen 4.8</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/trailer-4-8-0.jpg"><img src="/assets/trailer-4-8-0.jpg" alt="Alpha 4.8 Tactical Strike — trailer" loading="lazy"><span class="zoomic">⤢</span><figcaption>Tactical Strike · Trailer</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="SsOtI2dtvBc" style="background-image:url('/assets/trailer-4-8-0.jpg')"><span class="vlbl">Alpha 4.8 Tactical Strike — Trailer</span><button class="play" aria-label="Play trailer">▶</button></div>
      <p class="src reveal">Source: official Star Citizen YouTube channel &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=SsOtI2dtvBc" target="_blank" rel="noopener">Watch on YouTube ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-8-0-tactical-strike-groups" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
