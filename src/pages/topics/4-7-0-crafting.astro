---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
---
<Layout title={"Crafting — Star Citizen 4.7.0 | SC Patch-Archiv"} description={"Crafting in Alpha 4.7.0: aus Blueprints von Operation Breaker Stations und seltenen Mineralien fertigst du im Keeger Belt FPS-Waffen und Rüstung selbst."} themeColor="#1c1c20">
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* "Welcome to the Rock" — 4.7.0 Crafting-Theme */
:root{--bg:#1c1c20;--bg-2:#242429;--surface:#2a2a2e;--surface-2:#33333a;--accent:#FF5E1A;--accent-2:#1FA2FF;--hot:#FF5E1A;--text:#eef1f5;--muted:#9ba2ae;--line:rgba(255,94,26,.22);--line-soft:rgba(238,241,245,.10);--glow:0 0 44px rgba(255,94,26,.30);--ink:#1c1c20;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.lede-kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}
.qbar{display:flex;flex-wrap:wrap;gap:.5rem 1.4rem;margin-top:1.4rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.74rem;color:var(--muted)}
.qbar b{color:var(--accent-2)}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/index.html' }, { label: 'Alpha 4.7.0', href: '/patches/sc-4-7-0.html' }, { label: "Crafting" }]} pill={"FEATURE · ALPHA 4.7.0"} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-craft-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-7-0.html">Alpha 4.7.0 · Welcome to the Rock</a> &nbsp;·&nbsp; Feature</div>
      <h1><span class="thin">Bauen statt nur kaufen</span>Crafting</h1>
      <p class="lead">4.7.0 bringt die erste Crafting-Stufe: aus Blueprints und seltenen Mineralien fertigst du FPS-Waffen und Rüstung selbst — die Qualität des Materials entscheidet über die Werte.</p>
      <div class="tags"><span class="tag hot">Crafting T0</span><span class="tag">Blueprints</span><span class="tag">Keeger Belt</span><span class="tag">Operation Breaker Stations</span><span class="tag">Aurora Mk II</span></div>
      <div class="qbar"><span>Stufe <b>T0</b></span><span>System <b>Nyx</b></span><span>Schauplatz <b>Keeger Belt</b></span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>CRAFTING</span><span class="dot">◆</span><span>BLUEPRINTS</span><span class="dot">◆</span><span>KEEGER BELT</span><span class="dot">◆</span><span>BREAKER STATIONS</span><span class="dot">◆</span><span>SHUBIN</span><span class="dot">◆</span><span>STELLA FORTUNA</span><span class="dot">◆</span>
      <span>CRAFTING</span><span class="dot">◆</span><span>BLUEPRINTS</span><span class="dot">◆</span><span>KEEGER BELT</span><span class="dot">◆</span><span>BREAKER STATIONS</span><span class="dot">◆</span><span>SHUBIN</span><span class="dot">◆</span><span>STELLA FORTUNA</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- FULL-BLEED OPENING BAND (giant text over still, parallax) -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-craft-2.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">01 · Die erste Crafting-Stufe</div>
      <div class="big outline">DEIN WERK.</div>
      <p>Mit 4.7.0 verlässt das Verse den reinen Kauf-Loop. Aus <b style="color:var(--accent-2)">Blueprints</b> der Operation Breaker Stations und seltenen Mineralien fertigst du <b style="color:var(--accent-2)">FPS-Waffen und Rüstung</b> erstmals selbst.</p>
    </div>
  </section>

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="0">0</div><div class="c">Crafting-Stufe · T0 startet hier</div></div>
    <div class="s"><div class="n count" data-to="2">0</div><div class="c">Zutaten: Blueprint + Mineralien</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Neues Schiff · RSI Aurora Mk II</div></div>
    <div class="s"><div class="n">Nyx</div><div class="c">Keeger Belt · Asteroidengürtel</div></div>
  </div>

  <!-- WAS IST CRAFTING — full-bleed band, design on top -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-craft-4.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">02 · Was du baust</div>
      <div class="big" style="font-size:clamp(2.4rem,8vw,6rem)">WAFFE &amp; RÜSTUNG</div>
      <p>Crafting (T0) erlaubt die Fertigung von <b style="color:var(--accent-2)">FPS-Waffen und Rüstung</b>. Die Bauanleitungen — Blueprints — stammen aus den Operation Breaker Stations; die Rohstoffe sind seltene Mineralien aus dem Keeger Belt.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: Operation Breaker Stations — der Weg zum Material -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">03</span><h2>Operation Breaker Stations</h2><span class="rule"></span></div>
    <p class="lead-p reveal">Eine mehrstufige Koop-Mission im Keeger Belt. Sie liefert die Blueprints und das Material für deine erste Fertigung — Schritt für Schritt.</p></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-craft-2.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-craft-1.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/trailer-4-7-0.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-craft-4.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-craft-1.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Stationen reaktivieren</h3><p>Bring die stillgelegten Breaker Stations im Keeger Belt wieder ans Netz — der erste Schritt einer Operation, die nur im Team gelingt.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Laser zünden</h3><p>Mit den aktiven Stationen wird ein gewaltiger Laser gezündet, der einen Asteroiden aufbricht und die seltenen Mineralien im Inneren freilegt.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Gegner abwehren</h3><p>Die Anlage zieht Feinde an. Schlag dich durch Claw Salamander und eine Eis-Variante des Valakkar, während die Operation läuft.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Optische Komponenten fertigen</h3><p>Stelle vor Ort die optischen Komponenten her, die der Laser braucht — Fertigung wird hier zum festen Teil des Missionsablaufs.</p></div>
      <div class="sstep"><div class="sn">05</div><h3>Ressourcen extrahieren</h3><p>Hol die freigelegten Ressourcen aus dem aufgebrochenen Asteroiden. Genau dieses Material fließt zurück in deine eigene Fertigung.</p></div>
    </div>
  </div>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Die Qualität des <span class="hl">Materials</span> entscheidet über die Werte.</blockquote>
    <cite>Crafting T0 · Keeger Belt</cite>
  </section>

  <!-- VERSUS: Materialqualität (full-bleed dual pane) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚠ Geringe Qualität</h3>
        <ul>
          <li>Schwächere Werte am fertigen Gegenstand.</li>
          <li>Material aus jeder beliebigen Quelle.</li>
          <li>Niedrigste der mehreren Qualitätsstufen.</li>
          <li>Das Blueprint allein macht noch keine Top-Waffe.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ Hohe Qualität</h3>
        <ul>
          <li>Bessere Werte am gefertigten Gegenstand.</li>
          <li>Seltene Mineralien aus dem Keeger Belt.</li>
          <li>Lohn für den Aufwand der Breaker-Operation.</li>
          <li>Gleiches Blueprint, spürbar besseres Ergebnis.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- KEEGER BELT & SHUBIN — the ONE framed/split section -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-craft-2.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">04 · Schauplatz</div>
        <h3>Keeger Belt &amp; die QV Breaker Stations</h3>
        <p>Schauplatz ist der <b>Keeger Belt</b>, ein Asteroidengürtel im <b>Nyx-System</b> — rau, abgelegen und reich an den Mineralien, die das Crafting verlangt.</p>
        <p>Die <b>QV Breaker Stations</b> wurden ursprünglich von <b>QV Planet Services</b> gebaut und kürzlich von <b>Shubin</b> übernommen. Ihre Reaktivierung steht im Zentrum der Operation.</p>
      </div>
    </div>
  </section>

  <!-- AURORA & STELLA FORTUNA — full-bleed band -->
  <section class="band">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/img-aurora.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">05 · Mehr in 4.7.0</div>
      <div class="big" style="font-size:clamp(2.4rem,8vw,6rem)">AURORA MK II</div>
      <p>Mit der Crafting-Premiere kommt die neue <b style="color:var(--accent-2)">RSI Aurora Mk II</b>. Parallel läuft das Saison-Event <b style="color:var(--accent-2)">Stella Fortuna</b> — während im Keeger Belt Claw Salamander und die Eis-Variante des Valakkar lauern.</p>
    </div>
  </section>

  <!-- MEDIA (closing mixed gallery, no video embed) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">06</span><h2>Galerie</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-craft-3.jpg"><img src="/assets/t-craft-3.jpg" alt="Das CRAFT-Menü — Fertigung einer Volt Pulse Pistol" loading="lazy"><span class="zoomic">⤢</span><figcaption>CRAFT-Menü · Fertigung</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-craft-2.jpg"><img src="/assets/t-craft-2.jpg" alt="Operation Breaker Stations im Keeger Belt" loading="lazy"><span class="zoomic">⤢</span><figcaption>Breaker Stations · Keeger Belt</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/trailer-4-7-0.jpg"><img src="/assets/trailer-4-7-0.jpg" alt="Welcome to the Rock — 4.7.0" loading="lazy"><span class="zoomic">⤢</span><figcaption>Welcome to the Rock</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-aurora.jpg"><img src="/assets/img-aurora.jpg" alt="RSI Aurora Mk II" loading="lazy"><span class="zoomic">⤢</span><figcaption>RSI Aurora Mk II</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/vid-isc47.jpg"><img src="/assets/vid-isc47.jpg" alt="Inside Star Citizen — 4.7.0" loading="lazy"><span class="zoomic">⤢</span><figcaption>Inside Star Citizen · 4.7.0</figcaption></figure>
      </div>
      <p class="src reveal">Quelle: offizielle Star-Citizen-Kanäle &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="/patches/sc-4-7-0.html">Zurück zur Patch-Übersicht 4.7.0 ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-7-0-crafting" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Schließen">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
