---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TRADES from '../../data/wikelo-trades.json';

// On-brand Inline-SVG-Icons (statt Emojis) — Linien-Stil, currentColor.
const svg = (b) => `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${b}</svg>`;
const ICON = {
  ship: svg('<path d="M12 2c3 2.2 4.5 5.6 4.5 10 0 2.2-.5 4.3-1.5 6H9c-1-1.7-1.5-3.8-1.5-6C7.5 7.6 9 4.2 12 2z"/><circle cx="12" cy="9" r="1.8"/><path d="M7.5 14 4 17v3l3.5-2M16.5 14 20 17v3l-3.5-2M12 18v4"/>'),
  weapon: svg('<path d="M3 8h13l4 2v2h-5l-2 3H8v-3H5a2 2 0 0 1-2-2V8z"/><path d="M8 12v3M11 8V6M14 8V6"/>'),
  armor: svg('<path d="M12 3 5 5.5V11c0 4.4 3 8 7 10 4-2 7-5.6 7-10V5.5L12 3z"/><path d="M12 3v18M5 8h14"/>'),
  paint: svg('<path d="M12 3s6 6.5 6 10.5a6 6 0 0 1-12 0C6 9.5 12 3 12 3z"/><path d="M9.5 13.5a2.5 2.5 0 0 0 2.5 2.5"/>'),
  component: svg('<circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.2 6l2.1 2.1M17.7 15.9l2.1 2.1M2 12h3M19 12h3M4.2 18l2.1-2.1M17.7 8.1l2.1-2.1"/>'),
  recipe: svg('<path d="M6 3h9l4 4v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/><path d="M14 3v5h5M8.5 12h7M8.5 15.5h7M8.5 8.5h3"/>'),
  material: svg('<path d="M12 3 3 8v8l9 5 9-5V8l-9-5z"/><path d="m3 8 9 5 9-5M12 13v8"/>'),
  favor: svg('<path d="m12 3 2.5 5.3 5.8.8-4.2 4 1 5.7L12 21l-5.1 2.8 1-5.7-4.2-4 5.8-.8L12 3z"/>'),
  vehicle: svg('<path d="M3 13h18l-2-5H8L3 13z"/><path d="M3 13v4h2M21 13v4h-2M9 17h6"/><circle cx="7" cy="17.5" r="1.6"/><circle cx="17" cy="17.5" r="1.6"/>'),
  arrow: svg('<path d="M4 12h15M13 6l6 6-6 6"/>'),
};

// Trade-Kategorien (Filter-Pills)
const TCATS = [
  { key: 'all', label: 'Alle' },
  { key: 'conv', label: 'Favor-Umtausch' },
  { key: 'ship', label: 'Schiffe' },
  { key: 'weapon', label: 'Waffen' },
  { key: 'armor', label: 'Rüstung' },
  { key: 'misc', label: 'Sonstiges' },
];
const CAT_LABEL = { conv: 'Favor-Umtausch', ship: 'Schiff', weapon: 'Waffe', armor: 'Rüstung', misc: 'Sonstiges' };
const CAT_ICON = { conv: 'favor', ship: 'ship', weapon: 'weapon', armor: 'armor', misc: 'component' };
// Komponenten-Typen (Schiff-Loadout)
const COMP_LABEL = { pwr: 'Antrieb', shield: 'Schild', qd: 'Quantum', cooler: 'Kühler', weapon: 'Waffen' };

// VOLLSTÄNDIGE Trade-Liste (63 Trades) — Quelle: wikelotrades.com (scrape_wikelo.py),
// Patch 4.8.1, Stand 2026-06-04. Materialien/Favor faithful aus der Tracker-Datei
// PATCH_4_8_1.js übernommen (inkl. Original-Schreibweisen). Nichts erfunden; Werte patch-volatil.
// `img` = verifiziertes Schiff-Bild (/assets/<img>.jpg); ohne img → Kategorie-Icon-Fallback.
// TRADES wird aus src/data/wikelo-trades.json importiert (gemeinsam DE/EN).
---
<Layout title={"Wikelo's Emporium — Star Citizen 4.1 | SC Patch-Archiv"} description={"Wikelo's Emporium: der Banu-Händler Wikelo — erster spielbarer Alien-NPC in Star Citizen. Barter statt Geld: Items liefern, Wikelo Favor sammeln, Belohnungen aus dem Lager eintauschen. Drei Asteroiden-Stationen in Stanton, seit Alpha 4.1."} themeColor="#0d1513" ogType="article" translated={true}>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Wikelo / Banu-Emporium-Theme (4.1) — Türkis & Messing */
:root{--bg:#0d1513;--bg-2:#111d1a;--surface:#152420;--surface-2:#1c302b;--accent:#1FB8A6;--accent-2:#E8A33D;--hot:#C0392B;--text:#eef4f2;--muted:#93a7a1;--line:rgba(31,184,166,.22);--line-soft:rgba(238,244,242,.10);--glow:0 0 44px rgba(31,184,166,.28);--ink:#0d1513;--maxw:1180px;}
/* Reveal-Gate neutralisieren: Inhalt IMMER sichtbar.
   Grund: die sehr hohe Trade-Karten-Spalte (19 Karten) erreicht auf Mobil nie
   die 12%-Sichtbarkeitsschwelle des IntersectionObservers → würde sonst dauerhaft
   opacity:0 bleiben. Sichtbarkeit hat Vorrang vor der Einblend-Animation. */
.reveal{opacity:1 !important;transform:none !important}
/* page-local accents */
.hero h1{font-size:clamp(2.8rem,12vw,9rem)}
.hero{background:radial-gradient(120% 90% at 78% 12%,rgba(31,184,166,.18),transparent 60%),radial-gradient(90% 80% at 12% 90%,rgba(232,163,61,.12),transparent 55%),var(--bg)}
.banu-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}
.wk-lede{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

/* ---- Bento (Stationen + Reward-Kategorien) ---- */
.wk-bento{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-cell{border:1px solid var(--line);border-top:2px solid var(--accent);background:var(--surface);padding:1.3rem 1.4rem;display:flex;flex-direction:column;gap:.5rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px)}
.wk-cell .wk-ic{color:var(--accent);line-height:0;width:34px;height:34px}
.wk-cell.alt .wk-ic{color:var(--accent-2)}
.wk-cell .wk-ic svg{width:100%;height:100%;display:block}
.wk-cell h3{font-family:var(--font-display);font-weight:800;font-size:1.25rem;color:#fff;line-height:1.1}
.wk-cell .wk-sub{font-family:var(--font-ui);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.68rem;color:var(--accent)}
.wk-cell p{color:var(--muted);font-size:.98rem;line-height:1.5;margin:0}
.wk-cell.alt{border-top-color:var(--accent-2)}
.wk-cell.alt .wk-sub{color:var(--accent-2)}

/* ---- Zwei Interaktionstypen (mini-split) ---- */
.wk-duo{display:grid;grid-template-columns:1fr 1fr;gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-duo .wk-cell b{color:var(--text)}
@media(max-width:640px){.wk-duo{grid-template-columns:1fr}}

/* ---- Warn-/Stand-Banner ---- */
.wk-note{max-width:var(--maxw);margin:0 auto 1.1rem;display:flex;align-items:flex-start;gap:.75rem;border:1px solid var(--accent-2);border-left-width:3px;background:color-mix(in srgb,var(--accent-2) 8%,transparent);padding:.9rem 1.1rem;border-radius:4px;color:var(--text);font-size:.95rem;line-height:1.55}
.wk-note .wk-ic{color:var(--accent-2);flex:none;line-height:0;width:18px;height:18px;margin-top:.1rem}
.wk-note .wk-ic svg{width:100%;height:100%;display:block}
.wk-note a{color:var(--accent-2);border-bottom:1px solid var(--line);white-space:nowrap}

/* ---- Badge „patch-abhängig" ---- */
.wk-badge{display:inline-flex;align-items:center;gap:.3rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.62rem;color:var(--accent-2);border:1px solid color-mix(in srgb,var(--accent-2) 45%,transparent);background:color-mix(in srgb,var(--accent-2) 10%,transparent);padding:.12rem .45rem;border-radius:2px;white-space:nowrap}

/* ---- Trade-Übersicht: GIB → BEKOMM-Karten ---- */
.wk-filters{max-width:var(--maxw);margin:0 auto 1.2rem;display:flex;flex-wrap:wrap;gap:.5rem}
.wk-pill{font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.72rem;color:var(--muted);border:1px solid var(--line);background:rgba(0,0,0,.25);padding:.42rem .9rem;border-radius:50px;cursor:pointer;transition:color .18s,border-color .18s,background-color .18s}
.wk-pill:hover{color:var(--text);border-color:var(--accent)}
.wk-pill[aria-pressed="true"]{color:var(--ink);background:var(--accent);border-color:var(--accent)}
.wk-tc-grid{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1rem}
.wk-tc{border:1px solid var(--line);border-top:2px solid var(--accent);background:var(--surface);padding:1.1rem 1.15rem;display:flex;flex-direction:column;gap:.85rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px)}
.wk-tc[data-cat="conv"]{border-top-color:var(--accent-2)}
.wk-tc[hidden]{display:none}
.wk-tc__hd{display:flex;align-items:center;justify-content:space-between;gap:.6rem}
.wk-tc__cat{font-family:var(--font-ui);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.64rem;color:var(--accent)}
.wk-tc[data-cat="conv"] .wk-tc__cat{color:var(--accent-2)}
.wk-conf{font-family:var(--font-ui);font-weight:700;letter-spacing:.06em;text-transform:uppercase;font-size:.58rem;padding:.14rem .5rem;border-radius:2px;white-space:nowrap;border:1px solid}
.wk-conf.solid{color:var(--accent);border-color:color-mix(in srgb,var(--accent) 45%,transparent);background:color-mix(in srgb,var(--accent) 10%,transparent)}
.wk-conf.chk{color:var(--accent-2);border-color:color-mix(in srgb,var(--accent-2) 45%,transparent);background:color-mix(in srgb,var(--accent-2) 10%,transparent)}
.wk-tc__body{display:grid;grid-template-columns:1fr auto minmax(8.5rem,1fr);align-items:stretch;gap:.6rem}
.wk-side-h{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.6rem;color:var(--muted);margin-bottom:.4rem}
.wk-mats{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:.28rem}
.wk-mats li{position:relative;padding-left:.85rem;font-size:.86rem;line-height:1.35;color:var(--text)}
.wk-mats li::before{content:"";position:absolute;left:0;top:.5em;width:5px;height:5px;background:var(--accent);transform:rotate(45deg)}
.wk-tc[data-cat="conv"] .wk-mats li::before{background:var(--accent-2)}
.wk-favor{display:inline-flex;align-items:center;gap:.35rem;margin-top:.6rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.04em;font-size:.8rem;color:var(--accent-2);border:1px solid color-mix(in srgb,var(--accent-2) 40%,transparent);background:color-mix(in srgb,var(--accent-2) 9%,transparent);padding:.22rem .55rem;border-radius:3px;width:max-content}
.wk-favor svg{width:14px;height:14px;flex:none}
.wk-tc__note{margin-top:.5rem;font-size:.74rem;line-height:1.4;color:var(--muted)}
.wk-arrow{color:var(--accent);align-self:center;line-height:0}
.wk-arrow svg{width:26px;height:26px;display:block}
.wk-get{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:.5rem;border-left:1px solid var(--line-soft);padding-left:.7rem}
.wk-get-media{width:100%;aspect-ratio:16/10;overflow:hidden;border:1px solid var(--line);background:linear-gradient(150deg,var(--surface-2),var(--bg-2));position:relative}
.wk-get-media img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s ease}
.wk-tc:hover .wk-get-media img{transform:scale(1.05)}
.wk-get-media--ph{display:grid;place-items:center;color:var(--accent);padding:12px}
.wk-tc[data-cat="conv"] .wk-get-media--ph{color:var(--accent-2)}
.wk-get-media--ph svg{width:42px;height:42px}
.wk-get-name{font-family:var(--font-display);font-weight:800;font-size:.98rem;line-height:1.15;color:#fff}
.wk-tc-empty{max-width:var(--maxw);margin:.5rem auto 0;color:var(--muted);font-size:.9rem}

/* ---- Schiff-Loadout (Komponenten) ---- */
.wk-comps{margin-top:.2rem;padding-top:.75rem;border-top:1px solid var(--line-soft)}
.wk-comps__h{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.6rem;color:var(--accent);margin-bottom:.5rem}
.wk-comps ul{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:.32rem .9rem}
.wk-comps li{display:flex;align-items:baseline;gap:.4rem;flex-wrap:wrap;font-size:.8rem;line-height:1.3}
.wk-comps .ct{flex:none;min-width:4.6em;font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.05em;font-size:.6rem;color:var(--muted)}
.wk-comps .cn{color:var(--text)}
.wk-comps .cb{font-family:var(--font-ui);font-weight:700;font-size:.62rem;letter-spacing:.03em;color:var(--accent-2);white-space:nowrap}
@media(max-width:560px){.wk-comps ul{grid-template-columns:1fr}}

/* ---- Bild-Figur (Stationen / Szene) ---- */
.wk-figure{max-width:var(--maxw);margin:0 auto 1.4rem}
.wk-figure img{width:100%;height:clamp(180px,34vw,420px);object-fit:cover;display:block;border:1px solid var(--line);border-top:2px solid var(--accent-2);clip-path:polygon(14px 0,100% 0,100% calc(100% - 14px),calc(100% - 14px) 100%,0 100%,0 14px)}
.wk-figure figcaption{margin-top:.6rem;font-size:.82rem;line-height:1.5;color:var(--muted)}

@media(max-width:560px){
  .wk-tc-grid{grid-template-columns:1fr}
  .wk-tc__body{grid-template-columns:1fr;gap:.5rem}
  .wk-arrow{justify-self:center;transform:rotate(90deg);margin:.15rem 0}
  .wk-get{border-left:0;border-top:1px solid var(--line-soft);padding-left:0;padding-top:.7rem;align-items:stretch}
  .wk-get-media{aspect-ratio:16/9}
  .wk-get-name{text-align:center}
}

/* ---- Timeline ---- */
.wk-time{max-width:var(--maxw);margin:0 auto;display:grid;gap:0}
.wk-trow{display:grid;grid-template-columns:auto 1fr;gap:1.2rem;padding:1.1rem 0;border-bottom:1px solid var(--line-soft)}
.wk-trow:last-child{border-bottom:0}
.wk-ver{font-family:var(--font-display);font-weight:900;font-size:clamp(1.4rem,3vw,2rem);color:transparent;-webkit-text-stroke:1.5px var(--accent);line-height:1;min-width:3.2em}
.wk-tbody h3{font-family:var(--font-display);font-weight:800;font-size:1.15rem;color:#fff;margin:0 0 .25rem}
.wk-tbody p{color:var(--muted);font-size:.98rem;line-height:1.55;margin:0;max-width:64ch}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/index.html' }, { label: 'Alpha 4.1.0', href: '/patches/sc-4-1-0.html' }, { label: "Wikelo" }]} pill={"THEMA · ALPHA 4.1"} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/wk-emporium.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-1-0.html">Alpha 4.1 · Orbital Assault</a> &nbsp;·&nbsp; <span class="banu-tag">Banu-Händler</span></div>
      <h1><span class="thin">Der erste spielbare Alien-Händler</span>Wikelo's Emporium</h1>
      <p class="lead">Wikelo ist ein <b>Banu</b> — und der erste spielbare Alien-NPC in Star Citizen. Sein Emporium kennt kein Geld: Du lieferst geforderte Items, sammelst <b>Wikelo Favor</b> und tauschst sie gegen Belohnungen aus seinem Lager.</p>
      <div class="tags"><span class="tag">Banu</span><span class="tag">Barter</span><span class="tag">Wikelo Favor</span><span class="tag">3 Stationen</span><span class="tag">seit Alpha 4.1</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>WIKELO</span><span class="dot">◆</span><span>BANU-HÄNDLER</span><span class="dot">◆</span><span>EMPORIUM</span><span class="dot">◆</span><span>DASI</span><span class="dot">◆</span><span>SELO</span><span class="dot">◆</span><span>KINGA</span><span class="dot">◆</span><span>WIKELO FAVOR</span><span class="dot">◆</span><span>BARTER</span><span class="dot">◆</span>
      <span>WIKELO</span><span class="dot">◆</span><span>BANU-HÄNDLER</span><span class="dot">◆</span><span>EMPORIUM</span><span class="dot">◆</span><span>DASI</span><span class="dot">◆</span><span>SELO</span><span class="dot">◆</span><span>KINGA</span><span class="dot">◆</span><span>WIKELO FAVOR</span><span class="dot">◆</span><span>BARTER</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK -->
  <TopicFacts topicSlug="wikelo-emporium" />

  <!-- STAT STRIP -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Asteroiden-Stationen in Stanton</div></div>
    <div class="s"><div class="n">Banu</div><div class="c">Erster spielbarer Alien-NPC</div></div>
    <div class="s"><div class="n">4.1<span class="u">Alpha</span></div><div class="c">Eingeführt</div></div>
    <div class="s"><div class="n">0<span class="u">aUEC</span></div><div class="c">Reines Barter — kein Geld</div></div>
  </div>

  <!-- BAND 01 — Barter-Prinzip -->
  <section class="band band--center">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/wk-wikelo.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">01 · Das Barter-Prinzip</div>
      <div class="big outline" style="font-size:clamp(2rem,8vw,6rem)">LIEFERN · BEKOMMEN</div>
      <p>Wikelo's Emporium ist ein <b style="color:var(--accent-2)">Tauschhandel ohne Währung im klassischen Sinn</b>. Statt aUEC zu zahlen, erfüllst du Contracts: Du bringst die geforderten Materialien und Items — und bekommst dafür Belohnungen aus Wikelos Lager. Der Zwischenschritt sind <b style="color:var(--accent-2)">Wikelo Favor</b>, Token, die du aus Contracts erhältst und gegen Ausrüstung, Komponenten oder sogar Schiffe eintauschst.</p>
    </div>
  </section>

  <!-- PROCESS — der Ablauf -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>So läuft ein Trade ab</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/wk-emporium.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/wk-idris.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/wk-taurus.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/wk-polaris.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Contract annehmen</h3><p>An einer der drei Emporium-Stationen nimmst du bei Wikelo einen Contract an. Er nennt dir, welche Materialien oder Items er sucht — die Grundlage jedes Tauschs.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Items sammeln</h3><p>Du beschaffst die geforderten Waren: schürfen, bergen, kaufen oder herstellen. Das ist der eigentliche Grind — der Loop, der dich durch das Verse schickt.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Am Freight Elevator abliefern</h3><p>Zurück an der Station lieferst du die Waren über den Freight Elevator ab. Wikelo verbucht die Lieferung und schreibt dir <b>Wikelo Favor</b> gut.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Reward eintauschen</h3><p>Mit genügend Favor (plus ggf. weiterer Materialien) tauschst du eine Belohnung ein. Sie landet im lokalen Stations-Inventar — von dort holst du sie ab.</p></div>
    </div>
  </div>

  <!-- ZWEI INTERAKTIONSTYPEN -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">03</span><h2>Zwei Interaktionstypen</h2><span class="rule"></span></div></div>
    <div class="wk-duo reveal">
      <div class="wk-cell">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8a8 8 0 0 1 13.7-3.3L20 7"/><path d="M20 3v4h-4"/><path d="M20 16a8 8 0 0 1-13.7 3.3L4 17"/><path d="M4 21v-4h4"/></svg></div>
        <div class="wk-sub">Favor-Conversion</div>
        <h3>Rohstoffe → Favors</h3>
        <p>Du lieferst geforderte <b>Rohstoffe/Materialien</b> und erhältst dafür <b>Wikelo Favor</b>. Der Aufbau deines Guthabens — die Token, mit denen du später bezahlst.</p>
      </div>
      <div class="wk-cell alt">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 8H4v3h16V8z"/><path d="M5 11v9h14v-9"/><path d="M12 8v12"/><path d="M12 8S10.5 4.5 8.5 4.5A2 2 0 0 0 8.5 8.5H12zM12 8s1.5-3.5 3.5-3.5A2 2 0 0 1 15.5 8.5H12z"/></svg></div>
        <div class="wk-sub">Reward-Trade</div>
        <h3>Favors + Material → Ausrüstung</h3>
        <p>Du gibst <b>Favors zusammen mit weiteren Materialien</b> und bekommst eine konkrete Belohnung: Ausrüstung, Komponenten oder ein Schiff aus Wikelos Lager.</p>
      </div>
    </div>
  </section>

  <!-- DIE DREI STATIONEN -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">04</span><h2>Die drei Emporium-Stationen</h2><span class="rule"></span></div></div>
    <figure class="wk-figure reveal">
      <img src="/assets/wk-emporium.jpg" alt="Wikelo's Emporium — Banu-Handelsstation im Asteroidenfeld" loading="lazy" decoding="async" />
      <figcaption>Wikelo's Emporium — die Banu-Handelsstation. Jede der drei Stationen (Dasi, Selo, Kinga) teilt denselben Aufbau; eigene Stations-Fotos existieren im Wiki nicht.</figcaption>
    </figure>
    <div class="wk-bento reveal">
      <div class="wk-cell">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13 8 5l7-2 5 6-3 9-8 1z"/><path d="m8 5 3 5 4-1M11 10l-2 8m6-8 2 4"/></svg></div>
        <div class="wk-sub">bei Hurston</div>
        <h3>Dasi</h3>
        <p>Asteroiden-Station im Einflussbereich von Hurston. Einer der drei Anlaufpunkte für Contracts und Rewards.</p>
      </div>
      <div class="wk-cell">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13 8 5l7-2 5 6-3 9-8 1z"/><path d="m8 5 3 5 4-1M11 10l-2 8m6-8 2 4"/></svg></div>
        <div class="wk-sub">bei Crusader / Yela</div>
        <h3>Selo</h3>
        <p>Asteroiden-Station nahe Crusader und dem Mond Yela. Zweiter Standort des Emporiums in Stanton.</p>
      </div>
      <div class="wk-cell">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13 8 5l7-2 5 6-3 9-8 1z"/><path d="m8 5 3 5 4-1M11 10l-2 8m6-8 2 4"/></svg></div>
        <div class="wk-sub">bei microTech</div>
        <h3>Kinga</h3>
        <p>Asteroiden-Station im Umfeld von microTech. Dritter Standort — Rewards landen jeweils im lokalen Stations-Inventar.</p>
      </div>
    </div>
  </section>

  <!-- TRADE-ÜBERSICHT — Kernstück: GIB → BEKOMM -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">05</span><h2>Liefern → Bekommen</h2><span class="rule"></span></div>
      <p class="lead-p reveal">Das Herzstück des Emporiums: konkrete Trades mit <b>Schiff-Bild</b>, benötigten Materialien und Favor-Kosten. Filtere nach Kategorie — links, was du <b>gibst</b>, rechts, was du <b>bekommst</b>.</p></div>
    <div class="wk-note reveal">
      <span class="wk-ic" aria-hidden="true" set:html={ICON.favor}></span>
      <span><b>Alle {TRADES.length} Trades</b> aus <b>Patch 4.8.1</b> (Stand <b>04.06.2026</b>), 1:1 aus dem Live-Tracker <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com ↗</a> übernommen. Mengen &amp; Favor-Kosten sind <b>patch-volatil</b> — vor dem Grind <b>in-game gegenprüfen</b>. Links, was du <b>gibst</b>, rechts, was du <b>bekommst</b>. Schiffe mit verifiziertem Bild, sonst Kategorie-Icon. Die <b>Loadout-Komponenten</b> der Schiffe stammen aus <a href="https://tinyurl.com/yj739hxy" target="_blank" rel="noopener">ChrisGBG's Wikelo-Sheet ↗</a> (Datamining: WayfinderDrax, <b>Stand 4.7 / 26.03.2026</b>).</span>
    </div>

    <div class="wk-filters reveal" role="group" aria-label="Trades nach Kategorie filtern">
      {TCATS.map((f, i) => (
        <button type="button" class="wk-pill" data-filter={f.key} aria-pressed={i === 0 ? 'true' : 'false'}>{f.label}</button>
      ))}
    </div>

    <div class="wk-tc-grid reveal" id="wk-tc-grid">
      {TRADES.map((t) => (
        <article class="wk-tc" data-cat={t.cat}>
          <header class="wk-tc__hd">
            <span class="wk-tc__cat">{CAT_LABEL[t.cat]}</span>
            {t.rep && (<span class="wk-conf chk">{t.rep}</span>)}
          </header>
          <div class="wk-tc__body">
            <div class="wk-give">
              <div class="wk-side-h">Gib</div>
              <ul class="wk-mats">{t.mats.map((m) => (<li>{m}</li>))}</ul>
              {t.favor != null && (<div class="wk-favor"><span set:html={ICON.favor}></span>{t.favor} Favor</div>)}
            </div>
            <div class="wk-arrow" aria-hidden="true" set:html={ICON.arrow}></div>
            <div class="wk-get">
              <div class="wk-side-h">Bekomm</div>
              {t.img
                ? (<div class="wk-get-media"><img src={`/assets/${t.img}.jpg`} alt={t.name} loading="lazy" decoding="async" /></div>)
                : (<div class="wk-get-media wk-get-media--ph" aria-hidden="true" set:html={ICON[CAT_ICON[t.cat]]}></div>)}
              <div class="wk-get-name">{t.get ?? t.name}</div>
            </div>
          </div>
          {t.comps && (
            <div class="wk-comps">
              <div class="wk-comps__h">Kommt mit · Loadout</div>
              <ul>{t.comps.map((c) => (
                <li><span class="ct">{COMP_LABEL[c.k]}</span><span class="cn">{c.q ? c.q + ' ' : ''}{c.n}</span>{c.s && (<span class="cb">S{c.s}{c.g ? ' · ' + c.g : ''}</span>)}</li>
              ))}</ul>
            </div>
          )}
        </article>
      ))}
    </div>
    <p class="wk-tc-empty" id="wk-tc-empty" hidden>Keine Trades in dieser Kategorie.</p>

    <p class="src reveal">Vollständige Liste aller {TRADES.length} Trades des Patches <b>4.8.1</b>, direkt aus der Datendatei des Live-Trackers <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com ↗</a> (generiert 04.06.2026). Original-Schreibweisen &amp; -Mengen der Quelle beibehalten. Da Wikelos Angebot pro Patch rotiert, können einzelne Trades inzwischen abweichen — im Zweifel in-game prüfen.</p>
  </section>

  <script is:inline>
    (function () {
      var pills = document.querySelectorAll('.wk-pill');
      var cards = document.querySelectorAll('#wk-tc-grid .wk-tc');
      var empty = document.getElementById('wk-tc-empty');
      pills.forEach(function (p) {
        p.addEventListener('click', function () {
          var key = p.getAttribute('data-filter');
          pills.forEach(function (q) { q.setAttribute('aria-pressed', q === p ? 'true' : 'false'); });
          var shown = 0;
          cards.forEach(function (c) {
            var vis = key === 'all' || c.getAttribute('data-cat') === key;
            c.hidden = !vis;
            if (vis) shown++;
          });
          if (empty) empty.hidden = shown !== 0;
        });
      });
    })();
  </script>

  <!-- BELOHNUNGS-KATEGORIEN -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">06</span><h2>Belohnungs-Kategorien</h2><span class="rule"></span></div></div>
    <div class="wk-bento reveal">
      <div class="wk-cell"><div class="wk-ic" aria-hidden="true" set:html={ICON.ship}></div><div class="wk-sub">Kategorie</div><h3>Schiffe &amp; Fahrzeuge</h3><p>Ausgewählte Schiffe und Bodenfahrzeuge aus Wikelos rotierendem Pool.</p></div>
      <div class="wk-cell"><div class="wk-ic" aria-hidden="true" set:html={ICON.weapon}></div><div class="wk-sub">Kategorie</div><h3>Waffen</h3><p>Hand- und Schiffswaffen als Tausch-Belohnung.</p></div>
      <div class="wk-cell"><div class="wk-ic" aria-hidden="true" set:html={ICON.armor}></div><div class="wk-sub">Kategorie</div><h3>Rüstung</h3><p>Rüstungs-Sets und Ausrüstungsteile.</p></div>
      <div class="wk-cell alt"><div class="wk-ic" aria-hidden="true" set:html={ICON.paint}></div><div class="wk-sub">Kategorie</div><h3>Paints / Skins</h3><p>Kosmetische Lackierungen für Schiffe und Ausrüstung.</p></div>
      <div class="wk-cell alt"><div class="wk-ic" aria-hidden="true" set:html={ICON.component}></div><div class="wk-sub">Kategorie</div><h3>Ship-Komponenten</h3><p>Komponenten zum Aufrüsten und Ausstatten von Schiffen.</p></div>
      <div class="wk-cell alt"><div class="wk-ic" aria-hidden="true" set:html={ICON.recipe}></div><div class="wk-sub">Kategorie</div><h3>Crafting-Rezepte</h3><p>Rezepte, die in das Crafting-System einfließen.</p></div>
    </div>
  </section>

  <!-- PATCH-TIMELINE -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">07</span><h2>Wikelo im Patch-Verlauf</h2><span class="rule"></span></div></div>
    <div class="wrap"><div class="wk-time reveal">
      <div class="wk-trow">
        <div class="wk-ver">4.1</div>
        <div class="wk-tbody"><h3>Einführung — der erste Alien</h3><p>Wikelo kommt ins Spiel: der Banu-Händler und erste spielbare Alien-NPC. Das Emporium startet mit dem Barter-Prinzip und den Wikelo-Favor-Contracts.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.1.1</div>
        <div class="wk-tbody"><h3>Zweite Etage</h3><p>Das Emporium wird erweitert — eine zweite Etage kommt hinzu und vergrößert das Angebot vor Ort.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.2 / 4.2.1</div>
        <div class="wk-tbody"><h3>Reward-Rework — deterministisch</h3><p>Die Belohnungen werden überarbeitet: der Zufalls-Loot fällt weg, die Rewards werden <b>deterministisch</b> — du weißt vorher, was ein Trade bringt.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.8</div>
        <div class="wk-tbody"><h3>Reset &amp; Economy-Cleanup</h3><p>Ein Reset bzw. Economy-Cleanup bereinigt das Emporium-System — Teil der laufenden Balance-Arbeit an Wikelos Wirtschaft.</p></div>
      </div>
    </div></div>
  </section>

  <!-- LORE-QUOTE -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Kein Geld wechselt den Besitzer — nur <span class="hl">Ware gegen Gunst</span>, und Gunst gegen das Lager eines Banu.</blockquote>
    <cite>Wikelo's Emporium · Banu-Barter</cite>
  </section>

  <!-- QUELLEN -->
  <section>
    <div class="wrap">
      <p class="src reveal">Quellen: Star Citizen Wiki — <a href="https://starcitizen.tools/Wikelo" target="_blank" rel="noopener">Wikelo</a>, <a href="https://starcitizen.tools/Wikelo_Emporium" target="_blank" rel="noopener">Wikelo Emporium</a>, <a href="https://starcitizen.tools/Wikelo_Favor" target="_blank" rel="noopener">Wikelo Favor</a> (CC-BY-SA 4.0) · Trade-Daten: Live-Tracker <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com</a> (Patch 4.8.1, 04.06.2026) · Schiff-Loadouts: <a href="https://tinyurl.com/yj739hxy" target="_blank" rel="noopener">ChrisGBG's Wikelo-Sheet</a> (Datamining WayfinderDrax, 4.7). Handels-Details ändern sich mit jedem Patch.</p>
      <p class="src reveal">Bilder (Emporium, Wikelo, Belohnungs-Schiffe): <a href="https://starcitizen.tools/Wikelo" target="_blank" rel="noopener">Star Citizen Wiki</a> (starcitizen.tools, CC-BY-SA 4.0) — nicht-kommerzielle Fan-Nutzung. Star Citizen® ist eine Marke der Cloud Imperium Rights LLC.</p>
    </div>
  </section>

