---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
---
<Layout title={"Wikelo's Emporium — Star Citizen 4.1 | SC Patch-Archiv"} description={"Wikelo's Emporium: der Banu-Händler Wikelo — erster spielbarer Alien-NPC in Star Citizen. Barter statt Geld: Items liefern, Wikelo Favor sammeln, Belohnungen aus dem Lager eintauschen. Drei Asteroiden-Stationen in Stanton, seit Alpha 4.1."} themeColor="#0d1513" ogType="article" translated={true}>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Wikelo / Banu-Emporium-Theme (4.1) — Türkis & Messing */
:root{--bg:#0d1513;--bg-2:#111d1a;--surface:#152420;--surface-2:#1c302b;--accent:#1FB8A6;--accent-2:#E8A33D;--hot:#C0392B;--text:#eef4f2;--muted:#93a7a1;--line:rgba(31,184,166,.22);--line-soft:rgba(238,244,242,.10);--glow:0 0 44px rgba(31,184,166,.28);--ink:#0d1513;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(2.8rem,12vw,9rem)}
.hero{background:radial-gradient(120% 90% at 78% 12%,rgba(31,184,166,.18),transparent 60%),radial-gradient(90% 80% at 12% 90%,rgba(232,163,61,.12),transparent 55%),var(--bg)}
.banu-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}
.wk-lede{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

/* ---- Bento (Stationen + Reward-Kategorien) ---- */
.wk-bento{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-cell{border:1px solid var(--line);border-top:2px solid var(--accent);background:var(--surface);padding:1.3rem 1.4rem;display:flex;flex-direction:column;gap:.5rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px)}
.wk-cell .wk-ic{font-size:1.6rem;line-height:1}
.wk-cell h3{font-family:var(--font-display);font-weight:800;font-size:1.25rem;color:#fff;line-height:1.1}
.wk-cell .wk-sub{font-family:var(--font-ui);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.68rem;color:var(--accent)}
.wk-cell p{color:var(--muted);font-size:.98rem;line-height:1.5;margin:0}
.wk-cell.alt{border-top-color:var(--accent-2)}
.wk-cell.alt .wk-sub{color:var(--accent-2)}

/* ---- Zwei Interaktionstypen (mini-split) ---- */
.wk-duo{display:grid;grid-template-columns:1fr 1fr;gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-duo .wk-cell b{color:var(--text)}
@media(max-width:640px){.wk-duo{grid-template-columns:1fr}}

/* ---- Warn-/Stand-Banner ---- */
.wk-note{max-width:var(--maxw);margin:0 auto 1.1rem;display:flex;align-items:flex-start;gap:.75rem;border:1px solid var(--accent-2);border-left-width:3px;background:color-mix(in srgb,var(--accent-2) 8%,transparent);padding:.9rem 1.1rem;border-radius:4px;color:var(--text);font-size:.95rem;line-height:1.55}
.wk-note .wk-ic{color:var(--accent-2);font-size:1.1rem;flex:none;line-height:1.4}
.wk-note a{color:var(--accent-2);border-bottom:1px solid var(--line);white-space:nowrap}

/* ---- Badge „patch-abhängig" ---- */
.wk-badge{display:inline-flex;align-items:center;gap:.3rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.62rem;color:var(--accent-2);border:1px solid color-mix(in srgb,var(--accent-2) 45%,transparent);background:color-mix(in srgb,var(--accent-2) 10%,transparent);padding:.12rem .45rem;border-radius:2px;white-space:nowrap}

/* ---- Trade-Tabelle: Kernstück. Mobil horizontal scrollbar statt Overflow. ---- */
.wk-tradewrap{max-width:var(--maxw);margin:0 auto;border:1px solid var(--line);border-radius:8px;overflow-x:auto;-webkit-overflow-scrolling:touch;background:var(--surface)}
.wk-trade{width:100%;min-width:720px;border-collapse:collapse;font-size:clamp(.86rem,1.4vw,.98rem)}
.wk-trade caption{caption-side:top;text-align:left;padding:.9rem 1.1rem .2rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.06em;color:var(--muted);font-size:.8rem}
.wk-trade thead th{position:sticky;top:0;text-align:left;font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.68rem;color:var(--accent);background:var(--bg-2);padding:.75rem 1rem;border-bottom:1px solid var(--line);white-space:nowrap}
.wk-trade tbody th[scope="rowgroup"]{text-align:left;font-family:var(--font-ui);font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.7rem;color:var(--accent-2);background:var(--bg-2);padding:.6rem 1rem;border-top:1px solid var(--line);border-bottom:1px solid var(--line-soft)}
.wk-trade td{padding:.7rem 1rem;border-bottom:1px solid var(--line-soft);vertical-align:top;color:var(--text)}
.wk-trade tbody tr:last-child td{border-bottom:0}
.wk-trade .wk-rw{font-weight:600}
.wk-trade .wk-mat{color:var(--muted);line-height:1.45}
.wk-trade .wk-var{color:var(--accent-2);font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.04em}
.wk-trade .wk-stand{color:var(--muted);font-size:.8rem;white-space:nowrap}
.wk-trade tbody tr:hover td{background:color-mix(in srgb,var(--accent) 5%,transparent)}

/* ---- Timeline ---- */
.wk-time{max-width:var(--maxw);margin:0 auto;display:grid;gap:0}
.wk-trow{display:grid;grid-template-columns:auto 1fr;gap:1.2rem;padding:1.1rem 0;border-bottom:1px solid var(--line-soft)}
.wk-trow:last-child{border-bottom:0}
.wk-ver{font-family:var(--font-display);font-weight:900;font-size:clamp(1.4rem,3vw,2rem);color:transparent;-webkit-text-stroke:1.5px var(--accent);line-height:1;min-width:3.2em}
.wk-tbody h3{font-family:var(--font-display);font-weight:800;font-size:1.15rem;color:#fff;margin:0 0 .25rem}
.wk-tbody p{color:var(--muted);font-size:.98rem;line-height:1.55;margin:0;max-width:64ch}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/index.html' }, { label: 'Alpha 4.1.0', href: '/patches/sc-4-1-0.html' }, { label: "Wikelo" }]} pill={"THEMA · ALPHA 4.1"} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-1-0.html">Alpha 4.1 · Orbital Assault</a> &nbsp;·&nbsp; <span class="banu-tag">Banu-Händler</span></div>
      <h1><span class="thin">Der erste spielbare Alien-Händler</span>Wikelo's Emporium</h1>
      <p class="lead">Wikelo ist ein <b>Banu</b> — und der erste spielbare Alien-NPC in Star Citizen. Sein Emporium kennt kein Geld: Du lieferst geforderte Items, sammelst <b>Wikelo Favor</b> und tauschst sie gegen Belohnungen aus seinem Lager.</p>
      <div class="tags"><span class="tag">Banu</span><span class="tag">Barter</span><span class="tag">Wikelo Favor</span><span class="tag">3 Stationen</span><span class="tag">seit Alpha 4.1</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>WIKELO</span><span class="dot">◆</span><span>BANU-HÄNDLER</span><span class="dot">◆</span><span>EMPORIUM</span><span class="dot">◆</span><span>DASI</span><span class="dot">◆</span><span>SELO</span><span class="dot">◆</span><span>KINGA</span><span class="dot">◆</span><span>WIKELO FAVOR</span><span class="dot">◆</span><span>BARTER</span><span class="dot">◆</span>
      <span>WIKELO</span><span class="dot">◆</span><span>BANU-HÄNDLER</span><span class="dot">◆</span><span>EMPORIUM</span><span class="dot">◆</span><span>DASI</span><span class="dot">◆</span><span>SELO</span><span class="dot">◆</span><span>KINGA</span><span class="dot">◆</span><span>WIKELO FAVOR</span><span class="dot">◆</span><span>BARTER</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK -->
  <TopicFacts topicSlug="wikelo-emporium" />

  <!-- STAT STRIP -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Asteroiden-Stationen in Stanton</div></div>
    <div class="s"><div class="n">Banu</div><div class="c">Erster spielbarer Alien-NPC</div></div>
    <div class="s"><div class="n">4.1<span class="u">Alpha</span></div><div class="c">Eingeführt</div></div>
    <div class="s"><div class="n">0<span class="u">aUEC</span></div><div class="c">Reines Barter — kein Geld</div></div>
  </div>

  <!-- BAND 01 — Barter-Prinzip -->
  <section class="band band--center" style="min-height:auto;padding-block:clamp(3rem,8vw,6rem)">
    <div class="band__in reveal">
      <div class="kx">01 · Das Barter-Prinzip</div>
      <div class="big outline" style="font-size:clamp(2rem,8vw,6rem)">LIEFERN · BEKOMMEN</div>
      <p>Wikelo's Emporium ist ein <b style="color:var(--accent-2)">Tauschhandel ohne Währung im klassischen Sinn</b>. Statt aUEC zu zahlen, erfüllst du Contracts: Du bringst die geforderten Materialien und Items — und bekommst dafür Belohnungen aus Wikelos Lager. Der Zwischenschritt sind <b style="color:var(--accent-2)">Wikelo Favor</b>, Token, die du aus Contracts erhältst und gegen Ausrüstung, Komponenten oder sogar Schiffe eintauschst.</p>
    </div>
  </section>

  <!-- PROCESS — der Ablauf -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>So läuft ein Trade ab</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background:radial-gradient(80% 80% at 30% 30%,rgba(31,184,166,.35),transparent),var(--bg-2)"></div>
      <div class="frame" style="background:radial-gradient(80% 80% at 70% 40%,rgba(232,163,61,.32),transparent),var(--bg-2)"></div>
      <div class="frame" style="background:radial-gradient(80% 80% at 40% 70%,rgba(31,184,166,.30),transparent),var(--bg-2)"></div>
      <div class="frame" style="background:radial-gradient(80% 80% at 60% 60%,rgba(232,163,61,.30),transparent),var(--bg-2)"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Contract annehmen</h3><p>An einer der drei Emporium-Stationen nimmst du bei Wikelo einen Contract an. Er nennt dir, welche Materialien oder Items er sucht — die Grundlage jedes Tauschs.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Items sammeln</h3><p>Du beschaffst die geforderten Waren: schürfen, bergen, kaufen oder herstellen. Das ist der eigentliche Grind — der Loop, der dich durch das Verse schickt.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Am Freight Elevator abliefern</h3><p>Zurück an der Station lieferst du die Waren über den Freight Elevator ab. Wikelo verbucht die Lieferung und schreibt dir <b>Wikelo Favor</b> gut.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Reward eintauschen</h3><p>Mit genügend Favor (plus ggf. weiterer Materialien) tauschst du eine Belohnung ein. Sie landet im lokalen Stations-Inventar — von dort holst du sie ab.</p></div>
    </div>
  </div>

  <!-- ZWEI INTERAKTIONSTYPEN -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">03</span><h2>Zwei Interaktionstypen</h2><span class="rule"></span></div></div>
    <div class="wk-duo reveal">
      <div class="wk-cell">
        <div class="wk-ic">🔁</div>
        <div class="wk-sub">Favor-Conversion</div>
        <h3>Rohstoffe → Favors</h3>
        <p>Du lieferst geforderte <b>Rohstoffe/Materialien</b> und erhältst dafür <b>Wikelo Favor</b>. Der Aufbau deines Guthabens — die Token, mit denen du später bezahlst.</p>
      </div>
      <div class="wk-cell alt">
        <div class="wk-ic">🎁</div>
        <div class="wk-sub">Reward-Trade</div>
        <h3>Favors + Material → Ausrüstung</h3>
        <p>Du gibst <b>Favors zusammen mit weiteren Materialien</b> und bekommst eine konkrete Belohnung: Ausrüstung, Komponenten oder ein Schiff aus Wikelos Lager.</p>
      </div>
    </div>
  </section>

  <!-- DIE DREI STATIONEN -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">04</span><h2>Die drei Emporium-Stationen</h2><span class="rule"></span></div></div>
    <div class="wk-bento reveal">
      <div class="wk-cell">
        <div class="wk-ic">🪨</div>
        <div class="wk-sub">bei Hurston</div>
        <h3>Dasi</h3>
        <p>Asteroiden-Station im Einflussbereich von Hurston. Einer der drei Anlaufpunkte für Contracts und Rewards.</p>
      </div>
      <div class="wk-cell">
        <div class="wk-ic">🪨</div>
        <div class="wk-sub">bei Crusader / Yela</div>
        <h3>Selo</h3>
        <p>Asteroiden-Station nahe Crusader und dem Mond Yela. Zweiter Standort des Emporiums in Stanton.</p>
      </div>
      <div class="wk-cell">
        <div class="wk-ic">🪨</div>
        <div class="wk-sub">bei microTech</div>
        <h3>Kinga</h3>
        <p>Asteroiden-Station im Umfeld von microTech. Dritter Standort — Rewards landen jeweils im lokalen Stations-Inventar.</p>
      </div>
    </div>
  </section>

  <!-- TRADE-TABELLE — Kernstück -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">05</span><h2>Liefern → Bekommen</h2><span class="rule"></span></div></div>
    <div class="wk-note reveal">
      <span class="wk-ic" aria-hidden="true">⚠</span>
      <span>Konkrete Mengen, Favor-Kosten und der verfügbare Schiffs-/Reward-Pool <b>ändern sich mit jedem Patch</b>. Die folgenden Zeilen sind <b>kuratierte Beispiele nach Kategorie</b>, keine feststehenden Preise. Genaue, aktuelle Werte immer <b>in-game</b> oder über einen Live-Tracker prüfen: <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com ↗</a></span>
    </div>
    <div class="wk-tradewrap reveal">
      <table class="wk-trade">
        <caption>Beispiel-Trades nach Reward-Kategorie · Stand-Angaben markiert · Mengen/Favor patch-abhängig</caption>
        <thead>
          <tr>
            <th scope="col">Belohnung</th>
            <th scope="col">Kategorie</th>
            <th scope="col">Benötigte Materialien (Menge)</th>
            <th scope="col">Favor-Kosten</th>
            <th scope="col">Stand / Patch</th>
          </tr>
        </thead>
        <tbody>
          <tr><th scope="rowgroup" colspan="5">Schiffe &amp; Fahrzeuge <span class="wk-badge">patch-abhängig</span></th></tr>
          <tr>
            <td class="wk-rw">Schiff aus Wikelos Pool</td>
            <td>Schiffe/Fahrzeuge</td>
            <td class="wk-mat">Umfangreiche Materiallieferung + mehrere Contract-Stufen — <span class="wk-var">Menge prüfen</span></td>
            <td class="wk-var">variabel · Tracker</td>
            <td class="wk-stand">Beispiel · zu verifizieren</td>
          </tr>

          <tr><th scope="rowgroup" colspan="5">Waffen &amp; Rüstung <span class="wk-badge">patch-abhängig</span></th></tr>
          <tr>
            <td class="wk-rw">Handfeuerwaffe</td>
            <td>Waffen</td>
            <td class="wk-mat">Rohstoffe/Refined Goods — <span class="wk-var">Menge prüfen</span></td>
            <td class="wk-var">variabel · Tracker</td>
            <td class="wk-stand">Beispiel · zu verifizieren</td>
          </tr>
          <tr>
            <td class="wk-rw">Rüstungs-Set</td>
            <td>Rüstung</td>
            <td class="wk-mat">Rohstoffe + Favor-Guthaben — <span class="wk-var">Menge prüfen</span></td>
            <td class="wk-var">variabel · Tracker</td>
            <td class="wk-stand">Beispiel · zu verifizieren</td>
          </tr>

          <tr><th scope="rowgroup" colspan="5">Kosmetik &amp; Komponenten <span class="wk-badge">patch-abhängig</span></th></tr>
          <tr>
            <td class="wk-rw">Paint / Skin</td>
            <td>Paints/Skins</td>
            <td class="wk-mat">Favor-Guthaben (ggf. + Material) — <span class="wk-var">Menge prüfen</span></td>
            <td class="wk-var">variabel · Tracker</td>
            <td class="wk-stand">Beispiel · zu verifizieren</td>
          </tr>
          <tr>
            <td class="wk-rw">Ship-Komponente</td>
            <td>Ship-Komponenten</td>
            <td class="wk-mat">Rohstoffe + Favor-Guthaben — <span class="wk-var">Menge prüfen</span></td>
            <td class="wk-var">variabel · Tracker</td>
            <td class="wk-stand">Beispiel · zu verifizieren</td>
          </tr>
          <tr>
            <td class="wk-rw">Crafting-Rezept</td>
            <td>Crafting-Rezepte</td>
            <td class="wk-mat">Favor-Guthaben — <span class="wk-var">Menge prüfen</span></td>
            <td class="wk-var">variabel · Tracker</td>
            <td class="wk-stand">Beispiel · zu verifizieren</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="src reveal">Die Kategorien sind belegt; konkrete Zeilenwerte sind bewusst als Beispiel/„zu verifizieren" markiert, weil sie sich pro Patch ändern. Live-Daten: <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com ↗</a></p>
  </section>

  <!-- BELOHNUNGS-KATEGORIEN -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">06</span><h2>Belohnungs-Kategorien</h2><span class="rule"></span></div></div>
    <div class="wk-bento reveal">
      <div class="wk-cell"><div class="wk-ic">🚀</div><div class="wk-sub">Kategorie</div><h3>Schiffe &amp; Fahrzeuge</h3><p>Ausgewählte Schiffe und Bodenfahrzeuge aus Wikelos rotierendem Pool.</p></div>
      <div class="wk-cell"><div class="wk-ic">🔫</div><div class="wk-sub">Kategorie</div><h3>Waffen</h3><p>Hand- und Schiffswaffen als Tausch-Belohnung.</p></div>
      <div class="wk-cell"><div class="wk-ic">🛡️</div><div class="wk-sub">Kategorie</div><h3>Rüstung</h3><p>Rüstungs-Sets und Ausrüstungsteile.</p></div>
      <div class="wk-cell alt"><div class="wk-ic">🎨</div><div class="wk-sub">Kategorie</div><h3>Paints / Skins</h3><p>Kosmetische Lackierungen für Schiffe und Ausrüstung.</p></div>
      <div class="wk-cell alt"><div class="wk-ic">⚙️</div><div class="wk-sub">Kategorie</div><h3>Ship-Komponenten</h3><p>Komponenten zum Aufrüsten und Ausstatten von Schiffen.</p></div>
      <div class="wk-cell alt"><div class="wk-ic">📜</div><div class="wk-sub">Kategorie</div><h3>Crafting-Rezepte</h3><p>Rezepte, die in das Crafting-System einfließen.</p></div>
    </div>
  </section>

  <!-- PATCH-TIMELINE -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">07</span><h2>Wikelo im Patch-Verlauf</h2><span class="rule"></span></div></div>
    <div class="wrap"><div class="wk-time reveal">
      <div class="wk-trow">
        <div class="wk-ver">4.1</div>
        <div class="wk-tbody"><h3>Einführung — der erste Alien</h3><p>Wikelo kommt ins Spiel: der Banu-Händler und erste spielbare Alien-NPC. Das Emporium startet mit dem Barter-Prinzip und den Wikelo-Favor-Contracts.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.1.1</div>
        <div class="wk-tbody"><h3>Zweite Etage</h3><p>Das Emporium wird erweitert — eine zweite Etage kommt hinzu und vergrößert das Angebot vor Ort.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.2 / 4.2.1</div>
        <div class="wk-tbody"><h3>Reward-Rework — deterministisch</h3><p>Die Belohnungen werden überarbeitet: der Zufalls-Loot fällt weg, die Rewards werden <b>deterministisch</b> — du weißt vorher, was ein Trade bringt.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.8</div>
        <div class="wk-tbody"><h3>Reset &amp; Economy-Cleanup</h3><p>Ein Reset bzw. Economy-Cleanup bereinigt das Emporium-System — Teil der laufenden Balance-Arbeit an Wikelos Wirtschaft.</p></div>
      </div>
    </div></div>
  </section>

  <!-- LORE-QUOTE -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Kein Geld wechselt den Besitzer — nur <span class="hl">Ware gegen Gunst</span>, und Gunst gegen das Lager eines Banu.</blockquote>
    <cite>Wikelo's Emporium · Banu-Barter</cite>
  </section>

  <!-- QUELLEN -->
