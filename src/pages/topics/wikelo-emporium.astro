---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import WikeloBridge from '../../components/WikeloBridge.astro';
import { matchItemName } from '../../lib/wikeloItemMatch';
import TRADES from '../../../assets/wikelo-trades.json';
import { existsSync } from 'node:fs';
import TopicSeo from '../../components/dossier/TopicSeo.astro';

// Only show trade photos whose image file actually exists (build-time check
// against public/assets). If missing, the category-icon fallback kicks in —
// so no dead /assets/wk-* references remain (publish gate).
const hasAsset = (name: string) => existsSync(`public/assets/${name}`);

// Item-finder bridge: names with an item match are marked clickable in the
// SSR markup (data-item = canonical DB name) — visible without loading the DB.
const linkAttrs = (raw: string) => {
  const it = matchItemName(raw);
  return it ? { 'data-item': it, role: 'button', tabindex: '0', title: 'Show where to get it' } : {};
};

// On-brand inline SVG icons (instead of emojis) — line style, currentColor.
const svg = (b) => `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${b}</svg>`;
const ICON = {
  ship: svg('<path d="M12 2c3 2.2 4.5 5.6 4.5 10 0 2.2-.5 4.3-1.5 6H9c-1-1.7-1.5-3.8-1.5-6C7.5 7.6 9 4.2 12 2z"/><circle cx="12" cy="9" r="1.8"/><path d="M7.5 14 4 17v3l3.5-2M16.5 14 20 17v3l-3.5-2M12 18v4"/>'),
  weapon: svg('<path d="M3 8h13l4 2v2h-5l-2 3H8v-3H5a2 2 0 0 1-2-2V8z"/><path d="M8 12v3M11 8V6M14 8V6"/>'),
  armor: svg('<path d="M12 3 5 5.5V11c0 4.4 3 8 7 10 4-2 7-5.6 7-10V5.5L12 3z"/><path d="M12 3v18M5 8h14"/>'),
  paint: svg('<path d="M12 3s6 6.5 6 10.5a6 6 0 0 1-12 0C6 9.5 12 3 12 3z"/><path d="M9.5 13.5a2.5 2.5 0 0 0 2.5 2.5"/>'),
  component: svg('<circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.2 6l2.1 2.1M17.7 15.9l2.1 2.1M2 12h3M19 12h3M4.2 18l2.1-2.1M17.7 8.1l2.1-2.1"/>'),
  recipe: svg('<path d="M6 3h9l4 4v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/><path d="M14 3v5h5M8.5 12h7M8.5 15.5h7M8.5 8.5h3"/>'),
  material: svg('<path d="M12 3 3 8v8l9 5 9-5V8l-9-5z"/><path d="m3 8 9 5 9-5M12 13v8"/>'),
  favor: svg('<path d="m12 3 2.5 5.3 5.8.8-4.2 4 1 5.7L12 21l-5.1 2.8 1-5.7-4.2-4 5.8-.8L12 3z"/>'),
  vehicle: svg('<path d="M3 13h18l-2-5H8L3 13z"/><path d="M3 13v4h2M21 13v4h-2M9 17h6"/><circle cx="7" cy="17.5" r="1.6"/><circle cx="17" cy="17.5" r="1.6"/>'),
  arrow: svg('<path d="M4 12h15M13 6l6 6-6 6"/>'),
};

// Trade categories (filter pills)
const TCATS = [
  { key: 'all', label: 'All' },
  { key: 'conv', label: 'Favor exchange' },
  { key: 'ship', label: 'Ships' },
  { key: 'weapon', label: 'Weapons' },
  { key: 'armor', label: 'Armor' },
  { key: 'misc', label: 'Misc' },
];
const CAT_LABEL = { conv: 'Favor exchange', ship: 'Ship', weapon: 'Weapon', armor: 'Armor', misc: 'Misc' };
const CAT_ICON = { conv: 'favor', ship: 'ship', weapon: 'weapon', armor: 'armor', misc: 'component' };
// Component types (ship loadout)
const COMP_LABEL = { pwr: 'Power Plant', shield: 'Shield', qd: 'Quantum', cooler: 'Cooler', weapon: 'Weapons' };

// FULL trade list (63 trades) — source: wikelotrades.com (scrape_wikelo.py), patch 4.8.1,
// as of 2026-06-04. Materials/Favor taken faithfully from the tracker data file
// PATCH_4_8_1.js (original spellings kept). Nothing invented; values are patch-volatile.
// TRADES imported from src/data/wikelo-trades.json (shared DE/EN).

// Media rule: the same image file at most 2× per page. Rewards granted by
// several trades (e.g. ATLS GEO) show the category icon from the 3rd
// occurrence on — the name carries the information, not the photo.
const imgUse = new Map<string, number>();
const showImg = TRADES.map((t: { img?: string }) => {
  if (!t.img || !hasAsset(t.img)) return false;
  const n = (imgUse.get(t.img) ?? 0) + 1;
  imgUse.set(t.img, n);
  return n <= 2;
});
---
<Layout title={"Wikelo's Emporium — Star Citizen 4.1 | VerseBase"} description={"Wikelo's Emporium: the Banu trader Wikelo — the first playable alien NPC in Star Citizen. Barter instead of money: deliver items, earn Wikelo Favor, trade for rewards from his stock. Three asteroid stations in Stanton, since Alpha 4.1."} themeColor="#0d1513" ogType="article" ogImage="/assets/wk-hero.jpg" translated={true}>
<TopicSeo slug="wikelo-emporium" image="/assets/wk-hero.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Wikelo / Banu Emporium theme (4.1) — turquoise & brass */
:root{--bg:#0d1513;--bg-2:#111d1a;--surface:#152420;--surface-2:#1c302b;--accent:#1FB8A6;--accent-2:#E8A33D;--hot:#C0392B;--text:#eef4f2;--muted:#93a7a1;--line:rgba(31,184,166,.22);--line-soft:rgba(238,244,242,.10);--glow:0 0 44px rgba(31,184,166,.28);--ink:#0d1513;--maxw:1180px;}
/* Neutralize the reveal gate: content is ALWAYS visible.
   Reason: the very tall trade-card column (19 cards) never meets the
   IntersectionObserver's 12% visibility threshold on mobile → it would stay
   opacity:0 forever. Visibility takes priority over the fade-in animation. */
.reveal{opacity:1 !important;transform:none !important}
/* page-local accents */
.hero h1{font-size:clamp(2.8rem,12vw,9rem)}
.hero{background:radial-gradient(120% 90% at 78% 12%,rgba(31,184,166,.18),transparent 60%),radial-gradient(90% 80% at 12% 90%,rgba(232,163,61,.12),transparent 55%),var(--bg)}
.banu-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}
.wk-lede{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

/* ---- Bento (stations + reward categories) ---- */
.wk-bento{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-cell{border:1px solid var(--line);border-top:2px solid var(--accent);background:var(--surface);padding:1.3rem 1.4rem;display:flex;flex-direction:column;gap:.5rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px)}
.wk-cell .wk-ic{color:var(--accent);line-height:0;width:34px;height:34px}
.wk-cell.alt .wk-ic{color:var(--accent-2)}
.wk-cell .wk-ic svg{width:100%;height:100%;display:block}
.wk-cell h3{font-family:var(--font-display);font-weight:800;font-size:1.25rem;color:#fff;line-height:1.1}
.wk-cell .wk-sub{font-family:var(--font-ui);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.68rem;color:var(--accent)}
.wk-cell p{color:var(--muted);font-size:.98rem;line-height:1.5;margin:0}
.wk-cell.alt{border-top-color:var(--accent-2)}
.wk-cell.alt .wk-sub{color:var(--accent-2)}

/* ---- Two interaction types (mini-split) ---- */
.wk-duo{display:grid;grid-template-columns:1fr 1fr;gap:1rem;max-width:var(--maxw);margin:0 auto}
.wk-duo .wk-cell b{color:var(--text)}
@media(max-width:640px){.wk-duo{grid-template-columns:1fr}}

/* ---- "patch-dependent" badge ---- */
.wk-badge{display:inline-flex;align-items:center;gap:.3rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.62rem;color:var(--accent-2);border:1px solid color-mix(in srgb,var(--accent-2) 45%,transparent);background:color-mix(in srgb,var(--accent-2) 10%,transparent);padding:.12rem .45rem;border-radius:2px;white-space:nowrap}

/* ---- Trade overview: GIVE → GET cards ---- */
.wk-filters{max-width:var(--maxw);margin:0 auto 1.2rem;display:flex;flex-wrap:wrap;gap:.5rem}
.wk-pill{font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.72rem;color:var(--muted);border:1px solid var(--line);background:rgba(0,0,0,.25);padding:.42rem .9rem;border-radius:50px;cursor:pointer;transition:color .18s,border-color .18s,background-color .18s}
.wk-pill:hover{color:var(--text);border-color:var(--accent)}
.wk-pill[aria-pressed="true"]{color:var(--ink);background:var(--accent);border-color:var(--accent)}
.wk-tc-grid{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1rem}
.wk-tc{border:1px solid var(--line);border-top:2px solid var(--accent);background:var(--surface);padding:1.1rem 1.15rem;display:flex;flex-direction:column;gap:.85rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px)}
.wk-tc[data-cat="conv"]{border-top-color:var(--accent-2)}
.wk-tc[hidden]{display:none}
.wk-tc__hd{display:flex;align-items:center;justify-content:space-between;gap:.6rem}
.wk-tc__cat{font-family:var(--font-ui);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-size:.64rem;color:var(--accent)}
.wk-tc[data-cat="conv"] .wk-tc__cat{color:var(--accent-2)}
.wk-conf{font-family:var(--font-ui);font-weight:700;letter-spacing:.06em;text-transform:uppercase;font-size:.58rem;padding:.14rem .5rem;border-radius:2px;white-space:nowrap;border:1px solid}
.wk-conf.solid{color:var(--accent);border-color:color-mix(in srgb,var(--accent) 45%,transparent);background:color-mix(in srgb,var(--accent) 10%,transparent)}
.wk-conf.chk{color:var(--accent-2);border-color:color-mix(in srgb,var(--accent-2) 45%,transparent);background:color-mix(in srgb,var(--accent-2) 10%,transparent)}
.wk-tc__body{display:grid;grid-template-columns:1fr auto minmax(8.5rem,1fr);align-items:stretch;gap:.6rem}
.wk-side-h{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.6rem;color:var(--muted);margin-bottom:.4rem}
.wk-mats{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:.28rem}
.wk-mats li{position:relative;padding-left:.85rem;font-size:.86rem;line-height:1.35;color:var(--text)}
.wk-mats li::before{content:"";position:absolute;left:0;top:.5em;width:5px;height:5px;background:var(--accent);transform:rotate(45deg)}
.wk-tc[data-cat="conv"] .wk-mats li::before{background:var(--accent-2)}
.wk-favor{display:inline-flex;align-items:center;gap:.35rem;margin-top:.6rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.04em;font-size:.8rem;color:var(--accent-2);border:1px solid color-mix(in srgb,var(--accent-2) 40%,transparent);background:color-mix(in srgb,var(--accent-2) 9%,transparent);padding:.22rem .55rem;border-radius:3px;width:max-content}
.wk-favor svg{width:14px;height:14px;flex:none}
.wk-tc__note{margin-top:.5rem;font-size:.74rem;line-height:1.4;color:var(--muted)}
.wk-arrow{color:var(--accent);align-self:center;line-height:0}
.wk-arrow svg{width:26px;height:26px;display:block}
.wk-get{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:.5rem;border-left:1px solid var(--line-soft);padding-left:.7rem}
.wk-get-media{width:100%;aspect-ratio:16/10;overflow:hidden;border:1px solid var(--line);background:linear-gradient(150deg,var(--surface-2),var(--bg-2));position:relative}
.wk-get-media img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s ease}
.wk-get-media[data-lb]{cursor:pointer}
.wk-get-media .zoomic{position:absolute;top:.5rem;right:.5rem;width:30px;height:30px;border-radius:50%;background:rgba(0,0,0,.55);border:1px solid var(--line);display:grid;place-items:center;font-size:.85rem;color:#fff;opacity:.55;transition:opacity .2s,background .2s,transform .2s}
.wk-get-media:hover .zoomic{opacity:1;background:var(--accent);color:var(--ink);transform:scale(1.12)}
/* Portrait renders (full-body armor, ATLS exosuit) would be cropped to a middle
   sliver under cover — contain shows the whole figure, centred on the card's
   dark gradient (transparent PNGs then read as intentional). */
.wk-get-media.is-contain img{object-fit:contain;padding:6px;box-sizing:border-box}
.wk-tc:hover .wk-get-media img{transform:scale(1.05)}
.wk-get-media--ph{display:grid;place-items:center;color:var(--accent);padding:12px}
.wk-tc[data-cat="conv"] .wk-get-media--ph{color:var(--accent-2)}
.wk-get-media--ph svg{width:42px;height:42px}
.wk-get-name{font-family:var(--font-display);font-weight:800;font-size:.98rem;line-height:1.15;color:#fff}
.wk-tc-empty{max-width:var(--maxw);margin:.5rem auto 0;color:var(--muted);font-size:.9rem}

/* ---- Ship loadout (components) ---- */
.wk-comps{margin-top:.2rem;padding-top:.75rem;border-top:1px solid var(--line-soft)}
.wk-comps__h{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.6rem;color:var(--accent);margin-bottom:.5rem}
.wk-comps ul{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:.32rem .9rem}
.wk-comps li{display:flex;align-items:baseline;gap:.4rem;flex-wrap:wrap;font-size:.8rem;line-height:1.3}
.wk-comps .ct{flex:none;min-width:4.6em;font-family:var(--font-ui);font-weight:700;text-transform:uppercase;letter-spacing:.05em;font-size:.6rem;color:var(--muted)}
.wk-comps .cn{color:var(--text)}
.wk-comps .cb{font-family:var(--font-ui);font-weight:700;font-size:.62rem;letter-spacing:.03em;color:var(--accent-2);white-space:nowrap}
@media(max-width:560px){.wk-comps ul{grid-template-columns:1fr}}

/* ---- Image figure (stations / scene) ---- */
.wk-figure{max-width:var(--maxw);margin:0 auto 1.4rem}
.wk-figure img{width:100%;height:clamp(180px,34vw,420px);object-fit:cover;display:block;border:1px solid var(--line);border-top:2px solid var(--accent-2);clip-path:polygon(14px 0,100% 0,100% calc(100% - 14px),calc(100% - 14px) 100%,0 100%,0 14px)}
.wk-figure figcaption{margin-top:.6rem;font-size:.82rem;line-height:1.5;color:var(--muted)}

@media(max-width:560px){
  .wk-tc-grid{grid-template-columns:1fr}
  .wk-tc__body{grid-template-columns:1fr;gap:.5rem}
  .wk-arrow{justify-self:center;transform:rotate(90deg);margin:.15rem 0}
  .wk-get{border-left:0;border-top:1px solid var(--line-soft);padding-left:0;padding-top:.7rem;align-items:stretch}
  .wk-get-media{aspect-ratio:16/9}
  .wk-get-name{text-align:center}
}

/* ---- Timeline ---- */
.wk-time{max-width:var(--maxw);margin:0 auto;display:grid;gap:0}
.wk-trow{display:grid;grid-template-columns:auto 1fr;gap:1.2rem;padding:1.1rem 0;border-bottom:1px solid var(--line-soft)}
.wk-trow:last-child{border-bottom:0}
.wk-ver{font-family:var(--font-display);font-weight:900;font-size:clamp(1.4rem,3vw,2rem);color:transparent;-webkit-text-stroke:1.5px var(--accent);line-height:1;min-width:3.2em}
.wk-tbody h3{font-family:var(--font-display);font-weight:800;font-size:1.15rem;color:#fff;margin:0 0 .25rem}
.wk-tbody p{color:var(--muted);font-size:.98rem;line-height:1.55;margin:0;max-width:64ch}

</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.1.0', href: '/patches/sc-4-1-0.html' }, { label: "Wikelo" }]} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/wk-hero.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-1-0.html">Alpha 4.1 · Orbital Assault</a> &nbsp;·&nbsp; <span class="banu-tag">Banu trader</span></div>
      <h1><span class="thin">The first playable alien trader</span>Wikelo's Emporium</h1>
      <p class="lead">Deliver items, earn <b>Favor</b>, trade for rewards — no aUEC.</p>
      <div class="tags"><span class="tag">Banu</span><span class="tag">Barter</span><span class="tag">Wikelo Favor</span><span class="tag">3 stations</span><span class="tag">since Alpha 4.1</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>WIKELO</span><span class="dot">◆</span><span>BANU TRADER</span><span class="dot">◆</span><span>EMPORIUM</span><span class="dot">◆</span><span>DASI</span><span class="dot">◆</span><span>SELO</span><span class="dot">◆</span><span>KINGA</span><span class="dot">◆</span><span>WIKELO FAVOR</span><span class="dot">◆</span><span>BARTER</span><span class="dot">◆</span>
      <span>WIKELO</span><span class="dot">◆</span><span>BANU TRADER</span><span class="dot">◆</span><span>EMPORIUM</span><span class="dot">◆</span><span>DASI</span><span class="dot">◆</span><span>SELO</span><span class="dot">◆</span><span>KINGA</span><span class="dot">◆</span><span>WIKELO FAVOR</span><span class="dot">◆</span><span>BARTER</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AT A GLANCE -->
  <TopicFacts topicSlug="wikelo-emporium" />

  <!-- STAT STRIP -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Asteroid stations in Stanton</div></div>
    <div class="s"><div class="n">Banu</div><div class="c">First playable alien NPC</div></div>
    <div class="s"><div class="n">4.1<span class="u">Alpha</span></div><div class="c">Introduced</div></div>
    <div class="s"><div class="n">0<span class="u">aUEC</span></div><div class="c">Pure barter — no money</div></div>
  </div>

  <!-- BAND 01 — barter principle -->
  <section class="band band--center">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/wk-kinga.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">01 · The barter principle</div>
      <div class="big outline" style="font-size:clamp(2rem,8vw,6rem)">DELIVER · RECEIVE</div>
      <p>Fulfilling contracts earns <b style="color:var(--accent-2)">Wikelo Favor</b> — the tokens you spend on equipment, components and ships.</p>
    </div>
  </section>

  <!-- TWO INTERACTION TYPES -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>Two interaction types</h2><span class="rule"></span></div></div>
    <div class="wk-duo reveal">
      <div class="wk-cell">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8a8 8 0 0 1 13.7-3.3L20 7"/><path d="M20 3v4h-4"/><path d="M20 16a8 8 0 0 1-13.7 3.3L4 17"/><path d="M4 21v-4h4"/></svg></div>
        <div class="wk-sub">Favor conversion</div>
        <h3>Raw materials → Favors</h3>
        <p>You deliver requested <b>raw materials</b> and receive <b>Wikelo Favor</b> in return. Building up your balance — the tokens you pay with later.</p>
      </div>
      <div class="wk-cell alt">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 8H4v3h16V8z"/><path d="M5 11v9h14v-9"/><path d="M12 8v12"/><path d="M12 8S10.5 4.5 8.5 4.5A2 2 0 0 0 8.5 8.5H12zM12 8s1.5-3.5 3.5-3.5A2 2 0 0 1 15.5 8.5H12z"/></svg></div>
        <div class="wk-sub">Reward trade</div>
        <h3>Favors + materials → gear</h3>
        <p>You spend <b>Favors together with additional materials</b> and get a concrete reward: gear, components or a ship from Wikelo's stock.</p>
      </div>
    </div>
  </section>

  <!-- THE THREE STATIONS -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">03</span><h2>The three Emporium stations</h2><span class="rule"></span></div></div>
    <figure class="wk-figure reveal">
      <img src="/assets/wk-selo.jpg" alt="Wikelo Emporium Selo Station — Banu trading station on an asteroid near Yela" loading="lazy" decoding="async" />
      <figcaption>Wikelo Emporium — the Selo station on an asteroid near Yela, with its Banu spires and landing pads. Each of the three stations (Dasi, Selo, Kinga) shares the same layout.</figcaption>
    </figure>
    <div class="wk-bento reveal">
      <div class="wk-cell">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13 8 5l7-2 5 6-3 9-8 1z"/><path d="m8 5 3 5 4-1M11 10l-2 8m6-8 2 4"/></svg></div>
        <div class="wk-sub">near Hurston</div>
        <h3>Dasi</h3>
        <p>Asteroid station within Hurston's sphere of influence. One of the three points of contact for contracts and rewards.</p>
      </div>
      <div class="wk-cell">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13 8 5l7-2 5 6-3 9-8 1z"/><path d="m8 5 3 5 4-1M11 10l-2 8m6-8 2 4"/></svg></div>
        <div class="wk-sub">near Crusader / Yela</div>
        <h3>Selo</h3>
        <p>Asteroid station close to Crusader and the moon Yela. The Emporium's second location in Stanton.</p>
      </div>
      <div class="wk-cell">
        <div class="wk-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13 8 5l7-2 5 6-3 9-8 1z"/><path d="m8 5 3 5 4-1M11 10l-2 8m6-8 2 4"/></svg></div>
        <div class="wk-sub">near microTech</div>
        <h3>Kinga</h3>
        <p>Asteroid station in microTech's vicinity. The third location — rewards land in the local station inventory each time.</p>
      </div>
    </div>
  </section>

  <!-- TRADE OVERVIEW — the core: GIVE → GET -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">04</span><h2>Deliver → Receive</h2><span class="rule"></span></div>
      <p class="lead-p reveal">On the left what you <b>give</b> — on the right what you <b>get</b>. Underlined items show where to get them.</p></div>

    <div class="wk-filters reveal" role="group" aria-label="Filter trades by category">
      {TCATS.map((f, i) => (
        <button type="button" class="wk-pill" data-filter={f.key} aria-pressed={i === 0 ? 'true' : 'false'}>{f.label}</button>
      ))}
    </div>

    <div class="wk-tc-grid reveal" id="wk-tc-grid">
      {TRADES.map((t, ti) => (
        <article class="wk-tc" data-cat={t.cat}>
          <header class="wk-tc__hd">
            <span class="wk-tc__cat">{CAT_LABEL[t.cat]}</span>
            {t.rep && (<span class="wk-conf chk">{t.rep}</span>)}
          </header>
          <div class="wk-tc__body">
            <div class="wk-give">
              <div class="wk-side-h">Give</div>
              <ul class="wk-mats">{t.mats.map((m) => (<li class:list={[matchItemName(m) && 'wk-linkable']} {...linkAttrs(m)}>{m}</li>))}</ul>
              {t.favor != null && (<div class="wk-favor"><span set:html={ICON.favor}></span>{t.favor} Favor</div>)}
            </div>
            <div class="wk-arrow" aria-hidden="true" set:html={ICON.arrow}></div>
            <div class="wk-get">
              <div class="wk-side-h">Get</div>
              {/* Karte lädt das 480-px-WebP-Thumb (build-thumbs.mjs, ~20–50 KB);
                  die wk-*.png-Originale (1,5–2,7 MB) holt erst die Lightbox
                  (data-lb) beim bewussten Zoom-Klick — vorher lud die Seite
                  beim Durchscrollen ~45 MB PNGs. */}
              {t.img && showImg[ti]
                ? (<div class:list={['wk-get-media', (t.cat === 'armor' || (t.img ?? '').startsWith('wk-atls')) && 'is-contain']} data-lb={`img:/assets/${t.img}`} data-title={t.get ?? t.name}><img src={`/assets/thumb/${(t.img ?? '').replace(/\.[^.]+$/, '')}.webp`} alt={t.name} loading="lazy" decoding="async" /><span class="zoomic" aria-hidden="true">⤢</span></div>)
                : (<div class="wk-get-media wk-get-media--ph" aria-hidden="true" set:html={ICON[CAT_ICON[t.cat]]}></div>)}
              <div class:list={['wk-get-name', matchItemName(t.get ?? t.name) && 'wk-linkable']} {...linkAttrs(t.get ?? t.name)}>{t.get ?? t.name}</div>
            </div>
          </div>
          {t.comps && (
            <div class="wk-comps">
              <div class="wk-comps__h">Comes with · loadout</div>
              <ul>{t.comps.map((c) => (
                <li><span class="ct">{COMP_LABEL[c.k]}</span><span class="cn">{c.q ? c.q + ' ' : ''}{c.n}</span>{c.s && (<span class="cb">S{c.s}{c.g ? ' · ' + c.g : ''}</span>)}</li>
              ))}</ul>
            </div>
          )}
        </article>
      ))}
    </div>
    <p class="wk-tc-empty" id="wk-tc-empty" hidden>No trades in this category.</p>

    <p class="src reveal">Full list of all {TRADES.length} trades in patch <b>4.8.1</b>, taken straight from the data file of the live tracker <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com ↗</a> (generated 2026-06-04). Original spellings &amp; quantities of the source kept. Since Wikelo's stock rotates each patch, individual trades may since differ — verify in game if in doubt.</p>
  </section>

  <script is:inline>
    (function () {
      var pills = document.querySelectorAll('.wk-pill');
      var cards = document.querySelectorAll('#wk-tc-grid .wk-tc');
      var empty = document.getElementById('wk-tc-empty');
      pills.forEach(function (p) {
        p.addEventListener('click', function () {
          var key = p.getAttribute('data-filter');
          pills.forEach(function (q) { q.setAttribute('aria-pressed', q === p ? 'true' : 'false'); });
          var shown = 0;
          cards.forEach(function (c) {
            var vis = key === 'all' || c.getAttribute('data-cat') === key;
            c.hidden = !vis;
            if (vis) shown++;
          });
          if (empty) empty.hidden = shown !== 0;
        });
      });
    })();
  </script>

  <!-- REWARD CATEGORIES -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">05</span><h2>Reward categories</h2><span class="rule"></span></div></div>
    <div class="wk-bento reveal">
      <div class="wk-cell"><div class="wk-ic" aria-hidden="true" set:html={ICON.ship}></div><div class="wk-sub">Category</div><h3>Ships &amp; vehicles</h3><p>Selected ships and ground vehicles from Wikelo's rotating pool.</p></div>
      <div class="wk-cell"><div class="wk-ic" aria-hidden="true" set:html={ICON.weapon}></div><div class="wk-sub">Category</div><h3>Weapons</h3><p>Handheld and ship weapons as trade rewards.</p></div>
      <div class="wk-cell"><div class="wk-ic" aria-hidden="true" set:html={ICON.armor}></div><div class="wk-sub">Category</div><h3>Armor</h3><p>Armor sets and gear pieces.</p></div>
      <div class="wk-cell alt"><div class="wk-ic" aria-hidden="true" set:html={ICON.paint}></div><div class="wk-sub">Category</div><h3>Paints / skins</h3><p>Cosmetic liveries for ships and gear.</p></div>
      <div class="wk-cell alt"><div class="wk-ic" aria-hidden="true" set:html={ICON.component}></div><div class="wk-sub">Category</div><h3>Ship components</h3><p>Components for upgrading and outfitting ships.</p></div>
      <div class="wk-cell alt"><div class="wk-ic" aria-hidden="true" set:html={ICON.recipe}></div><div class="wk-sub">Category</div><h3>Crafting recipes</h3><p>Recipes that feed into the crafting system.</p></div>
    </div>
  </section>

  <!-- PATCH TIMELINE -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">06</span><h2>Wikelo across the patches</h2><span class="rule"></span></div></div>
    <div class="wrap"><div class="wk-time reveal">
      <div class="wk-trow">
        <div class="wk-ver">4.1</div>
        <div class="wk-tbody"><h3>Introduction — the first alien</h3><p>Wikelo enters the game: the Banu trader and first playable alien NPC. The Emporium launches with the barter principle and Wikelo Favor contracts.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.1.1</div>
        <div class="wk-tbody"><h3>Second floor</h3><p>The Emporium is expanded — a second floor is added, growing the on-site offering.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.2 / 4.2.1</div>
        <div class="wk-tbody"><h3>Reward rework — deterministic</h3><p>Rewards are reworked: random loot is removed and rewards become <b>deterministic</b> — you know in advance what a trade yields.</p></div>
      </div>
      <div class="wk-trow">
        <div class="wk-ver">4.8</div>
        <div class="wk-tbody"><h3>Reset &amp; economy cleanup</h3><p>A reset / economy cleanup tidies up the Emporium system — part of the ongoing balancing work on Wikelo's economy.</p></div>
      </div>
    </div></div>
  </section>

  <!-- LORE QUOTE -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>No money changes hands — only <span class="hl">goods for favor</span>, and favor for the stock of a Banu.</blockquote>
    <cite>Wikelo's Emporium · Banu barter</cite>
  </section>

  <!-- SOURCES -->
  <section>
    <div class="wrap">
      <p class="src reveal">Sources: Star Citizen Wiki — <a href="https://starcitizen.tools/Wikelo" target="_blank" rel="noopener">Wikelo</a>, <a href="https://starcitizen.tools/Wikelo_Emporium" target="_blank" rel="noopener">Wikelo Emporium</a>, <a href="https://starcitizen.tools/Wikelo_Favor" target="_blank" rel="noopener">Wikelo Favor</a> (CC-BY-SA 4.0) · trade data: live tracker <a href="https://wikelotrades.com/" target="_blank" rel="noopener">wikelotrades.com</a> (patch 4.8.1, 2026-06-04) · ship loadouts: <a href="https://docs.google.com/spreadsheets/d/1ji0q_pp6iW35RG1YyFEsv-lsmZOaCStJXGdIEdLLwhM/edit?gid=481073732" target="_blank" rel="noopener">ChrisGBG's Wikelo Sheet</a> (datamining WayfinderDrax, 4.7). Trade details change with every patch.</p>
