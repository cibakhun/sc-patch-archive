---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import TopicFacts from '../../components/TopicFacts.astro';
import RelatedTopics from '../../components/RelatedTopics.astro';
import Attribution from '../../components/Attribution.astro';
import TopicSeo from '../../components/dossier/TopicSeo.astro';
---
<Layout title={"Vanduul — Star Citizen 4.4.0 | VerseBase"} description={"Vanduul: aggressive blade aliens that arrive with Alpha 4.4.0 as AI enemies in the persistent universe for the first time — Stinger, Glaive, Scythe and Blade patrol Nyx and attack without warning."} themeColor="#0c1020" ogType="article" ogImage="/assets/t-vanduul-3.jpg" translated={true}>
<TopicSeo slug="4-4-0-vanduul" image="/assets/t-vanduul-3.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

:root{--bg:#0c1020;--bg-2:#121a30;--surface:#16203a;--surface-2:#1d2949;--accent:#7fb2d9;--accent-2:#d4af37;--hot:#c0271f;--text:#e6edfb;--muted:#93a4c4;--line:rgba(127,178,217,.22);--line-soft:rgba(230,237,251,.10);--glow:0 0 44px rgba(127,178,217,.30);--ink:#0c1020;--maxw:1180px;}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f5f7fe;--bg-2:#e9eef9;--surface:#fdfdff;--surface-2:#eef2fc;--text:#1a1f29;--muted:#4e586c;--accent:#246089;--accent-2:#685301;--hot:#9e0004;--ink:#ffffff;--accent-media:#7fb2d9;--accent-2-media:#d4af37;--line:rgba(61,119,162,.3);--line-soft:rgba(41,46,56,.12);--glow:0 6px 22px rgba(61,119,162,.18)}

/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.lede-kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}</style>
<a class="skip" href="#main">Skip to content</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Alpha 4.4.0', href: '/patches/sc-4-4-0.html' }, { label: "Vanduul" }]} hasEn={true} />


<main id="main">

  <!-- HERO (full-bleed, kinetic) -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-vanduul-3.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/patches/sc-4-4-0.html">Alpha 4.4.0 · Welcome to Nyx</a> &nbsp;·&nbsp; Enemy</div>
      <h1><span class="thin">The first alien threat in the PU</span>Vanduul</h1>
      <p class="lead">Aggressive blade aliens that arrive with 4.4.0 as AI enemies in the persistent universe for the first time — Stinger, Glaive, Scythe and Blade patrol Nyx and attack without warning.</p>
      <div class="tags"><span class="tag hot">Alien</span><span class="tag">AI enemy</span><span class="tag">Nyx</span><span class="tag">Operation Sworn Enemies</span><span class="tag hot">Hostile</span></div>
      <div class="hero__play" data-lb="yt:ilDmGyHLQNg"><span class="pbtn">▶</span>Watch trailer</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>VANDUUL</span><span class="dot">◆</span><span>SCYTHE</span><span class="dot">◆</span><span>GLAIVE</span><span class="dot">◆</span><span>BLADE</span><span class="dot">◆</span><span>STINGER</span><span class="dot">◆</span><span>NYX</span><span class="dot">◆</span><span>OPERATION SWORN ENEMIES</span><span class="dot">◆</span>
      <span>VANDUUL</span><span class="dot">◆</span><span>SCYTHE</span><span class="dot">◆</span><span>GLAIVE</span><span class="dot">◆</span><span>BLADE</span><span class="dot">◆</span><span>STINGER</span><span class="dot">◆</span><span>NYX</span><span class="dot">◆</span><span>OPERATION SWORN ENEMIES</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AT A GLANCE (data register, uniform) -->
  <TopicFacts topicSlug="4-4-0-vanduul" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="4">0</div><div class="c">AI ship types · Stinger · Glaive · Scythe · Blade</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">New system · Nyx</div></div>
    <div class="s"><div class="n count" data-to="0">0</div><div class="c">Warnings before the attack</div></div>
    <div class="s"><div class="n">ARCHENEMY</div><div class="c">Debut in the persistent universe</div></div>
  </div>

  <!-- FULL-BLEED BAND #1 (parallax, big overlaid text) -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/img-vanduul.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">An archenemy returns</div>
      <div class="big outline">BLADES IN THE SKY</div>
      <p>The Vanduul are an aggressive alien species with blade-shaped ships — a decades-old archenemy of humanity from the Vanduul War. With Alpha 4.4.0 they enter the persistent universe for the first time.</p>
    </div>
  </section>

  <!-- OVERVIEW as full-bleed BAND #2 (no card) -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-vanduul-4.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">01 · First time in the PU</div>
      <div class="big" style="font-size:clamp(2.4rem,8vw,6rem)">AI FACTION</div>
      <p>What was background lore until now becomes an acute danger with 4.4.0: the Vanduul appear for the first time as a standalone <b style="color:var(--accent-2)">AI enemy faction</b> in the persistent universe. Their pilots have no thought of negotiating — they hunt.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: Operation Sworn Enemies -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>Operation Sworn Enemies</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/trailer-4-4-0.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-ruin.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-vanduul-7.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-vanduul-2.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Mission in Nyx</h3><p>The investigation mission Operation Sworn Enemies takes you into the newly opened Nyx system — to where the Vanduul patrol.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Abandoned stations</h3><p>The trail leads to abandoned stations where clues to dangerous Vanduul technology have been left behind.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>On the trail of the technology</h3><p>You collect and document what the Vanduul left behind — and get closer to the nature of the archenemy piece by piece.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Without warning</h3><p>But the Vanduul tolerate no intruders: their AI pilots attack without warning — the mission can turn into a firefight at any moment.</p></div>
    </div>
  </div>

  <!-- VERSUS: Humanity vs Vanduul (full-bleed dual pane) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚠ Vanduul</h3>
        <ul>
          <li>Aggressive alien species, decades-long archenemy.</li>
          <li>Blade-shaped ships, flown by AI pilots.</li>
          <li>Patrol Nyx and attack without warning.</li>
          <li>Four AI ship types over Nyx: Stinger, Glaive, Scythe, Blade.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>★ Humanity</h3>
        <ul>
          <li>Players encounter the aliens directly for the first time in Nyx.</li>
          <li>Operation Sworn Enemies investigates their technology.</li>
          <li>Every jump to Nyx can become an ambush.</li>
          <li>The Vanduul War now takes place in the PU.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SPLIT: The four ship types (one framed/split section) -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-vanduul-6.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">03 · The blade fleet</div>
        <h3>Stinger · Glaive · Scythe · Blade</h3>
        <p>The Vanduul AI pilots fly <b>four ship types</b>. Each carries the unmistakable blade silhouette of the species — and each shows up in the patrols over Nyx.</p>
        <p>From the light <b>Stinger</b> through <b>Glaive</b> and <b>Scythe</b> to the <b>Blade</b>: whoever intrudes into their territory has to deal with exactly this squadron.</p>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND #3: NYX -->
  <section class="band">
    <div class="bbg" data-par="0.13" style="background-image:url('/assets/img-nyx.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · Their territory</div>
      <div class="big outline" style="font-size:clamp(2.6rem,9vw,7rem)">NYX</div>
      <p>The newly opened <b style="color:var(--accent-2)">Nyx system</b> is their hunting ground. Here the Vanduul patrol — and attack without warning any player who crosses their path.</p>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>They do not negotiate. They <span class="hl">hunt</span> — and Nyx belongs to them now.</blockquote>
    <cite>Vanduul · Operation Sworn Enemies</cite>
  </section>

  <!-- MEDIA (mixed gallery + trailer) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">05</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-vanduul-3.jpg"><img src="/assets/t-vanduul-3.jpg" alt="Vanduul warrior in close combat" loading="lazy"><span class="zoomic">⤢</span><figcaption>Blades in battle</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-vanduul-5.jpg"><img src="/assets/t-vanduul-5.jpg" alt="Vanduul — head study" loading="lazy"><span class="zoomic">⤢</span><figcaption>The archenemy</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-vanduul-4.jpg"><img src="/assets/t-vanduul-4.jpg" alt="Vanduul threatening an officer" loading="lazy"><span class="zoomic">⤢</span><figcaption>Eye to eye</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-vanduul-1.jpg"><img src="/assets/t-vanduul-1.jpg" alt="Vanduul fighter over Nyx" loading="lazy"><span class="zoomic">⤢</span><figcaption>Hunter over Nyx</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="ilDmGyHLQNg" style="background-image:url('/assets/trailer-4-4-0.jpg')"><span class="vlbl">Welcome to Nyx — Trailer</span><button class="play" aria-label="Play trailer">▶</button></div>
      <p class="src reveal">Source: official Star Citizen YouTube channel &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=ilDmGyHLQNg" target="_blank" rel="noopener">Watch on YouTube ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-4-0-vanduul" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Close">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
