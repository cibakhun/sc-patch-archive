---
// SHIPS (EN) — /schiffe.html. English ship-database browser (Phase 2).
// Holo-card fleet grid, same data + client-side filter/sort as the DE page;
// text resolved via the vehicleText helpers (vType/vSize/vStatus). Each card
// carries BOTH prices — Pledge (USD) and the cheapest in-game buy (UEX aUEC).
// Links point into the ship detail pages (English, prefix-free root).
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import { getCollection } from 'astro:content';
import vehiclesSnapshot from '../data/vehicles.json';
import { pickThumb } from '../lib/shipRenders';
import { priceInfo, pricesFetchedAt } from '../lib/shipExtras';
import { vType, vSize, vStatus, vRole } from '../i18n/vehicleText';

const lang = 'en' as const;
const vehicles = (await getCollection('vehicles')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name, 'en')
);
const makers = [...new Set(vehicles.map((v) => v.data.manufacturer).filter(Boolean))].sort() as string[];
const types = [...new Set(vehicles.map((v) => vType(v.data, lang)).filter(Boolean))].sort() as string[];
const flightReady = vehicles.filter((v) => v.data.statusEn === 'flight-ready').length;
const inArchive = vehicles.filter((v) => v.data.patches.length > 0).length;

// Card model: join prices up front so the JSX stays lean.
const cards = vehicles.map((v) => ({
  d: v.data,
  id: v.id,
  thumb: pickThumb(v.data),
  buy: priceInfo(v.id)?.buy[0]?.price ?? null,
}));
const buyable = cards.filter((c) => c.buy != null).length;

const crewFmt = (v: (typeof vehicles)[number]['data']) =>
  v.crewMin != null || v.crewMax != null
    ? v.crewMin != null && v.crewMax != null && v.crewMax !== v.crewMin
      ? `${v.crewMin}–${v.crewMax}`
      : `${v.crewMin ?? v.crewMax}`
    : '—';
const auecShort = (n: number) => n.toLocaleString('en-US');
---
<Layout
  title="Star Citizen Ships & Vehicles — Database | VerseBase"
  description={`${vehicles.length} Star Citizen ships and vehicles with specs, pledge and in-game prices, English descriptions and patch history — data as of ${vehiclesSnapshot.fetchedAt}.`}
  themeColor="#05070d"
  footer={true}
  translated={true}
  ogImage="/assets/img-hammerhead.jpg"
>
<style is:inline>
:root{
  --bg:#05070d;--bg-2:#0a0e18;--surface:#0f1524;--surface-2:#141c30;
  --accent:#2dd4ff;--accent-2:#6ea8ff;--gold:#d4af37;
  --text:#e8eefc;--muted:#8a99b8;--line:rgba(110,168,255,.16);
  --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;
  --maxw:1440px;
}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f4f7fe;--bg-2:#e9eef9;--surface:#fdfdff;--surface-2:#eef2fc;--text:#1b1f29;--muted:#4e586c;--accent:#05657c;--accent-2:#0850ad;--gold:#685301;--ink:#ffffff;--accent-media:#2dd4ff;--accent-2-media:#6ea8ff;--line:rgba(43,125,148,.3)}

*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
::selection{background:var(--accent);color:var(--ink)}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px}

.sdb{position:relative}
/* soft page backdrop below the hero so the area isn't dead black */
.sdb::before{content:"";position:fixed;inset:0;z-index:-1;pointer-events:none;
  background:radial-gradient(70% 45% at 82% 4%,rgba(45,212,255,.05),transparent 60%)}

/* ---------- Hero ---------- */
.sdb__hero{position:relative;min-height:clamp(440px,60vh,700px);display:flex;flex-direction:column;justify-content:flex-end;
  padding:7rem clamp(1rem,4vw,3rem) 2.2rem;overflow:hidden;border-bottom:1px solid var(--line)}
.sdb__hero::before{content:"";position:absolute;inset:0;z-index:0;
  background:url('/assets/img-polaris.jpg') center right/cover no-repeat;animation:heroKb 36s ease-in-out infinite alternate}
.sdb__hero::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(90deg,var(--veil-2) 0%,var(--veil-2) 40%,var(--veil) 100%),
  linear-gradient(180deg,var(--veil-2),transparent 26%,var(--veil) 60%,var(--bg) 99%)}
@keyframes heroKb{from{transform:scale(1)}to{transform:scale(1.08)}}
@media(prefers-reduced-motion:reduce){.sdb__hero::before{animation:none}}
/* fine HUD grid over the scrim */
.sdb__grid{position:absolute;inset:0;z-index:2;pointer-events:none;opacity:.6;
  background-image:linear-gradient(rgba(110,168,255,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(110,168,255,.06) 1px,transparent 1px);
  background-size:52px 52px;-webkit-mask-image:linear-gradient(180deg,transparent,#000 45%,transparent);mask-image:linear-gradient(180deg,transparent,#000 45%,transparent)}
.sdb__heroin{position:relative;z-index:3;max-width:var(--maxw);margin:0 auto;width:100%}
.sdb__eyebrow{font-family:var(--font-ui);font-weight:700;font-size:.8rem;letter-spacing:.28em;text-transform:uppercase;
  color:var(--accent);display:flex;align-items:center;gap:.6rem;margin-bottom:.5rem;text-shadow:0 2px 10px var(--shadow-color)}
.sdb__eyebrow::before{content:"";width:26px;height:1px;background:linear-gradient(90deg,var(--accent),transparent)}
.sdb__hero h1{font-family:var(--font-display);font-weight:900;font-size:clamp(2.4rem,7vw,4.6rem);line-height:1;background:linear-gradient(180deg,var(--title-hi),var(--accent-2) 66%,var(--accent));-webkit-background-clip:text;background-clip:text;color:transparent;filter:drop-shadow(0 3px 24px var(--shadow-color))}
.sdb__sub{max-width:56ch;color:#dbe6ff;margin-top:.8rem;font-size:clamp(1rem,1.4vw,1.15rem);text-shadow:0 2px 12px var(--shadow-color)}

/* metrics as a glassy HUD band at the bottom of the hero */
.sdb__metrics{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;margin:1.9rem 0 0;max-width:900px;
  border:1px solid var(--line);background:var(--line);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}
.sdb__metrics div{position:relative;background:var(--veil-2);padding:.8rem 1rem;overflow:hidden}
.sdb__metrics div::before{content:"";position:absolute;top:0;left:0;width:14px;height:2px;background:var(--accent)}
.sdb__metrics dt{font-family:var(--font-ui);font-weight:700;font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.sdb__metrics dd{margin:.2rem 0 0;font-family:var(--font-ui);font-weight:700;font-size:1.7rem;color:var(--accent);font-variant-numeric:tabular-nums;line-height:1}
@media(max-width:640px){
  .sdb__metrics{grid-template-columns:repeat(2,1fr)}
  .sdb__metrics div{padding:.55rem .7rem}.sdb__metrics dd{font-size:1.25rem}.sdb__metrics dt{font-size:.64rem}
  /* hero hugs its content instead of near-full-screen emptiness; compact 2-col filter */
  .sdb__hero{min-height:auto;padding:5.5rem 1rem 1.5rem}
  .sdb__sub{font-size:.98rem;max-width:none}
  .sdb__panel{padding:1.6rem 1rem 3rem}
}

/* ---------- Content (filter + grid) ---------- */
.sdb__panel{max-width:var(--maxw);margin:0 auto;padding:2rem clamp(1rem,3vw,2.5rem) 4rem}

/* ---------- Filter console ---------- */
.sdb__filter{display:flex;flex-wrap:wrap;gap:.6rem;align-items:center;margin:0 0 1.4rem;padding:.9rem 1rem;
  border:1px solid var(--line);background:linear-gradient(160deg,var(--surface),var(--bg-2));position:relative}
.sdb__filter::before{content:"";position:absolute;top:-1px;left:-1px;width:14px;height:14px;
  border-top:2px solid var(--accent);border-left:2px solid var(--accent)}
.sdb__filter::after{content:"";position:absolute;bottom:-1px;right:-1px;width:14px;height:14px;
  border-bottom:2px solid var(--accent);border-right:2px solid var(--accent)}
.sdb__filter input,.sdb__filter select{background:var(--veil);border:1px solid var(--line);color:var(--text);
  font-family:var(--font-ui);font-weight:600;font-size:.95rem;padding:.5rem .7rem;min-width:150px}
.sdb__filter input{flex:1;min-width:220px}
.sdb__filter input::placeholder{color:var(--muted);opacity:.7}
.sdb__filter select:focus,.sdb__filter input:focus{border-color:var(--accent);outline:none}
.sdb__count{margin-left:auto;font-family:var(--font-ui);font-weight:700;font-size:.82rem;letter-spacing:.12em;
  text-transform:uppercase;color:var(--accent);white-space:nowrap}

/* ---------- Fleet grid ---------- */
.sdb__fleet{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,270px),1fr));gap:1.1rem}
.sdb__empty{grid-column:1/-1;text-align:center;padding:4rem 1rem;color:var(--muted);
  font-family:var(--font-ui);font-weight:600;letter-spacing:.06em}

.fcard{position:relative;display:flex;flex-direction:column;background:var(--surface);border:1px solid var(--line);
  cursor:pointer;overflow:hidden;transition:transform .22s ease,border-color .22s ease,box-shadow .22s ease}
.fcard:hover{transform:translateY(-4px);border-color:color-mix(in srgb,var(--accent) 55%,transparent);
  box-shadow:0 12px 34px color-mix(in srgb,var(--accent) 16%,transparent)}
/* HUD brackets (only on hover/focus) */
.fcard::before,.fcard::after{content:"";position:absolute;width:16px;height:16px;z-index:3;pointer-events:none;
  opacity:0;transition:opacity .22s ease}
.fcard::before{top:6px;left:6px;border-top:2px solid var(--accent);border-left:2px solid var(--accent)}
.fcard::after{bottom:6px;right:6px;border-bottom:2px solid var(--accent);border-right:2px solid var(--accent)}
.fcard:hover::before,.fcard:hover::after,.fcard:focus-within::before,.fcard:focus-within::after{opacity:.9}

.fcard__media{position:relative;aspect-ratio:16/10;background:radial-gradient(120% 120% at 70% 0,rgba(45,212,255,.1),transparent 60%),linear-gradient(135deg,var(--veil-2),#141c30);overflow:hidden}
.fcard__media img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
.fcard:hover .fcard__media img{transform:scale(1.06)}
.fcard__noimg{display:grid;place-items:center;width:100%;height:100%;color:var(--muted);opacity:.5;
  font-family:var(--font-ui);font-size:.72rem;letter-spacing:.16em;text-transform:uppercase}
.fcard__scrim{position:absolute;inset:0;background:linear-gradient(180deg,var(--veil) 30%,var(--veil-2) 62%,var(--veil-2))}
.fcard__id{position:absolute;left:.8rem;right:.8rem;bottom:.55rem;z-index:2}
.fcard__maker{font-family:var(--font-ui);font-weight:700;font-size:.68rem;letter-spacing:.16em;text-transform:uppercase;color:var(--accent-2)}
.fcard__name{font-family:var(--font-ui);font-weight:700;font-size:1.18rem;line-height:1.12;color:var(--text);text-shadow:0 2px 12px var(--shadow-color);margin-top:.05rem}
.fcard__name a::after{content:"";position:absolute;inset:0;z-index:1}

/* corner markers over the image */
.fcard__status{position:absolute;top:.55rem;left:.6rem;z-index:2;display:inline-flex;align-items:center;gap:.34rem;
  font-family:var(--font-ui);font-weight:700;font-size:.64rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);background:var(--veil-2);border:1px solid var(--line);padding:.14rem .42rem;backdrop-filter:blur(3px)}
.fcard__dot{width:6px;height:6px;border-radius:50%;background:var(--muted);box-shadow:0 0 6px currentColor}
.fcard__status.fr{color:#5ad19a}
.fcard__status.fr .fcard__dot{background:#5ad19a}
.fcard__patch{position:absolute;top:.55rem;right:.6rem;z-index:2;font-family:var(--font-ui);font-weight:700;font-size:.66rem;
  letter-spacing:.08em;text-transform:uppercase;color:var(--gold);background:var(--veil-2);
  border:1px solid color-mix(in srgb,var(--gold) 50%,transparent);padding:.14rem .44rem;backdrop-filter:blur(3px)}
.fcard__patch:hover{background:color-mix(in srgb,var(--gold) 18%,var(--veil-2))}

.fcard__body{display:flex;flex-direction:column;gap:.6rem;padding:.75rem .85rem .85rem;flex:1}
.fcard__chips{display:flex;flex-wrap:wrap;gap:.32rem;min-height:1.4rem}
.fcard__chip{font-family:var(--font-ui);font-weight:600;font-size:.68rem;letter-spacing:.05em;text-transform:uppercase;
  color:var(--accent-2);border:1px solid var(--line);background:rgba(110,168,255,.06);padding:.1rem .42rem;white-space:nowrap}

.fcard__stats{display:grid;grid-template-columns:repeat(3,1fr);gap:.3rem;margin-top:auto;
  border-top:1px solid var(--line);padding-top:.6rem}
.fcard__stat dt{font-family:var(--font-ui);font-weight:700;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.fcard__stat dd{margin:.1rem 0 0;font-family:var(--font-ui);font-weight:700;font-size:.95rem;color:var(--text);
  font-variant-numeric:tabular-nums;line-height:1.1}

.fcard__prices{display:grid;grid-template-columns:1fr 1fr;gap:.4rem;border-top:1px solid var(--line);padding-top:.55rem}
.fprice{display:flex;flex-direction:column;gap:.06rem;min-width:0}
.fprice dt{font-family:var(--font-ui);font-weight:700;font-size:.58rem;letter-spacing:.13em;text-transform:uppercase;color:var(--muted)}
.fprice .v{font-family:var(--font-ui);font-weight:700;font-size:1rem;font-variant-numeric:tabular-nums;line-height:1.1;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fprice__u{font-size:.62rem;font-weight:600;color:var(--muted);letter-spacing:.04em;margin-left:.15rem}
.fprice--pledge .v{color:var(--gold)}
.fprice--game{border-left:1px solid var(--line);padding-left:.5rem}
.fprice--game .v{color:var(--accent)}
.fprice .v.none{color:var(--muted);opacity:.6}

@media(max-width:520px){
  .sdb__fleet{grid-template-columns:1fr 1fr;gap:.7rem}
  .fcard__name{font-size:1rem}
  .fcard__body{padding:.6rem .6rem .7rem;gap:.5rem}
  .fcard__stats{grid-template-columns:1fr 1fr}
  .fcard__stat:nth-child(3){display:none}
  /* stack prices so long aUEC values aren't clipped */
  .fcard__prices{grid-template-columns:1fr;gap:.25rem}
  .fprice--game{border-left:0;padding-left:0;border-top:1px solid var(--line);padding-top:.25rem}
}

.sdb__src{margin-top:1.5rem;font-size:.85rem;color:var(--muted)}
.sdb__src a{text-decoration:underline}
.sdb__src a:hover{color:var(--accent)}
/* mobile filter: AFTER the base rules so display:grid (same specificity) wins */
@media(max-width:640px){
  .sdb__filter{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
  .sdb__filter input{grid-column:1/-1;min-width:0}
  .sdb__filter select{min-width:0}
  .sdb__count{grid-column:1/-1;margin-left:0;justify-self:start}
}
/* Hell-Entsprechungen — erzeugt von scripts/build-light-overrides.mjs. Nicht von Hand ändern. */
:root[data-theme="light"] .sdb__sub{color:#4d5871}
:root[data-theme="light"] .fcard__status.fr{color:#046945}
</style>

<SiteNav crumbs={[{ label: 'Archive', href: '/archiv.html' }, { label: 'Ships' }]} hasEn={true} />

<main class="sdb">
  <section class="sdb__hero">
    <div class="sdb__grid" aria-hidden="true"></div>
    <div class="sdb__heroin">
      <div class="sdb__eyebrow">Registry // Fleet Catalog</div>
      <h1>Ships &amp; Vehicles</h1>
      <dl class="sdb__metrics">
        <div><dt>Entries</dt><dd>{vehicles.length}</dd></div>
        <div><dt>Manufacturers</dt><dd>{makers.length}</dd></div>
        <div><dt>Flight Ready</dt><dd>{flightReady}</dd></div>
        <div><dt>Buyable in-game</dt><dd>{buyable}</dd></div>
        <div><dt>In archive</dt><dd>{inArchive}</dd></div>
      </dl>
    </div>
  </section>

  <div class="sdb__panel">
  <div class="sdb__filter">
    <input id="sf-q" type="search" placeholder="Search ship or manufacturer…" aria-label="Search" autocomplete="off" />
    <select id="sf-maker" aria-label="Manufacturer">
      <option value="">All manufacturers</option>
      {makers.map((m) => <option value={m}>{m}</option>)}
    </select>
    <select id="sf-type" aria-label="Type">
      <option value="">All types</option>
      {types.map((tp) => <option value={tp}>{tp}</option>)}
    </select>
    <select id="sf-status" aria-label="Status">
      <option value="">Any status</option>
      <option value="flight-ready">Flight Ready</option>
      <option value="in-production">In production</option>
      <option value="in-concept">Concept</option>
    </select>
    <select id="sf-archive" aria-label="Archive">
      <option value="">All</option>
      <option value="1">In the patch archive</option>
    </select>
    <select id="sf-sort" aria-label="Sort">
      <option value="name">Name A–Z</option>
      <option value="pledge">Pledge price ↓</option>
      <option value="game">In-game price ↓</option>
      <option value="cargo">Cargo ↓</option>
      <option value="crew">Crew ↓</option>
    </select>
    <span class="sdb__count" id="sf-count">{vehicles.length} results</span>
  </div>

  <div class="sdb__fleet" id="sf-fleet">
    {cards.map(({ d, id, thumb, buy }) => (
      <article
        class="fcard"
        data-q={`${d.name} ${d.manufacturer ?? ''}`.toLowerCase()}
        data-maker={d.manufacturer ?? ''}
        data-type={vType(d, lang) ?? ''}
        data-status={d.statusEn ?? ''}
        data-archive={d.patches.length ? '1' : ''}
        data-href={`/schiffe/${id}.html`}
        data-pledge={d.msrpUSD ?? -1}
        data-game={buy ?? -1}
        data-cargo={d.cargoSCU ?? -1}
        data-crew={d.crewMax ?? d.crewMin ?? -1}
      >
        <div class="fcard__media">
          {thumb ? (
            <img src={thumb.src} alt="" loading="lazy" referrerpolicy="no-referrer"
              onerror="this.style.display='none'" />
          ) : (
            <span class="fcard__noimg" aria-hidden="true">No image</span>
          )}
          <span class="fcard__scrim" aria-hidden="true"></span>
          <span class={`fcard__status${d.statusEn === 'flight-ready' ? ' fr' : ''}`}>
            <span class="fcard__dot"></span>{vStatus(d, lang) ?? '—'}
          </span>
          {d.patches.length > 0 && (
            <a class="fcard__patch" href={`/patches/sc-${d.patches[0].replaceAll('.', '-')}.html`}>
              {d.patches[0]}
            </a>
          )}
          <div class="fcard__id">
            <div class="fcard__maker">{d.manufacturer ?? '—'}</div>
            <div class="fcard__name"><a href={`/schiffe/${id}.html`}>{d.name}</a></div>
          </div>
        </div>
        <div class="fcard__body">
          <div class="fcard__chips">
            {vRole(d, lang) && <span class="fcard__chip">{vRole(d, lang)}</span>}
            {vSize(d, lang) && <span class="fcard__chip">{vSize(d, lang)}</span>}
          </div>
          <dl class="fcard__stats">
            <div class="fcard__stat"><dt>Crew</dt><dd>{crewFmt(d)}</dd></div>
            <div class="fcard__stat"><dt>Cargo</dt><dd>{d.cargoSCU != null ? `${d.cargoSCU} SCU` : '—'}</dd></div>
            <div class="fcard__stat"><dt>Length</dt><dd>{d.lengthM != null ? `${d.lengthM} m` : '—'}</dd></div>
          </dl>
          <dl class="fcard__prices">
            <div class="fprice fprice--pledge">
              <dt>Pledge</dt>
              <dd class={`v${d.msrpUSD == null ? ' none' : ''}`}>{d.msrpUSD != null ? `$${d.msrpUSD.toLocaleString('en-US')}` : '—'}</dd>
            </div>
            <div class="fprice fprice--game">
              <dt>In-game</dt>
              <dd class={`v${buy == null ? ' none' : ''}`}>{buy != null ? <>{auecShort(buy)}<span class="fprice__u">aUEC</span></> : '—'}</dd>
            </div>
          </dl>
        </div>
      </article>
    ))}
    <p class="sdb__empty" id="sf-empty" hidden>No matches — reset the filters.</p>
  </div>

  <p class="sdb__src">
    Source: <a href="https://api.star-citizen.wiki" target="_blank" rel="noopener">Star Citizen Wiki API</a>
    (community project) · as of {vehiclesSnapshot.fetchedAt}
    {vehiclesSnapshot.gameVersion && ` · game data ${vehiclesSnapshot.gameVersion.split('-')[0]}`}
    · In-game prices: <a href="https://uexcorp.space" target="_blank" rel="noopener">UEX Corp</a> (as of {pricesFetchedAt})
    · Images: starcitizen.tools
  </p>
  </div>
</main>

<script is:inline>
(function () {
  var q = document.getElementById('sf-q');
  var selMaker = document.getElementById('sf-maker');
  var selType = document.getElementById('sf-type');
  var selStatus = document.getElementById('sf-status');
  var selArchive = document.getElementById('sf-archive');
  var selSort = document.getElementById('sf-sort');
  var count = document.getElementById('sf-count');
  var empty = document.getElementById('sf-empty');
  var fleet = document.getElementById('sf-fleet');
  var cards = [].slice.call(fleet.querySelectorAll('.fcard'));

  var norm = function (s) {
    return (s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  };
  var numAttr = function (el, name) {
    var v = parseFloat(el.getAttribute(name));
    return isNaN(v) ? -1 : v;
  };

  function apply() {
    var nq = norm(q.value).trim();
    var m = selMaker.value, t = selType.value, st = selStatus.value, ar = selArchive.value;
    var n = 0;
    cards.forEach(function (c) {
      var ok =
        (!nq || norm(c.getAttribute('data-q')).indexOf(nq) >= 0) &&
        (!m || c.getAttribute('data-maker') === m) &&
        (!t || c.getAttribute('data-type') === t) &&
        (!st || c.getAttribute('data-status') === st) &&
        (!ar || c.getAttribute('data-archive') === ar);
      c.style.display = ok ? '' : 'none';
      if (ok) n++;
    });
    count.textContent = n + ' results';
    empty.hidden = n !== 0;
  }

  function sort() {
    var key = selSort.value;
    var ordered;
    if (key === 'name') {
      ordered = cards; // already alphabetical from the server
    } else {
      var attr = { pledge: 'data-pledge', game: 'data-game', cargo: 'data-cargo', crew: 'data-crew' }[key];
      ordered = cards.slice().sort(function (a, b) { return numAttr(b, attr) - numAttr(a, attr); });
    }
    ordered.forEach(function (c) { fleet.insertBefore(c, empty); });
  }

  [q, selMaker, selType, selStatus, selArchive].forEach(function (el) {
    el.addEventListener('input', apply);
    el.addEventListener('change', apply);
  });
  selSort.addEventListener('change', sort);

  // whole card clickable (inner links keep working)
  cards.forEach(function (c) {
    c.addEventListener('click', function (e) {
      if (e.target.closest('a')) return;
      location.href = c.getAttribute('data-href');
    });
  });
})();
</script>
</Layout>
