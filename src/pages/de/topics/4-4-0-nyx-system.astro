---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import TopicFacts from '../../../components/TopicFacts.astro';
import RelatedTopics from '../../../components/RelatedTopics.astro';
import Attribution from '../../../components/Attribution.astro';
import TopicSeo from '../../../components/dossier/TopicSeo.astro';
---
<Layout title={"Nyx — Star Citizen 4.4.0 | VerseBase"} description={"Welcome to Nyx: mit Alpha 4.4.0 wird Nyx das dritte voll simulierte Sternsystem — Glaciem Ring, die Felsenstadt Levski und die ersten Vanduul-KI-Gegner."} themeColor="#0c1020" ogType="article" ogImage="/assets/t-nyx-1.jpg" translated={true}>
<TopicSeo slug="4-4-0-nyx-system" image="/assets/t-nyx-1.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Nyx-Theme (Alpha 4.4.0) — dunkel, nebelverhangen, eisblau */
:root{
  --bg:#0c1020;--bg-2:#121a30;--surface:#16203a;--surface-2:#1d2949;
  --accent:#7fb2d9;--accent-2:#d4af37;--hot:#c0271f;
  --text:#e6edfb;--muted:#93a4c4;
  --line:rgba(127,178,217,.22);--line-soft:rgba(230,237,251,.10);
  --glow:0 0 44px rgba(127,178,217,.30);--ink:#0c1020;
  --maxw:1180px;
}
/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.lede-kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/de/archiv.html' }, { label: 'Alpha 4.4.0', href: '/de/patches/sc-4-4-0.html' }, { label: "Nyx-System" }]} pill={"SYSTEM · ALPHA 4.4.0"} hasEn={true} />


<main id="main">

  <!-- HERO (full-bleed lead media) -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-nyx-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/de/patches/sc-4-4-0.html">Alpha 4.4.0 · Welcome to Nyx</a> &nbsp;·&nbsp; Sternsystem</div>
      <h1><span class="thin">Das dritte Sternsystem</span>Nyx</h1>
      <p class="lead">Dunkel, asteroidendicht, nebelverhangen: mit 4.4.0 wird Nyx das dritte voll simulierte Sternsystem — Heimat des Glaciem Ring und der in den Fels gebauten Stadt Levski.</p>
      <div class="tags"><span class="tag">Sternsystem</span><span class="tag">Glaciem Ring</span><span class="tag">Levski</span><span class="tag">Delamar</span><span class="tag">Peoples Alliance</span></div>
      <div class="hero__play" data-lb="yt:ilDmGyHLQNg"><span class="pbtn">▶</span>Trailer ansehen</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>NYX</span><span class="dot">◆</span><span>GLACIEM RING</span><span class="dot">◆</span><span>LEVSKI</span><span class="dot">◆</span><span>DELAMAR</span><span class="dot">◆</span><span>PEOPLES ALLIANCE</span><span class="dot">◆</span><span>DRITTES SYSTEM</span><span class="dot">◆</span>
      <span>NYX</span><span class="dot">◆</span><span>GLACIEM RING</span><span class="dot">◆</span><span>LEVSKI</span><span class="dot">◆</span><span>DELAMAR</span><span class="dot">◆</span><span>PEOPLES ALLIANCE</span><span class="dot">◆</span><span>DRITTES SYSTEM</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-4-0-nyx-system" />

  <!-- FULL-BLEED BAND — the arrival statement (parallax) -->
  <section class="band band--center">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-nyx-3.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">Nach Stanton. Nach Pyro.</div>
      <div class="big outline">SYSTEM DREI.</div>
      <p>Mit Alpha 4.4.0 öffnet sich Nyx als drittes voll simuliertes Sternsystem. Über Jump Points verbunden, betritt man eine gesetzlose, nebelverhangene Welt — die Bühne für die ersten Vanduul-KI-Gegner und die IAE 2955.</p>
    </div>
  </section>

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Voll simuliertes System · nach Stanton &amp; Pyro</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Felsenstadt · Levski in Delamar</div></div>
    <div class="s"><div class="n">VANDUUL</div><div class="c">Erste KI-Gegner · IAE 2955</div></div>
  </div>

  <!-- VERSUS: Stanton/Pyro vs Nyx — the two faces (full-bleed dual pane) -->
  <section style="padding:0">
    <div class="versus reveal">
      <div class="side a">
        <h3>⚠ Glaciem Ring</h3>
        <ul>
          <li>Dichter, nebelverhangener Asteroidengürtel quer durchs System.</li>
          <li>Enge Sicht, kaum Orientierung zwischen den Felsen.</li>
          <li>Jagdrevier der ersten Vanduul-KI-Gegner.</li>
        </ul>
      </div>
      <div class="vs">VS</div>
      <div class="side b">
        <h3>✦ Levski · Delamar</h3>
        <ul>
          <li>Landezone, in den Asteroiden Delamar getrieben — Stadt im Fels.</li>
          <li>Sitz der Fraktion Peoples Alliance.</li>
          <li>Einziger fester Halt im sonst gesetzlosen Nyx.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- SCROLLYTELLING: Ankunft in Nyx — der Weg ins System (full-bleed process) -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">01</span><h2>Ankunft in Nyx</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/trailer-4-4-0.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-nyx-5.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-nyx-2.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/img-levski.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Durch den Jump Point</h3><p>Nyx ist über Jump Points an das bekannte Verse angebunden. Mit Alpha 4.4.0 wird es als drittes voll simuliertes Sternsystem nach Stanton und Pyro erreichbar.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>In den Glaciem Ring</h3><p>Jenseits des Sprungs liegt der Glaciem Ring — ein dichter, dunkler, nebelverhangener Asteroidengürtel, der dem System sein raues, kaltes Gesicht gibt.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Gesetzloses Terrain</h3><p>Nyx ist die düstere, gesetzlose Kulisse, in der die ersten Vanduul-KI-Gegner auftauchen — und in der zur IAE 2955 das Geschehen kulminiert.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Anflug auf Levski</h3><p>Tief im System wartet Delamar: ein Asteroid, in dessen Fels die Landezone Levski gebaut wurde — verbunden mit der Fraktion Peoples Alliance.</p></div>
    </div>
  </div>

  <!-- GLACIEM RING — full-bleed band (image as background, design on top) -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-nyx-4.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">02 · Der Asteroidengürtel</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">GLACIEM RING</div>
      <p>Ein dichter, dunkler, nebelverhangener Asteroidengürtel zieht sich durch das System. Der <b style="color:var(--accent-2)">Glaciem Ring</b> prägt Nyx mehr als jeder andere Ort — kalt, eng, schwer zu durchqueren.</p>
    </div>
  </section>

  <!-- LEVSKI — the one framed/split section (50/50 media | text) -->
  <section style="padding-bottom:0">
    <div class="split split--rev reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/img-levski.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">03 · Stadt im Fels</div>
        <h3>Levski — gebaut in Delamar</h3>
        <p>Mitten im System liegt der Asteroid <b>Delamar</b>. In seinen Fels hinein wurde die Landezone <b>Levski</b> getrieben — kein orbitaler Außenposten, sondern eine Stadt im Gestein.</p>
        <p>Levski ist eng mit der <b>Peoples Alliance</b> verbunden, einer Fraktion, deren Geschichte sich in den Gängen und Hallen dieses Ortes spiegelt. Ein Zufluchtsort am Rande der bekannten Welt.</p>
      </div>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Drei Systeme. <span class="hl">Ein neues Ende</span> der Karte.</blockquote>
    <cite>Nyx · Alpha 4.4.0</cite>
  </section>

  <!-- MEDIA (mixed gallery + closing full-bleed trailer) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">04</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/img-nyx.jpg"><img src="/assets/img-nyx.jpg" alt="Nyx-System — Übersichtskarte" loading="lazy"><span class="zoomic">⤢</span><figcaption>Nyx · System</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-nyx-4.jpg"><img src="/assets/t-nyx-4.jpg" alt="Glaciem Ring mit Lichtstrahl im Nyx-Raum" loading="lazy"><span class="zoomic">⤢</span><figcaption>Glaciem Ring</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-nyx-3.jpg"><img src="/assets/t-nyx-3.jpg" alt="Der Nyx-Stern mit Nebel" loading="lazy"><span class="zoomic">⤢</span><figcaption>Nyx · Stern</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-nyx-5.jpg"><img src="/assets/t-nyx-5.jpg" alt="Der Keeger-Gürtel in Nyx" loading="lazy"><span class="zoomic">⤢</span><figcaption>Keeger-Gürtel</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-nyx-2.jpg"><img src="/assets/t-nyx-2.jpg" alt="Levski — Landekrater im Asteroiden Delamar" loading="lazy"><span class="zoomic">⤢</span><figcaption>Levski · Delamar</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="ilDmGyHLQNg" style="background-image:url('/assets/trailer-4-4-0.jpg')"><span class="vlbl">Welcome to Nyx — Trailer</span><button class="play" aria-label="Trailer abspielen">▶</button></div>
      <p class="src reveal">Quelle: offizieller Star-Citizen-YouTube-Kanal &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=ilDmGyHLQNg" target="_blank" rel="noopener">Auf YouTube ansehen ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-4-0-nyx-system" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Schließen">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
