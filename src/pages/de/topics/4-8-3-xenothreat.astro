---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import TopicFacts from '../../../components/TopicFacts.astro';
import RelatedTopics from '../../../components/RelatedTopics.astro';
import Attribution from '../../../components/Attribution.astro';
import TopicSeo from '../../../components/dossier/TopicSeo.astro';
---
<Layout title={"XenoThreat — Star Citizen 4.8.3 | VerseBase"} description={"XenoThreat: eine menschen-suprematistische, anti-alien Outlaw-Fraktion — mit Alpha 4.8.3 kehrt der Assault on Stanton als punktebasiertes Kampf-Event zurück (1.–15. Juli 2026, 120.000 Event-Punkte, Blueprint-Belohnungen)."} themeColor="#0d0a16" ogType="article" ogImage="/assets/t-xeno-1.jpg" translated={true}>
<TopicSeo slug="4-8-3-xenothreat" image="/assets/t-xeno-1.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* Tactical-Strike-Theme (4.8.x) */
:root{--bg:#0d0a16;--bg-2:#140f24;--surface:#1a1330;--surface-2:#231a3e;--accent:#E8651E;--accent-2:#1FB8A6;--hot:#E8651E;--text:#ede9f5;--muted:#a39db5;--line:rgba(232,101,30,.22);--line-soft:rgba(237,233,245,.10);--glow:0 0 44px rgba(232,101,30,.30);--ink:#0d0a16;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.kx-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--accent-2);font-size:.8rem}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/de/archiv.html' }, { label: 'Alpha 4.8.3', href: '/de/patches/sc-4-8-3.html' }, { label: "XenoThreat" }]} pill={"FRAKTION · ALPHA 4.8.3"} hasEn={true} />


<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-xeno-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/de/patches/sc-4-8-3.html">Alpha 4.8.3 · XenoThreat</a> &nbsp;·&nbsp; Fraktion</div>
      <h1><span class="thin">Der Angriff auf Stanton</span>XenoThreat</h1>
      <p class="lead">Eine menschen-suprematistische, anti-alien Outlaw-Fraktion: mit 4.8.3 kehrt ihr Assault-on-Stanton-Event zurück — diesmal nicht als kinoreifer Server-Krieg, sondern als punktebasiertes PvE-Kampf-Event vom 1. bis 15. Juli 2026.</p>
      <div class="tags"><span class="tag hot">Outlaw-Fraktion</span><span class="tag">Assault on Stanton</span><span class="tag">Punkte-Event</span><span class="tag">Foxwell Enforcement</span><span class="tag">Idris-Ziel</span></div>
      <div class="hero__play" data-lb="yt:SsOtI2dtvBc"><span class="pbtn">▶</span>Trailer ansehen</div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>XENOTHREAT</span><span class="dot">◆</span><span>ASSAULT ON STANTON</span><span class="dot">◆</span><span>FOXWELL ENFORCEMENT</span><span class="dot">◆</span><span>120.000 PUNKTE</span><span class="dot">◆</span><span>5 MISSIONSTYPEN</span><span class="dot">◆</span><span>IDRIS-FREGATTE</span><span class="dot">◆</span>
      <span>XENOTHREAT</span><span class="dot">◆</span><span>ASSAULT ON STANTON</span><span class="dot">◆</span><span>FOXWELL ENFORCEMENT</span><span class="dot">◆</span><span>120.000 PUNKTE</span><span class="dot">◆</span><span>5 MISSIONSTYPEN</span><span class="dot">◆</span><span>IDRIS-FREGATTE</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-8-3-xenothreat" />

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="120000">0</div><div class="c">Event-Punkte für die volle Reward-Spur</div></div>
    <div class="s"><div class="n count" data-to="5">0</div><div class="c">Missionstypen sammeln Punkte</div></div>
    <div class="s"><div class="n">1.–15. JULI</div><div class="c">Event-Fenster 2026</div></div>
  </div>

  <!-- FULL-BLEED BAND (parallax) — wer ist XenoThreat -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-xeno-3.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">Aus den Ruinen von Pyro</div>
      <div class="big outline">VERRAT.</div>
      <p>XenoThreat ist eine menschen-suprematistische, alien-feindliche Outlaw-Gruppe aus Pyro — grösstenteils ehemalige <b style="color:var(--accent-2)">UEE-Navy-Mitglieder</b>, die die Koexistenz der UEE mit fremden Spezies als Verrat an der Menschheit sehen. Weil Stanton diese Koexistenz stützt, greift XenoThreat das System an.</p>
    </div>
  </section>

  <!-- OVERVIEW as SPLIT (the one framed/split section) -->
  <section style="padding-bottom:0">
    <div class="split reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-hh-2.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">01 · Wer sie sind</div>
        <h3>Deserteure mit einer Doktrin</h3>
        <p>Was XenoThreat von gewöhnlichen Outlaws unterscheidet, ist die Überzeugung. Es sind ausgebildete Soldaten, die ihre Loyalität zur UEE aufgekündigt haben — überzeugt davon, dass das Bündnis mit fremden Spezies die Menschheit verrät.</p>
        <p>Aus den gesetzlosen Tiefen Pyros heraus formen sie keine bloße Bande, sondern eine <b>paramilitärische Fraktion</b> mit Schiffen, Disziplin und einem Ziel: Stanton dort zu treffen, wo es die Alien-Koexistenz am offensten lebt.</p>
      </div>
    </div>
  </section>

  <!-- HISTORY — full-bleed band (image as background, design on top) -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/cz-ruin.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">02 · Der historische Auftakt (2951)</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">STANTON 2951</div>
      <p>Schon 2951 überfiel XenoThreat einen zivilen Konvoi in Stanton auf dem Weg nach Terra — alle Schiffe zerstört, die Crews hingerichtet. Die UEE-Navy mobilisierte die <b style="color:var(--accent-2)">Civilian Defense Force</b>; nach elf Tagen Gefechten zog sich XenoThreat zurück nach Pyro. 4.8.3 lässt sie zurückkehren.</p>
    </div>
  </section>

  <!-- SCROLLYTELLING: Die fünf Missionstypen -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">03</span><h2>Fünf Wege, Punkte zu sammeln</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-xeno-2.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/img-hammerhead.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-hh-3.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-def-2.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/img-idris.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Alien-Schiffe verteidigen</h3><p>Von Aliens gebaute Schiffe geraten unter Beschuss der Isolationisten — Spieler halten sie frei.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Anti-Alien-Jäger ausschalten</h3><p>Xenophobe Jäger-Wellen treffen ein und müssen abgefangen werden.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Verbände abfangen</h3><p>Eintreffende ausgrenzende Elitisten werden aufgespürt und vernichtet.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Lieutenants herauslocken</h3><p>Xenophobe Anführer werden herausgelockt und besiegt, um die Kommandostruktur zu schwächen.</p></div>
      <div class="sstep"><div class="sn">05</div><h3>Idris-Fregatte</h3><p>Das Kapitalschiff-Ziel: die Idris entweder zerstören oder ihren Piloten ausschalten — der anspruchsvollste Auftrag der Spur.</p></div>
    </div>
  </div>

  <!-- REWARD BAND -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/cz-loot.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · Die Reward-Spur</div>
      <div class="big">120.000 PUNKTE</div>
      <p>4.8.3 ist ein Combat-Point-Farm: Der Fortschritt wird im Journal getrackt, Standard-Missionen geben grob 4.000 Punkte. Wer sich zur vollen Spur von <b style="color:var(--accent-2)">120.000 Event-Punkten</b> hocharbeitet, schaltet <b style="color:var(--accent-2)">einzigartige Blueprints</b> frei, die über künftige Updates hinweg bestehen bleiben.</p>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Fünf Fronten, ein Ziel: die <span class="hl">Idris</span> fällt — oder Stanton beugt sich der Xenophobie.</blockquote>
    <cite>XenoThreat · Assault on Stanton (4.8.3)</cite>
  </section>

  <!-- MEDIA (mixed gallery + trailer) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">05</span><h2>Media</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-xeno-1.jpg"><img src="/assets/t-xeno-1.jpg" alt="XenoThreat-Streitkräfte über Stanton" loading="lazy"><span class="zoomic">⤢</span><figcaption>XenoThreat · Streitkräfte</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-xeno-2.jpg"><img src="/assets/t-xeno-2.jpg" alt="XenoThreat im Gefecht" loading="lazy"><span class="zoomic">⤢</span><figcaption>Im Gefecht</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-idris.jpg"><img src="/assets/img-idris.jpg" alt="Idris-Fregatte als Kapitalschiff-Ziel" loading="lazy"><span class="zoomic">⤢</span><figcaption>Idris · Kapitalschiff-Ziel</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-hammerhead.jpg"><img src="/assets/img-hammerhead.jpg" alt="Hammerhead-Gunship" loading="lazy"><span class="zoomic">⤢</span><figcaption>Hammerhead-Gunship</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-xeno-3.jpg"><img src="/assets/t-xeno-3.jpg" alt="XenoThreat-Propagandaübertragung vor versammelter Menge" loading="lazy"><span class="zoomic">⤢</span><figcaption>Propaganda-Übertragung</figcaption></figure>
      </div>
      <div class="video reveal" data-yt="SsOtI2dtvBc" style="background-image:url('/assets/t-hh-1.jpg')"><span class="vlbl">XenoThreat — Assault on Stanton</span><button class="play" aria-label="Trailer abspielen">▶</button></div>
      <p class="src reveal">Quelle: offizieller Star-Citizen-YouTube-Kanal &amp; Star Citizen Wiki (© Cloud Imperium Games). · <a href="https://www.youtube.com/watch?v=SsOtI2dtvBc" target="_blank" rel="noopener">Auf YouTube ansehen ↗</a></p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-8-3-xenothreat" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Schließen">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
