---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import TopicFacts from '../../../components/TopicFacts.astro';
import RelatedTopics from '../../../components/RelatedTopics.astro';
import Attribution from '../../../components/Attribution.astro';
import MiningApp from '../../../components/MiningApp.astro';
import SignatureIdentifier from '../../../components/SignatureIdentifier.astro';
import FracturingCalc from '../../../components/FracturingCalc.astro';
import RefineryFinder from '../../../components/RefineryFinder.astro';
import { buildMiningShips } from '../../../lib/miningShips';
import DB from '../../../../assets/mining-db.json';
import TopicSeo from '../../../components/dossier/TopicSeo.astro';

const total = DB.counts.minerals;
const snap = DB.snapshot_date;
const ver = DB.game_version;
const verShort = ver.split('-')[0]; // "4.9.0-live.12248363" -> "4.9.0"

// Mining-Schiffe aus der eigenen Schiff-DB (vehicles.json) — verlinken auf das
// echte Datenblatt /schiffe/<id>.html.
const ships = buildMiningShips('de');
---
<Layout title={"Mining-Datenbank — Star Citizen 4.9 | VerseBase"} description={`Interaktive Mining-Datenbank für Star Citizen 4.9: ${total} Minerale durchsuchen, nach System, Methode & Typ filtern, echte Deposit-Regionen mit Erz-Anteil (%) ansehen, Scan-Signaturen identifizieren, Refinery-Methoden abwägen und Fracturing planen.`} themeColor="#14181a" ogType="article" ogImage="/assets/img-mole.jpg" translated={true}>
<TopicSeo slug="mining" image="/assets/img-mole.jpg" />
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>
:root{--bg:#14181a;--bg-2:#181d1f;--surface:#1e2427;--surface-2:#252c30;--accent:#2FBFA4;--accent-2:#E0A526;--hot:#2FBFA4;--text:#eaf2f1;--muted:#8fa3a0;--line:rgba(47,191,164,.22);--line-soft:rgba(234,242,241,.10);--glow:0 0 44px rgba(47,191,164,.26);--ink:#0e1214;--maxw:1240px;}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f3f8fb;--bg-2:#e8eff2;--surface:#fcfefe;--surface-2:#ebf4f9;--text:#1b2120;--muted:#4a5c5a;--accent:#036a5a;--accent-2:#704f00;--hot:#046151;--ink:#ffffff;--accent-media:#2FBFA4;--accent-2-media:#E0A526;--line:rgba(43,130,113,.3);--line-soft:rgba(41,47,46,.12);--glow:0 6px 22px rgba(43,130,113,.18)}


.reveal{opacity:1 !important;transform:none !important}
/* Hero-Titel: heller Gradient (kein dunkles Buchstaben-Ende) + kräftiger Scrim,
   damit "Mining" über dem Bild voll lesbar bleibt und nicht dahinter verschwindet. */
.hero h1{font-size:clamp(2.6rem,11vw,8rem);background:linear-gradient(180deg,var(--title-hi),#7fe6d5 58%,var(--accent));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;filter:drop-shadow(0 3px 20px var(--on-media-shadow)) drop-shadow(0 0 30px rgba(47,191,164,.45))}
.hero{background:radial-gradient(120% 90% at 78% 12%,rgba(47,191,164,.16),transparent 60%),radial-gradient(90% 80% at 12% 90%,rgba(224,165,38,.12),transparent 55%),var(--bg)}
.hero__in{max-width:var(--maxw)}
.mn-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}
.qbar{display:flex;flex-wrap:wrap;gap:.5rem 1.4rem;margin-top:1.4rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.74rem;color:var(--muted)}
.qbar b{color:var(--accent)}
.mn-note{max-width:var(--maxw);margin:0 auto 1.2rem;display:flex;align-items:flex-start;gap:.75rem;border:1px solid var(--accent-2);border-left-width:3px;background:color-mix(in srgb,var(--accent-2) 8%,transparent);padding:.9rem 1.1rem;border-radius:4px;color:var(--text);font-size:.92rem;line-height:1.55}
.mn-note b{color:var(--text)}
.mn-note a{color:var(--accent);border-bottom:1px solid var(--line);white-space:nowrap}
.mn-sec-h{max-width:var(--maxw);margin:2.6rem auto 1rem;display:flex;align-items:baseline;gap:.8rem;padding:0 clamp(1rem,4vw,2rem)}
.mn-sec-h h2{font-family:var(--font-display);font-weight:900;font-size:clamp(1.5rem,4vw,2.4rem);color:var(--text);margin:0}
.mn-sec-h .num{font-family:var(--font-display);font-weight:900;color:transparent;-webkit-text-stroke:1.4px var(--accent);font-size:clamp(1.4rem,3.6vw,2.2rem)}
.mn-wrap{max-width:var(--maxw);margin:0 auto;padding:0 clamp(1rem,4vw,2rem)}
/* Refinery methods */
.rf-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:.7rem}
.rf-card{border:1px solid var(--line);border-top:2px solid var(--accent-2);background:var(--surface);border-radius:2px;padding:.85rem .9rem}
.rf-card h3{font-family:var(--font-display);font-weight:800;color:var(--text);font-size:1.02rem;margin:0 0 .1rem}
.rf-code{font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.6rem;color:var(--muted)}
.rf-rows{margin-top:.6rem;display:flex;flex-direction:column;gap:.28rem}
.rf-row{display:flex;justify-content:space-between;align-items:center;font-size:.8rem;color:var(--muted);font-family:var(--font-ui)}
.rf-row b{color:var(--text);font-weight:600}
.pips{display:inline-flex;gap:3px;vertical-align:middle}
.pips i{width:8px;height:8px;border-radius:50%;background:var(--line-soft);display:inline-block}
.pips i.on{background:var(--accent)}
.pips.cost i.on{background:var(--accent-2)}
/* Ships */
.sh-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:.8rem}
.sh-card{border:1px solid var(--line);background:var(--surface);border-radius:4px;overflow:hidden;display:flex;flex-direction:column;color:inherit;text-decoration:none;transition:border-color .15s,transform .1s}
.sh-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.sh-link{margin-top:.2rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.06em;text-transform:uppercase;font-size:.66rem;color:var(--accent)}
.sh-photo{height:120px;background-size:cover;background-position:center;background-color:var(--surface-2);border-bottom:1px solid var(--line)}
.sh-icon{height:120px;display:flex;align-items:center;justify-content:center;font-size:2.4rem;color:var(--accent);background:linear-gradient(135deg,var(--surface-2),var(--surface));border-bottom:1px solid var(--line)}
.sh-body{padding:.85rem .9rem;display:flex;flex-direction:column;gap:.35rem}
.sh-role{font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.58rem;color:var(--accent-2)}
.sh-card h3{font-family:var(--font-display);font-weight:800;color:var(--text);font-size:1.06rem;margin:0}
.sh-meta{display:flex;gap:.9rem;font-size:.74rem;color:var(--muted);font-family:var(--font-ui)}
.sh-meta b{color:var(--text)}
.sh-note{font-size:.82rem;color:var(--muted);line-height:1.45}
.mn-cta{display:flex;align-items:center;gap:1rem;border:1px solid var(--line);border-left:3px solid var(--accent);background:linear-gradient(180deg,var(--surface),var(--bg-2));border-radius:4px;padding:1rem 1.2rem;text-decoration:none;color:inherit;transition:border-color .15s,box-shadow .15s}
.mn-cta:hover{border-color:var(--accent);box-shadow:var(--glow)}
.mn-cta__ico{flex:none;width:44px;height:44px;display:grid;place-items:center;color:var(--accent);border:1px solid var(--line);background:color-mix(in srgb,var(--accent) 10%,transparent);border-radius:3px}
.mn-cta__body{flex:1;min-width:0;display:flex;flex-direction:column;gap:.15rem}
.mn-cta__body b{font-family:var(--font-display);font-weight:800;color:var(--text);font-size:1.02rem}
.mn-cta__body span{font-size:.85rem;color:var(--muted);line-height:1.45}
.mn-cta__go{flex:none;font-family:var(--font-ui);font-weight:700;letter-spacing:.06em;text-transform:uppercase;font-size:.72rem;color:var(--accent);white-space:nowrap}
@media(max-width:560px){.mn-cta{flex-wrap:wrap}.mn-cta__go{width:100%;text-align:right}}</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/de/archiv.html' }, { label: "Mining" }]} hasEn={true} />

<main id="main">
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/img-mole.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <script is:inline>if(location.search.indexOf('nofx')>-1){document.documentElement.style.setProperty('scroll-behavior','auto');var c=document.getElementById('stars');if(c)c.remove();}</script>
    <div class="hero__in">
      <div class="eyebrow">Alpha {verShort} · Live-Daten</div>
      <h1>Mining</h1>
      <p class="lead">Minerale, Fundorte, Signaturen, Refinery &amp; Fracturing — game-genau, durchsuchbar.</p>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <TopicFacts topicSlug="mining" dataVersion={verShort} />

  <div class="mn-sec-h reveal" id="db"><span class="num">01</span><h2>Mineral-Datenbank</h2></div>

  <MiningApp lang="de" />

  <div class="mn-sec-h reveal" id="signatures"><span class="num">02</span><h2>Scan-Signatur-Identifier</h2></div>

  <SignatureIdentifier lang="de" />

  <div class="mn-sec-h reveal" id="fracturing"><span class="num">03</span><h2>Fracturing-Rechner</h2></div>

  <FracturingCalc lang="de" />

  <div class="mn-sec-h reveal" id="refinery"><span class="num">04</span><h2>Refinery Finder</h2></div>
  <RefineryFinder lang="de" />
  <div class="mn-wrap reveal" style="margin-top:1.2rem">
    <a class="mn-cta" href="/de/refinery.html">
      <span class="mn-cta__ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M10 3v5.5L4.6 19A1.4 1.4 0 0 0 5.8 21h12.4a1.4 1.4 0 0 0 1.2-2L14 8.5V3"/><path d="M7.5 15h9"/></svg></span>
      <span class="mn-cta__body">
        <b>Refinery Dashboard</b>
        <span>Verfolge deine echten Refinery-Aufträge — Station, Methode, Live-Countdown &amp; Erlös, in deinem Konto gespeichert.</span>
      </span>
      <span class="mn-cta__go">Öffnen →</span>
    </a>
    <a class="mn-cta" href="/de/precision-jump.html" style="margin-top:.7rem">
      <span class="mn-cta__ico" aria-hidden="true"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="M12 1.5v3M12 19.5v3M1.5 12h3M19.5 12h3"/><circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none"/></svg></span>
      <span class="mn-cta__body">
        <b>Precision Jump — Aaron-Halo-Routenrechner</b>
        <span>Plotte die Quantum-Travel-Linie zwischen zwei Markern und erhalte die exakte Ausstiegs-Koordinate für das Asteroidenband, das du abbauen willst.</span>
      </span>
      <span class="mn-cta__go">Öffnen →</span>
    </a>
  </div>

  <div class="mn-sec-h reveal" id="ships"><span class="num">05</span><h2>Mining-Schiffe</h2></div>
  <div class="mn-wrap">
    <div class="sh-grid reveal">
      {ships.map((s) => (
        <a class="sh-card" href={s.href}>
          {s.img ? (<div class="sh-photo" style={`background-image:url('${s.img}')`}></div>) : (<div class="sh-icon">⛏</div>)}
          <div class="sh-body">
            <span class="sh-role">{s.role}</span>
            <h3>{s.name}</h3>
            <div class="sh-meta">{s.ore && (<span>Erz-Fracht <b>{s.ore}</b></span>)}<span>Crew <b>{s.crew}</b></span></div>
            <span class="sh-link">Datenblatt →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</main>

<RelatedTopics topicSlug="mining" />
<Attribution sources={[]} updated={snap} />

<script is:inline src="/assets/detail.js"></script>
</Layout>
