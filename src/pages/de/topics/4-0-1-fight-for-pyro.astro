---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import TopicFacts from '../../../components/TopicFacts.astro';
import RelatedTopics from '../../../components/RelatedTopics.astro';
import Attribution from '../../../components/Attribution.astro';
---
<Layout title={"Fight for Pyro — Star Citizen 4.0.1 | VerseBase"} description={"Fight for Pyro: Kapitel 2 der Save-Stanton-Kampagne. Schwöre dich dauerhaft einer von drei Fraktionen zu und entscheide, wem das gesetzlose Pyro gehört — eingeführt mit Alpha 4.0.1."} themeColor="#0c1320" ogType="article" ogImage="/assets/t-ffp-1.jpg" translated={true}>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>

/* 4.0.1 "Stabilität & Save Stanton II" — Konsolen-Blau (geerbt vom Patch) */
:root{--bg:#0c1320;--bg-2:#101a2b;--surface:#152237;--surface-2:#1c2d46;--accent:#36c5d8;--accent-2:#f0a32a;--hot:#36c5d8;--text:#e6f0fa;--muted:#8ba3bd;--line:rgba(54,197,216,.22);--line-soft:rgba(230,240,250,.10);--glow:0 0 44px rgba(54,197,216,.30);--ink:#0c1320;--maxw:1180px;}
/* page-local accents */
.hero h1{font-size:clamp(3.2rem,13vw,10rem)}
.trio{display:grid;grid-template-columns:repeat(3,1fr);gap:.9rem;max-width:var(--maxw);margin:0 auto}
@media(max-width:860px){.trio{grid-template-columns:1fr}}
.fcard{position:relative;overflow:hidden;border:1px solid var(--line);border-radius:10px;min-height:340px;display:flex;flex-direction:column;justify-content:flex-end;padding:1.5rem 1.4rem;isolation:isolate}
.fcard .fbg{position:absolute;inset:0;z-index:-2;background-size:cover;background-position:center;transition:transform .8s;filter:saturate(.9)}
.fcard:hover .fbg{transform:scale(1.07)}
.fcard::after{content:"";position:absolute;inset:0;z-index:-1;background:linear-gradient(0deg,rgba(8,12,20,.94),rgba(8,12,20,.55) 45%,rgba(8,12,20,.15))}
.fcard .fk{font-family:var(--font-ui);font-weight:700;letter-spacing:.22em;text-transform:uppercase;font-size:.68rem;color:var(--accent-2)}
.fcard h3{font-family:var(--font-display);font-weight:800;font-size:clamp(1.2rem,2.2vw,1.6rem);line-height:1.05;color:#fff;margin:.35rem 0 .5rem}
.fcard p{color:var(--text);font-size:.95rem;opacity:.92}
.fcard .ftag{margin-top:.8rem;display:inline-flex;align-self:flex-start;font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.66rem;padding:.3rem .7rem;border:1px solid var(--line);border-radius:50px;color:var(--accent)}
.reward{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:1.1rem}
.reward .chip{font-family:var(--font-ui);font-weight:600;font-size:.82rem;color:var(--text);padding:.45rem .85rem;border:1px solid var(--line);border-radius:6px;background:rgba(0,0,0,.35)}
.reward .chip b{color:var(--accent-2)}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/de/archiv.html' }, { label: 'Alpha 4.0.1', href: '/de/patches/sc-4-0-1.html' }, { label: "Fight for Pyro" }]} pill={"EVENT · ALPHA 4.0.1"} hasEn={true} />


<main id="main">

  <!-- HERO (full-bleed lead media) -->
  <section class="hero">
    <div class="hero__photo" data-par="0.10" style="background-image:url('/assets/t-ffp-1.jpg')" aria-hidden="true"></div>
    <canvas id="stars" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow"><a href="/de/patches/sc-4-0-1.html">Alpha 4.0.1 · Save Stanton II</a> &nbsp;·&nbsp; Dynamisches Event</div>
      <h1><span class="thin">Save Stanton · Kapitel 2</span>Fight for Pyro</h1>
      <p class="lead">Der Krieg verlagert sich nach Pyro: in Kapitel 2 der Save-Stanton-Kampagne schwörst du dich dauerhaft einer von drei Fraktionen zu und entscheidest mit, wem das gesetzlose System gehört.</p>
      <div class="tags"><span class="tag hot">Dynamisches Event</span><span class="tag">3 Fraktionen</span><span class="tag">Permanente Wahl</span><span class="tag">Ripper SMG</span><span class="tag">Pyro</span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scrollen ↓</div>
  </section>

  <!-- MARQUEE -->
  <div class="dmarquee" aria-hidden="true">
    <div class="dmtrack">
      <span>FIGHT FOR PYRO</span><span class="dot">◆</span><span>SAVE STANTON</span><span class="dot">◆</span><span>CITIZENS FOR PROSPERITY</span><span class="dot">◆</span><span>HEADHUNTERS</span><span class="dot">◆</span><span>FRONTIER FIGHTERS</span><span class="dot">◆</span><span>RIPPER SMG</span><span class="dot">◆</span>
      <span>FIGHT FOR PYRO</span><span class="dot">◆</span><span>SAVE STANTON</span><span class="dot">◆</span><span>CITIZENS FOR PROSPERITY</span><span class="dot">◆</span><span>HEADHUNTERS</span><span class="dot">◆</span><span>FRONTIER FIGHTERS</span><span class="dot">◆</span><span>RIPPER SMG</span><span class="dot">◆</span>
    </div>
  </div>

  <!-- AUF EINEN BLICK (Daten-Register, uniform) -->
  <TopicFacts topicSlug="4-0-1-fight-for-pyro" />

  <!-- FULL-BLEED BAND — der Krieg zieht nach Pyro -->
  <section class="band">
    <div class="bbg" data-par="0.14" style="background-image:url('/assets/t-pyro-4.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">Kapitel 2 · Der Krieg zieht weiter</div>
      <div class="big outline">NACH PYRO.</div>
      <p>Nach dem Angriff auf Stanton folgt die Handlung dem Konflikt ins gesetzlose <b style="color:var(--accent-2)">Pyro</b>. Wo kein Recht gilt, ringen drei Fraktionen um Kontrolle — und du entscheidest mit, auf welcher Seite du stehst.</p>
    </div>
  </section>

  <!-- STAT STRIP (animated counters) -->
  <div class="statstrip reveal">
    <div class="s"><div class="n count" data-to="2">0</div><div class="c">Kapitel der Save-Stanton-Kampagne</div></div>
    <div class="s"><div class="n count" data-to="3">0</div><div class="c">Fraktionen zur Auswahl</div></div>
    <div class="s"><div class="n count" data-to="1">0</div><div class="c">Wahl · und sie ist endgültig</div></div>
    <div class="s"><div class="n">Pyro</div><div class="c">Schauplatz · gesetzloses System</div></div>
  </div>

  <!-- DREI FRAKTIONEN (image-backed trio, design on top) -->
  <section>
    <div class="wrap"><div class="sec-head reveal"><span class="num">01</span><h2>Wähle deine Seite</h2><span class="rule"></span></div>
      <p class="lead-p reveal" style="margin-bottom:1.6rem">Drei Fraktionen kämpfen um Pyro. Mit deiner ersten Mission bekennst du Farbe — danach sind deine Missionen reputationsgebunden.</p>
    </div>
    <div class="trio reveal">
      <div class="fcard">
        <div class="fbg" style="background-image:url('/assets/cz-facility.jpg')"></div>
        <div class="fk">Fraktion 01</div>
        <h3>Citizens for Prosperity</h3>
        <p>Kämpfe für ein Pyro, das mehr sein will als Chaos — Ordnung und Wohlstand im gesetzlosen System.</p>
        <span class="ftag">Reputationsgebunden</span>
      </div>
      <div class="fcard">
        <div class="fbg" style="background-image:url('/assets/cz-combat.jpg')"></div>
        <div class="fk">Fraktion 02</div>
        <h3>Headhunters</h3>
        <p>Kopfgeld, Stahl und harte Hand: stell dich auf die Seite derer, die in Pyro nach eigenen Regeln jagen.</p>
        <span class="ftag">Reputationsgebunden</span>
      </div>
      <div class="fcard">
        <div class="fbg" style="background-image:url('/assets/t-ffp-2.jpg')"></div>
        <div class="fk">Fraktion 03</div>
        <h3>Frontier Fighters</h3>
        <p>Die freie Grenze verteidigen — für jene, die Pyro als letzte unabhängige Front begreifen.</p>
        <span class="ftag">Reputationsgebunden</span>
      </div>
    </div>
  </section>

  <!-- SCROLLYTELLING — so legst du dich fest (process) -->
  <section style="padding-bottom:0">
    <div class="wrap"><div class="sec-head reveal"><span class="num">02</span><h2>So legst du dich fest</h2><span class="rule"></span></div></div>
  </section>
  <div class="scrolly">
    <div class="scrolly__media" aria-hidden="true">
      <div class="frame active" style="background-image:url('/assets/t-pyro-4.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-combat.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/cz-facility.jpg')"></div>
      <div class="frame" style="background-image:url('/assets/t-pyro-3.jpg')"></div>
    </div>
    <div class="scrolly__steps">
      <div class="sstep"><div class="sn">01</div><h3>Nach Pyro</h3><p>Folge der Save-Stanton-Kampagne in Kapitel 2 ins gesetzlose Pyro-System, wo der Konflikt um die Vorherrschaft entbrannt ist.</p></div>
      <div class="sstep"><div class="sn">02</div><h3>Die erste Mission</h3><p>Citizens for Prosperity, Headhunters oder Frontier Fighters: deine erste Mission entscheidet, für wen du in Pyro kämpfst.</p></div>
      <div class="sstep"><div class="sn">03</div><h3>Festgelegt</h3><p>Nach der ersten Mission ist die Wahl dauerhaft. Es gibt kein Zurück — ab jetzt sind alle Missionen an die Reputation deiner Fraktion gebunden.</p></div>
      <div class="sstep"><div class="sn">04</div><h3>Bis zum Abschluss</h3><p>Arbeite die Kette deiner Fraktion ab und schließe Fight for Pyro ab — der Zeitpunkt entscheidet über deine Belohnung.</p></div>
    </div>
  </div>

  <!-- MANIFESTO pull-quote -->
  <section class="manifesto reveal" style="padding-inline:clamp(1.25rem,5vw,4rem)">
    <blockquote>Eine Mission. Eine Fraktion. <span class="hl">Keine zweite Wahl.</span></blockquote>
    <cite>Fight for Pyro · Save Stanton Kapitel 2</cite>
  </section>

  <!-- SPLIT (the ONE framed section) — permanente Wahl -->
  <section style="padding-bottom:0">
    <div class="split reveal">
      <div class="split__media"><div class="m" style="background-image:url('/assets/t-pyro-5.jpg')"></div></div>
      <div class="split__text">
        <div class="kx">03 · Permanente Wahl</div>
        <h3>Eine Entscheidung, die bleibt</h3>
        <p>Anders als bei vielen Events ist deine Fraktionswahl in Fight for Pyro <b>dauerhaft</b>: Sobald die erste Mission abgeschlossen ist, bist du festgelegt. Es gibt keinen Wechsel mehr zur Gegenseite.</p>
        <p>Von da an sind deine Missionen <b>reputationsgebunden</b> — du verdienst dir das Vertrauen deiner Fraktion und kämpfst ihre Schlachten bis zum Ende der Kampagne.</p>
      </div>
    </div>
  </section>

  <!-- FULL-BLEED BAND — Belohnungen / Ripper SMG -->
  <section class="band band--right">
    <div class="bbg" data-par="0.12" style="background-image:url('/assets/t-ffp-2.jpg')" aria-hidden="true"></div>
    <div class="band__in reveal">
      <div class="kx">04 · Was du verdienst</div>
      <div class="big outline" style="font-size:clamp(2.4rem,8vw,6rem)">RIPPER SMG</div>
      <p>Wer Fight for Pyro <b style="color:var(--accent-2)">vor dem Start von 4.0.2</b> abschloss, sicherte sich die exklusive Pyro-Ripper-SMG — eine Belohnung nur für jene, die rechtzeitig für ihre Fraktion kämpften.</p>
      <div class="reward">
        <span class="chip"><b>Exklusiv</b> · Pyro-Ripper-SMG</span>
        <span class="chip">nur vor Start von <b>4.0.2</b></span>
      </div>
    </div>
  </section>

  <!-- LACKIERUNGEN (data over surface, no image card) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">05</span><h2>Fraktions-Lackierungen</h2><span class="rule"></span></div>
      <p class="lead-p reveal">Wer <b>Save Stanton Kapitel 1</b> <i>und</i> <b>Fight for Pyro Kapitel 2</b> abschloss, verdiente sich fraktionsspezifische Schiffs-Lackierungen — Farben, die zeigen, für wen du in Pyro gekämpft hast.</p>
      <div class="reward reveal" style="margin-top:1.4rem">
        <span class="chip">Anvil <b>C8R Pisces</b></span>
        <span class="chip">Anvil <b>Carrack</b></span>
        <span class="chip">Drake <b>Cutter</b></span>
        <span class="chip">RSI <b>Zeus Mk II</b></span>
      </div>
    </div>
  </section>

  <!-- CLOSING — mixed full-bleed gallery (no official video) -->
  <section>
    <div class="wrap">
      <div class="sec-head reveal"><span class="num">06</span><h2>Bildergalerie</h2><span class="rule"></span></div>
      <div class="gallery reveal">
        <figure class="gtile full b2" data-lb="img:/assets/t-ffp-1.jpg"><img src="/assets/t-ffp-1.jpg" alt="Fight for Pyro — Kampf um Pyro" loading="lazy"><span class="zoomic">⤢</span><figcaption>Fight for Pyro</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-pyro-7.jpg"><img src="/assets/t-pyro-7.jpg" alt="Patch City — Outlaw-Station in Pyros Asteroidenfeld" loading="lazy"><span class="zoomic">⤢</span><figcaption>Patch City · Outlaw-Hafen</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/t-ruin-1.jpg"><img src="/assets/t-ruin-1.jpg" alt="Ruin Station vor dem Planeten Terminus" loading="lazy"><span class="zoomic">⤢</span><figcaption>Ruin Station · Terminus</figcaption></figure>
        <figure class="gtile" data-lb="img:/assets/img-cutlass.jpg"><img src="/assets/img-cutlass.jpg" alt="Drake Cutlass über Pyro" loading="lazy"><span class="zoomic">⤢</span><figcaption>Drake Cutlass</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/t-pyro-6.jpg"><img src="/assets/t-pyro-6.jpg" alt="Leuchtende Vegetation zwischen Felsnadeln auf einer Pyro-Welt" loading="lazy"><span class="zoomic">⤢</span><figcaption>Pyros Wildnis</figcaption></figure>
        <figure class="gtile w2" data-lb="img:/assets/trailer-4-0-0.jpg"><img src="/assets/trailer-4-0-0.jpg" alt="Destination Pyro" loading="lazy"><span class="zoomic">⤢</span><figcaption>Destination Pyro</figcaption></figure>
      </div>
      <p class="src reveal">Quelle: Star Citizen Wiki &amp; offizielle Community-Quellen (© Cloud Imperium Games). Bilder zu Illustrationszwecken.</p>
    </div>
  </section>

</main>

<RelatedTopics topicSlug="4-0-1-fight-for-pyro" />

<Attribution />

<div class="lb" id="lb" aria-hidden="true"><div class="lb__body"><button class="lb__x" aria-label="Schließen">✕</button><div class="lb__content"></div></div></div>

<script is:inline src="/assets/detail.js"></script>
</Layout>
