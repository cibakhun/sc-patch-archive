---
// Item-Datenblatt (DE) — /de/items/<id>.html
import ItemDetail from '../../../components/ItemDetail.astro';
import { pageItems } from '../../../lib/items';

export async function getStaticPaths() {
  return pageItems.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
---
<ItemDetail item={item} lang="de" />
