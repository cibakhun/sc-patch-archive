---
// Kategorie-Liste (DE) — /de/items/category/<cat>.html
import ItemListing from '../../../../components/ItemListing.astro';
import { categories, pageCount } from '../../../../lib/items';

export async function getStaticPaths() {
  return categories.flatMap((node) =>
    Array.from({ length: pageCount(node) }, (_, n) => n + 1).map((page) => ({
      params: { slug: page > 1 ? `${node.slug}-${page}` : node.slug },
      props: { node, page },
    }))
  );
}

const { node, page } = Astro.props;
---
<ItemListing node={node} page={page} lang="de" />
