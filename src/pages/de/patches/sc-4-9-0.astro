---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import QuickFacts from '../../../components/dossier/QuickFacts.astro';
import PatchDossier from '../../../components/dossier/PatchDossier.astro';
import PatchSeo from '../../../components/dossier/PatchSeo.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('patches', '4-9-0');
if (!entry) throw new Error('Patch-Daten 4-9-0 fehlen in src/data/patches/');
const patch = entry.data;
---
<Layout title={"Star Citizen Alpha 4.9.0 — Frontier Tensions | VerseBase"} description={"Alpha 4.9: People's-Alliance-Kontrakte um Recco Battaglia in Nyx, der Schrott-Jäger Grey's Market Basher, Hit-Marker mit sechs Trefferzuständen, +20 % Mining-Laserleistung — live seit 15. Juli 2026."} themeColor="#140f0c" ogType="article" ogImage="/assets/trailer-4-9-0.jpg" translated={true}>
<PatchSeo patch={patch} image="/assets/trailer-4-9-0.jpg" />
<style is:inline>

/* 4.9.0 "Frontier Tensions" — media-first / low-text / Rust-Frontier
   Design-Welt: Nyx-Staub, Alliance-Zinnober, Schrott-Manifest-Mono */
:root{
  --bg:#140f0c;--bg-2:#1b1410;--surface:#241a14;--surface-2:#2e211a;
  --accent:#e94f3d;--accent-2:#e3aa4b;--hot:#e94f3d;
  --text:#f2ece4;--muted:#b3a698;
  --line:rgba(233,79,61,.24);--line-soft:rgba(242,236,228,.10);
  --glow:0 0 44px rgba(233,79,61,.28);
  --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;--font-mono:'Share Tech Mono',monospace;
  --maxw:1280px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
::selection{background:var(--accent);color:#140f0c}
:focus-visible{outline:2px solid var(--accent-2);outline-offset:3px}
.skip{position:absolute;left:-999px;top:0;z-index:200;background:var(--accent);color:#140f0c;padding:.6rem 1rem;font-family:var(--font-ui);font-weight:700}.skip:focus{left:0}

/* Effekt-Overlays: warme Vignette + feine Scanlines */
body::after{content:"";position:fixed;inset:0;z-index:9000;pointer-events:none;background:radial-gradient(130% 115% at 50% 42%,transparent 54%,rgba(10,4,2,.62) 100%),repeating-linear-gradient(0deg,rgba(0,0,0,.13) 0 1px,transparent 1px 3px);opacity:.5}
.cursorglow{position:fixed;inset:0;z-index:8800;pointer-events:none;background:radial-gradient(440px circle at var(--mx,50%) var(--my,28%),rgba(233,79,61,.12),transparent 60%)}

/* HERO */
.hero{position:relative;min-height:100svh;display:flex;flex-direction:column;justify-content:flex-end;padding:7rem clamp(1.25rem,5vw,4.5rem) 4rem;overflow:hidden}
.hero__photo{position:absolute;inset:0;z-index:0;background:url('/assets/trailer-4-9-0.jpg') center/cover;animation:kb 30s ease-in-out infinite alternate}
@keyframes kb{from{transform:scale(1.06)}to{transform:scale(1.18) translate(-1.5%,-1.5%)}}
.hero__photo::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(16,8,4,.30),rgba(16,8,4,.55) 55%,var(--bg)),radial-gradient(120% 90% at 80% 20%,transparent,var(--bg) 88%)}
#dust{position:absolute;inset:0;z-index:1;opacity:.5}
.hero__in{position:relative;z-index:2;max-width:var(--maxw);margin:0 auto;width:100%}
.eyebrow{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;font-size:.8rem;color:var(--accent-2)}
.hero h1{position:relative;font-family:var(--font-display);font-weight:900;line-height:.82;letter-spacing:-.02em;margin:.6rem 0 .1rem;font-size:clamp(4.5rem,22vw,18rem);
  background:linear-gradient(180deg,#fff,var(--accent) 75%,#5e1710);-webkit-background-clip:text;background-clip:text;color:transparent;filter:drop-shadow(0 0 36px rgba(233,79,61,.45));animation:flick 8s steps(1) infinite}
@keyframes flick{0%,92%,100%{opacity:1}93%{opacity:.55}94%{opacity:1}96%{opacity:.8}97%{opacity:1}}
.hero h1::after{content:attr(data-text);position:absolute;left:3px;top:0;-webkit-text-fill-color:var(--accent-2);color:var(--accent-2);opacity:0;mix-blend-mode:screen;animation:rgbs 8s steps(1) infinite}
@keyframes rgbs{0%,92%,100%{opacity:0;transform:translate(0,0)}93%{opacity:.6;transform:translate(-4px,2px)}95%{opacity:0}}
.hero .codename{font-family:var(--font-display);font-weight:700;font-size:clamp(1.3rem,4vw,2.6rem);color:#fff}
.hero .codename span{color:var(--accent-2)}
.hero .tagline{font-family:var(--font-ui);font-weight:600;font-size:clamp(1rem,2vw,1.4rem);color:var(--accent);letter-spacing:.02em;margin-top:.7rem}
.tags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1.4rem}
.tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.08em;text-transform:uppercase;font-size:.74rem;padding:.4rem .8rem;border:1px solid var(--line);border-radius:50px;background:rgba(10,4,2,.45);color:var(--text)}
.tag.hot{border-color:rgba(233,79,61,.55);color:#ffa08f}
.scrollcue{position:absolute;bottom:1.3rem;left:50%;transform:translateX(-50%);z-index:2;font-family:var(--font-ui);letter-spacing:.2em;text-transform:uppercase;font-size:.7rem;color:var(--muted);animation:bob 2s ease-in-out infinite}
@keyframes bob{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,7px)}}

/* Marquee */
.marquee{overflow:hidden;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:linear-gradient(90deg,var(--bg-2),var(--surface),var(--bg-2));padding:.8rem 0}
.mtrack{display:flex;gap:2.4rem;white-space:nowrap;width:max-content;animation:scrollx 32s linear infinite;font-family:var(--font-display);font-weight:700;font-size:1.05rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent)}
.mtrack .dot{color:var(--accent-2)}
@keyframes scrollx{to{transform:translateX(-50%)}}

/* Section */
section{position:relative;padding:clamp(3rem,7vw,6rem) clamp(1.25rem,5vw,4.5rem)}
.wrap{max-width:var(--maxw);margin:0 auto}
.sec-head{display:flex;align-items:center;gap:1rem;margin-bottom:2rem}
.sec-head .num{font-family:var(--font-display);font-weight:900;font-size:.95rem;color:var(--accent);opacity:.8}
.sec-head h2{font-family:var(--font-display);font-weight:700;font-size:clamp(1.4rem,3.5vw,2.3rem)}
.sec-head .rule{flex:1;height:1px;background:var(--line)}

/* BENTO */
.bento{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:185px;gap:.8rem}
@media(max-width:820px){.bento{grid-template-columns:repeat(2,1fr)}}
.tile{position:relative;border:1px solid var(--line);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;padding:1.2rem}
.tile .tbg{position:absolute;inset:0;z-index:0;background-size:cover;background-position:center;transition:transform .9s ease}
.tile:hover .tbg{transform:scale(1.09)}
.tile.img::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(0deg,rgba(10,4,2,.9),rgba(10,4,2,.1) 65%)}
.tile>*{position:relative;z-index:2}
.tile .lbl{font-family:var(--font-ui);font-weight:700;letter-spacing:.04em;font-size:1rem;text-shadow:0 1px 8px #000}
.tile .sub{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.12em;font-size:.68rem;color:var(--accent-2);margin-top:.2rem}
.tile.word{background:linear-gradient(140deg,var(--surface),var(--bg-2));justify-content:center}
.tile.word b{font-family:var(--font-display);font-weight:900;font-size:clamp(1.35rem,2.4vw,2.1rem);line-height:.95;color:var(--accent)}
.tile.word.hot b{color:#ffa08f}
.tile.word small{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.12em;font-size:.7rem;color:var(--muted);margin-top:.5rem}
.tile.stat{background:linear-gradient(140deg,var(--surface-2),var(--bg-2));align-items:center;justify-content:center;text-align:center}
.tile.stat .num{font-family:var(--font-display);font-weight:900;font-size:clamp(2.2rem,5vw,3.6rem);color:var(--accent);line-height:1}
.tile.stat .cap{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.14em;font-size:.7rem;color:var(--muted);margin-top:.5rem}
.w2{grid-column:span 2}.h2{grid-row:span 2}.b2{grid-column:span 2;grid-row:span 2}
@media(max-width:820px){.b2{grid-column:span 2}.h2{grid-row:span 1}}

/* SHOT */
.shot{position:relative;min-height:90vh;display:flex;align-items:flex-end;padding:clamp(2.5rem,7vw,7rem) clamp(1.25rem,5vw,4.5rem);overflow:hidden}
.shot .sbg{position:absolute;inset:0;z-index:0;background-size:cover;background-position:center;animation:kb2 26s ease-in-out infinite alternate}
@keyframes kb2{from{transform:scale(1.08)}to{transform:scale(1.24) translate(-3%,-2%)}}
.shot::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(10,4,2,.15),rgba(10,4,2,.5) 60%,var(--bg)),linear-gradient(90deg,rgba(10,4,2,.6),transparent 55%)}
.shot__in{position:relative;z-index:2;max-width:var(--maxw);margin:0 auto;width:100%}
.shot .kx{font-family:var(--font-ui);font-weight:700;letter-spacing:.32em;text-transform:uppercase;color:var(--accent-2);font-size:.82rem}
.shot .big{font-family:var(--font-display);font-weight:900;font-size:clamp(3rem,15vw,11.5rem);line-height:.8;color:#fff;text-shadow:0 6px 70px rgba(0,0,0,.8),0 0 50px rgba(233,79,61,.26);overflow-wrap:normal;text-wrap:balance}
.shot p{max-width:48ch;color:#f6efe6;font-size:clamp(1rem,1.6vw,1.25rem);margin-top:.6rem;text-shadow:0 2px 14px #000}

/* CONTRACT BOARD — Alliance-Aushang (Signatur-Element dieser Seite) */
.cbnote{max-width:64ch;color:var(--muted);font-size:.98rem;line-height:1.55;margin-bottom:1.4rem}
.cbnote b{color:#ffa08f}
.cboard{display:grid;grid-template-columns:repeat(auto-fit,minmax(255px,1fr));gap:.8rem}
.contract{position:relative;background:var(--surface);border:1px solid var(--line-soft);border-top:2px solid var(--accent-2);padding:1.05rem 1.15rem .95rem;clip-path:polygon(0 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%)}
.contract::before{content:"";position:absolute;top:0;right:0;width:34px;height:34px;background:repeating-linear-gradient(-45deg,rgba(227,170,75,.5) 0 5px,transparent 5px 10px);clip-path:polygon(100% 0,0 0,100% 100%);opacity:.5}
.contract .cid{font-family:var(--font-mono);font-size:.72rem;letter-spacing:.14em;color:var(--accent-2);text-transform:uppercase}
.contract b{display:block;font-family:var(--font-ui);font-weight:700;font-size:1.12rem;color:var(--text);margin:.35rem 0 .25rem}
.contract small{display:block;color:var(--muted);font-size:.88rem;line-height:1.5}
.contract.rep{grid-column:1/-1;border-top-color:var(--accent);background:linear-gradient(140deg,var(--surface-2),var(--bg-2))}
.contract.rep b{color:#ffa08f}
.chips{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:.7rem}
.chip{font-family:var(--font-mono);font-size:.74rem;letter-spacing:.06em;color:var(--text);border:1px solid rgba(227,170,75,.4);padding:.28rem .6rem;border-radius:2px;background:rgba(10,4,2,.35)}

/* BASHER — Schrott-Manifest + Spec-Readout */
.basher{display:grid;grid-template-columns:1.15fr .85fr;gap:.9rem}
@media(max-width:900px){.basher{grid-template-columns:1fr}}
.panel{background:var(--surface);border:1px solid var(--line-soft);padding:1.15rem 1.3rem;clip-path:polygon(10px 0,100% 0,100% calc(100% - 10px),calc(100% - 10px) 100%,0 100%,0 10px)}
.panel .phead{display:flex;align-items:baseline;justify-content:space-between;gap:.8rem;border-bottom:1px solid var(--line);padding-bottom:.5rem;margin-bottom:.75rem}
.panel .phead h3{font-family:var(--font-ui);font-weight:700;font-size:1.05rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text)}
.panel .phead .pc{font-family:var(--font-mono);font-size:.7rem;letter-spacing:.12em;color:var(--accent-2);text-transform:uppercase}
.manifest{list-style:none;display:grid;gap:.45rem;font-family:var(--font-mono);font-size:.92rem}
.manifest li{display:flex;gap:.7rem;align-items:baseline;border-left:2px solid rgba(227,170,75,.35);padding:.3rem 0 .3rem .7rem;color:var(--text)}
.manifest .mk{color:var(--accent-2);flex:none;font-size:.78rem;letter-spacing:.1em}
.manifest small{color:var(--muted);font-family:var(--font-body);font-size:.85rem}
.readout{display:grid;gap:.4rem;font-family:var(--font-mono);font-size:.92rem}
.readout .row{display:flex;align-items:baseline;gap:.6rem}
.readout dt{color:var(--muted);font-size:.74rem;letter-spacing:.12em;text-transform:uppercase;flex:none}
.readout .lead{flex:1;border-bottom:1px dotted rgba(242,236,228,.25);transform:translateY(-3px)}
.readout dd{color:var(--text);text-align:right}
.readout dd em{color:var(--accent-2);font-style:normal}
.bvid{position:relative;grid-column:1/-1;aspect-ratio:21/8;border:1px solid var(--line);border-radius:10px;overflow:hidden;background:center/cover no-repeat;cursor:pointer}
@media(max-width:900px){.bvid{aspect-ratio:16/9}}
.bvid::after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,rgba(10,4,2,.65),transparent 55%)}
.bvid .play{position:absolute;inset:0;margin:auto;width:74px;height:74px;z-index:2;border:0;border-radius:50%;background:rgba(10,4,2,.55);color:#fff;font-size:26px;cursor:pointer;display:grid;place-items:center;transition:transform .2s,background .2s;backdrop-filter:blur(2px)}
.bvid:hover .play{transform:scale(1.12);background:var(--accent);color:#140f0c}
.bvid .vlbl{position:absolute;left:14px;bottom:12px;z-index:2;font-family:var(--font-ui);font-weight:700;font-size:.9rem;color:#fff;text-shadow:0 1px 8px #000}

/* HIT MARKERS — Reticle-Zustandsleiste */
.hmnote{max-width:64ch;color:var(--muted);font-size:.98rem;line-height:1.55;margin-bottom:1.4rem}
.hmnote b{color:#ffa08f}
.hms{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.8rem}
.hm{display:flex;flex-direction:column;align-items:center;text-align:center;gap:.6rem;background:var(--surface);border:1px solid var(--line-soft);border-radius:10px;padding:1.1rem .8rem .95rem;transition:border-color .15s,background-color .15s}
.hm:hover{border-color:var(--line);background:var(--surface-2)}
.hm svg{width:56px;height:56px;flex:none}
.hm b{font-family:var(--font-ui);font-weight:700;font-size:.98rem;letter-spacing:.04em}
.hm small{color:var(--muted);font-size:.8rem;line-height:1.4}
.hmaudio{margin-top:1rem;font-family:var(--font-mono);font-size:.82rem;letter-spacing:.04em;color:var(--muted);border:1px dashed rgba(227,170,75,.4);padding:.7rem .9rem}
.hmaudio b{color:var(--accent-2);font-weight:400}
.hmsrc{margin-top:.6rem;font-family:var(--font-mono);font-size:.72rem;letter-spacing:.04em;color:var(--muted);opacity:.75}

/* Video wall */
.vwall{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:1rem}
.video{position:relative;aspect-ratio:16/9;border:1px solid var(--line);border-radius:10px;overflow:hidden;background:#000 center/cover no-repeat;cursor:pointer}
.video::after{content:"";position:absolute;inset:0;background:linear-gradient(0deg,rgba(10,4,2,.6),transparent 55%);pointer-events:none}
.video iframe{position:absolute;inset:0;width:100%;height:100%;border:0;z-index:3}
.video .play{position:absolute;inset:0;margin:auto;width:74px;height:74px;z-index:2;border:0;border-radius:50%;background:rgba(10,4,2,.55);color:#fff;font-size:26px;cursor:pointer;display:grid;place-items:center;transition:transform .2s,background .2s;backdrop-filter:blur(2px)}
.video:hover .play{transform:scale(1.12);background:var(--accent);color:#140f0c}
.video .vlbl{position:absolute;left:14px;bottom:12px;z-index:2;font-family:var(--font-ui);font-weight:700;font-size:.9rem;color:#fff;text-shadow:0 1px 8px #000}
.vsrc{margin-top:1rem;font-size:.8rem;color:var(--muted)}.vsrc a{color:var(--accent);border-bottom:1px solid var(--line)}

/* Mosaic gallery */
.mosaic{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:160px;gap:.7rem}
@media(max-width:820px){.mosaic{grid-template-columns:repeat(2,1fr)}}
.mosaic figure{position:relative;margin:0;overflow:hidden;border-radius:10px;border:1px solid var(--line)}
.mosaic img{width:100%;height:100%;object-fit:cover;transition:transform .6s,filter .6s;filter:saturate(.92)}
.mosaic figure:hover img{transform:scale(1.1);filter:saturate(1.15)}
.mosaic figcaption{position:absolute;left:0;right:0;bottom:0;padding:.6rem .7rem;font-family:var(--font-ui);font-weight:600;font-size:.78rem;background:linear-gradient(0deg,rgba(10,4,2,.85),transparent)}

/* Footer */
footer{border-top:1px solid var(--line);background:var(--bg-2);padding:clamp(2.5rem,6vw,4rem) clamp(1.25rem,5vw,4.5rem) 3rem}
.pager{display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;max-width:var(--maxw);margin-inline:auto}
.pager>a,.pager>span{flex:1;min-width:min(200px,100%);display:flex;flex-direction:column;border:1px solid var(--line);border-radius:8px;padding:1.1rem 1.3rem;background:var(--surface);transition:border-color .2s,transform .2s}
.pager a:hover{border-color:var(--accent);transform:translateY(-2px)}
.pager .dir{font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.16em;font-size:.7rem;color:var(--muted)}
.pager .ttl{font-family:var(--font-display);font-weight:700;font-size:1rem;margin-top:.3rem;overflow-wrap:break-word}
.pager .next{text-align:right}
.pager .disabled{opacity:.35}
.foot-meta{max-width:var(--maxw);margin:0 auto;display:flex;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;font-size:.85rem;color:var(--muted)}
.foot-meta a{color:var(--accent)}
.home-link{font-family:var(--font-ui);font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.8rem}
.disclaimer{max-width:var(--maxw);margin:1.6rem auto 0;font-size:.72rem;color:var(--muted);opacity:.65;border-top:1px solid var(--line-soft);padding-top:1.2rem}

/* Klickbar-Affordance + Lightbox */
.tile.img,.tile.word,.tile.stat,.mosaic figure{cursor:pointer}
.zoomic{position:absolute;top:.7rem;right:.7rem;z-index:3;width:34px;height:34px;border-radius:50%;background:rgba(10,4,2,.55);border:1px solid var(--line);display:grid;place-items:center;font-size:.9rem;color:#fff;opacity:.55;transition:opacity .2s,background .2s,transform .2s}
.tile.img:hover .zoomic,.tile.word:hover .zoomic,.tile.stat:hover .zoomic,.mosaic figure:hover .zoomic{opacity:1;background:var(--accent);color:#140f0c;transform:scale(1.12)}
.lb{position:fixed;inset:0;z-index:9500;display:none;align-items:center;justify-content:center;background:rgba(8,3,1,.93);backdrop-filter:blur(5px);padding:3vh 3vw}
.lb.open{display:flex}
.lb__body{position:relative;max-width:1120px;width:100%}
.lb__body img{display:block;width:100%;height:auto;max-height:88vh;object-fit:contain;border:1px solid var(--line);border-radius:8px}
.lb__body .ratio{position:relative;aspect-ratio:16/9}
.lb__body .ratio iframe{position:absolute;inset:0;width:100%;height:100%;border:0;border-radius:8px}
.lb__x{position:absolute;top:-3.4rem;right:0;background:none;border:1px solid var(--line);color:#fff;width:46px;height:46px;border-radius:50%;font-size:1.2rem;cursor:pointer;transition:background .2s,color .2s}
.lb__x:hover{background:var(--accent);color:#140f0c}
.lb__info{background:var(--surface);border:1px solid var(--line);border-radius:8px;overflow:hidden;max-height:88vh;overflow-y:auto}
.lb__info img{display:block;width:100%;max-height:46vh;object-fit:cover}
.lb__txt{padding:1.4rem 1.7rem}
.lb__txt h3{font-family:var(--font-display);font-weight:800;font-size:1.4rem;color:var(--accent);margin-bottom:.5rem}
.lb__txt p{color:var(--text);font-size:1rem;line-height:1.6}
.reveal{opacity:0;transform:translateY(26px);transition:opacity .7s,transform .7s}.reveal.in{opacity:1;transform:none}
@media (prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none}*{animation:none!important}}

</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Archiv', href: '/de/archiv.html' }, { label: 'Alpha 4.9.0' }]} pill={"ALPHA 4.9.0"} hasEn={true} />

<main id="main">

  <!-- HERO -->
  <section class="hero">
    <div class="hero__photo" aria-hidden="true"></div>
    <canvas id="dust" aria-hidden="true"></canvas>
    <div class="hero__in">
      <div class="eyebrow">15. Juli 2026 · Major-Patch</div>
      <h1 data-text="4.9">4.9</h1>
      <div class="codename">Frontier<span>Tensions</span></div>
      <div class="tagline">Nyx unter Druck — die Alliance sucht Helfer</div>
      <div class="tags">
