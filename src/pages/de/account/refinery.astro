---
// Refinery-Dashboard — DE (/de/account/refinery.html). noindex: private Inhalte.
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import Attribution from '../../../components/Attribution.astro';
import AccountShell from '../../../components/account/AccountShell.astro';
import RefineryDashboard from '../../../components/account/RefineryDashboard.astro';
---
<Layout
  title={'Refinery-Dashboard | VerseBase'}
  description={'Verfolge deine Star-Citizen-Refinery-Aufträge — Station, Methode, Erze, Countdown und Erlös. An dein VerseBase-Konto gebunden.'}
  themeColor="#05070d"
  ogImage="/assets/og-default.jpg"
  translated={true}
  noindex={true}
>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>
:root{--bg:#05070d;--bg-2:#0a0e18;--surface:#0d1322;--surface-2:#131b30;--accent:#2dd4ff;--accent-2:#7ae2ff;--hot:#2dd4ff;--text:#e8eefc;--muted:#8a99b8;--line:rgba(45,212,255,.22);--line-soft:rgba(232,238,252,.10);--glow:0 0 46px rgba(45,212,255,.18);--ink:#04121a;--maxw:1180px;}
.reveal{opacity:1 !important;transform:none !important}
.hero__in{max-width:var(--maxw)}
.hero--acct{min-height:34svh}
.acwrap--wide .sec-head{margin-top:2.6rem}
</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Konto', href: '/de/account.html' }, { label: 'Refinery' }]} hasEn={true} />

<main id="main">
  <AccountShell
    eyebrow="VerseBase · Bergbau-Betrieb"
    titleThin="Refinery"
    title="Dashboard"
    lead="Verfolge jeden Refinery-Auftrag — Station, Methode, Erze, Live-Countdown und Erlös — an dein Konto gebunden."
    wide={true}
  >
    <RefineryDashboard lang="de" />
  </AccountShell>
</main>

<Attribution sources={[]} />

<script is:inline src="/assets/detail.js"></script>
</Layout>
