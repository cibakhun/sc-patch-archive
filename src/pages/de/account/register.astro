---
// Konto erstellen — DE-Spiegel von /account/register.html.
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import Attribution from '../../../components/Attribution.astro';
import AccountShell from '../../../components/account/AccountShell.astro';
import AuthRegister from '../../../components/account/AuthRegister.astro';
---
<Layout
  title={'Konto erstellen | VerseBase'}
  description={'Erstelle dein kostenloses VerseBase-Konto: Lieblingsschiffe aus Star Citizen merken und dein Profil verwalten.'}
  themeColor="#05070d"
  ogImage="/assets/og-default.jpg"
  translated={true}
>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>
:root{--bg:#05070d;--bg-2:#0a0e18;--surface:#0d1322;--surface-2:#131b30;--accent:#2dd4ff;--accent-2:#7ae2ff;--hot:#2dd4ff;--text:#e8eefc;--muted:#8a99b8;--line:rgba(45,212,255,.22);--line-soft:rgba(232,238,252,.10);--glow:0 0 46px rgba(45,212,255,.18);--ink:#04121a;--maxw:1180px;}
/* Hellmodus — erzeugt von scripts/build-light-palettes.mjs. Nicht von Hand ändern. */
:root[data-theme="light"]{--bg:#f4f7fe;--bg-2:#e9eef9;--surface:#fdfdff;--surface-2:#eef2fc;--text:#1b1f29;--muted:#4e586c;--accent:#05657c;--accent-2:#025f73;--hot:#065c71;--ink:#ffffff;--accent-media:#2dd4ff;--accent-2-media:#7ae2ff;--line:rgba(43,125,148,.3);--line-soft:rgba(41,46,56,.12);--glow:0 6px 22px rgba(43,125,148,.18)}

.reveal{opacity:1 !important;transform:none !important}
.hero__in{max-width:var(--maxw)}</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Konto', href: '/de/account.html' }, { label: 'Konto erstellen' }]} hasEn={true} />

<main id="main">
  <AccountShell
    eyebrow="VerseBase · Systemzugang"
    titleThin="Werde Teil der Basis"
    title="Konto erstellen"
    lead="Kostenlos und unverbindlich — Lieblingsschiffe markieren und dein Profil an einem Ort verwalten."
  >
    <AuthRegister lang="de" />
  </AccountShell>
</main>

<Attribution sources={[]} />

<script is:inline src="/assets/detail.js"></script>
</Layout>
