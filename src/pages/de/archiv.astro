---
// Patch-Archiv (DE). Der Seitenkörper liegt in PatchArchive.astro — identisch
// mit /archiv.astro, damit beide Sprachen nicht auseinanderlaufen.
import Layout from '../../layouts/Layout.astro';
import PatchArchive from '../../components/PatchArchive.astro';
import { getCollection } from 'astro:content';

const patches = await getCollection('patches');
const patchCount = patches.length;
const topicCount = patches.reduce((n, p) => n + p.data.topics.length, 0);
---

<Layout
  title="Star Citizen Patch-Archiv — Alpha 4.0 bis 4.9 | VerseBase"
  description={`Das komplette Star-Citizen-Patch-Archiv der Alpha-4-Ära: ${patchCount} Patches von Destination Pyro (4.0.0) bis Frontier Tensions (4.9.0), mit ${topicCount} Themen-Deep-Dives.`}
  themeColor="#05070d"
  footer={true}
  translated={true}
  ogImage="/assets/trailer-4-9-0.jpg"
>
  <link slot="head" rel="stylesheet" href="/assets/archive.css" />
  <PatchArchive />
</Layout>
