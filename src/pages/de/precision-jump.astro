---
// Precision Jump — Aaron-Halo-Routenrechner (DE, /de/precision-jump.html).
// Reines Client-Werkzeug (kein Konto), indexierbar. Navigations-HUD-Theme
// (Amber/Cyan). Open-Source-Einsendung von „Jordessey", auf den Site-Design-
// Kit portiert. EN-Pendant: /precision-jump.html.
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import Attribution from '../../components/Attribution.astro';
import PrecisionJumpApp from '../../components/PrecisionJumpApp.astro';
import { buildAnchorRecords, AH_BAND_INFO } from '../../data/precision-jump';

const anchorCount = buildAnchorRecords().length;
const bandCount = Object.keys(AH_BAND_INFO).length;
---
<Layout
  title={'Precision Jump — Aaron-Halo-Routenrechner · Star Citizen | VerseBase'}
  description={`Aaron-Halo-Routenrechner fürs Star-Citizen-Mining: plotte die Quantum-Travel-Linie zwischen zwei von ${anchorCount} QT-Ankern und erhalte die exakte Ausstiegs-Koordinate samt Bandfenster für jedes der ${bandCount} Halo-Dichtebänder. Kostenloses, zweisprachiges Navigations-Werkzeug.`}
  themeColor="#080a14"
  ogType="article"
  ogImage="/assets/og-default.jpg"
  translated={true}
>
<link slot="head" rel="stylesheet" href="/assets/detail.css" />
<style is:inline>
:root{--bg:#080a14;--bg-2:#0c1020;--surface:#111726;--surface-2:#18203a;--accent:#f5a623;--accent-2:#35d0ff;--hot:#ff5b6e;--text:#e8eefc;--muted:#8a97b5;--line:rgba(245,166,35,.20);--line-soft:rgba(232,238,252,.10);--glow:0 0 46px rgba(245,166,35,.24);--ink:#0a0d16;--maxw:1240px;}
.reveal{opacity:1 !important;transform:none !important}
.hero{min-height:74svh;background:radial-gradient(120% 90% at 82% 8%,rgba(245,166,35,.16),transparent 58%),radial-gradient(100% 90% at 10% 96%,rgba(53,208,255,.14),transparent 55%),var(--bg)}
.hero h1{font-size:clamp(2.6rem,11vw,7.6rem);background:linear-gradient(180deg,#fff,#ffd27f 56%,var(--accent));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;filter:drop-shadow(0 3px 20px rgba(0,0,0,.8)) drop-shadow(0 0 30px rgba(245,166,35,.4))}
.hero__in{max-width:var(--maxw)}
.pj-tag{font-family:var(--font-ui);font-weight:700;letter-spacing:.16em;text-transform:uppercase;font-size:.72rem;color:var(--accent-2)}
.qbar{display:flex;flex-wrap:wrap;gap:.5rem 1.4rem;margin-top:1.4rem;font-family:var(--font-ui);font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.74rem;color:var(--muted)}
.qbar b{color:var(--accent-2)}
</style>
<a class="skip" href="#main">Zum Inhalt springen</a>
<div class="cursorglow" aria-hidden="true"></div>

<SiteNav crumbs={[{ label: 'Mining', href: '/de/topics/mining.html' }, { label: 'Precision Jump' }]} hasEn={true} />

<main id="main">
  <section class="hero">
    <canvas id="stars" aria-hidden="true"></canvas>
    <script is:inline>if(location.search.indexOf('nofx')>-1){document.documentElement.style.setProperty('scroll-behavior','auto');var c=document.getElementById('stars');if(c)c.remove();}</script>
    <div class="hero__in">
      <div class="eyebrow"><a href="/de/topics/mining.html">Mining</a> &nbsp;·&nbsp; <span class="pj-tag">Aaron-Halo-Navigation</span></div>
      <h1><span class="thin">Aaron-Halo-Routenrechner</span>Precision Jump</h1>
      <p class="lead">Plotte die Quantum-Travel-Linie zwischen zwei Markern und erhalte die exakte Koordinate zum Aussteigen — direkt in das Asteroidenband, das du abbauen willst.</p>
      <div class="qbar"><span>QT-Anker <b>{anchorCount}</b></span><span>Halo-Bänder <b>{bandCount}</b></span><span>System <b>Stanton</b></span><span>Daten <b>Community-Vermessung</b></span></div>
    </div>
    <div class="scrollcue" aria-hidden="true">Scroll ↓</div>
  </section>

  <PrecisionJumpApp lang="de" />
</main>

<Attribution sources={["Jordessey (Werkzeug & Routendaten)", "cstone.space (Halo-Band-Vermessung)"]} credit="VerseBase · ein Star-Citizen-Fan-Projekt" />

<script is:inline src="/assets/detail.js"></script>
</Layout>
