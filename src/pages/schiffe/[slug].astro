---
// Ship data sheet (DE) — dünner Wrapper. Die gesamte Ansicht lebt jetzt in
// ../../components/ShipDetail.astro (geteilt mit der EN-Route unter /en/).
// getStaticPaths bleibt hier (baut alle 226 DE-Seiten wie bisher).
import { getCollection } from 'astro:content';
import ShipDetail from '../../components/ShipDetail.astro';
import { buildVisuals } from '../../lib/shipVisuals';
import { buildProfile, similarShips } from '../../lib/shipExtras';

export async function getStaticPaths() {
  const vs = await getCollection('vehicles');
  return vs.map((v) => ({
    params: { slug: v.id },
    props: {
      d: v.data,
      id: v.id,
      similar: similarShips(vs, v),
      profile: buildProfile(vs, v.data),
      viz: buildVisuals(vs, v.data),
    },
  }));
}

const { d, id, similar, profile, viz } = Astro.props;
// Stufe 2: jede Schiffseite hat jetzt ein EN-Gegenstück -> hreflang immer.
---
<ShipDetail d={d} id={id} similar={similar} profile={profile} viz={viz} lang="de" hasEn={true} />
