---
// Ship data sheet (EN, Standardsprache) — /schiffe/<slug>.html
// Stufe 2: baut ALLE Fahrzeuge auf Englisch (geteilte ShipDetail-Ansicht,
// lang="en"). Labels über die lang-fähige lib, Freitext über vehicles-en.json.
import { getCollection } from 'astro:content';
import ShipDetail from '../../components/ShipDetail.astro';
import { buildVisuals } from '../../lib/shipVisuals';
import { buildProfile, similarShips } from '../../lib/shipExtras';

export async function getStaticPaths() {
  const vs = await getCollection('vehicles');
  return vs.map((v) => ({
    params: { slug: v.id },
    props: {
      d: v.data,
      id: v.id,
      similar: similarShips(vs, v, 'en'),
      profile: buildProfile(vs, v.data, 'en'),
      viz: buildVisuals(vs, v.data, 'en'),
    },
  }));
}

const { d, id, similar, profile, viz } = Astro.props;
---
<ShipDetail d={d} id={id} similar={similar} profile={profile} viz={viz} lang="en" hasEn={true} />
