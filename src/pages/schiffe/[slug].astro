---
// Ship data sheet — holo stage (RSI-inspired) + trade panel (UEX in-game
// prices & buy locations) + REGISTRATUR spec dossier + patch spine + similar
// ships. Logic lives in src/lib — frontmatter stays thin (compiler gotcha).
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/SiteNav.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import vehiclesSnapshot from '../../data/vehicles.json';
import { buildFacts, buildGroups, buildArmament, crewFmt } from '../../lib/shipFacts';
import { pickHero } from '../../lib/shipRenders';
import { priceInfo, aUEC, pricesFetchedAt, similarShips } from '../../lib/shipExtras';
import type { SimilarShip } from '../../lib/shipExtras';

export async function getStaticPaths() {
  const vs = await getCollection('vehicles');
  return vs.map((v) => ({
    params: { slug: v.id },
    props: { d: v.data, id: v.id, similar: similarShips(vs, v) },
  }));
}

interface Props {
  d: CollectionEntry<'vehicles'>['data'];
  id: string;
  similar: SimilarShip[];
}
const { d, id, similar } = Astro.props;

const hero = pickHero(d);
const prices = priceInfo(id);
const buyMin = prices?.buy[0] ?? null;
const rentMin = prices?.rent[0] ?? null;
const MAX_ROWS = 6;

// patch-spine: version -> codename/page
const patches = await getCollection('patches');
const spine = d.patches
  .map((v) => patches.find((p) => p.data.version === v))
  .filter(Boolean);

const facts = buildFacts(d);
const armament = buildArmament(d);
const groups = buildGroups(d);

const dims = [d.lengthM, d.widthM, d.heightM].every((x) => x != null)
  ? `L ${d.lengthM} m · B ${d.widthM} m · H ${d.heightM} m`
  : null;
const stageStats: { label: string; value: string }[] = [
  { label: 'Länge', value: d.lengthM != null ? `${d.lengthM.toLocaleString('de-DE')} m` : '—' },
  { label: 'Besatzung', value: crewFmt(d) },
  { label: 'Fracht', value: d.cargoSCU != null ? `${d.cargoSCU.toLocaleString('de-DE')} SCU` : '—' },
  { label: 'SCM', value: d.scmSpeed != null ? `${d.scmSpeed} m/s` : '—' },
  {
    label: buyMin ? 'Im Verse ab' : 'Pledge',
    value: buyMin ? aUEC(buyMin.price) : d.msrpUSD != null ? `$${d.msrpUSD.toLocaleString('en-US')}` : '—',
  },
];
---
<Layout
  title={`${d.name} — Datenblatt | SC Patch-Archiv`}
  description={`${d.name} von ${d.manufacturer ?? 'unbekannt'}: Specs, Ingame-Preis & Kauforte, Beschreibung und Patch-Historie.`}
  themeColor="#05070d"
  footer={true}
>
<style is:inline>
:root{
  --bg:#05070d;--bg-2:#0a0e18;--surface:#0f1524;--surface-2:#141c30;
  --accent:#2dd4ff;--accent-2:#6ea8ff;--gold:#d4af37;
  --text:#e8eefc;--muted:#8a99b8;--line:rgba(110,168,255,.16);
  --font-display:'Orbitron',sans-serif;--font-ui:'Rajdhani',sans-serif;--font-body:'Barlow',system-ui,sans-serif;
  --maxw:1100px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
::selection{background:var(--accent);color:#05070d}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px}

/* ============ HOLO-BÜHNE ============ */
.holo{position:relative;height:clamp(480px,68vh,720px);margin-top:56px;overflow:hidden;
  background:radial-gradient(120% 90% at 50% 8%,#0c1424 0%,var(--bg) 62%),var(--bg);
  border-bottom:1px solid var(--line)}
.holo__grid{position:absolute;left:-24%;right:-24%;bottom:-4%;height:56%;pointer-events:none;
  transform:perspective(760px) rotateX(63deg);transform-origin:50% 100%;
  background:
    repeating-linear-gradient(90deg,rgba(45,212,255,.14) 0 1px,transparent 1px 44px),
    repeating-linear-gradient(0deg,rgba(45,212,255,.14) 0 1px,transparent 1px 44px);
  -webkit-mask-image:linear-gradient(0deg,rgba(0,0,0,.85),transparent 82%);
  mask-image:linear-gradient(0deg,rgba(0,0,0,.85),transparent 82%)}
.holo__beam{position:absolute;bottom:12%;left:50%;transform:translateX(-50%);width:min(64%,640px);height:70%;pointer-events:none;
  background:linear-gradient(0deg,rgba(45,212,255,.16),rgba(45,212,255,.045) 55%,transparent 88%);
  clip-path:polygon(34% 100%,66% 100%,100% 0,0 0);opacity:.9}
.holo__pad{position:absolute;bottom:9%;left:50%;transform:translateX(-50%);width:min(48%,460px);height:5%;pointer-events:none;
  border-radius:50%;background:radial-gradient(50% 50% at 50% 50%,rgba(45,212,255,.55),rgba(45,212,255,.14) 55%,transparent 72%);
  filter:blur(5px)}
.holo__ship{position:absolute;inset:11% 8% 20%;display:grid;place-items:center}
.holo__ship img{max-width:100%;max-height:100%;object-fit:contain;
  filter:sepia(1) saturate(4) hue-rotate(158deg) brightness(1.2) contrast(1.05) drop-shadow(0 0 36px rgba(45,212,255,.4));
  mix-blend-mode:screen;animation:hfloat 7s ease-in-out infinite}
.holo__scan{position:absolute;inset:0;pointer-events:none;mix-blend-mode:screen;opacity:.55;
  background:repeating-linear-gradient(0deg,rgba(45,212,255,.09) 0 2px,transparent 2px 6px);
  animation:hscan 11s linear infinite}
.holo__frame{position:absolute;inset:14px;pointer-events:none;
  background:
    linear-gradient(90deg,var(--accent) 0 22px,transparent 22px) top left/44px 2px no-repeat,
    linear-gradient(180deg,var(--accent) 0 22px,transparent 22px) top left/2px 44px no-repeat,
    linear-gradient(270deg,var(--accent) 0 22px,transparent 22px) bottom right/44px 2px no-repeat,
    linear-gradient(0deg,var(--accent) 0 22px,transparent 22px) bottom right/2px 44px no-repeat;
  opacity:.6}
.holo__hud{position:absolute;top:26px;left:30px;font-family:var(--font-ui);font-weight:700;font-size:.78rem;
  letter-spacing:.22em;text-transform:uppercase;color:var(--muted)}
.holo__hud b{color:var(--accent);font-weight:700}
.holo__dims{position:absolute;top:26px;right:30px;font-family:var(--font-ui);font-weight:700;font-size:.78rem;
  letter-spacing:.14em;text-transform:uppercase;color:var(--muted);text-align:right}
.holo__toggle{position:absolute;right:26px;bottom:24px;z-index:4;display:flex;border:1px solid var(--line);background:rgba(5,7,13,.6);backdrop-filter:blur(4px)}
.holo__toggle button{appearance:none;border:0;background:transparent;color:var(--muted);cursor:pointer;
  font-family:var(--font-ui);font-weight:700;font-size:.8rem;letter-spacing:.16em;text-transform:uppercase;padding:.5rem .95rem}
.holo__toggle button[aria-pressed="true"]{background:color-mix(in srgb,var(--accent) 16%,transparent);color:var(--accent)}
.holo__title{position:absolute;left:30px;bottom:22px;z-index:3;max-width:min(64%,720px)}
.holo__title .sd__maker{margin-bottom:.15rem}
.holo__title h1{font-family:var(--font-display);font-weight:900;font-size:clamp(2rem,5.5vw,3.6rem);line-height:1.02;color:#fff;
  text-shadow:0 2px 26px rgba(0,0,0,.85),0 0 44px rgba(45,212,255,.25)}
.holo__chips{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:.7rem}
.holo__chips span{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;
  color:var(--accent);border:1px solid color-mix(in srgb,var(--accent) 40%,transparent);
  background:rgba(5,7,13,.55);padding:.28rem .6rem}
.holo--foto .holo__ship img{filter:none;mix-blend-mode:normal;animation:none}
.holo--foto .holo__scan,.holo--foto .holo__beam{opacity:0}
.holo--foto .holo__pad{opacity:.35}
.holo--noimg .holo__ship{place-items:center}
.holo__none{font-family:var(--font-ui);font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);opacity:.6}
@keyframes hfloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
@keyframes hscan{to{background-position:0 132px}}
@media(max-width:760px){
  .holo{height:clamp(420px,72vh,560px)}
  .holo__title{left:18px;bottom:70px;max-width:88%}
  .holo__toggle{right:14px;bottom:14px}
  .holo__hud{left:16px;top:18px}.holo__dims{display:none}
  .holo__ship{inset:14% 4% 26%}
}
@media (prefers-reduced-motion:reduce){.holo__ship img,.holo__scan{animation:none!important}}

/* Kennwerte-Leiste unter der Bühne */
.holo__bar{border-bottom:1px solid var(--line);background:var(--bg-2)}
.holo__bar dl{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:0;padding:0 clamp(1rem,3vw,2.5rem)}
.holo__bar .kv{padding:.85rem 1rem .9rem;border-left:1px solid var(--line)}
.holo__bar .kv:first-child{border-left:0}
.holo__bar dt{font-family:var(--font-ui);font-weight:700;font-size:.74rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}
.holo__bar dd{margin:.1rem 0 0;font-family:var(--font-ui);font-weight:700;font-size:1.18rem;font-variant-numeric:tabular-nums;color:var(--text)}
.holo__bar .kv--price dd{color:var(--gold)}
@media(max-width:760px){.holo__bar dl{grid-template-columns:repeat(2,1fr)}.holo__bar .kv{border-left:0;border-top:1px solid var(--line)}}

.sd{max-width:var(--maxw);margin:0 auto;padding:1.8rem clamp(1rem,3vw,2.5rem) 4rem}
.sd__maker{font-family:var(--font-ui);font-weight:700;font-size:.85rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent)}

.sd__panel{position:relative;background:var(--surface);border:1px solid var(--line);border-top:2px solid var(--accent);
  padding:1.25rem 1.5rem 1.4rem;clip-path:polygon(12px 0,100% 0,100% calc(100% - 12px),calc(100% - 12px) 100%,0 100%,0 12px);
  margin-bottom:1.6rem}
.sd__phead{display:flex;align-items:baseline;justify-content:space-between;gap:1rem;border-bottom:1px solid var(--line);padding-bottom:.55rem;margin-bottom:1rem}
.sd__phead h2{font-family:var(--font-ui);font-weight:700;font-size:.95rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent)}
.sd__code{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* Handel / Kaufen im Verse */
.sd__pricehero{display:flex;flex-wrap:wrap;align-items:baseline;gap:.6rem 1rem;margin-bottom:1rem}
.sd__pricehero .val{font-family:var(--font-ui);font-weight:700;font-size:clamp(1.7rem,4vw,2.4rem);color:var(--gold);font-variant-numeric:tabular-nums}
.sd__pricehero .at{font-size:1rem;color:var(--muted)}
.sd__shoprows{display:flex;flex-direction:column}
.sd__shoprow{display:grid;grid-template-columns:minmax(0,1.3fr) minmax(0,1fr) auto;gap:.3rem 1.2rem;align-items:baseline;
  padding:.5rem 0;border-bottom:1px solid rgba(255,255,255,.06)}
.sd__shoprow:last-child{border-bottom:0}
.sd__shopname{font-family:var(--font-ui);font-weight:700;font-size:.95rem;letter-spacing:.06em;color:var(--text)}
.sd__shopwhere{color:var(--muted);font-size:.95rem}
.sd__shopprice{font-family:var(--font-ui);font-weight:700;font-size:1.05rem;font-variant-numeric:tabular-nums;white-space:nowrap;color:var(--text)}
.sd__more{margin-top:.6rem}
.sd__more summary{cursor:pointer;font-family:var(--font-ui);font-weight:700;font-size:.82rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent)}
.sd__nobuy{color:var(--muted);font-size:1.02rem;margin-bottom:.6rem}
.sd__pledgerow{margin-top:.9rem;padding-top:.8rem;border-top:1px solid var(--line);display:flex;flex-wrap:wrap;gap:.5rem 1.2rem;align-items:baseline}
.sd__pledgerow .p{font-family:var(--font-ui);font-weight:700;font-size:1.05rem;color:var(--text)}
.sd__pledgerow a{color:var(--accent);text-decoration:underline}
.sd__pledgerow a:hover{color:#fff}
.sd__hint{margin-top:.9rem;font-size:.85rem;color:var(--muted)}
@media(max-width:640px){.sd__shoprow{grid-template-columns:1fr auto}.sd__shopwhere{grid-column:1 / -1;margin-top:-.2rem}}

.sd__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:.7rem 1.4rem;margin:0}
.sd__item{border-left:1px solid var(--line);padding-left:.8rem}
.sd__item dt{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
.sd__item dd{margin:.15rem 0 0;font-weight:500;font-size:1.15rem;line-height:1.35;font-variant-numeric:tabular-nums;color:var(--text)}
.sd__sub{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);
  margin:1.6rem 0 .8rem;padding-bottom:.4rem;border-bottom:1px solid var(--line)}

/* Bewaffnung: hardpoint rows — size-class chips + equipped loadout + DPS */
.sd__arm{display:flex;flex-direction:column}
.sd__armrow{display:grid;grid-template-columns:200px minmax(0,1fr) auto;gap:.35rem 1.2rem;align-items:baseline;
  padding:.6rem 0;border-bottom:1px solid rgba(255,255,255,.06)}
.sd__armrow:last-child{border-bottom:0;padding-bottom:.15rem}
.sd__armhead{display:flex;flex-direction:column;gap:.05rem}
.sd__armlabel{font-family:var(--font-ui);font-weight:700;font-size:.82rem;letter-spacing:.14em;text-transform:uppercase;color:var(--text)}
.sd__armmeta{font-family:var(--font-ui);font-weight:600;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
.sd__armmid{display:flex;flex-wrap:wrap;gap:.4rem .6rem;align-items:baseline;min-width:0}
.sd__chip{font-family:var(--font-ui);font-weight:700;font-size:.85rem;line-height:1;color:var(--accent);
  border:1px solid color-mix(in srgb,var(--accent) 40%,transparent);background:color-mix(in srgb,var(--accent) 7%,transparent);
  padding:.3rem .5rem;white-space:nowrap}
.sd__chip i{font-style:normal;opacity:.78;margin-left:.28rem;font-size:.78rem}
.sd__armitems{font-size:.98rem;color:var(--text);opacity:.9}
.sd__armval{font-family:var(--font-ui);font-weight:700;font-size:1.05rem;color:var(--text);font-variant-numeric:tabular-nums;white-space:nowrap}
@media(max-width:640px){.sd__armrow{grid-template-columns:1fr}.sd__armval{justify-self:start}}

.sd__desc{max-width:78ch;margin:0 0 1.6rem;font-size:1.05rem;line-height:1.65;color:var(--text);opacity:.92}

.sd__spine{margin-bottom:1.6rem;border:1px solid var(--line);border-left:3px solid var(--gold);background:var(--bg-2);padding:1rem 1.2rem}
.sd__spine h2{font-family:var(--font-ui);font-weight:700;font-size:.78rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.5rem}
.sd__spine a{display:block;padding:.3rem 0;font-family:var(--font-ui);font-weight:700;font-size:1rem}
.sd__spine a:hover{color:var(--gold);text-decoration:underline}
.sd__spine span{color:var(--muted);font-weight:600}

/* Ähnliche Schiffe */
.sd__simgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.8rem}
.sd__sim{border:1px solid var(--line);background:var(--surface);transition:border-color .15s,background .15s;display:flex;flex-direction:column}
.sd__sim:hover{border-color:color-mix(in srgb,var(--accent) 55%,transparent);background:var(--surface-2)}
.sd__sim .im{aspect-ratio:16/9;background:#080c16 center/cover no-repeat;display:grid;place-items:center}
.sd__sim .im img{width:100%;height:100%;object-fit:cover}
.sd__sim .im span{font-family:var(--font-ui);font-weight:700;letter-spacing:.2em;color:var(--muted);font-size:.72rem}
.sd__sim .tx{padding:.6rem .8rem .7rem}
.sd__sim .nm{font-family:var(--font-ui);font-weight:700;font-size:1rem;color:var(--text)}
.sd__sim .mt{font-size:.85rem;color:var(--muted)}

.sd__links{display:flex;flex-wrap:wrap;gap:.7rem;margin-top:1.6rem}
.sd__links a{font-family:var(--font-ui);font-weight:700;font-size:.85rem;letter-spacing:.1em;text-transform:uppercase;
  border:1px solid var(--line);padding:.45rem .9rem;transition:border-color .15s,color .15s}
.sd__links a:hover{border-color:var(--accent);color:var(--accent)}
.sd__src{margin-top:1.4rem;font-size:.85rem;color:var(--muted)}
.sd__src a{text-decoration:underline}
.sd__src a:hover{color:var(--accent)}
</style>

<SiteNav
  crumbs={[
    { label: 'Archiv', href: '/index.html' },
    { label: 'Schiffe', href: '/schiffe.html' },
    { label: d.name },
  ]}
  pill={d.makerCode ?? 'DATENBLATT'}
/>

<main>
  <!-- HOLO-BÜHNE -->
  <section class={`holo${hero ? '' : ' holo--noimg'}`} id="holo" aria-label={`${d.name} — Visual`}>
    <div class="holo__grid" aria-hidden="true"></div>
    <div class="holo__beam" aria-hidden="true"></div>
    <div class="holo__pad" aria-hidden="true"></div>
    <figure class="holo__ship">
      {hero ? (
        <img
          src={hero.src}
          alt={`${d.name} — Darstellung`}
          referrerpolicy="no-referrer"
          onerror={hero.fallback ? `this.onerror=null;this.src='${hero.fallback}'` : undefined}
        />
      ) : (
        <span class="holo__none">Kein Visual im Datenbestand</span>
      )}
    </figure>
    <div class="holo__scan" aria-hidden="true"></div>
    <div class="holo__frame" aria-hidden="true"></div>
    <div class="holo__hud">HOLO-BUCHT // <b>{d.makerCode ?? 'SCHIFF'}</b></div>
    {dims && <div class="holo__dims">{dims}</div>}
    {hero && (
      <div class="holo__toggle" role="group" aria-label="Darstellung wechseln">
        <button type="button" data-m="holo" aria-pressed="true">Holo</button>
        <button type="button" data-m="foto" aria-pressed="false">Foto</button>
      </div>
    )}
    <header class="holo__title">
      <div class="sd__maker">{d.manufacturer}</div>
      <h1>{d.name}</h1>
      <div class="holo__chips">
        {d.typeDe && <span>{d.typeDe}</span>}
        {d.sizeDe && <span>{d.sizeDe}</span>}
        {d.statusDe && <span>{d.statusDe}</span>}
      </div>
    </header>
  </section>

  <!-- Kennwerte -->
  <div class="holo__bar">
    <dl>
      {stageStats.map((s, i) => (
        <div class={`kv${i === stageStats.length - 1 ? ' kv--price' : ''}`}>
          <dt>{s.label}</dt>
          <dd>{s.value}</dd>
        </div>
      ))}
    </dl>
  </div>

  <div class="sd">
    <!-- KAUFEN IM VERSE -->
    <section class="sd__panel" aria-label="Kaufen im Verse">
      <header class="sd__phead">
        <h2>Kaufen im Verse</h2>
        <span class="sd__code">HANDEL&nbsp;//&nbsp;UEX · Stand {pricesFetchedAt}</span>
      </header>
      {buyMin ? (
        <>
          <div class="sd__pricehero">
            <span class="val">{aUEC(buyMin.price)}</span>
            <span class="at">günstigster Kaufort: {buyMin.shop}, {buyMin.where}{buyMin.system && ` · ${buyMin.system}`}</span>
          </div>
          <div class="sd__shoprows">
            {prices!.buy.slice(0, MAX_ROWS).map((b) => (
              <div class="sd__shoprow">
                <span class="sd__shopname">{b.shop}</span>
                <span class="sd__shopwhere">{b.where}{b.system && ` · ${b.system}`}</span>
                <span class="sd__shopprice">{aUEC(b.price)}</span>
              </div>
            ))}
          </div>
          {prices!.buy.length > MAX_ROWS && (
            <details class="sd__more">
              <summary>+{prices!.buy.length - MAX_ROWS} weitere Kauforte</summary>
              <div class="sd__shoprows">
                {prices!.buy.slice(MAX_ROWS).map((b) => (
                  <div class="sd__shoprow">
                    <span class="sd__shopname">{b.shop}</span>
                    <span class="sd__shopwhere">{b.where}{b.system && ` · ${b.system}`}</span>
                    <span class="sd__shopprice">{aUEC(b.price)}</span>
                  </div>
                ))}
              </div>
            </details>
          )}
        </>
      ) : (
        <p class="sd__nobuy">Aktuell nicht an Ingame-Terminals kaufbar — nur als Pledge erhältlich.</p>
      )}
      {rentMin && (
        <>
          <h3 class="sd__sub">Mieten</h3>
          <div class="sd__shoprows">
            {prices!.rent.slice(0, 4).map((r) => (
              <div class="sd__shoprow">
                <span class="sd__shopname">{r.shop}</span>
                <span class="sd__shopwhere">{r.where}{r.system && ` · ${r.system}`}</span>
                <span class="sd__shopprice">{aUEC(r.price)} / Tag</span>
              </div>
            ))}
          </div>
        </>
      )}
      {d.msrpUSD != null && (
        <div class="sd__pledgerow">
          <span class="p">Pledge: ${d.msrpUSD.toLocaleString('en-US')}</span>
          {d.pledgeUrl && <a href={d.pledgeUrl} target="_blank" rel="noopener">RSI Pledge-Store ↗</a>}
        </div>
      )}
      <p class="sd__hint">Ingame-Preise: UEX Corp (Community-Daten) · ändern sich mit Patches und Events.</p>
    </section>

    {d.descriptionDe && <p class="sd__desc">{d.descriptionDe}</p>}

    <!-- DATENBLATT -->
    <section class="sd__panel" aria-label="Datenblatt">
      <header class="sd__phead">
        <h2>Datenblatt</h2>
        <span class="sd__code">DAT&nbsp;//&nbsp;{d.makerCode ?? 'SCHIFF'} · Stand {vehiclesSnapshot.fetchedAt}</span>
      </header>
      <dl class="sd__grid">
        {facts.map((f) => (
          <div class="sd__item">
            <dt>{f.label}</dt>
            <dd>{f.value}</dd>
          </div>
        ))}
      </dl>
      {armament.length > 0 && (
        <div class="sd__group">
          <h3 class="sd__sub">Bewaffnung</h3>
          <div class="sd__arm">
            {armament.map((r) => (
              <div class="sd__armrow">
                <div class="sd__armhead">
                  <span class="sd__armlabel">{r.label}</span>
                  {r.meta && <span class="sd__armmeta">{r.meta}</span>}
                </div>
                <div class="sd__armmid">
                  {r.chips.map((c) => (
                    <span class="sd__chip">{c.label}{c.count > 1 && <i>×{c.count}</i>}</span>
                  ))}
                  {r.items && <span class="sd__armitems">{r.items}</span>}
                </div>
                {r.value && <div class="sd__armval">{r.value}</div>}
              </div>
            ))}
          </div>
        </div>
      )}
      {groups.map((g) => (
        <div class="sd__group">
          <h3 class="sd__sub">{g.title}</h3>
          <dl class="sd__grid">
            {g.facts.map((f) => (
              <div class="sd__item">
                <dt>{f.label}</dt>
                <dd>{f.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      ))}
    </section>

    {spine.length > 0 && (
      <section class="sd__spine" aria-label="Im Patch-Archiv">
        <h2>Im Patch-Archiv</h2>
        {spine.map((p) => (
          <a href={`/patches/sc-${p!.id}.html`}>
            Alpha {p!.data.version} — {p!.data.codename} <span>· {p!.data.dateDisplay} →</span>
          </a>
        ))}
      </section>
    )}

    {similar.length > 0 && (
      <section aria-label="Ähnliche Schiffe">
        <h3 class="sd__sub">Ähnliche Schiffe</h3>
        <div class="sd__simgrid">
          {similar.map((s) => (
            <a class="sd__sim" href={`/schiffe/${s.id}.html`}>
              <div class="im">
                {s.thumb ? <img src={s.thumb} alt={s.name} loading="lazy" referrerpolicy="no-referrer" /> : <span>KEIN BILD</span>}
              </div>
              <div class="tx">
                <div class="nm">{s.name}</div>
                <div class="mt">{s.meta}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="sd__links">
      <a href="/schiffe.html">← Alle Schiffe</a>
      {d.pledgeUrl && <a href={d.pledgeUrl} target="_blank" rel="noopener">RSI Pledge-Store ↗</a>}
    </div>

    <p class="sd__src">
      Quelle: <a href="https://api.star-citizen.wiki" target="_blank" rel="noopener">Star Citizen Wiki API</a>
      (Community-Projekt, Daten aus den Spieldateien) · Stand {vehiclesSnapshot.fetchedAt}
      {d.gameVersion && ` · Spieldaten ${d.gameVersion.split('-')[0]}`}
      {hero?.api && ` · Bild: ${d.image?.source ?? 'starcitizen.tools'}`}
      {' '}· Ingame-Preise: <a href="https://uexcorp.space" target="_blank" rel="noopener">UEX Corp</a> · Stand {pricesFetchedAt}
    </p>
  </div>
</main>

<script is:inline>
(function () {
  var stage = document.getElementById('holo');
  if (!stage) return;
  var btns = stage.querySelectorAll('.holo__toggle button');
  btns.forEach(function (b) {
    b.addEventListener('click', function () {
      var m = b.getAttribute('data-m');
      stage.classList.toggle('holo--foto', m === 'foto');
      btns.forEach(function (x) { x.setAttribute('aria-pressed', String(x === b)); });
    });
  });
})();
</script>
</Layout>
