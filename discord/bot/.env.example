# ─────────────────────────────────────────────────────────────
#  VerseBase rank bot — environment
# ─────────────────────────────────────────────────────────────
#  Copy to ".env" and fill in. The real .env is git-ignored.
#
#  This is an ALWAYS-ON bot (it must keep running to award XP from
#  messages and voice). See README.md for deploy (pm2 / systemd / Docker).
# ─────────────────────────────────────────────────────────────

# Required — the bot token (Developer Portal → your app → Bot → Reset Token)
DISCORD_TOKEN=

# Optional — the application ID (Developer Portal → General Information).
# If left blank it is derived from the token automatically.
CLIENT_ID=

# Optional — a single server ID. If set, slash commands register there
# instantly and the bot treats it as its home guild. Leave blank to run
# across every server the bot is in (global commands, ~1h to appear).
GUILD_ID=

# Optional — where the SQLite file lives (default: ./data/leveling.db)
# DB_PATH=./data/leveling.db
